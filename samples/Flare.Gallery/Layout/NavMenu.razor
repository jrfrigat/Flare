@inherits LocalizedPage
@using Flare.Gallery.Models

@* Primary navigation rail: the top-level sections. Plain pages (Overview, Getting started) navigate;
   the section triggers (Themes, Components, Services, API) toggle the secondary drawer instead of
   navigating, so clicking one reveals that section's pages in the column to the right. *@
<FlareNavMenu Mode="Mode">
    <Footer>
        <FlareNavLink Href="/settings" Tooltip="@GalleryStrings.Settings_Title">
            <Icon><FlareIcon Size="1.25rem" Name="settings" /></Icon>
            <ChildContent>@GalleryStrings.Settings_Title</ChildContent>
        </FlareNavLink>
        <FlareNavLink Href="/about" Tooltip="@GalleryStrings.Nav_About">
            <Icon><FlareIcon Size="1.25rem" Name="info" /></Icon>
            <ChildContent>@GalleryStrings.Nav_About</ChildContent>
        </FlareNavLink>
    </Footer>
    <ChildContent>
        <FlareNavLink Href="/" Match="NavMatchMode.Exact">
            <Icon><FlareIcon Size="1.25rem" Name="home" /></Icon>
            <ChildContent>@GalleryStrings.Nav_Overview</ChildContent>
        </FlareNavLink>
        <FlareNavLink Href="/getting-started">
            <Icon><FlareIcon Size="1.25rem" Name="rocket_launch" /></Icon>
            <ChildContent>@GalleryStrings.Nav_GettingStarted</ChildContent>
        </FlareNavLink>

        <FlareNavLink OnClick="@(() => ToggleSection(GallerySection.Themes))" Active="@(Section == GallerySection.Themes)">
            <Icon><FlareIcon Size="1.25rem" Name="palette" /></Icon>
            <ChildContent>@GalleryStrings.Nav_Theming</ChildContent>
        </FlareNavLink>
        <FlareNavLink OnClick="@(() => ToggleSection(GallerySection.Components))" Active="@(Section == GallerySection.Components)">
            <Icon><FlareIcon Size="1.25rem" Name="category" /></Icon>
            <ChildContent>@GalleryStrings.Nav_Components</ChildContent>
        </FlareNavLink>
        <FlareNavLink OnClick="@(() => ToggleSection(GallerySection.Services))" Active="@(Section == GallerySection.Services)">
            <Icon><FlareIcon Size="1.25rem" Name="bolt" /></Icon>
            <ChildContent>@GalleryStrings.Nav_Services</ChildContent>
        </FlareNavLink>
        <FlareNavLink OnClick="@(() => ToggleSection(GallerySection.Api))" Active="@(Section == GallerySection.Api)">
            <Icon><FlareIcon Size="1.25rem" Name="data_object" /></Icon>
            <ChildContent>@GalleryStrings.Nav_Api</ChildContent>
        </FlareNavLink>
    </ChildContent>
</FlareNavMenu>

@code {
    /// <summary>How the primary rail renders (labeled rail when collapsed, full when expanded).</summary>
    [Parameter] public NavMenuMode Mode { get; set; } = NavMenuMode.RailLabeled;
    /// <summary>The currently open section. Supports <c>@bind-Section</c>.</summary>
    [Parameter] public GallerySection Section { get; set; }
    /// <summary>Raised when a section trigger toggles the open section.</summary>
    [Parameter] public EventCallback<GallerySection> SectionChanged { get; set; }

    // Clicking the open section closes the secondary drawer; clicking another switches to it.
    private Task ToggleSection(GallerySection s)
        => SectionChanged.InvokeAsync(Section == s ? GallerySection.None : s);
}
