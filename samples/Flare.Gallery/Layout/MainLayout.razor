@inherits LayoutComponentBase
@implements IDisposable
@inject NavigationManager NavManager
@inject IVersionCheckService VersionCheck
@inject ISnackbarService Snackbar
@inject Flare.Gallery.Services.DrawerModeService NavMode

<FlareLayout @bind-DrawerOpen="_navOpen" Mode="NavMode.CurrentMode" ContentMaxWidth="ContainerMaxWidth.Full">
    <AppBar>
        <FlareLayoutAppBar DrawerToggle="true">
            <FlareStack Row Align="FlareAlignItems.Center" Gap="FlareSpacing.Small" Style="flex:1;min-width:0;">
                <FlareLink Href="/" Underline="LinkUnderline.None" Color="FlareColor.Default">
                    <FlareStack Row Align="FlareAlignItems.Center" Gap="FlareSpacing.XSmall">
                        <FlareIcon Color="FlareColor.Primary" Icon="@FlareIcons.Brands.FlareLogoShort" Size="2.25rem" AriaLabel="Flare" />
                        <FlareText Typo="TypographyScale.TitleLarge" Weight="FontWeight.ExtraBold" Style="letter-spacing:-0.5px;">Flare</FlareText>
                    </FlareStack>
                </FlareLink>
                <FlareBadge Text="v0.0.5" Standalone="true" Color="FlareColor.Secondary" />
                <FlareSpacer />
                <GallerySearch />
                <FlareSpacer />
            </FlareStack>
        </FlareLayoutAppBar>
    </AppBar>
    <Drawer>
        <FlareLayoutDrawer>
            @* NavMenu owns its own pinned footer (Settings entry + build version) via FlareNavMenu's
               Footer slot, and collapses to an icon rail with the drawer (FlareLayout MiniRail). *@
            <NavMenu />
        </FlareLayoutDrawer>
    </Drawer>
    <Content>
        @* Two-column doc layout built from Flare primitives: a flexible content column and a fixed
           "On this page" rail. The rail hides below the md breakpoint (Css.Classes.Hidden.BelowMd) --
           when it does, the content column simply fills the row. No gallery CSS. *@
        <FlareStack Row Gap="FlareSpacing.XLarge" Align="FlareAlignItems.Start">
            @* Plain content host: Flare has no "fills remaining space" primitive, so the flex sizing
               (grow + min-width:0 to let wide code blocks shrink) is expressed inline. The id is a
               scan target for the TOC, not a styling hook. *@
            <div id="gallery-main" style="flex:1;min-width:0;">@Body</div>
            @* Recreated per navigation (@key) so it re-scans the new page's demo-section titles.
               Sticky positioning is a layout concern of this rail, expressed via the component's Style. *@
            <FlareOnThisPage @key="NavManager.Uri"
                             Root="#gallery-main"
                             HeadingSelector=".demo-section__title"
                             Class="@Css.Classes.Hidden.BelowMd"
                             Style="position:sticky;top:1rem;flex:none;width:14rem;max-height:calc(100vh - 6rem);overflow-y:auto;" />
        </FlareStack>
    </Content>
</FlareLayout>

<FlareDialogProvider />
<FlareSnackbarProvider />
<FlareMessageBoxProvider />

@code {
    private bool _navOpen = true;

    // Stable id for the update toast so the "new version" notice and the later "updating" state are the
    // same snackbar (changed in place), not two separate toasts.
    private readonly Guid _updateToastId = Guid.NewGuid();

    protected override void OnInitialized()
    {
        // The service polls in the background; surface any new version as a toast.
        VersionCheck.NewVersionAvailable += OnNewVersionAsync;
        VersionCheck.Start();
        // Re-render when the user changes the navigation drawer mode in Settings (applied live).
        NavMode.DrawerModeChanged += OnDrawerModeChanged;
    }

    private void OnDrawerModeChanged() => InvokeAsync(StateHasChanged);

    // Actionable, persistent toast: "Update" applies the waiting service worker and reloads (the service
    // owns the service-worker plumbing - the app just calls ApplyUpdateAsync). Once a newer version is
    // known there is nothing more to discover, so stop the background polling.
    private Task OnNewVersionAsync(VersionCheckInfo info) => InvokeAsync(() =>
    {
        VersionCheck.Stop();
        Snackbar.Show(new SnackbarMessage(_updateToastId, GalleryStrings.Pwa_NewVersion, SnackbarSeverity.Info,
            DurationMs: 0, ActionText: GalleryStrings.Pwa_Update, OnAction: StartUpdateAsync));
    });

    // Change the SAME toast in place into an "updating" state with a progress bar (rather than adding a
    // second toast), so the user sees the update has started; the reload then replaces the page.
    private async Task StartUpdateAsync()
    {
        Snackbar.Update(new SnackbarMessage(_updateToastId, GalleryStrings.Pwa_Updating, SnackbarSeverity.Info,
            DurationMs: 0, ShowClose: false, ShowProgress: true));
        await VersionCheck.ApplyUpdateAsync();
    }

    // The anti-FOUC startup splash is revealed automatically by FlareThemeProvider once the theme
    // CSS and web fonts are ready, so the layout no longer needs to hide it by hand.

    public void Dispose()
    {
        VersionCheck.NewVersionAvailable -= OnNewVersionAsync;
        NavMode.DrawerModeChanged -= OnDrawerModeChanged;
    }
}
