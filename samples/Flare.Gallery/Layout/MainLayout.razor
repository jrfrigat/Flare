@inherits LayoutComponentBase
@implements IDisposable
@inject NavigationManager NavManager
@inject IVersionCheckService VersionCheck
@inject ISnackbarService Snackbar
@inject Flare.Gallery.Services.RailLabelService RailLabels
@using Flare.Gallery.Models

<FlareLayout>
    <FlareLayoutAppBar DrawerToggle="true">
        <FlareStack Row Align="FlareAlignItems.Center" Gap="FlareSpacing.Small" Style="flex:1;min-width:0;">
            <FlareLink Href="/" Underline="LinkUnderline.None" Color="FlareColor.Default">
                <FlareStack Row Align="FlareAlignItems.Center" Gap="FlareSpacing.XSmall">
                    <FlareIconView Color="FlareColor.Primary" Icon="@FlareIcons.Brands.FlareLogoShort" Size="2.25rem" AriaLabel="Flare" />
                    <FlareText Typo="TypographyScale.TitleLarge" Weight="FontWeight.ExtraBold" Style="letter-spacing:-0.5px;">Flare</FlareText>
                </FlareStack>
            </FlareLink>
            <FlareSpacer />
            <GallerySearch />
            <FlareSpacer />
            <FlareIconButton AriaLabel="GitHub" Href="https://github.com/jrfrigat/Flare" Target="_blank">
                <FlareIconView Icon="@GitHubIcon" Size="1.35rem" />
            </FlareIconButton>
        </FlareStack>
    </FlareLayoutAppBar>

    @* Primary navigation rail (owns its own @bind-Open): a Mini drawer that collapses to a labeled or
       icon-only rail per the Settings preference, and expands to a full menu when toggled. Selecting
       Themes/Components/Services/API opens the secondary column. *@
    <FlareLayoutDrawer @bind-Open="_navOpen" Variant="DrawerVariant.Mini" Width="16rem" RailWidth="5.5rem">
        <NavMenu Mode="@PrimaryNavMode" @bind-Section="_section" RouteSection="_routeSection" />
    </FlareLayoutDrawer>

    @* Secondary section column: a separate Persistent drawer, opened by selecting a section. Its open
       state is its own parameter -- the layout does not own it. *@
    <FlareLayoutDrawer Open="@(_section != GallerySection.None)" Variant="DrawerVariant.Persistent" Width="17rem">
        @if (_section != GallerySection.None)
        {
            <SecondaryNav Section="_section" />
        }
    </FlareLayoutDrawer>

    <FlareLayoutContent>
        @* Two-column doc layout built from Flare primitives: a flexible content column and a fixed
           "On this page" rail. The rail hides below the md breakpoint (Css.Classes.Hidden.BelowMd) --
           when it does, the content column simply fills the row. No gallery CSS. *@
        <FlareStack Row Gap="FlareSpacing.XLarge" Align="FlareAlignItems.Start" StretchFirst>
            @* Plain content host: StretchFirst makes this first child fill the space beside the fixed rail
               (flex:1 1 auto + min-width:0 so wide code blocks can shrink) - no inline flex needed. The id
               is a scan target for the TOC, not a styling hook. *@
            <div id="gallery-main">@Body</div>
            @* Recreated per navigation (@key) so it re-scans the new page's demo-section titles.
               Sticky positioning is a layout concern of this rail, expressed via the component's Style. *@
            <FlareOnThisPage @key="NavManager.Uri"
                             Root="#gallery-main"
                             HeadingSelector=".demo-section__title"
                             Class="@Css.Classes.Hidden.BelowMd"
                             Style="position:sticky;top:1rem;flex:none;width:14rem;max-height:calc(100vh - 6rem);overflow-y:auto;" />
        </FlareStack>
    </FlareLayoutContent>
</FlareLayout>

<FlareDialogProvider />
<FlareSnackbarProvider />
<FlareMessageBoxProvider />

@code {
    // GitHub mark (24x24 path data) for the app-bar link - a third-party brand, so kept local to the
    // Gallery rather than in the Flare icon pack.
    private const string GitHubIcon = "M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12";

    // The primary drawer starts collapsed (a rail); the secondary column is driven by the section.
    private bool _navOpen;
    private GallerySection _section = GallerySection.None;
    // The section of the current route -- highlights the matching rail trigger (independent of which
    // secondary panel happens to be open).
    private GallerySection _routeSection = GallerySection.None;

    // Opening the drawer expands the rail to a full menu; collapsed, the rail honors the user's
    // labeled/icon-only preference from Settings.
    private NavMenuMode PrimaryNavMode => _navOpen
        ? NavMenuMode.Full
        : (RailLabels.ShowLabels ? NavMenuMode.RailLabeled : NavMenuMode.Rail);

    // Stable id for the update toast so the "new version" notice and the later "updating" state are the
    // same snackbar (changed in place), not two separate toasts.
    private readonly Guid _updateToastId = Guid.NewGuid();

    protected override void OnInitialized()
    {
        // The service polls in the background; surface any new version as a toast.
        VersionCheck.NewVersionAvailable += OnNewVersionAsync;
        VersionCheck.Start();
        // Re-render the rail when the user changes the labeled/icon-only preference in Settings.
        RailLabels.Changed += OnRailLabelsChanged;
        // Highlight the rail trigger for the current route's section, updated on every navigation.
        _routeSection = GallerySections.FromPath(NavManager.ToBaseRelativePath(NavManager.Uri));
        // Open the matching secondary panel on direct load / reload, not just on a trigger click.
        _section = _routeSection;
        NavManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        _routeSection = GallerySections.FromPath(NavManager.ToBaseRelativePath(e.Location));
        // The secondary column follows the route: navigating into a section opens its panel (so a direct
        // link or reload lands with the right panel open, not just the highlight), and leaving every
        // section (Overview / Getting started) closes it. A trigger click can still collapse it in place.
        _section = _routeSection;
        StateHasChanged();
    }

    private void OnRailLabelsChanged() => InvokeAsync(StateHasChanged);

    // Actionable, persistent toast: "Update" applies the waiting service worker and reloads (the service
    // owns the service-worker plumbing - the app just calls ApplyUpdateAsync). Once a newer version is
    // known there is nothing more to discover, so stop the background polling.
    private Task OnNewVersionAsync(VersionCheckInfo info) => InvokeAsync(() =>
    {
        VersionCheck.Stop();
        Snackbar.Show(new SnackbarMessage(_updateToastId, GalleryStrings.Pwa_NewVersion, SnackbarSeverity.Info,
            DurationMs: 0, ActionText: GalleryStrings.Pwa_Update, OnAction: StartUpdateAsync));
    });

    // Change the SAME toast in place into an "updating" state with a progress bar (rather than adding a
    // second toast), so the user sees the update has started; the reload then replaces the page.
    private async Task StartUpdateAsync()
    {
        Snackbar.Update(new SnackbarMessage(_updateToastId, GalleryStrings.Pwa_Updating, SnackbarSeverity.Info,
            DurationMs: 0, ShowClose: false, ShowProgress: true));
        await VersionCheck.ApplyUpdateAsync();
    }

    // The anti-FOUC startup splash is revealed automatically by FlareThemeProvider once the theme
    // CSS and web fonts are ready, so the layout no longer needs to hide it by hand.

    public void Dispose()
    {
        VersionCheck.NewVersionAvailable -= OnNewVersionAsync;
        RailLabels.Changed -= OnRailLabelsChanged;
        NavManager.LocationChanged -= OnLocationChanged;
    }
}
