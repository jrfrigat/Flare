@inherits LocalizedPage

<FlareStack Row Gap="FlareSpacing.XXSmall">
    @foreach (var (code, _) in LanguageService.SupportedCultures)
    {
        var c = code;
        <FlareButton Size="ButtonSize.Sm"
                     Variant="@(Lang.CurrentCulture == c ? ButtonVariant.Filled : ButtonVariant.Text)"
                     OnClick="@(() => Lang.SetCultureAsync(c))">
            @c.ToUpperInvariant()
        </FlareButton>
    }
</FlareStack>
