@inherits LocalizedPage
@implements IDisposable
@inject IVersionCheckService VersionCheck

@* The live service-worker build version, shown as a quiet caption pinned in the nav footer so a
   deploy / SW swap is visible at a glance. Marked flare-nav-menu__meta so it disappears when the
   drawer collapses to a mini-rail (where only icons fit). *@
<div class="@Css.Classes.Navigation.NavMenuMeta">
    <FlareStack Row Align="FlareAlignItems.Center" Justify="FlareJustifyContent.SpaceBetween" Gap="FlareSpacing.Small">
        <FlareText Typo="TypographyScale.LabelSmall">@GalleryStrings.Settings_Version</FlareText>
        <FlareText Typo="TypographyScale.LabelSmall" title="@VersionText"
                   Style="font-family:monospace;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@VersionText</FlareText>
    </FlareStack>
    @if (_updateAvailable)
    {
        <FlareStack Row Align="FlareAlignItems.Center" Gap="FlareSpacing.XXSmall" Style="margin-top:0.25rem;">
            <FlareIconView Value="@MaterialDesign3Icons.Regular.SystemUpdateAlt" Size="0.9rem" Color="FlareColor.Warning" />
            <FlareText Typo="TypographyScale.LabelSmall" Color="FlareColor.Warning">@GalleryStrings.Settings_UpdateAvailable</FlareText>
        </FlareStack>
    }
</div>

@code {
    private bool _updateAvailable;
    private bool _disposed;

    // The build version reported by the service worker, or a "dev" placeholder when none is active.
    private string VersionText => VersionCheck.CurrentVersion ?? GalleryStrings.Settings_VersionDev;

    protected override void OnInitialized()
    {
        base.OnInitialized(); // LocalizedPage: subscribe to language changes
        VersionCheck.NewVersionAvailable += OnNewVersionAsync;
    }

    // The app-wide service starts in MainLayout and probes immediately; read the resulting baseline
    // once the first render has happened so the footer shows the running version without interaction.
    // A single probe can transiently fail (offline blip, JS not ready yet) and the baseline, once the
    // background loop later establishes it, is set silently - so retry a few times until the running
    // version is known rather than getting stuck on the "dev" placeholder forever.
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        for (var attempt = 0; attempt < 5 && !_disposed && VersionCheck.CurrentVersion is null; attempt++)
        {
            try
            {
                await VersionCheck.CheckNowAsync();
                RefreshUpdateFlag();
                StateHasChanged();
            }
            catch { /* no service worker / JS unavailable (dev): keep the "dev" placeholder */ }

            if (VersionCheck.CurrentVersion is not null) break;
            try { await Task.Delay(2000); } catch { break; }
        }
    }

    private Task OnNewVersionAsync(VersionCheckInfo info) => InvokeAsync(() =>
    {
        RefreshUpdateFlag();
        StateHasChanged();
    });

    private void RefreshUpdateFlag() =>
        _updateAvailable = VersionCheck.LatestVersion is { } latest && latest != VersionCheck.CurrentVersion;

    public override void Dispose()
    {
        _disposed = true;
        VersionCheck.NewVersionAvailable -= OnNewVersionAsync;
        base.Dispose();
    }
}
