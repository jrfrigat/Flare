@page "/"
@inject IThemeService ThemeService
@inject ISnackbarService Snackbar
@inherits LocalizedPage

<PageTitle>Flare - Blazor Component Library</PageTitle>

<GalleryPageTitle>
    <FlareStack Row Gap="FlareSpacing.Small" Align="FlareAlignItems.Center">
        <FlareIconView Color="FlareColor.Primary" Icon="@FlareIcons.Brands.FlareLogoShort" Size="4rem" />
        <FlareStack Gap="FlareSpacing.None">
            <FlareText Typo="TypographyScale.DisplaySmall" Weight="FontWeight.ExtraBold" Style="letter-spacing:-1px;">@GalleryStrings.Home_Title</FlareText>
            <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.TitleMedium">
                @GalleryStrings.Home_Subtitle
            </FlareText>
        </FlareStack>
    </FlareStack>
</GalleryPageTitle>

<FlareStack Gap="FlareSpacing.Large">

<section>
    <FlareGrid Columns="3" Gap="FlareSpacing.Medium">
        <FlareCol Span="1">
            <FlareCard Variant="CardVariant.Filled" Style="text-align:center;">
                <FlareText Color="FlareColor.Primary" Typo="TypographyScale.DisplaySmall" Weight="FontWeight.ExtraBold">130+</FlareText>
                <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.LabelMedium">@GalleryStrings.Home_ComponentsLabel</FlareText>
            </FlareCard>
        </FlareCol>
        <FlareCol Span="1">
            <FlareCard Variant="CardVariant.Filled" Style="text-align:center;">
                <FlareText Color="FlareColor.Secondary" Typo="TypographyScale.DisplaySmall" Weight="FontWeight.ExtraBold">@ThemeService.Themes.Count</FlareText>
                <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.LabelMedium">@GalleryStrings.Home_ThemesLabel</FlareText>
            </FlareCard>
        </FlareCol>
        <FlareCol Span="1">
            <FlareCard Variant="CardVariant.Filled" Style="text-align:center;">
                <FlareText Color="FlareColor.Tertiary" Typo="TypographyScale.DisplaySmall" Weight="FontWeight.ExtraBold">10</FlareText>
                <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.LabelMedium">@GalleryStrings.Home_DotNetLabel</FlareText>
            </FlareCard>
        </FlareCol>
    </FlareGrid>
</section>

<section>
    <GallerySectionHeader Icon="@MaterialDesign3Icons.Regular.Widgets" Title="@GalleryStrings.Home_ComponentsHeader" />
    <FlareGrid Columns="4" Gap="FlareSpacing.Medium">
        <FlareCol Span="1">
            <FlareCard Variant="CardVariant.Outlined" Style="cursor:pointer;">
                <FlareLink Href="/components/buttons" Color="FlareColor.Default" Underline="LinkUnderline.None" Style="display:block;">
                    <FlareIconView Size="1.75rem" Color="FlareColor.Primary" Value="@MaterialDesign3Icons.Regular.Widgets" />
                    <FlareText Typo="TypographyScale.TitleSmall">@GalleryStrings.Home_Card_Buttons</FlareText>
                    <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.BodySmall">@GalleryStrings.Home_Card_Buttons_Desc</FlareText>
                </FlareLink>
            </FlareCard>
        </FlareCol>
        <FlareCol Span="1">
            <FlareCard Variant="CardVariant.Outlined" Style="cursor:pointer;">
                <FlareLink Href="/components/text-field" Color="FlareColor.Default" Underline="LinkUnderline.None" Style="display:block;">
                    <FlareIconView Size="1.75rem" Color="FlareColor.Primary" Value="@MaterialDesign3Icons.Regular.TextFields" />
                    <FlareText Typo="TypographyScale.TitleSmall">@GalleryStrings.Home_Card_Inputs</FlareText>
                    <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.BodySmall">@GalleryStrings.Home_Card_Inputs_Desc</FlareText>
                </FlareLink>
            </FlareCard>
        </FlareCol>
        <FlareCol Span="1">
            <FlareCard Variant="CardVariant.Outlined" Style="cursor:pointer;">
                <FlareLink Href="/components/datagrid" Color="FlareColor.Default" Underline="LinkUnderline.None" Style="display:block;">
                    <FlareIconView Size="1.75rem" Color="FlareColor.Primary" Value="@MaterialDesign3Icons.Regular.GridOn" />
                    <FlareText Typo="TypographyScale.TitleSmall">@GalleryStrings.Home_Card_DataGrid</FlareText>
                    <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.BodySmall">@GalleryStrings.Home_Card_DataGrid_Desc</FlareText>
                </FlareLink>
            </FlareCard>
        </FlareCol>
        <FlareCol Span="1">
            <FlareCard Variant="CardVariant.Outlined" Style="cursor:pointer;">
                <FlareLink Href="/components/dialog" Color="FlareColor.Default" Underline="LinkUnderline.None" Style="display:block;">
                    <FlareIconView Size="1.75rem" Color="FlareColor.Primary" Value="@MaterialDesign3Icons.Regular.OpenInNew" />
                    <FlareText Typo="TypographyScale.TitleSmall">@GalleryStrings.Home_Card_Dialogs</FlareText>
                    <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.BodySmall">@GalleryStrings.Home_Card_Dialogs_Desc</FlareText>
                </FlareLink>
            </FlareCard>
        </FlareCol>
        <FlareCol Span="1">
            <FlareCard Variant="CardVariant.Outlined" Style="cursor:pointer;">
                <FlareLink Href="/components/alerts" Color="FlareColor.Default" Underline="LinkUnderline.None" Style="display:block;">
                    <FlareIconView Size="1.75rem" Color="FlareColor.Primary" Value="@MaterialDesign3Icons.Regular.Notifications" />
                    <FlareText Typo="TypographyScale.TitleSmall">@GalleryStrings.Home_Card_Feedback</FlareText>
                    <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.BodySmall">@GalleryStrings.Home_Card_Feedback_Desc</FlareText>
                </FlareLink>
            </FlareCard>
        </FlareCol>
        <FlareCol Span="1">
            <FlareCard Variant="CardVariant.Outlined" Style="cursor:pointer;">
                <FlareLink Href="/components/tabs" Color="FlareColor.Default" Underline="LinkUnderline.None" Style="display:block;">
                    <FlareIconView Size="1.75rem" Color="FlareColor.Primary" Value="@MaterialDesign3Icons.Regular.Tab" />
                    <FlareText Typo="TypographyScale.TitleSmall">@GalleryStrings.Home_Card_Navigation</FlareText>
                    <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.BodySmall">@GalleryStrings.Home_Card_Navigation_Desc</FlareText>
                </FlareLink>
            </FlareCard>
        </FlareCol>
        <FlareCol Span="1">
            <FlareCard Variant="CardVariant.Outlined" Style="cursor:pointer;">
                <FlareLink Href="/components/typography" Color="FlareColor.Default" Underline="LinkUnderline.None" Style="display:block;">
                    <FlareIconView Size="1.75rem" Color="FlareColor.Primary" Value="@MaterialDesign3Icons.Regular.FormatSize" />
                    <FlareText Typo="TypographyScale.TitleSmall">@GalleryStrings.Home_Card_Display</FlareText>
                    <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.BodySmall">@GalleryStrings.Home_Card_Display_Desc</FlareText>
                </FlareLink>
            </FlareCard>
        </FlareCol>
    </FlareGrid>
</section>

<section>
    <GallerySectionHeader Icon="@MaterialDesign3Icons.Regular.Palette" Title="@GalleryStrings.Home_ThemeShowcase" />
    <FlareCard Variant="CardVariant.Outlined">
        <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.BodyMedium" Style="margin-bottom:1rem">
            @GalleryStrings.Home_ThemeShowcase_Active: <strong>@ThemeService.CurrentTheme.DisplayName</strong> - @GalleryStrings.Home_ThemeShowcaseHint
        </FlareText>
        <FlareStack Row Wrap Gap="FlareSpacing.Small" Style="margin-bottom:1rem;">
            @foreach (var theme in ThemeService.Themes)
            {
                var tid = theme.Id;
                <FlareButton Variant="@(ThemeService.CurrentTheme.Id == tid ? ButtonVariant.Filled : ButtonVariant.Outlined)"
                             OnClick="@(() => SwitchTheme(tid))">
                    @theme.DisplayName
                </FlareButton>
            }
        </FlareStack>
        <FlareStack Row Wrap Gap="FlareSpacing.Small" Align="FlareAlignItems.Center">
            <FlareButton Variant="ButtonVariant.Filled">Filled</FlareButton>
            <FlareButton Variant="ButtonVariant.Outlined">Outlined</FlareButton>
            <FlareButton Variant="ButtonVariant.Text">Text</FlareButton>
            <FlareButton Variant="ButtonVariant.Elevated">Elevated</FlareButton>
            <FlareButton Variant="ButtonVariant.Tonal">Tonal</FlareButton>
            <FlareBadge Count="5">
                <FlareButton Variant="ButtonVariant.Outlined">Notifications</FlareButton>
            </FlareBadge>
            <FlareChip Label="Design" @bind-Selected="_chip1Selected" />
            <FlareChip Label="Blazor" @bind-Selected="_chip2Selected" />
            <FlareIconView Size="1.5rem" Color="FlareColor.Primary" Value="@MaterialDesign3Icons.Regular.LocalFireDepartment" />
            <FlareIconView Size="1.5rem" Color="FlareColor.Tertiary" Value="@MaterialDesign3Icons.Regular.Star" />
            <FlareIconView Size="1.5rem" Color="FlareColor.Error" Value="@MaterialDesign3Icons.Regular.Favorite" />
        </FlareStack>
    </FlareCard>
</section>

</FlareStack>

@code {
    private bool _chip1Selected = true;
    private bool _chip2Selected;

    private async Task SwitchTheme(string id)
    {
        await ThemeService.SetThemeAsync(id);
    }
}
