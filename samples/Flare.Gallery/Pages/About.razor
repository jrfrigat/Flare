@page "/about"
@inject NavigationManager Nav
@inject Flare.Gallery.Services.ChangelogService Changelog
@inherits LocalizedPage

<PageTitle>@GalleryStrings.About_Title - Flare</PageTitle>

<GalleryPageTitle>
    <FlareStack Row Gap="FlareSpacing.Small" Align="FlareAlignItems.Center">
        <FlareIcon Size="2.5rem" Color="FlareColor.Primary" Name="local_fire_department" Style="font-variation-settings:'FILL' 1,'wght' 700,'GRAD' 0,'opsz' 48" />
        <FlareStack Gap="FlareSpacing.None">
            <FlareText Typo="TypographyScale.HeadlineMedium">@GalleryStrings.About_Title</FlareText>
            <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.BodyLarge">
                @GalleryStrings.About_Subtitle
            </FlareText>
        </FlareStack>
    </FlareStack>
</GalleryPageTitle>

<FlareStack Gap="FlareSpacing.Large">

<section>
    <FlareGrid Columns="3" Gap="FlareSpacing.Medium">
        <FlareCol Span="1">
            <FlareCard Variant="CardVariant.Filled" Style="text-align:center;">
                <FlareText Color="FlareColor.Primary" Typo="TypographyScale.DisplaySmall" Weight="FontWeight.ExtraBold">@_version</FlareText>
                <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.LabelMedium">@GalleryStrings.About_Version</FlareText>
            </FlareCard>
        </FlareCol>
        <FlareCol Span="1">
            <FlareCard Variant="CardVariant.Filled" Style="text-align:center;">
                <FlareText Color="FlareColor.Secondary" Typo="TypographyScale.DisplaySmall" Weight="FontWeight.ExtraBold">116+</FlareText>
                <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.LabelMedium">@GalleryStrings.About_Components</FlareText>
            </FlareCard>
        </FlareCol>
        <FlareCol Span="1">
            <FlareCard Variant="CardVariant.Filled" Style="text-align:center;">
                <FlareText Color="FlareColor.Tertiary" Typo="TypographyScale.DisplaySmall" Weight="FontWeight.ExtraBold">7</FlareText>
                <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.LabelMedium">@GalleryStrings.About_Themes</FlareText>
            </FlareCard>
        </FlareCol>
    </FlareGrid>
</section>

<section>
    <GallerySectionHeader Icon="new_releases" Title="@GalleryStrings.About_WhatsNew" />
    @* The latest releases are read straight from CHANGELOG.md (see ChangelogService) - no hand-maintained
       cards. The full history lives on the /changelog page. *@
    @foreach (var entry in Changelog.Entries().Take(3))
    {
        <FlareCard Variant="CardVariant.Outlined" Style="margin-bottom:1rem;">
            <FlareStack Row Gap="FlareSpacing.Small" Align="FlareAlignItems.Center" Style="margin-bottom:0.5rem;">
                <FlareBadge Text="@($"v{entry.Version}")" Standalone="true" Color="FlareColor.Secondary" />
                @if (entry.Date is not null)
                {
                    <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.BodySmall">@entry.Date</FlareText>
                }
            </FlareStack>
            <FlareMarkdown Value="@entry.Markdown" />
        </FlareCard>
    }
    <FlareButton Variant="ButtonVariant.Tonal" OnClick="@(() => Nav.NavigateTo("changelog"))">
        <LeadingIcon><FlareIcon Size="1.1rem" Name="history" /></LeadingIcon>
        <ChildContent>@GalleryStrings.About_FullChangelog</ChildContent>
    </FlareButton>
</section>

<section>
    <FlareCard Variant="CardVariant.Outlined" Style="text-align:center;">
        <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.BodyMedium" Style="margin-bottom:1rem">
            @GalleryStrings.About_Intro
        </FlareText>
        <FlareButton Variant="ButtonVariant.Outlined" OnClick="@GoToGitHub">
            <LeadingIcon><FlareIcon Size="1.1rem" Name="open_in_new" /></LeadingIcon>
            <ChildContent>@GalleryStrings.About_ViewOnGitHub</ChildContent>
        </FlareButton>
    </FlareCard>
</section>

</FlareStack>

@code {
    private string _version => Changelog.LatestVersion;

    private void GoToGitHub() => Nav.NavigateTo("https://github.com/jrfrigat/Flare", forceLoad: true);
}
