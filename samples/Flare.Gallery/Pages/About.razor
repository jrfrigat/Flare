@page "/about"
@inject NavigationManager Nav
@inherits LocalizedPage

<PageTitle>@GalleryStrings.About_Title - Flare</PageTitle>

<GalleryPageTitle>
    <FlareStack Row Gap="FlareSpacing.Small" Align="FlareAlignItems.Center">
        <FlareIcon Size="2.5rem" Color="FlareColor.Primary" Name="local_fire_department" Style="font-variation-settings:'FILL' 1,'wght' 700,'GRAD' 0,'opsz' 48" />
        <FlareStack Gap="FlareSpacing.None">
            <FlareText Typo="TypographyScale.HeadlineMedium">@GalleryStrings.About_Title</FlareText>
            <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.BodyLarge">
                @GalleryStrings.About_Subtitle
            </FlareText>
        </FlareStack>
    </FlareStack>
</GalleryPageTitle>

<FlareStack Gap="FlareSpacing.Large">

<section>
    <FlareGrid Columns="3" Gap="FlareSpacing.Medium">
        <FlareCol Span="1">
            <FlareCard Variant="CardVariant.Filled" Style="text-align:center;">
                <FlareText Color="FlareColor.Primary" Typo="TypographyScale.DisplaySmall" Weight="FontWeight.ExtraBold">@_version</FlareText>
                <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.LabelMedium">@GalleryStrings.About_Version</FlareText>
            </FlareCard>
        </FlareCol>
        <FlareCol Span="1">
            <FlareCard Variant="CardVariant.Filled" Style="text-align:center;">
                <FlareText Color="FlareColor.Secondary" Typo="TypographyScale.DisplaySmall" Weight="FontWeight.ExtraBold">116+</FlareText>
                <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.LabelMedium">@GalleryStrings.About_Components</FlareText>
            </FlareCard>
        </FlareCol>
        <FlareCol Span="1">
            <FlareCard Variant="CardVariant.Filled" Style="text-align:center;">
                <FlareText Color="FlareColor.Tertiary" Typo="TypographyScale.DisplaySmall" Weight="FontWeight.ExtraBold">5</FlareText>
                <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.LabelMedium">@GalleryStrings.About_Themes</FlareText>
            </FlareCard>
        </FlareCol>
    </FlareGrid>
</section>

<section>
    <GallerySectionHeader Icon="new_releases" Title="@GalleryStrings.About_WhatsNew" />
    <FlareCard Variant="CardVariant.Outlined" Style="margin-bottom:1rem;">
        <FlareText Typo="TypographyScale.TitleMedium" Style="margin-bottom:0.75rem;">v0.0.3 - 2026-06-27</FlareText>
        <FlareStack Gap="FlareSpacing.XSmall" Align="FlareAlignItems.Start">
            @foreach (var item in _whatsNewV3)
            {
                <FlareStack Row Gap="FlareSpacing.XSmall" Align="FlareAlignItems.Start">
                    <FlareIcon Size="1rem" Color="FlareColor.Primary" Name="check_circle" Style="margin-top:2px" />
                    <FlareText Typo="TypographyScale.BodyMedium">@item</FlareText>
                </FlareStack>
            }
        </FlareStack>
    </FlareCard>
    <FlareCard Variant="CardVariant.Outlined" Style="margin-bottom:1rem;">
        <FlareText Typo="TypographyScale.TitleMedium" Style="margin-bottom:0.75rem;">v0.0.2 - 2026-06-27</FlareText>
        <FlareStack Gap="FlareSpacing.XSmall" Align="FlareAlignItems.Start">
            @foreach (var item in _whatsNewV2)
            {
                <FlareStack Row Gap="FlareSpacing.XSmall" Align="FlareAlignItems.Start">
                    <FlareIcon Size="1rem" Color="FlareColor.Primary" Name="check_circle" Style="margin-top:2px" />
                    <FlareText Typo="TypographyScale.BodyMedium">@item</FlareText>
                </FlareStack>
            }
        </FlareStack>
    </FlareCard>
    <FlareCard Variant="CardVariant.Outlined">
        <FlareText Typo="TypographyScale.TitleMedium" Style="margin-bottom:0.75rem;">v0.0.1 - 2026-05-30</FlareText>
        <FlareStack Gap="FlareSpacing.XSmall" Align="FlareAlignItems.Start">
            @foreach (var item in _whatsNewV1)
            {
                <FlareStack Row Gap="FlareSpacing.XSmall" Align="FlareAlignItems.Start">
                    <FlareIcon Size="1rem" Color="FlareColor.Primary" Name="check_circle" Style="margin-top:2px" />
                    <FlareText Typo="TypographyScale.BodyMedium">@item</FlareText>
                </FlareStack>
            }
        </FlareStack>
    </FlareCard>
</section>

<section>
    <FlareCard Variant="CardVariant.Outlined" Style="text-align:center;">
        <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.BodyMedium" Style="margin-bottom:1rem">
            Flare is an open-source Blazor component library built with .NET 10.
        </FlareText>
        <FlareButton Variant="ButtonVariant.Outlined" OnClick="@GoToGitHub">
            <LeadingIcon><FlareIcon Size="1.1rem" Name="open_in_new" /></LeadingIcon>
            <ChildContent>@GalleryStrings.About_ViewOnGitHub</ChildContent>
        </FlareButton>
    </FlareCard>
</section>

</FlareStack>

@code {
    private readonly string _version = "0.0.3";

    private void GoToGitHub() => Nav.NavigateTo("https://github.com/jrfrigat/Flare", forceLoad: true);

    private readonly string[] _whatsNewV3 =
    [
        "Two new design systems - Material Design 3 (baseline, non-Expressive) and Material Design 2 - so Flare now ships 7 themes",
        "Dynamic Color palette: derives a full light/dark palette from the OS/browser accent (Windows/macOS accent, Android Material You) via the active theme's generator, with a seed fallback",
        "MD3 Expressive palette aligned to the updated spec (light on-*-container roles now use tone 30)",
        "Cleaner token model: common component tokens (nav, input, menu, progress, dialog, snackbar, popover, card) promoted from the Extended bag to typed DesignTokens records",
        "Fluent UI 2 typography and motion aligned to the official Fluent 2 design tokens",
        "Visual Studio 2026 connected document tabs - the active tab now takes the editor color",
    ];

    private readonly string[] _whatsNewV2 =
    [
        "Clean onion / ports-and-adapters architecture: 5 rings (Flare.Abstractions, Flare.Theming, Flare.Infrastructure, Flare.Components, Flare.Blazor) with dependencies pointing strictly inward",
        "Flare.Components is now UI-only - every service implementation (JS interop, storage, dialog/snackbar/message-box) moved to Flare.Infrastructure; the old Flare.Core grab-bag was retired",
        "AddFlare wires ports to adapters in the Flare.Blazor composition root, so the browser host stays swappable and Flare.Components never depends on Infrastructure",
        "Declarative [CssVar] linkage on every design token, and typed Vars.Var(Css.Tokens.*) token values instead of magic var(--flare-*) strings",
        "Compound components standardised on a single typed cascading context (Tree, Menu, FAB)",
        "1,200+ automated tests, 0 failures; zero build warnings",
    ];

    private readonly string[] _whatsNewV1 =
    [
        "Theme system v2: three independent axes - design system (MD3 Expressive / Fluent UI 2 / Aero / Liquid Glass / Visual Studio 2026) x palette x light/dark/auto",
        "Class-toggle delivery: switching is a class swap on <html>, no per-switch CSS-var injection",
        "Reusable palettes (Office + Material sets) and PaletteFactory.FromColors(brand) generation",
        "Override any token via Md3/Fluent2 reference records; one-line anti-FOUC bootstrap",
        "Full OWASP GS-1..GS-8 security audit - all critical findings fixed",
        "XSS protection: FlareLink, FlareBreadcrumb, FlareNavLink, FlareImage blocked javascript: URIs",
        "CSS injection guards on FlareGrid, FlareStack, FlareResizable, FlareText",
        "FlareClipboard: eval() removed, replaced with safe JS interop",
        "MarkdownParser: vbscript/data-uri/expression()/dangerous-tag defenses",
        "HtmlSanitizer and CssValidator security utilities",
        "Gallery rebuilt entirely on Flare components - no raw divs or magic code",
    ];

}
