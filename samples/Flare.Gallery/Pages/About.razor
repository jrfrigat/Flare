@page "/about"
@inject NavigationManager Nav
@inherits LocalizedPage

<PageTitle>@GalleryStrings.About_Title - Flare</PageTitle>

<GalleryPageTitle>
    <FlareStack Row Gap="FlareSpacing.Small" Align="FlareAlignItems.Center">
        <FlareIcon Size="2.5rem" Color="FlareColor.Primary" Name="local_fire_department" Style="font-variation-settings:'FILL' 1,'wght' 700,'GRAD' 0,'opsz' 48" />
        <FlareStack Gap="FlareSpacing.None">
            <FlareText Typo="TypographyScale.HeadlineMedium">@GalleryStrings.About_Title</FlareText>
            <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.BodyLarge">
                @GalleryStrings.About_Subtitle
            </FlareText>
        </FlareStack>
    </FlareStack>
</GalleryPageTitle>

<FlareStack Gap="FlareSpacing.Large">

<section>
    <FlareGrid Columns="3" Gap="FlareSpacing.Medium">
        <FlareCol Span="1">
            <FlareCard Variant="CardVariant.Filled" Style="text-align:center;">
                <FlareText Color="FlareColor.Primary" Typo="TypographyScale.DisplaySmall" Weight="FontWeight.ExtraBold">@_version</FlareText>
                <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.LabelMedium">@GalleryStrings.About_Version</FlareText>
            </FlareCard>
        </FlareCol>
        <FlareCol Span="1">
            <FlareCard Variant="CardVariant.Filled" Style="text-align:center;">
                <FlareText Color="FlareColor.Secondary" Typo="TypographyScale.DisplaySmall" Weight="FontWeight.ExtraBold">116+</FlareText>
                <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.LabelMedium">@GalleryStrings.About_Components</FlareText>
            </FlareCard>
        </FlareCol>
        <FlareCol Span="1">
            <FlareCard Variant="CardVariant.Filled" Style="text-align:center;">
                <FlareText Color="FlareColor.Tertiary" Typo="TypographyScale.DisplaySmall" Weight="FontWeight.ExtraBold">7</FlareText>
                <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.LabelMedium">@GalleryStrings.About_Themes</FlareText>
            </FlareCard>
        </FlareCol>
    </FlareGrid>
</section>

