<section>
    <FlareCard Variant="CardVariant.Outlined" Style="text-align:center;">
        <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.BodyMedium" Style="margin-bottom:1rem">
            @GalleryStrings.About_Intro
        </FlareText>
        <FlareButton Variant="ButtonVariant.Outlined" OnClick="@GoToGitHub">
            <LeadingIcon><FlareIcon Size="1.1rem" Name="open_in_new" /></LeadingIcon>
            <ChildContent>@GalleryStrings.About_ViewOnGitHub</ChildContent>
        </FlareButton>
    </FlareCard>
</section>

</FlareStack>

@code {
    private readonly string _version = "0.1.6";

    private void GoToGitHub() => Nav.NavigateTo("https://github.com/jrfrigat/Flare", forceLoad: true);

    // Localized changelog: each resource holds one item per line (see GalleryStrings.About_WhatsNew*).
    private static string[] Lines(string value) =>
        value.Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

    private string[] _whatsNewV18 => Lines(GalleryStrings.About_WhatsNewV18);
    private string[] _whatsNewV17 => Lines(GalleryStrings.About_WhatsNewV17);
