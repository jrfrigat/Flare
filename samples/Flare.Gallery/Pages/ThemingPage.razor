@page "/theming"
@inject IThemeService ThemeService
@inherits LocalizedPage
@using Flare.Abstractions.Tokens
@using Flare.Theming

<PageTitle>@GalleryStrings.Theming_Title - Flare</PageTitle>

<GalleryPageTitle>
    <FlareText Typo="TypographyScale.HeadlineMedium">@GalleryStrings.Theming_Title</FlareText>
    <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.BodyLarge">@GalleryStrings.Theming_Subtitle</FlareText>
</GalleryPageTitle>

<FlareStack Gap="FlareSpacing.Large">

<section>
    <GallerySectionHeader Icon="palette" Title="@GalleryStrings.Theming_LiveSwitcher" />
    <FlareStack Gap="FlareSpacing.Medium">

        <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.BodyMedium">
            @GalleryStrings.Theming_Active: <strong>@ThemeService.CurrentTheme.DisplayName</strong> · @ThemeService.CurrentPalette.Name · @ThemeService.Mode
        </FlareText>

        @* Design system (theme) -- the component look & feel, independent of colors. *@
        <FlareCard Variant="CardVariant.Outlined">
            <FlareText Typo="TypographyScale.LabelLarge" Style="margin-bottom:0.75rem;display:block;">@GalleryStrings.Theme_DesignSystem</FlareText>
            <FlareStack Row Wrap Gap="FlareSpacing.Small">
                @foreach (var t in ThemeService.Themes)
                {
                    var tid = t.Id;
                    <FlareButton Variant="@(ThemeService.CurrentTheme.Id == tid ? ButtonVariant.Filled : ButtonVariant.Outlined)"
                                 OnClick="@(() => ThemeService.SetThemeAsync(tid))">
                        @t.DisplayName
                    </FlareButton>
                }
            </FlareStack>
        </FlareCard>

        @* Palette -- just the colors. The swatch makes it obvious these are color sets, not themes. *@
        <FlareCard Variant="CardVariant.Outlined">
            <FlareText Typo="TypographyScale.LabelLarge" Style="margin-bottom:0.75rem;display:block;">@GalleryStrings.Theme_Palette</FlareText>
            <FlareStack Row Wrap Gap="FlareSpacing.Small">
                @foreach (var p in ThemeService.Palettes)
                {
                    var pid = p.Id;
                    var swatch = ThemeService.IsDark ? p.Dark.Primary : p.Light.Primary;
                    <FlareButton Variant="@(ThemeService.CurrentPalette.Id == pid ? ButtonVariant.Filled : ButtonVariant.Outlined)"
                                 OnClick="@(() => ThemeService.SetPaletteAsync(pid))">
                        <LeadingIcon>
                            <span style="@($"display:inline-block;width:0.85rem;height:0.85rem;border-radius:50%;background:{swatch};")"></span>
                        </LeadingIcon>
                        <ChildContent>@p.Name</ChildContent>
                    </FlareButton>
                }
            </FlareStack>
        </FlareCard>

        @* Mode -- light / dark / auto. The third independent axis. *@
        <FlareCard Variant="CardVariant.Outlined">
            <FlareText Typo="TypographyScale.LabelLarge" Style="margin-bottom:0.75rem;display:block;">@GalleryStrings.Theme_Mode</FlareText>
            <FlareStack Row Wrap Gap="FlareSpacing.Small">
                <FlareButton Variant="@(ThemeService.Mode == ThemeMode.Light ? ButtonVariant.Filled : ButtonVariant.Outlined)"
                             OnClick="@(() => ThemeService.SetModeAsync(ThemeMode.Light))">
                    <LeadingIcon><FlareIconView Name="light_mode" /></LeadingIcon>
                    <ChildContent>@GalleryStrings.Theme_ModeLight</ChildContent>
                </FlareButton>
                <FlareButton Variant="@(ThemeService.Mode == ThemeMode.Dark ? ButtonVariant.Filled : ButtonVariant.Outlined)"
                             OnClick="@(() => ThemeService.SetModeAsync(ThemeMode.Dark))">
                    <LeadingIcon><FlareIconView Name="dark_mode" /></LeadingIcon>
                    <ChildContent>@GalleryStrings.Theme_ModeDark</ChildContent>
                </FlareButton>
                <FlareButton Variant="@(ThemeService.Mode == ThemeMode.Auto ? ButtonVariant.Filled : ButtonVariant.Outlined)"
                             OnClick="@(() => ThemeService.SetModeAsync(ThemeMode.Auto))">
                    <LeadingIcon><FlareIconView Name="brightness_auto" /></LeadingIcon>
                    <ChildContent>@GalleryStrings.Theme_ModeAuto</ChildContent>
                </FlareButton>
            </FlareStack>
        </FlareCard>

    </FlareStack>
</section>

<section>
    <GallerySectionHeader Icon="dark_mode" Title="@GalleryStrings.Theming_AutoDarkMode" />
    <FlareCard Variant="CardVariant.Outlined">
        <FlareText Typo="TypographyScale.BodyMedium" Style="margin-bottom:0.75rem;">
            @GalleryStrings.Theming_AutoDarkModeDesc
        </FlareText>
        <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.BodyMedium">
            @GalleryStrings.Theming_AutoDarkModeNote
        </FlareText>
    </FlareCard>
</section>

<section>
    <GallerySectionHeader Icon="code" Title="@GalleryStrings.Theming_HowItWorks" />
    <FlareCard Variant="CardVariant.Outlined">
        <FlareText Typo="TypographyScale.BodyMedium" Style="margin-bottom:1rem;">
            @GalleryStrings.Theming_HowItWorksDesc
        </FlareText>
        <FlareCodeBlock Value="@_howItWorksCode" Language="razor" />
    </FlareCard>
</section>

<section>
    <GallerySectionHeader Icon="brush" Title="@GalleryStrings.Theming_CreateTheme" />
    <FlareCard Variant="CardVariant.Outlined">
        <FlareText Typo="TypographyScale.BodyMedium" Style="margin-bottom:1rem;">
            @GalleryStrings.Theming_CustomThemeDesc
        </FlareText>
        <FlareCodeBlock Value="@_createThemeCode" Language="csharp" />
    </FlareCard>
</section>

<section>
    <GallerySectionHeader Icon="table_chart" Title="@GalleryStrings.Theming_TokenReference" />
    <FlareCard Style="padding:0;overflow:hidden;">
        <FlareTable TItem="object">
            <thead>
                <tr><th>@GalleryStrings.Theming_TokenCol</th><th>@GalleryStrings.Theming_PurposeCol</th><th>@GalleryStrings.Theming_ExampleCol</th></tr>
            </thead>
            <tbody>
                <tr><td><code>--flare-color-primary</code></td><td>@GalleryStrings.Theming_Token_Primary</td><td>#6750a4</td></tr>
                <tr><td><code>--flare-color-on-primary</code></td><td>@GalleryStrings.Theming_Token_OnPrimary</td><td>#ffffff</td></tr>
                <tr><td><code>--flare-color-primary-container</code></td><td>@GalleryStrings.Theming_Token_PrimaryContainer</td><td>#eaddff</td></tr>
                <tr><td><code>--flare-color-secondary</code></td><td>@GalleryStrings.Theming_Token_Secondary</td><td>#625b71</td></tr>
                <tr><td><code>--flare-color-surface</code></td><td>@GalleryStrings.Theming_Token_Surface</td><td>#fffbfe</td></tr>
                <tr><td><code>--flare-color-surface-container</code></td><td>@GalleryStrings.Theming_Token_SurfaceContainer</td><td>#f3edf7</td></tr>
                <tr><td><code>--flare-color-on-surface</code></td><td>@GalleryStrings.Theming_Token_OnSurface</td><td>#1c1b1f</td></tr>
                <tr><td><code>--flare-color-on-surface-variant</code></td><td>@GalleryStrings.Theming_Token_OnSurfaceVariant</td><td>#49454f</td></tr>
                <tr><td><code>--flare-color-outline</code></td><td>@GalleryStrings.Theming_Token_Outline</td><td>#79747e</td></tr>
                <tr><td><code>--flare-color-error</code></td><td>@GalleryStrings.Theming_Token_Error</td><td>#b3261e</td></tr>
                <tr><td><code>--flare-shape-small</code></td><td>@GalleryStrings.Theming_Token_ShapeSmall</td><td>8px</td></tr>
                <tr><td><code>--flare-shape-medium</code></td><td>@GalleryStrings.Theming_Token_ShapeMedium</td><td>12px</td></tr>
                <tr><td><code>--flare-shape-full</code></td><td>@GalleryStrings.Theming_Token_ShapeFull</td><td>9999px</td></tr>
                <tr><td><code>--flare-state-hover-opacity</code></td><td>@GalleryStrings.Theming_Token_StateOpacity</td><td>0.08</td></tr>
                <tr><td><code>--flare-motion-duration-short2</code></td><td>@GalleryStrings.Theming_Token_Motion</td><td>100ms</td></tr>
                <tr><td><code>--flare-typescale-body-large-font</code></td><td>@GalleryStrings.Theming_Token_BodyFont</td><td>Roboto, sans-serif</td></tr>
            </tbody>
        </FlareTable>
    </FlareCard>
</section>

<section>
    <GallerySectionHeader Icon="auto_awesome" Title="@GalleryStrings.Theming_GenerateTitle" />
    <FlareCard Variant="CardVariant.Outlined">
        <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.BodyMedium" Style="margin-bottom:1rem">
            @GalleryStrings.Theming_GenerateDesc
        </FlareText>
        <FlareStack Row Wrap Gap="FlareSpacing.Medium" Style="align-items:center;">
            <FlareColorPicker @bind-Value="_seed" />
            <FlareButton Variant="ButtonVariant.Filled" OnClick="GenerateAsync">
                <LeadingIcon><FlareIconView Name="palette" /></LeadingIcon>
                <ChildContent>@GalleryStrings.Theming_GenerateBtn</ChildContent>
            </FlareButton>
        </FlareStack>
    </FlareCard>
</section>

<section>
    <GallerySectionHeader Icon="contrast" Title="@GalleryStrings.Theming_ScopeTitle" />
    <FlareCard Variant="CardVariant.Outlined">
        <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.BodyMedium" Style="margin-bottom:1rem">
            @GalleryStrings.Theming_ScopeDesc
        </FlareText>
        <FlareStack Row Wrap Gap="FlareSpacing.Large">
            <FlareThemeScope Mode="ThemeMode.Dark">
                <FlareCard Style="min-width:14rem;">
                    <FlareStack Gap="FlareSpacing.Small">
                        <FlareText Typo="TypographyScale.LabelLarge">@GalleryStrings.Theming_ScopeDark</FlareText>
                        <FlareStack Row Gap="FlareSpacing.Small">
                            <FlareButton>Filled</FlareButton>
                            <FlareButton Variant="ButtonVariant.Tonal">Tonal</FlareButton>
                        </FlareStack>
                        <FlareChip Color="FlareColor.Primary">Chip</FlareChip>
                    </FlareStack>
                </FlareCard>
            </FlareThemeScope>
            <FlareThemeScope Mode="ThemeMode.Light">
                <FlareCard Style="min-width:14rem;">
                    <FlareStack Gap="FlareSpacing.Small">
                        <FlareText Typo="TypographyScale.LabelLarge">@GalleryStrings.Theming_ScopeLight</FlareText>
                        <FlareStack Row Gap="FlareSpacing.Small">
                            <FlareButton>Filled</FlareButton>
                            <FlareButton Variant="ButtonVariant.Tonal">Tonal</FlareButton>
                        </FlareStack>
                        <FlareChip Color="FlareColor.Primary">Chip</FlareChip>
                    </FlareStack>
                </FlareCard>
            </FlareThemeScope>
        </FlareStack>
    </FlareCard>
</section>
</FlareStack>

@code {
    private string _seed = "#7B1FA2";

    private const string _howItWorksCode =
        """
        // Three independent axes: theme (design system), palette (colors), mode
        @inject IThemeService ThemeService

        await ThemeService.SetThemeAsync("fluent2");       // design system
        await ThemeService.SetPaletteAsync("fluent-blue"); // colors
        await ThemeService.SetModeAsync(ThemeMode.Dark);   // Light / Dark / Auto

        // Read current selection
        var theme   = ThemeService.CurrentTheme;
        var palette = ThemeService.CurrentPalette;
        var isDark  = ThemeService.IsDark;
        """;

    private const string _createThemeCode =
        """
        using Flare.Abstractions.Tokens;

        // A palette is just colors (light + dark) - reuse a built-in design system,
        // only swap the colors. Register it without touching any theme.
        var ocean = new Palette
        {
            Id = "ocean",
            Name = "Ocean",
            Light = Md3.LightColors with { Primary = "#006782", PrimaryContainer = "#BCE9FF" },
            Dark  = Md3.DarkColors  with { Primary = "#5DD5FC", PrimaryContainer = "#004E63" },
        };

        // Or generate a whole palette from one brand color:
        var brand = PaletteFactory.Brand("brand", "Brand", Md3.LightColors, Md3.DarkColors, "#7B1FA2");

        // Override ANY design token (shape, typography, ...) from the reference:
        var design = Md3.DesignReference with
        {
            Shape = Md3.DesignReference.Shape with { Medium = "10px" },
        };

        // Register at startup...
        builder.Services.AddFlare(opts => opts.DefaultPalette = ocean);

        // ...or at runtime, then switch on the fly
        themeService.RegisterPalette(ocean);
        await themeService.SetPaletteAsync("ocean");
        """;

    private async Task GenerateAsync()
    {
        var hex = string.IsNullOrWhiteSpace(_seed) ? "#7B1FA2" : _seed.Trim();
        var id = "gen-" + new string(hex.Where(char.IsLetterOrDigit).ToArray()).ToLowerInvariant();
        if (ThemeService.Palettes.All(p => p.Id != id))
            ThemeService.RegisterPalette(ThemeService.GeneratePalette(
                id, hex, new PaletteSeed(hex), GalleryStrings.Theme_PaletteGenerated));
        await ThemeService.SetPaletteAsync(id);
    }
}
