@page "/services/version-check"
@implements IAsyncDisposable
@inherits LocalizedPage
@inject ISnackbarService Snackbar
@using Flare.Components.Services

<PageTitle>@GalleryStrings.Services_VersionCheckTitle - Flare</PageTitle>

<GalleryPageTitle>
    <FlareText Typo="TypographyScale.HeadlineMedium">@GalleryStrings.Services_VersionCheckTitle</FlareText>
    <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.BodyLarge">@GalleryStrings.Services_VersionCheckSubtitle</FlareText>
</GalleryPageTitle>

<FlareCard Variant="CardVariant.Outlined" Style="max-width:40rem;">
    <FlareStack Gap="FlareSpacing.Small">
        <FlareText Typo="TypographyScale.BodyMedium">@GalleryStrings.Services_VersionCheckBody</FlareText>

        <FlareStack Row Align="FlareAlignItems.Center" Gap="FlareSpacing.XSmall">
            <FlareIconView Name="check_circle" Color="FlareColor.OnSurfaceVariant" />
            <FlareText Typo="TypographyScale.BodyMedium">
                @GalleryStrings.Services_VersionCheckCurrent: <strong>@_currentVersion</strong>
            </FlareText>
        </FlareStack>

        <FlareStack Row Align="FlareAlignItems.Center" Gap="FlareSpacing.XSmall">
            @if (_updating)
            {
                <FlareProgress Variant="ProgressVariant.Circular" Size="TrackSize.Xs" Color="FlareColor.Primary" />
                <FlareText Typo="TypographyScale.BodyMedium">@GalleryStrings.Services_VersionCheckUpdating</FlareText>
            }
            else if (_detected is not null)
            {
                <FlareIconView Name="system_update" Color="FlareColor.Warning" />
                <FlareText Typo="TypographyScale.BodyMedium">@GalleryStrings.Services_VersionCheckDetected <strong>@_detected</strong></FlareText>
            }
            else if (_checking)
            {
                <FlareProgress Variant="ProgressVariant.Circular" Size="TrackSize.Xs" Color="FlareColor.Primary" />
                <FlareText Typo="TypographyScale.BodyMedium">@GalleryStrings.Services_VersionCheckChecking</FlareText>
            }
            else
            {
                <FlareIconView Name="check_circle" Color="FlareColor.Success" />
                <FlareText Typo="TypographyScale.BodyMedium">@GalleryStrings.Services_VersionCheckUpToDate</FlareText>
            }
        </FlareStack>

        <FlareStack Row Wrap Gap="FlareSpacing.Small">
            <FlareButton Variant="ButtonVariant.Outlined" OnClick="CheckNowAsync" Disabled="@(_checking || _updating)">
                <LeadingIcon><FlareIconView Name="refresh" /></LeadingIcon>
                <ChildContent>@GalleryStrings.Services_VersionCheckCheckNow</ChildContent>
            </FlareButton>
            @if (_detected is not null || _updating)
            {
                <FlareButton Variant="ButtonVariant.Filled" OnClick="ApplyUpdate" Disabled="@_updating">
                    <LeadingIcon><FlareIconView Name="system_update" /></LeadingIcon>
                    <ChildContent>@(_updating ? GalleryStrings.Services_VersionCheckUpdating : GalleryStrings.Services_VersionCheckUpdate)</ChildContent>
                </FlareButton>
            }
        </FlareStack>

        <FlareText Typo="TypographyScale.LabelSmall" Color="FlareColor.OnSurfaceVariant">@GalleryStrings.Services_VersionCheckSimNote</FlareText>
        <FlareText Typo="TypographyScale.LabelSmall" Color="FlareColor.OnSurfaceVariant">@GalleryStrings.Services_VersionCheckNote</FlareText>
    </FlareStack>
</FlareCard>

<FlareText Typo="TypographyScale.TitleSmall" Style="margin:1.75rem 0 0.5rem">@GalleryStrings.Services_VersionCheckSetupTitle</FlareText>
<FlareText Typo="TypographyScale.BodyMedium" Color="FlareColor.OnSurfaceVariant" Style="max-width:48rem;">@GalleryStrings.Services_VersionCheckSetupIntro</FlareText>

<FlareStack Gap="FlareSpacing.Large" Style="margin-top:1rem;max-width:48rem;">
    <FlareStack Gap="FlareSpacing.XSmall">
        <FlareText Typo="TypographyScale.TitleSmall">@GalleryStrings.Services_VersionCheckSetupStep1Title</FlareText>
        <FlareText Typo="TypographyScale.BodyMedium">@GalleryStrings.Services_VersionCheckSetupStep1</FlareText>
        <FlareCodeBlock Value="@_csproj" Language="xml" ReadOnly="true" />
    </FlareStack>

    <FlareStack Gap="FlareSpacing.XSmall">
        <FlareText Typo="TypographyScale.TitleSmall">@GalleryStrings.Services_VersionCheckSetupStep2Title</FlareText>
        <FlareText Typo="TypographyScale.BodyMedium">@GalleryStrings.Services_VersionCheckSetupStep2</FlareText>
        <FlareCodeBlock Value="@_swClaim" Language="javascript" ReadOnly="true" LineNumbers="true" />
    </FlareStack>

    <FlareStack Gap="FlareSpacing.XSmall">
        <FlareText Typo="TypographyScale.TitleSmall">@GalleryStrings.Services_VersionCheckSetupStep3Title</FlareText>
        <FlareText Typo="TypographyScale.BodyMedium">@GalleryStrings.Services_VersionCheckSetupStep3</FlareText>
        <FlareCodeBlock Value="@_nginx" Language="nginx" ReadOnly="true" />
    </FlareStack>

    <FlareStack Gap="FlareSpacing.XSmall">
        <FlareText Typo="TypographyScale.TitleSmall">@GalleryStrings.Services_VersionCheckSetupStep4Title</FlareText>
        <FlareText Typo="TypographyScale.BodyMedium">@GalleryStrings.Services_VersionCheckSetupStep4</FlareText>
    </FlareStack>
</FlareStack>

<FlareText Typo="TypographyScale.TitleSmall" Style="margin:1.75rem 0 0.5rem">@GalleryStrings.Services_Usage</FlareText>
<FlareCodeBlock Value="@_usage" Language="csharp" ReadOnly="true" LineNumbers="true" />

@code {
    // A self-contained demo instance (generic mode) with a simulated probe, so the full lifecycle
    // is visible here without deploying a new build. The real app-wide service is registered in
    // Program.cs in service-worker mode (see MainLayout) and only fires after an actual new release.
    private VersionCheckService? _demo;

    private string _currentVersion = "1.0.0";
    private string _nextVersion = "1.1.0";
    private string? _detected;
    private bool _checking;
    private bool _updating;
    private int _checks;

    protected override void OnInitialized()
    {
        base.OnInitialized(); // LocalizedPage: subscribe to language changes
        var opts = new FlareVersionCheckOptions
        {
            CurrentVersion = _currentVersion,
            Interval = TimeSpan.FromSeconds(5),
            CheckImmediately = true,
            // First check reports the running version (up to date); after a couple of checks the
            // probe "sees" a newer deployed version, which raises NewVersionAvailable.
            CheckForLatestVersion = _ =>
            {
                _checks++;
                var reported = _checks >= 2 ? _nextVersion : _currentVersion;
                return Task.FromResult<string?>(reported);
            },
        };
        _demo = new VersionCheckService(opts);
        _demo.NewVersionAvailable += OnNewVersionAsync;
        _demo.Start();
    }

    private Task OnNewVersionAsync(VersionCheckInfo info) => InvokeAsync(() =>
    {
        _detected = info.LatestVersion;
        _checking = false;
        StateHasChanged();
    });

    private async Task CheckNowAsync()
    {
        if (_demo is null) return;
        _checking = true;
        StateHasChanged();
        await _demo.CheckNowAsync();
        // If the check did not surface a newer version, drop back to the up-to-date state.
        if (_detected is null) _checking = false;
        StateHasChanged();
    }

    // Mirrors the real "Update" action: a production app calls VersionCheck.ApplyUpdateAsync() to
    // activate the waiting service worker and reload. Here we surface progress (an "updating" state +
    // a short delay to stand in for the apply+reload) and confirm with a snackbar, so the click has
    // clear feedback instead of silently swapping the version.
    private async Task ApplyUpdate()
    {
        if (_demo is null || _updating || _detected is null) return;

        var target = _detected;
        _updating = true;
        _detected = null;          // leave the "new version" state, enter "updating..."
        StateHasChanged();

        await _demo.ApplyUpdateAsync(); // no-op in generic mode; shown for parity with real usage
        await Task.Delay(1200);         // stand in for the service-worker activation + reload

        _currentVersion = target;
        _nextVersion = BumpMinor(_currentVersion);
        _checks = 0;                // restart the cycle so the next version is not detected instantly
        _updating = false;
        StateHasChanged();

        Snackbar.Show($"{GalleryStrings.Services_VersionCheckUpdatedTo} {target}", SnackbarSeverity.Success);
    }

    private static string BumpMinor(string version)
    {
        var parts = version.Split('.');
        if (parts.Length >= 2 && int.TryParse(parts[1], out var minor))
            parts[1] = (minor + 1).ToString();
        return string.Join('.', parts);
    }

    public async ValueTask DisposeAsync()
    {
        if (_demo is not null)
        {
            _demo.NewVersionAvailable -= OnNewVersionAsync;
            await _demo.DisposeAsync();
        }
    }

    // Step 1: enable Blazor's PWA offline support so the build emits the worker + assets manifest.
    private const string _csproj = """
        <!-- Flare.Gallery.csproj: emits service-worker.js + service-worker-assets.js on publish. -->
        <ItemGroup>
          <ServiceWorker Include="wwwroot\service-worker.js"
                         PublishedContent="wwwroot\service-worker.published.js" />
        </ItemGroup>
        """;

    // Step 2: the single required tweak to the standard Blazor worker.
    private const string _swClaim = """
        // wwwroot/service-worker.published.js - the ONLY change from the stock Blazor worker.
        // Claim open pages on activate so a skipWaiting update reloads onto the NEW worker
        // (via controllerchange) instead of re-serving the old cache (the stale "dev" bug).
        async function onActivate(event) {
            const keys = await caches.keys();
            await Promise.all(keys
                .filter(k => k.startsWith(cacheNamePrefix) && k !== cacheName)
                .map(k => caches.delete(k)));

            await self.clients.claim();   // <-- add this line
        }
        """;

    // Step 3: host/proxy cache headers - the control files must never be cached.
    private const string _nginx = """
        # Never cache the PWA control files (host AND any reverse proxy / CDN). Otherwise the
        # version probe reads a stale service-worker-assets.js and the update never fires.
        location ~* (service-worker(-assets)?\.js|blazor\.boot\.json|\.webmanifest)$ {
            add_header Cache-Control "no-cache, no-store, must-revalidate" always;
        }
        """;

    // Step 4: register the service and surface the update.
    private const string _usage = """
        // Program.cs - service-worker mode. The service registers the SW (ServiceWorkerPath defaults
        // to service-worker.js), polls the deployed version, and applies the update. No app JS needed.
        builder.Services.AddFlareVersionCheck(opts =>
        {
            opts.Interval = TimeSpan.FromSeconds(10);
            opts.UseServiceWorker = true;
        });

        // ...or generic mode: provide your own probe (e.g. poll a version.json).
        builder.Services.AddFlareVersionCheck(opts =>
        {
            opts.Interval = TimeSpan.FromMinutes(30);
            opts.CurrentVersion = "1.0.0";
            opts.CheckForLatestVersion = async ct =>
                (await http.GetFromJsonAsync<VersionDto>("version.json", ct))?.Version;
        });

        // MainLayout.razor - the service renders nothing; you decide how to surface it.
        @inject IVersionCheckService VersionCheck
        @inject ISnackbarService Snackbar

        private readonly Guid _toastId = Guid.NewGuid();

        protected override void OnInitialized()
        {
            VersionCheck.NewVersionAvailable += OnNewVersion;
            VersionCheck.Start();
        }

        // Stop polling once a version is known, then show one actionable toast.
        Task OnNewVersion(VersionCheckInfo info) => InvokeAsync(() =>
        {
            VersionCheck.Stop();
            Snackbar.Show(new SnackbarMessage(_toastId, "A new version is available",
                SnackbarSeverity.Info, DurationMs: 0, ActionText: "Update", OnAction: StartUpdate));
        });

        // Change the SAME toast in place into an "updating" state with a progress bar, then apply:
        // ApplyUpdateAsync activates the waiting worker and reloads onto the new version.
        async Task StartUpdate()
        {
            Snackbar.Update(new SnackbarMessage(_toastId, "Updating...", SnackbarSeverity.Info,
                DurationMs: 0, ShowClose: false, ShowProgress: true));
            await VersionCheck.ApplyUpdateAsync();
        }
        """;
}
