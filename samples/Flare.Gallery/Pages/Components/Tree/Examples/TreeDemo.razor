<FlareTreeView AriaLabel="File explorer">
    <FlareTreeItem Label="Documents" Icon="@MaterialDesign3Icons.Regular.Folder" Expanded="true">
        <FlareTreeItem Label="Projects" Icon="@MaterialDesign3Icons.Regular.Folder">
            <FlareTreeItem Label="Flare.sln" Icon="@MaterialDesign3Icons.Regular.Description"
                           Selected="@(_selected == "Flare.sln")"
                           OnClick="@(() => _selected = "Flare.sln")" />
            <FlareTreeItem Label="README.md" Icon="@MaterialDesign3Icons.Regular.Description"
                           Selected="@(_selected == "README.md")"
                           OnClick="@(() => _selected = "README.md")" />
        </FlareTreeItem>
        <FlareTreeItem Label="Resume.pdf" Icon="@MaterialDesign3Icons.Regular.PictureAsPdf"
                       Selected="@(_selected == "Resume.pdf")"
                       OnClick="@(() => _selected = "Resume.pdf")" />
    </FlareTreeItem>
    <FlareTreeItem Label="Downloads" Icon="@MaterialDesign3Icons.Regular.Folder">
        <FlareTreeItem Label="archive.zip" Icon="@MaterialDesign3Icons.Regular.FolderZip"
                       Selected="@(_selected == "archive.zip")"
                       OnClick="@(() => _selected = "archive.zip")" />
    </FlareTreeItem>
    <FlareTreeItem Label="settings.json" Icon="@MaterialDesign3Icons.Regular.Settings"
                   Selected="@(_selected == "settings.json")"
                   OnClick="@(() => _selected = "settings.json")" />
</FlareTreeView>

@if (_selected is not null)
{
    <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.LabelSmall" Style="margin-top:0.75rem">
        Selected: @_selected
    </FlareText>
}

@code {
    private string? _selected;
}
