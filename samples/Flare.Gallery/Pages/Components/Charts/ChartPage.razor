@page "/components/charts"
@inherits LocalizedPage

<PageTitle>@GalleryStrings.Charts_Title - Flare</PageTitle>

<GalleryPageTitle Api="FlareChart">
    <FlareText Typo="TypographyScale.HeadlineMedium">@GalleryStrings.Charts_Title</FlareText>
    <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.BodyLarge">
        @GalleryStrings.Charts_Subtitle
    </FlareText>
</GalleryPageTitle>

<AutoDemoSection Title="@GalleryStrings.Charts_Line" DemoType="typeof(Examples.ChartsLineDemo)" />
<AutoDemoSection Title="@GalleryStrings.Charts_Bar" DemoType="typeof(Examples.ChartsBarDemo)" />
<AutoDemoSection Title="@GalleryStrings.Charts_Pie" DemoType="typeof(Examples.ChartsPieDemo)" />
<AutoDemoSection Title="@GalleryStrings.Charts_MultiLine" DemoType="typeof(Examples.ChartsMultiLineDemo)" />
<AutoDemoSection Title="@GalleryStrings.Charts_Sparkline" DemoType="typeof(Examples.ChartsSparklineDemo)" />
<AutoDemoSection Title="@GalleryStrings.Charts_MoreTypes" DemoType="typeof(Examples.ChartsBreadthDemo)" />
<AutoDemoSection Title="@GalleryStrings.Charts_Config" DemoType="typeof(Examples.ChartsConfigDemo)" />
<AutoDemoSection Title="@GalleryStrings.Charts_Advanced" DemoType="typeof(Examples.ChartsAdvancedDemo)" />
<AutoDemoSection Title="@GalleryStrings.Charts_ExtraTypes" DemoType="typeof(Examples.ChartsExtraTypesDemo)" />