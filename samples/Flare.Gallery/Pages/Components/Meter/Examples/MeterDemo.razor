<FlareStack Gap="FlareSpacing.Large" Style="max-width:30rem;">
    @* Request timing breakdown: how a total splits into parts (the Weir use case). *@
    <FlareStack Gap="FlareSpacing.Small">
        <FlareText Typo="TypographyScale.LabelLarge">Request timing (18.9 ms)</FlareText>
        <FlareMeter ShowLegend="true" ShowValues="true" Format="N1">
            <FlareMeterSegment Value="12.4" Color="FlareColor.Error" Label="DB" />
            <FlareMeterSegment Value="3.4" Color="FlareColor.Warning" Label="Serialize" />
            <FlareMeterSegment Value="3.1" Color="FlareColor.OnSurfaceVariant" Label="Other" />
        </FlareMeter>
    </FlareStack>

    @* Test run ribbon: pass / fail / skip. *@
    <FlareStack Gap="FlareSpacing.Small">
        <FlareText Typo="TypographyScale.LabelLarge">Test run</FlareText>
        <FlareMeter ShowLegend="true" ShowValues="true">
            <FlareMeterSegment Value="182" Color="FlareColor.Success" Label="Passed" />
            <FlareMeterSegment Value="7" Color="FlareColor.Error" Label="Failed" />
            <FlareMeterSegment Value="11" Color="FlareColor.OnSurfaceVariant" Label="Skipped" />
        </FlareMeter>
    </FlareStack>

    @* Storage quota with a custom color. *@
    <FlareStack Gap="FlareSpacing.Small">
        <FlareText Typo="TypographyScale.LabelLarge">Storage</FlareText>
        <FlareMeter>
            <FlareMeterSegment Value="68" Color="FlareColor.Primary" Label="Used" />
            <FlareMeterSegment Value="32" Color="@FlareColor.Custom("#c7c7cc")" Label="Free" />
        </FlareMeter>
    </FlareStack>
</FlareStack>
