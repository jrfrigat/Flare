<FlareStack Gap="FlareSpacing.Large" Style="max-width:30rem;">
    @* Request timing breakdown: how a total splits into parts. A meter is a proportional zone host,
       so each part is a <FlareZone Value="..."> - the same zone component the slider uses. *@
    <FlareStack Gap="FlareSpacing.Small">
        <FlareText Typo="TypographyScale.LabelLarge">Request timing (18.9 ms)</FlareText>
        <FlareMeter ShowLegend="true" ShowValues="true" Format="N1">
            <FlareZone Value="12.4" Color="FlareColor.Error" Label="DB" />
            <FlareZone Value="3.4" Color="FlareColor.Warning" Label="Serialize" />
            <FlareZone Value="3.1" Color="FlareColor.OnSurfaceVariant" Label="Other" />
        </FlareMeter>
    </FlareStack>

    @* Test run ribbon: pass / fail / skip. *@
    <FlareStack Gap="FlareSpacing.Small">
        <FlareText Typo="TypographyScale.LabelLarge">Test run</FlareText>
        <FlareMeter ShowLegend="true" ShowValues="true">
            <FlareZone Value="182" Color="FlareColor.Success" Label="Passed" />
            <FlareZone Value="7" Color="FlareColor.Error" Label="Failed" />
            <FlareZone Value="11" Color="FlareColor.OnSurfaceVariant" Label="Skipped" />
        </FlareMeter>
    </FlareStack>

    @* Storage quota with a custom color. *@
    <FlareStack Gap="FlareSpacing.Small">
        <FlareText Typo="TypographyScale.LabelLarge">Storage</FlareText>
        <FlareMeter>
            <FlareZone Value="68" Color="FlareColor.Primary" Label="Used" />
            <FlareZone Value="32" Color="_free" Label="Free" />
        </FlareMeter>
    </FlareStack>
</FlareStack>

@code {
    private readonly FlareColor _free = FlareColor.Custom("#c7c7cc");
}
