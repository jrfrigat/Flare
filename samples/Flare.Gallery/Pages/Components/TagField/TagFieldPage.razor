    <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.BodyLarge">@GalleryStrings.TagInput_Subtitle</FlareText>
</GalleryPageTitle>

<AutoDemoSection Title="@GalleryStrings.TagInput_Basic" DemoType="typeof(Examples.TagFieldBasicDemo)" />
