@inherits LocalizedPage

<FlareField TValue="string" @bind-Value="_query" Label="@GalleryStrings.Highlighter_SearchTerm" Placeholder="@GalleryStrings.Highlighter_TypeToHighlight" />
<FlareStack Row Style="line-height:1.8;margin-top:1rem;">
    <FlareHighlighter Text="@_sampleText" Highlight="@_query" />
</FlareStack>

@code {
    private string? _query;

    private const string _sampleText =
        "Flare is a modern Blazor component library built on Material Design 3. " +
        "It ships with inputs, layout, navigation, data display, charts, and more.";
}
