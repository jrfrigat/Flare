<FlareStack Style="max-width:36rem;">
    <FlareDropZone OnFilesDropped="HandleFiles" />
    @if (_files.Count > 0)
    {
        <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.LabelSmall" Style="margin-top:0.75rem">
            Selected: @string.Join(", ", _files.Select(f => f.Name))
        </FlareText>
    }
</FlareStack>

@code {
    private List<Microsoft.AspNetCore.Components.Forms.IBrowserFile> _files = new();

    private void HandleFiles(IReadOnlyList<Microsoft.AspNetCore.Components.Forms.IBrowserFile> files)
        => _files = files.ToList();
}
