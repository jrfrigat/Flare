@page "/components/date-range-picker"
@inherits LocalizedPage

<PageTitle>@GalleryStrings.DateRangePicker_Title - Flare</PageTitle>

<GalleryPageTitle Api="FlareDateRangePicker">
    <FlareText Typo="TypographyScale.HeadlineMedium">@GalleryStrings.DateRangePicker_Title</FlareText>
    <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.BodyLarge">@GalleryStrings.DateRangePicker_Subtitle</FlareText>
</GalleryPageTitle>

<AutoDemoSection Title="@GalleryStrings.DateRangePicker_Basic" DemoType="typeof(Examples.DateRangePickerDemo)" />
<AutoDemoSection Title="@GalleryStrings.DateRangePicker_Presets" DemoType="typeof(Examples.DateRangePresetsDemo)" />
