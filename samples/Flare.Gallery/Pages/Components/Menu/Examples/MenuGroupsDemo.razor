@using Flare.Gallery.Resources
@inject ISnackbarService Snackbar

<FlareMenu Anchor="MenuAnchor.BottomLeft">
    <Activator>
        <FlareButton Variant="ButtonVariant.Outlined">@GalleryStrings.Menu_Groups_Activator ▾</FlareButton>
    </Activator>
    <ChildContent>
        <FlareMenuGroup Label="@GalleryStrings.Menu_Group_Edit">
            <FlareMenuItem Icon="content_cut" OnClick="@(() => Snackbar.Show(GalleryStrings.Menu_Action_Cut))">@GalleryStrings.Menu_Action_Cut</FlareMenuItem>
            <FlareMenuItem Icon="content_copy" OnClick="@(() => Snackbar.Show(GalleryStrings.Menu_Action_Copy))">@GalleryStrings.Menu_Action_Copy</FlareMenuItem>
            <FlareMenuItem Icon="content_paste" OnClick="@(() => Snackbar.Show(GalleryStrings.Menu_Action_Paste))">@GalleryStrings.Menu_Action_Paste</FlareMenuItem>
        </FlareMenuGroup>
        <FlareMenuGroup Label="@GalleryStrings.Menu_Group_View">
            <FlareMenuItem Icon="zoom_in" OnClick="@(() => Snackbar.Show(GalleryStrings.Menu_Action_ZoomIn))">@GalleryStrings.Menu_Action_ZoomIn</FlareMenuItem>
            <FlareMenuItem Icon="zoom_out" OnClick="@(() => Snackbar.Show(GalleryStrings.Menu_Action_ZoomOut))">@GalleryStrings.Menu_Action_ZoomOut</FlareMenuItem>
        </FlareMenuGroup>
    </ChildContent>
</FlareMenu>
