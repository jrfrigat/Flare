@* Четыре положения панели относительно активатора (MenuAnchor) *@
<FlareStack Row Gap="FlareSpacing.Large" Wrap Style="padding:4rem 0;">
    <FlareMenu Anchor="MenuAnchor.BottomLeft">
        <Activator>
            <FlareButton Variant="ButtonVariant.Outlined">Bottom-left ▾</FlareButton>
        </Activator>
        <ChildContent>
            <FlareMenuItem Icon="@MaterialDesign3Icons.Regular.NorthWest">Bottom-left</FlareMenuItem>
            <FlareMenuItem Icon="@MaterialDesign3Icons.Regular.Check">Option</FlareMenuItem>
        </ChildContent>
    </FlareMenu>

    <FlareMenu Anchor="MenuAnchor.BottomRight">
        <Activator>
            <FlareButton Variant="ButtonVariant.Outlined">Bottom-right ▾</FlareButton>
        </Activator>
        <ChildContent>
            <FlareMenuItem Icon="@MaterialDesign3Icons.Regular.NorthEast">Bottom-right</FlareMenuItem>
            <FlareMenuItem Icon="@MaterialDesign3Icons.Regular.Check">Option</FlareMenuItem>
        </ChildContent>
    </FlareMenu>

    <FlareMenu Anchor="MenuAnchor.TopLeft">
        <Activator>
            <FlareButton Variant="ButtonVariant.Outlined">Top-left ▴</FlareButton>
        </Activator>
        <ChildContent>
            <FlareMenuItem Icon="@MaterialDesign3Icons.Regular.SouthWest">Top-left</FlareMenuItem>
            <FlareMenuItem Icon="@MaterialDesign3Icons.Regular.Check">Option</FlareMenuItem>
        </ChildContent>
    </FlareMenu>

    <FlareMenu Anchor="MenuAnchor.TopRight">
        <Activator>
            <FlareButton Variant="ButtonVariant.Outlined">Top-right ▴</FlareButton>
        </Activator>
        <ChildContent>
            <FlareMenuItem Icon="@MaterialDesign3Icons.Regular.SouthEast">Top-right</FlareMenuItem>
            <FlareMenuItem Icon="@MaterialDesign3Icons.Regular.Check">Option</FlareMenuItem>
        </ChildContent>
    </FlareMenu>
</FlareStack>
