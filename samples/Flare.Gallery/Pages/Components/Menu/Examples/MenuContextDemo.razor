@inject ISnackbarService Snackbar

<FlareStack Row Gap="FlareSpacing.Medium" Wrap AlignItems="FlareAlignItems.Start">
    @* Context menu: right-click opens the menu pinned to the pointer. *@
    <FlareMenu Activation="MenuActivation.RightClick" PositionAtCursor="true" AriaLabel="@GalleryStrings.Menu_Context">
        <Activator>
            <FlarePaper Style="padding:2rem 3rem;">@GalleryStrings.Menu_ContextHint</FlarePaper>
        </Activator>
        <ChildContent>
            <FlareMenuItem Icon="content_cut" OnClick="@(() => Snackbar.Show(GalleryStrings.Menu_Action_Cut))">@GalleryStrings.Menu_Action_Cut</FlareMenuItem>
            <FlareMenuItem Icon="content_copy" OnClick="@(() => Snackbar.Show(GalleryStrings.Menu_Action_Copy))">@GalleryStrings.Menu_Action_Copy</FlareMenuItem>
            <FlareMenuItem Icon="content_paste" OnClick="@(() => Snackbar.Show(GalleryStrings.Menu_Action_Paste))">@GalleryStrings.Menu_Action_Paste</FlareMenuItem>
        </ChildContent>
    </FlareMenu>

    @* MaxHeight caps the panel so a long list scrolls instead of overflowing. *@
    <FlareMenu MaxHeight="14rem">
        <Activator>
            <FlareButton Variant="ButtonVariant.Outlined">@GalleryStrings.Menu_Scroll</FlareButton>
        </Activator>
        <ChildContent>
            @for (var i = 1; i <= 12; i++)
            {
                var n = i;
                <FlareMenuItem Icon="star" OnClick="@(() => Snackbar.Show($"{GalleryStrings.Menu_ScrollItem} {n}"))">@GalleryStrings.Menu_ScrollItem @n</FlareMenuItem>
            }
        </ChildContent>
    </FlareMenu>

    @* AutoClose=false keeps the menu open so several toggle items can be flipped in one pass. *@
    <FlareMenu AriaLabel="@GalleryStrings.Menu_KeepOpen">
        <Activator>
            <FlareButton Variant="ButtonVariant.Filled">@GalleryStrings.Menu_KeepOpen</FlareButton>
        </Activator>
        <ChildContent>
            <FlareMenuItem AutoClose="false" Icon="@(_a ? "check_box" : "check_box_outline_blank")" OnClick="@(() => _a = !_a)">@GalleryStrings.Menu_Action_Cut</FlareMenuItem>
            <FlareMenuItem AutoClose="false" Icon="@(_b ? "check_box" : "check_box_outline_blank")" OnClick="@(() => _b = !_b)">@GalleryStrings.Menu_Action_Copy</FlareMenuItem>
            <FlareDivider />
            <FlareMenuItem Icon="done">@GalleryStrings.Menu_Action_Paste</FlareMenuItem>
        </ChildContent>
    </FlareMenu>
</FlareStack>

@code {
    private bool _a;
    private bool _b;
}
