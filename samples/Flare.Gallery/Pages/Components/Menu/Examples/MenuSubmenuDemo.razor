<FlareStack Gap="FlareSpacing.Large" Direction="FlexDirection.Column">
    <FlareText Typo="TypographyScale.TitleMedium">Submenus</FlareText>
    <FlareText Typo="TypographyScale.BodyMedium" Color="FlareColor.OnSurfaceVariant">
        Nested submenus with hover activation and keyboard navigation.
    </FlareText>
    
    <FlareMenu>
        <Activator>
            <FlareButton>Open Menu with Submenus</FlareButton>
        </Activator>
        <ChildContent>
            <FlareMenuItem Icon="@MaterialDesign3Icons.Regular.Home" OnClick="@(() => _lastAction = "Home")">Home</FlareMenuItem>
            <FlareMenuItem Icon="@MaterialDesign3Icons.Regular.Settings" OnClick="@(() => _lastAction = "Settings")">Settings</FlareMenuItem>
            
            <FlareSubMenu Label="More Options" Icon="@MaterialDesign3Icons.Regular.MoreHoriz">
                <FlareMenuItem OnClick="@(() => _lastAction = "Option 1")">Option 1</FlareMenuItem>
                <FlareMenuItem OnClick="@(() => _lastAction = "Option 2")">Option 2</FlareMenuItem>
                
                <FlareSubMenu Label="Advanced">
                    <FlareMenuItem OnClick="@(() => _lastAction = "Advanced 1")">Advanced 1</FlareMenuItem>
                    <FlareMenuItem OnClick="@(() => _lastAction = "Advanced 2")">Advanced 2</FlareMenuItem>
                </FlareSubMenu>
            </FlareSubMenu>
            
            <FlareMenuItem Icon="@MaterialDesign3Icons.Regular.Help" OnClick="@(() => _lastAction = "Help")">Help</FlareMenuItem>
        </ChildContent>
    </FlareMenu>
    
    @if (!string.IsNullOrEmpty(_lastAction))
    {
        <FlareText Color="FlareColor.Primary">Last action: @_lastAction</FlareText>
    }
    
    <FlareText Typo="TypographyScale.TitleMedium">Submenu with Groups</FlareText>
    <FlareMenu>
        <Activator>
            <FlareButton>Actions Menu</FlareButton>
        </Activator>
        <ChildContent>
            <FlareMenuGroup Label="File">
                <FlareMenuItem Icon="@MaterialDesign3Icons.Regular.FileOpen">Open</FlareMenuItem>
                <FlareMenuItem Icon="@MaterialDesign3Icons.Regular.Save">Save</FlareMenuItem>
            </FlareMenuGroup>
            
            <FlareSubMenu Label="Edit" Icon="@MaterialDesign3Icons.Regular.Edit">
                <FlareMenuItem Icon="@MaterialDesign3Icons.Regular.ContentCopy">Copy</FlareMenuItem>
                <FlareMenuItem Icon="@MaterialDesign3Icons.Regular.ContentPaste">Paste</FlareMenuItem>
                <FlareMenuItem Icon="@MaterialDesign3Icons.Regular.Undo">Undo</FlareMenuItem>
            </FlareSubMenu>
            
            <FlareMenuGroup Label="Help">
                <FlareMenuItem Icon="@MaterialDesign3Icons.Regular.Help">Documentation</FlareMenuItem>
                <FlareMenuItem Icon="@MaterialDesign3Icons.Regular.Info">About</FlareMenuItem>
            </FlareMenuGroup>
        </ChildContent>
    </FlareMenu>
</FlareStack>

@code {
    private string? _lastAction;
}
