<FlareStack Gap="FlareSpacing.Large" Direction="FlexDirection.Column">
    <FlareText Typo="TypographyScale.TitleMedium">Submenus</FlareText>
    <FlareText Typo="TypographyScale.BodyMedium" Color="FlareColor.OnSurfaceVariant">
        Nested submenus with hover activation and keyboard navigation.
    </FlareText>
    
    <FlareMenu>
        <Activator>
            <FlareButton>Open Menu with Submenus</FlareButton>
        </Activator>
        <ChildContent>
            <FlareMenuItem Icon="@("home")" OnClick="@(() => _lastAction = "Home")">Home</FlareMenuItem>
            <FlareMenuItem Icon="@("settings")" OnClick="@(() => _lastAction = "Settings")">Settings</FlareMenuItem>
            
            <FlareSubMenu Label="More Options" Icon="more_horiz">
                <FlareMenuItem OnClick="@(() => _lastAction = "Option 1")">Option 1</FlareMenuItem>
                <FlareMenuItem OnClick="@(() => _lastAction = "Option 2")">Option 2</FlareMenuItem>
                
                <FlareSubMenu Label="Advanced">
                    <FlareMenuItem OnClick="@(() => _lastAction = "Advanced 1")">Advanced 1</FlareMenuItem>
                    <FlareMenuItem OnClick="@(() => _lastAction = "Advanced 2")">Advanced 2</FlareMenuItem>
                </FlareSubMenu>
            </FlareSubMenu>
            
            <FlareMenuItem Icon="@("help")" OnClick="@(() => _lastAction = "Help")">Help</FlareMenuItem>
        </ChildContent>
    </FlareMenu>
    
    @if (!string.IsNullOrEmpty(_lastAction))
    {
        <FlareText Color="FlareColor.Primary">Last action: @_lastAction</FlareText>
    }
    
    <FlareText Typo="TypographyScale.TitleMedium">Submenu with Groups</FlareText>
    <FlareMenu>
        <Activator>
            <FlareButton>Actions Menu</FlareButton>
        </Activator>
        <ChildContent>
            <FlareMenuGroup Label="File">
                <FlareMenuItem Icon="@("file_open")">Open</FlareMenuItem>
                <FlareMenuItem Icon="@("save")">Save</FlareMenuItem>
            </FlareMenuGroup>
            
            <FlareSubMenu Label="Edit" Icon="edit">
                <FlareMenuItem Icon="@("content_copy")">Copy</FlareMenuItem>
                <FlareMenuItem Icon="@("content_paste")">Paste</FlareMenuItem>
                <FlareMenuItem Icon="@("undo")">Undo</FlareMenuItem>
            </FlareSubMenu>
            
            <FlareMenuGroup Label="Help">
                <FlareMenuItem Icon="@("help")">Documentation</FlareMenuItem>
                <FlareMenuItem Icon="@("info")">About</FlareMenuItem>
            </FlareMenuGroup>
        </ChildContent>
    </FlareMenu>
</FlareStack>

@code {
    private string? _lastAction;
}
