@inject ISnackbarService Snackbar

<FlareStack Row Gap="FlareSpacing.Small">
    <FlareMenu Anchor="MenuAnchor.BottomLeft">
        <Activator>
            <FlareButton Variant="ButtonVariant.Outlined">Actions ▾</FlareButton>
        </Activator>
        <ChildContent>
            <FlareMenuItem Icon="@MaterialDesign3Icons.Regular.Edit" OnClick="@(() => Snackbar.Show("Edit clicked"))">Edit</FlareMenuItem>
            <FlareMenuItem Icon="@MaterialDesign3Icons.Regular.ContentCopy" OnClick="@(() => Snackbar.Show("Duplicated"))">Duplicate</FlareMenuItem>
            <FlareDivider />
            <FlareMenuItem Icon="@MaterialDesign3Icons.Regular.Delete" OnClick="@(() => Snackbar.Show("Deleted!", SnackbarSeverity.Error))">Delete</FlareMenuItem>
            <FlareMenuItem Disabled="true" Icon="@MaterialDesign3Icons.Regular.Lock">Locked action</FlareMenuItem>
        </ChildContent>
    </FlareMenu>

    <FlareMenu Anchor="MenuAnchor.BottomRight">
        <Activator>
            <FlareButton Variant="ButtonVariant.Filled">Right-aligned ▾</FlareButton>
        </Activator>
        <ChildContent>
            <FlareMenuItem Icon="@MaterialDesign3Icons.Regular.Settings" OnClick="@(() => Snackbar.Show("Settings"))">Settings</FlareMenuItem>
            <FlareMenuItem Icon="@MaterialDesign3Icons.Regular.Help" OnClick="@(() => Snackbar.Show("Help"))">Help</FlareMenuItem>
            <FlareMenuItem Icon="@MaterialDesign3Icons.Regular.Logout" OnClick="@(() => Snackbar.Show("Logged out", SnackbarSeverity.Warning))">Log out</FlareMenuItem>
        </ChildContent>
    </FlareMenu>

    <FlareMenu Anchor="MenuAnchor.BottomLeft" Dense="true">
        <Activator>
            <FlareButton Variant="ButtonVariant.Outlined">Dense ▾</FlareButton>
        </Activator>
        <ChildContent>
            <FlareMenuItem Icon="@MaterialDesign3Icons.Regular.Edit" OnClick="@(() => Snackbar.Show("Edit"))">Edit</FlareMenuItem>
            <FlareMenuItem Icon="@MaterialDesign3Icons.Regular.ContentCopy" OnClick="@(() => Snackbar.Show("Duplicate"))">Duplicate</FlareMenuItem>
            <FlareMenuItem Icon="@MaterialDesign3Icons.Regular.Delete" OnClick="@(() => Snackbar.Show("Delete"))">Delete</FlareMenuItem>
        </ChildContent>
    </FlareMenu>
</FlareStack>
