@* FlareCode: a themed inline <code> chip for mid-flow tokens. FlareText Mono: monospace with no chip
   (pair with Element="kbd" for keystrokes, Element="span" for a plain code run). *@
<FlareStack Gap="FlareSpacing.Small">
    <FlareText>
        Call <FlareCode>POST /api/orders</FlareCode> with an <FlareCode>X-Api-Key</FlareCode> header.
    </FlareText>
    <FlareText>
        Press <FlareText Element="kbd" Mono>Ctrl</FlareText> + <FlareText Element="kbd" Mono>S</FlareText> to save;
        the column type is <FlareText Element="span" Mono>NVARCHAR(MAX)</FlareText>.
    </FlareText>
</FlareStack>
