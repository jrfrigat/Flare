<FlareStack Gap="FlareSpacing.Medium" Align="FlareAlignItems.Start">
    <FlareSwitch @bind-Value="_wifi" Label="Wi-Fi (check / close)">
        <SelectedIcon><FlareIcon Name="check" /></SelectedIcon>
        <UnselectedIcon><FlareIcon Name="close" /></UnselectedIcon>
    </FlareSwitch>
    <FlareSwitch @bind-Value="_sync" Label="Sync (check when on)">
        <SelectedIcon><FlareIcon Name="check" /></SelectedIcon>
    </FlareSwitch>
    <FlareSwitch @bind-Value="_theme" Label="Theme (sun / moon)">
        <SelectedIcon><FlareIcon Name="dark_mode" /></SelectedIcon>
        <UnselectedIcon><FlareIcon Name="light_mode" /></UnselectedIcon>
    </FlareSwitch>
</FlareStack>
<FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.LabelSmall" Style="margin-top:0.5rem">
    Wi-Fi: @_wifi | Sync: @_sync | Theme: @(_theme ? "dark" : "light")
</FlareText>

@code {
    private bool _wifi = true;
    private bool _sync;
    private bool _theme = true;
}
