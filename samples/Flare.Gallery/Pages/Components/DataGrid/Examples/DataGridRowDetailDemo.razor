<FlareDataGrid Items="@DatagridData._people" PageSize="5">
    <RowDetailTemplate Context="item">
        <FlareStack Row Style="padding:1rem;">
            <strong>@item.Name</strong> - @item.City
        </FlareStack>
    </RowDetailTemplate>
    <Columns>
        <FlareColumn Title="Name" Field="@(p => p.Name)" Sortable />
        <FlareColumn Title="Role" Field="@(p => p.Role)" Sortable />
        <FlareColumn Title="Score" Field="@(p => p.Score)" Width="80px" />
    </Columns>
</FlareDataGrid>