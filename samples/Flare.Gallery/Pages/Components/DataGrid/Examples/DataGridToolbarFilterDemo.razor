@using Flare.Gallery.Pages.Components.DataGrid.Examples

<FlareDataGrid Items="@DatagridData._people" PageSize="5">
    <Columns>
        <FlareColumn Title="Name" Field="@(p => p.Name)" Filterable="true" />
        <FlareColumn Title="Role" Field="@(p => p.Role)" Filterable="true" />
        <FlareColumn Title="City" Field="@(p => p.City)" />
        <FlareColumn Title="Score" Field="@(p => p.Score)" Width="80px" />
    </Columns>
</FlareDataGrid>
