@* "EXCEL" produces a real .xlsx (OOXML, bold header) with no third-party dependency. *@
<FlareDataGrid Items="@DatagridData._people" PageSize="5" ExportFileName="people"
               Exporters="@(new List<IDataGridExporter<Person>> { DataGridExporters.Csv<Person>(), DataGridExporters.Json<Person>(), DataGridExporters.Tsv<Person>(), DataGridExporters.Excel<Person>() })">
    <Columns>
        <FlareColumn Title="Name" Field="@(p => p.Name)" Sortable="true" />
        <FlareColumn Title="Role" Field="@(p => p.Role)" Sortable="true" />
        <FlareColumn Title="City" Field="@(p => p.City)" />
        <FlareColumn Title="Score" Field="@(p => p.Score)" Width="80px" />
    </Columns>
</FlareDataGrid>
