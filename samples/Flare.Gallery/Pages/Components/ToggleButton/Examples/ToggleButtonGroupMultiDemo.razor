<FlareStack Gap="FlareSpacing.Medium" Align="FlareAlignItems.Start">
    <FlareToggleGroup TValue="string" MultiSelect="true" @bind-Values="_formatting">
        <FlareToggleButton Value="@("bold")" AriaLabel="Bold">
            <OffIcon><FlareIconView Value="@MaterialDesign3Icons.Regular.FormatBold" /></OffIcon>
            <ChildContent>Bold</ChildContent>
        </FlareToggleButton>
        <FlareToggleButton Value="@("italic")" AriaLabel="Italic">
            <OffIcon><FlareIconView Value="@MaterialDesign3Icons.Regular.FormatItalic" /></OffIcon>
            <ChildContent>Italic</ChildContent>
        </FlareToggleButton>
        <FlareToggleButton Value="@("underline")" AriaLabel="Underline">
            <OffIcon><FlareIconView Value="@MaterialDesign3Icons.Regular.FormatUnderlined" /></OffIcon>
            <ChildContent>Underline</ChildContent>
        </FlareToggleButton>
    </FlareToggleGroup>
    <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.LabelSmall">
        Active: @string.Join(", ", _formatting ?? [])
    </FlareText>
</FlareStack>

@code {
    private IReadOnlyList<string?>? _formatting;
}
