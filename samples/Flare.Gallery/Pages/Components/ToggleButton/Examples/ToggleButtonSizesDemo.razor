<FlareStack Row Align="FlareAlignItems.Center" Gap="FlareSpacing.Medium" Wrap>
    <FlareToggleButton Size="ButtonSize.Sm">
        <OffIcon><FlareIconView Value="@MaterialDesign3Icons.Regular.Star" /></OffIcon>
        <ChildContent>Small</ChildContent>
    </FlareToggleButton>
    <FlareToggleButton Size="ButtonSize.Md">
        <OffIcon><FlareIconView Value="@MaterialDesign3Icons.Regular.Star" /></OffIcon>
        <ChildContent>Medium</ChildContent>
    </FlareToggleButton>
    <FlareToggleButton Size="ButtonSize.Lg">
        <OffIcon><FlareIconView Value="@MaterialDesign3Icons.Regular.Star" /></OffIcon>
        <ChildContent>Large</ChildContent>
    </FlareToggleButton>
    <FlareToggleButton Toggled Disabled>
        <OffIcon><FlareIconView Value="@MaterialDesign3Icons.Regular.Lock" /></OffIcon>
        <ChildContent>Disabled</ChildContent>
    </FlareToggleButton>
</FlareStack>
