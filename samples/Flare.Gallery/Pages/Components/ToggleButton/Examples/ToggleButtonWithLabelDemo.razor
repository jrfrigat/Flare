<FlareStack Row Align="FlareAlignItems.Center" Gap="FlareSpacing.Medium" Wrap>
    <FlareToggleButton @bind-Toggled="_bold">
        <OffIcon><FlareIconView Value="@MaterialDesign3Icons.Regular.FormatBold" /></OffIcon>
        <ChildContent>Bold</ChildContent>
    </FlareToggleButton>

    <FlareToggleButton @bind-Toggled="_italic">
        <OffIcon><FlareIconView Value="@MaterialDesign3Icons.Regular.FormatItalic" /></OffIcon>
        <ChildContent>Italic</ChildContent>
    </FlareToggleButton>

    <FlareToggleButton @bind-Toggled="_underline">
        <OffIcon><FlareIconView Value="@MaterialDesign3Icons.Regular.FormatUnderlined" /></OffIcon>
        <ChildContent>Underline</ChildContent>
    </FlareToggleButton>
</FlareStack>

@code {
    private bool _bold;
    private bool _italic;
    private bool _underline;
}
