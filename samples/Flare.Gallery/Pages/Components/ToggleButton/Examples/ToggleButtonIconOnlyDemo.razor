<FlareStack Gap="FlareSpacing.Medium">
    <FlareStack Row Align="FlareAlignItems.Center" Gap="FlareSpacing.Medium" Wrap="true">
        <FlareToggleButton @bind-Toggled="_fav" AriaLabel="Favourite">
            <OffIcon><FlareIconView Value="@MaterialDesign3Icons.Regular.Favorite" /></OffIcon>
            <OnIcon><FlareIconView Color="FlareColor.Error" Value="@MaterialDesign3Icons.Regular.Favorite" /></OnIcon>
        </FlareToggleButton>

        <FlareToggleButton @bind-Toggled="_bookmark" AriaLabel="Bookmark">
            <OffIcon><FlareIconView Value="@MaterialDesign3Icons.Regular.Bookmark" /></OffIcon>
            <OnIcon><FlareIconView Value="@MaterialDesign3Icons.Regular.Bookmark" /></OnIcon>
        </FlareToggleButton>

        <FlareToggleButton @bind-Toggled="_mute" AriaLabel="Mute">
            <OffIcon><FlareIconView Value="@MaterialDesign3Icons.Regular.VolumeUp" /></OffIcon>
            <OnIcon><FlareIconView Value="@MaterialDesign3Icons.Regular.VolumeOff" /></OnIcon>
        </FlareToggleButton>
    </FlareStack>
    <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.LabelSmall">
        Fav: @_fav | Bookmark: @_bookmark | Mute: @_mute
    </FlareText>
</FlareStack>

@code {
    private bool _fav;
    private bool _bookmark;
    private bool _mute;
}
