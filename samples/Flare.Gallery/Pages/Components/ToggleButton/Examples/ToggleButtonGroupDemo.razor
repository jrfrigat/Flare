<FlareStack Gap="FlareSpacing.Medium" Align="FlareAlignItems.Start">
    <FlareToggleGroup TValue="string" @bind-Value="_alignment">
        <FlareToggleButton Value="@("left")" AriaLabel="Align left">
            <OffIcon><FlareIconView Value="@MaterialDesign3Icons.Regular.FormatAlignLeft" /></OffIcon>
        </FlareToggleButton>
        <FlareToggleButton Value="@("center")" AriaLabel="Align center">
            <OffIcon><FlareIconView Value="@MaterialDesign3Icons.Regular.FormatAlignCenter" /></OffIcon>
        </FlareToggleButton>
        <FlareToggleButton Value="@("right")" AriaLabel="Align right">
            <OffIcon><FlareIconView Value="@MaterialDesign3Icons.Regular.FormatAlignRight" /></OffIcon>
        </FlareToggleButton>
        <FlareToggleButton Value="@("justify")" AriaLabel="Justify">
            <OffIcon><FlareIconView Value="@MaterialDesign3Icons.Regular.FormatAlignJustify" /></OffIcon>
        </FlareToggleButton>
    </FlareToggleGroup>
    <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.LabelSmall">Alignment: @_alignment</FlareText>
</FlareStack>

@code {
    private string? _alignment;
}
