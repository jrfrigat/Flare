<FlareStack Gap="FlareSpacing.Medium" Align="FlareAlignItems.Start">
    <FlareSignaturePad @ref="_padRed" Width="400" Height="200" StrokeColor="#e53935" StrokeWidth="3" />
    <FlareButton Variant="ButtonVariant.Outlined" OnClick="ClearRedAsync">Clear</FlareButton>
</FlareStack>

@code {
    private FlareSignaturePad? _padRed;

    private async Task ClearRedAsync()
    {
        if (_padRed is not null)
            await _padRed.ClearAsync();
    }
}
