@using Flare.Components.IDE

@* FlareQuickAccessToolbar: the Office "Quick Access Toolbar" - a compact strip of small icon
   buttons, usually placed above or beside the ribbon. Purely structural; drop FlareButton items in. *@
<FlareStack Gap="FlareSpacing.Small">
    <div style="border:1px solid var(--flare-color-outline-variant);border-radius:var(--flare-shape-medium);overflow:hidden;">
        <FlareQuickAccessToolbar>
            <FlareButton Variant="ButtonVariant.Text" Size="ButtonSize.Xs" AriaLabel="Save" OnClick="@(() => Set("Save"))">
                <FlareIconView Value="@MaterialDesign3Icons.Regular.Save" />
            </FlareButton>
            <FlareButton Variant="ButtonVariant.Text" Size="ButtonSize.Xs" AriaLabel="Undo" OnClick="@(() => Set("Undo"))">
                <FlareIconView Value="@MaterialDesign3Icons.Regular.Undo" />
            </FlareButton>
            <FlareButton Variant="ButtonVariant.Text" Size="ButtonSize.Xs" AriaLabel="Redo" OnClick="@(() => Set("Redo"))">
                <FlareIconView Value="@MaterialDesign3Icons.Regular.Redo" />
            </FlareButton>
            <FlareRibbonSeparator />
            <FlareButton Variant="ButtonVariant.Text" Size="ButtonSize.Xs" AriaLabel="Print" OnClick="@(() => Set("Print"))">
                <FlareIconView Value="@MaterialDesign3Icons.Regular.Print" />
            </FlareButton>
            <FlareButton Variant="ButtonVariant.Text" Size="ButtonSize.Xs" AriaLabel="Email" OnClick="@(() => Set("Email"))">
                <FlareIconView Value="@MaterialDesign3Icons.Regular.Mail" />
            </FlareButton>
        </FlareQuickAccessToolbar>
    </div>

    <FlareText Typo="TypographyScale.BodySmall" Color="FlareColor.OnSurfaceVariant">
        Last command: <strong>@_status</strong>
    </FlareText>
</FlareStack>

@code {
    private string _status = "(none)";

    private void Set(string action) => _status = action;
}
