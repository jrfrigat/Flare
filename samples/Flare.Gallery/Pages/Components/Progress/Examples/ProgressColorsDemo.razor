@* Color accepts a semantic role (FlareColor.Primary…) or a custom value (FlareColor.Custom("#…")). *@
<FlareStack Gap="FlareSpacing.Large" Style="max-width:28rem;">
    <FlareStack Gap="FlareSpacing.None">
        <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.LabelSmall" Style="margin-bottom:0.5rem">Primary (default)</FlareText>
        <FlareProgress Value="70" Color="FlareColor.Primary" />
    </FlareStack>
    <FlareStack Gap="FlareSpacing.None">
        <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.LabelSmall" Style="margin-bottom:0.5rem">Secondary</FlareText>
        <FlareProgress Value="70" Color="FlareColor.Secondary" />
    </FlareStack>
    <FlareStack Gap="FlareSpacing.None">
        <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.LabelSmall" Style="margin-bottom:0.5rem">Tertiary</FlareText>
        <FlareProgress Value="70" Color="FlareColor.Tertiary" />
    </FlareStack>
    <FlareStack Gap="FlareSpacing.None">
        <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.LabelSmall" Style="margin-bottom:0.5rem">Success</FlareText>
        <FlareProgress Value="70" Color="FlareColor.Success" />
    </FlareStack>
    <FlareStack Gap="FlareSpacing.None">
        <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.LabelSmall" Style="margin-bottom:0.5rem">Error</FlareText>
        <FlareProgress Value="70" Color="FlareColor.Error" />
    </FlareStack>
    <FlareStack Gap="FlareSpacing.None">
        <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.LabelSmall" Style="margin-bottom:0.5rem">Custom #E91E63</FlareText>
        <FlareProgress Value="70" Color="_pink" />
    </FlareStack>
    <FlareStack Row Gap="FlareSpacing.Medium" Wrap Align="FlareAlignItems.Center">
        <FlareProgress Variant="ProgressVariant.Circular" Value="70" Color="FlareColor.Secondary" />
        <FlareProgress Variant="ProgressVariant.Circular" Value="70" Color="FlareColor.Success" />
        <FlareProgress Variant="ProgressVariant.Circular" Value="70" Color="FlareColor.Error" />
        <FlareProgress Variant="ProgressVariant.Circular" Value="70" Color="_pink" />
    </FlareStack>
</FlareStack>

@code {
    private readonly FlareColor _pink = FlareColor.Custom("#E91E63");
}
