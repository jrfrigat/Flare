@using Flare.Gallery.Resources

<FlareStack Gap="FlareSpacing.Medium" Style="max-width:22rem;">
    <FlarePasswordField @bind-Value="_password" Immediate="true" Label="Password" />
    <FlareText Typo="TypographyScale.BodySmall" Color="FlareColor.OnSurfaceVariant">
        @GalleryStrings.PasswordInput_LiveValue
        <b>@(string.IsNullOrEmpty(_password) ? GalleryStrings.PasswordInput_LiveValueEmpty : _password)</b>
        @if (!string.IsNullOrEmpty(_password))
        {
            <text> (@_password.Length)</text>
        }
    </FlareText>
</FlareStack>

@code {
    private string? _password;
}
