@page "/components/password-field"
@inherits LocalizedPage

<PageTitle>@GalleryStrings.PasswordInput_Title - Flare</PageTitle>

<GalleryPageTitle Api="FlarePasswordField">
    <FlareText Typo="TypographyScale.HeadlineMedium">@GalleryStrings.PasswordInput_Title</FlareText>
    <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.BodyLarge">@GalleryStrings.PasswordInput_Subtitle</FlareText>
</GalleryPageTitle>

<AutoDemoSection Title="@GalleryStrings.PasswordInput_Basic" DemoType="typeof(Examples.PasswordFieldBasicDemo)" />
<AutoDemoSection Title="@GalleryStrings.PasswordInput_WithHelperText" DemoType="typeof(Examples.PasswordFieldHelperTextDemo)" />
<AutoDemoSection Title="@GalleryStrings.PasswordInput_ErrorState" DemoType="typeof(Examples.PasswordFieldErrorStateDemo)" />
<AutoDemoSection Title="@GalleryStrings.PasswordInput_Disabled" DemoType="typeof(Examples.PasswordFieldDisabledDemo)" />
