<FlareStack Gap="FlareSpacing.Medium" Style="max-width:22rem;">
    <FlareMultiSelect TValue="string"
                      Items="_frameworks"
                      GetLabel="x => x"
                      SelectedValues="_selectedError"
                      SelectedValuesChanged="v => _selectedError = v.ToList()"
                      Label="Required field"
                      ErrorText="Please select at least one option." />
</FlareStack>

@code {
    private readonly List<string> _frameworks = ["Blazor", "Angular", "React", "Vue", "Svelte"];
    private List<string> _selectedError = [];
}
