<FlareStack Gap="FlareSpacing.Medium" Style="max-width:22rem;">
    <FlareMultiSelect TValue="string"
                      Items="_frameworks"
                      GetLabel="x => x"
                      SelectedValues="_selectedFrameworks"
                      SelectedValuesChanged="v => _selectedFrameworks = v.ToList()"
                      Label="Frameworks"
                      HelperText="Choose one or more." />
</FlareStack>

@code {
    private readonly List<string> _frameworks = ["Blazor", "Angular", "React", "Vue", "Svelte"];
    private List<string> _selectedFrameworks = [];
}
