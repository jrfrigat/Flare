<FlareStack Gap="FlareSpacing.Medium">
    <FlareMultiSelect TValue="string"
                      @bind-Values="_selected"
                      Items="_langs"
                      Label="Languages"
                      Placeholder="Pick languages"
                      Chips="true"
                      Style="max-width:24rem;">
        <ItemTemplate>
            <FlareIconView Value="@MaterialDesign3Icons.Regular.Code" Color="FlareColor.Primary" />
            <span>@context</span>
        </ItemTemplate>
    </FlareMultiSelect>
    <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.LabelSmall">
        Selected: @(_selected.Count == 0 ? "-" : string.Join(", ", _selected))
    </FlareText>
</FlareStack>

@code {
    private IReadOnlyList<string> _selected = [];

    private readonly string[] _langs = ["C#", "F#", "TypeScript", "Rust", "Go", "Python"];
}
