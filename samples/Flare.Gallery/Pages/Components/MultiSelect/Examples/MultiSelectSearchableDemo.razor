<FlareStack Gap="FlareSpacing.Medium" Style="max-width:24rem;">
    <FlareMultiSelect TValue="string"
                      @bind-Values="_selected"
                      Label="Languages"
                      Placeholder="Search languages..."
                      Items="_langs"
                      ItemLabel="x => x"
                      Searchable="true"
                      Chips="true"
                      ShowSelectAll="true" />
    <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.LabelSmall">
        Selected: @(_selected.Count == 0 ? "-" : string.Join(", ", _selected))
    </FlareText>
</FlareStack>

@code {
    private IReadOnlyList<string> _selected = [];

    private static readonly string[] _langs =
    [
        "C#", "C++", "Go", "Java", "JavaScript", "Kotlin", "PHP", "Python",
        "Ruby", "Rust", "Scala", "Swift", "TypeScript"
    ];
}
