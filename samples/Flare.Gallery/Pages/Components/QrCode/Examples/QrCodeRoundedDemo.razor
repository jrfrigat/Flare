@inherits LocalizedPage

<div style="display:flex; gap:24px; flex-wrap:wrap; align-items:flex-end;">
    <div style="display:flex; flex-direction:column; align-items:center; gap:8px;">
        <FlareQrCode Value="https://github.com/jrfrigat/Flare"
                     Size="180" CornerRadius="0.25" />
        <span style="font-size:12px; color:var(--flare-color-on-surface-variant);">CornerRadius="0.25"</span>
    </div>
    <div style="display:flex; flex-direction:column; align-items:center; gap:8px;">
        <FlareQrCode Value="https://github.com/jrfrigat/Flare"
                     Size="180" CornerRadius="0.4" />
        <span style="font-size:12px; color:var(--flare-color-on-surface-variant);">CornerRadius="0.4"</span>
    </div>
    <div style="display:flex; flex-direction:column; align-items:center; gap:8px;">
        <FlareQrCode Value="https://github.com/jrfrigat/Flare"
                     Size="180" CornerRadius="0.5"
                     ForeColor="#6750A4" BackColor="#F3EFF7" />
        <span style="font-size:12px; color:var(--flare-color-on-surface-variant);">CornerRadius="0.5" (circles)</span>
    </div>
</div>
