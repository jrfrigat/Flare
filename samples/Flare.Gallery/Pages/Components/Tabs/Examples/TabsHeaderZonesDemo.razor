@inject ISnackbarService Snackbar

<FlareStack Gap="FlareSpacing.Medium" Align="FlareAlignItems.Stretch">
    <FlareTabs Typo="_typo">
        <HeaderStart>
            <FlareText Typo="TypographyScale.TitleMedium" Style="padding-inline:0.5rem">Project</FlareText>
        </HeaderStart>
        <HeaderEnd>
            <FlareButton Variant="ButtonVariant.Text" Size="ButtonSize.Sm" OnClick="@(() => Snackbar.Show("Refresh"))">
                <LeadingIcon><FlareIconView Value="@MaterialDesign3Icons.Regular.Refresh" /></LeadingIcon>
                <ChildContent>Refresh</ChildContent>
            </FlareButton>
            <FlareButton Variant="ButtonVariant.Filled" Size="ButtonSize.Sm" OnClick="@(() => Snackbar.Show("New"))">
                <LeadingIcon><FlareIconView Value="@MaterialDesign3Icons.Regular.Add" /></LeadingIcon>
                <ChildContent>New</ChildContent>
            </FlareButton>
        </HeaderEnd>

        <ChildContent>
            <FlareTab Label="Overview">
                <FlareText Typo="TypographyScale.BodyMedium">A title sits at the start; action buttons at the end.</FlareText>
            </FlareTab>
            <FlareTab Label="Activity">
                <FlareText Typo="TypographyScale.BodyMedium">The tab bar grows between the zones, pushing actions to the edge.</FlareText>
            </FlareTab>
            <FlareTab Label="Settings">
                <FlareText Typo="TypographyScale.BodyMedium">Use the selector below to change the tab label type scale.</FlareText>
            </FlareTab>
        </ChildContent>
    </FlareTabs>

    <FlareSelect TValue="TypographyScale" @bind-Value="_typo" Items="_typoValues" Label="Label Typo" Style="max-width:18rem" />
</FlareStack>

@code {
    private TypographyScale _typo = TypographyScale.LabelLarge;
    private static readonly TypographyScale[] _typoValues =
        [TypographyScale.LabelLarge, TypographyScale.TitleSmall, TypographyScale.TitleMedium, TypographyScale.BodyLarge];
}

@* HeaderStart / HeaderEnd host arbitrary content (title, buttons) beside the tabs; Typo sets the label type scale. *@
