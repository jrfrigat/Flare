<FlareStack Row Wrap Gap="FlareSpacing.Large" Style="max-width:32rem;">
    <FlareDatePicker @bind-Value="_date" Label="Appointment date" Placeholder="Pick a date"
                     DateFormat="dd MMM yyyy" Style="flex:1;min-width:12rem;" />
    <FlareDatePicker Label="Disabled" Disabled Style="flex:1;min-width:12rem;" />
</FlareStack>
<FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.LabelSmall" Style="margin-top:0.5rem">
    Selected: @_date?.ToString("dd MMM yyyy")
</FlareText>

@code {
    private DateOnly? _date;
}
