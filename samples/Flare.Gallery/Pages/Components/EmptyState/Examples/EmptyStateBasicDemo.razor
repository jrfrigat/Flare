<FlareStack Row Justify="FlareJustifyContent.Center" Style="padding:2rem 1rem;">
    <FlareEmptyState Title="No results found"
                     Description="Try adjusting your search or filters to find what you're looking for.">
        <Icon>
            <FlareIconView Size="3rem" Color="FlareColor.OnSurfaceVariant" Value="@MaterialDesign3Icons.Regular.SearchOff" />
        </Icon>
        <ActionContent>
            <FlareButton Variant="ButtonVariant.Filled">Clear filters</FlareButton>
        </ActionContent>
    </FlareEmptyState>

    <FlareEmptyState Compact="true" Title="No items"
                     Description="This list is empty.">
        <Icon>
            <FlareIconView Size="2rem" Color="FlareColor.OnSurfaceVariant" Value="@MaterialDesign3Icons.Regular.Inbox" />
        </Icon>
    </FlareEmptyState>
</FlareStack>
