<FlareStack Row Justify="FlareJustifyContent.Center" Style="padding:2rem 1rem;">
    <FlareEmptyState Title="Something went wrong"
                     Description="We couldn't load your data. Please try again.">
        <Icon>
            <FlareIconView Size="3rem" Color="FlareColor.Error" Name="error_outline" />
        </Icon>
        <ActionContent>
            <FlareButton Variant="ButtonVariant.Outlined">Retry</FlareButton>
        </ActionContent>
    </FlareEmptyState>
</FlareStack>
