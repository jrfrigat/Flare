@* MinColumnWidth builds a responsive card wall with no media queries; AutoFit stretches the present
   cards to fill the row (auto-fit) instead of leaving empty trailing tracks (auto-fill). *@
<FlareGrid MinColumnWidth="12rem" AutoFit Gap="FlareSpacing.Small">
    <FlareCard Style="padding:1rem;background:var(--flare-color-primary-container);border-radius:var(--flare-shape-extra-small);text-align:center;">
        <FlareText Typo="TypographyScale.LabelLarge">Tile 1</FlareText>
    </FlareCard>
    <FlareCard Style="padding:1rem;background:var(--flare-color-secondary-container);border-radius:var(--flare-shape-extra-small);text-align:center;">
        <FlareText Typo="TypographyScale.LabelLarge">Tile 2</FlareText>
    </FlareCard>
    <FlareCard Style="padding:1rem;background:var(--flare-color-tertiary-container);border-radius:var(--flare-shape-extra-small);text-align:center;">
        <FlareText Typo="TypographyScale.LabelLarge">Tile 3</FlareText>
    </FlareCard>
</FlareGrid>
