<FlareStack Gap="FlareSpacing.Small">
    <FlareGrid Columns="12" Gap="FlareSpacing.XSmall">
        <FlareCol Xs="12" Sm="6" Md="4" Lg="3">
            <FlareCard Style="padding:0.75rem;background:var(--flare-color-primary-container);border-radius:var(--flare-shape-extra-small);text-align:center;">
                <FlareText Typo="TypographyScale.LabelSmall">xs=12 sm=6 md=4 lg=3</FlareText>
            </FlareCard>
        </FlareCol>
        <FlareCol Xs="12" Sm="6" Md="4" Lg="3">
            <FlareCard Style="padding:0.75rem;background:var(--flare-color-secondary-container);border-radius:var(--flare-shape-extra-small);text-align:center;">
                <FlareText Typo="TypographyScale.LabelSmall">xs=12 sm=6 md=4 lg=3</FlareText>
            </FlareCard>
        </FlareCol>
        <FlareCol Xs="12" Sm="6" Md="4" Lg="3">
            <FlareCard Style="padding:0.75rem;background:var(--flare-color-tertiary-container);border-radius:var(--flare-shape-extra-small);text-align:center;">
                <FlareText Typo="TypographyScale.LabelSmall">xs=12 sm=6 md=4 lg=3</FlareText>
            </FlareCard>
        </FlareCol>
        <FlareCol Xs="12" Sm="6" Md="12" Lg="3">
            <FlareCard Style="padding:0.75rem;background:var(--flare-color-error-container);border-radius:var(--flare-shape-extra-small);text-align:center;">
                <FlareText Typo="TypographyScale.LabelSmall">xs=12 sm=6 md=12 lg=3</FlareText>
            </FlareCard>
        </FlareCol>
    </FlareGrid>
    <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.BodySmall">
        Mobile: 1 column · Tablet: 2 columns · Desktop: 3–4 columns
    </FlareText>
</FlareStack>
