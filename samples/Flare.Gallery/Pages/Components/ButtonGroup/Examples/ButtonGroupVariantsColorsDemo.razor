@* Color задан на группе - все кнопки наследуют семантический цвет через каскад *@
<FlareStack Gap="FlareSpacing.Medium" Align="FlareAlignItems.Start">
    <FlareButtonGroup Variant="ButtonVariant.Filled" Color="@Colors.Primary">
        <FlareButton>Day</FlareButton>
        <FlareButton>Week</FlareButton>
        <FlareButton>Month</FlareButton>
    </FlareButtonGroup>

    <FlareButtonGroup Variant="ButtonVariant.Tonal" Color="@Colors.Success">
        <FlareButton>Low</FlareButton>
        <FlareButton>Medium</FlareButton>
        <FlareButton>High</FlareButton>
    </FlareButtonGroup>

    <FlareButtonGroup Variant="ButtonVariant.Outlined" Color="@Colors.Error">
        <FlareButton>Ignore</FlareButton>
        <FlareButton>Retry</FlareButton>
        <FlareButton>Abort</FlareButton>
    </FlareButtonGroup>

    <FlareButtonGroup Variant="ButtonVariant.Filled" Color="@Colors.Info">
        <FlareButton>Info</FlareButton>
        <FlareButton>Details</FlareButton>
        <FlareButton>More</FlareButton>
    </FlareButtonGroup>
</FlareStack>
