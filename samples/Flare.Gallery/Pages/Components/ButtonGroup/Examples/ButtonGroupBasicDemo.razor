@* Variant задан на группе - все кнопки наследуют его через каскад *@
<FlareStack Gap="FlareSpacing.Medium" Align="FlareAlignItems.Start">
    <FlareButtonGroup Variant="ButtonVariant.Filled">
        <FlareButton>Left</FlareButton>
        <FlareButton>Center</FlareButton>
        <FlareButton>Right</FlareButton>
    </FlareButtonGroup>

    <FlareButtonGroup Variant="ButtonVariant.Outlined">
        <FlareButton>Left</FlareButton>
        <FlareButton>Center</FlareButton>
        <FlareButton>Right</FlareButton>
    </FlareButtonGroup>

    <FlareButtonGroup Variant="ButtonVariant.Tonal">
        <FlareButton>Left</FlareButton>
        <FlareButton>Center</FlareButton>
        <FlareButton>Right</FlareButton>
    </FlareButtonGroup>
</FlareStack>
