<FlareCard Variant="CardVariant.Filled" Style="max-width:280px;padding:0.75rem 0;background:var(--flare-color-surface-container-low);border-radius:var(--flare-shape-medium);">
    <FlareNavMenu>
        <FlareNavLink Href="/" Match="NavMatchMode.Exact">
            <Icon><FlareIconView Size="1.1rem" Name="home" /></Icon>
            <ChildContent>Home</ChildContent>
        </FlareNavLink>
        <FlareNavGroup Label="Components" Icon="@("widgets")" Expanded="true">
            <FlareNavLink Href="/components/buttons">Buttons</FlareNavLink>
            <FlareNavLink Href="/components/inputs">Inputs</FlareNavLink>
            <FlareNavLink Href="/components/cards">Cards</FlareNavLink>
        </FlareNavGroup>
        <FlareNavGroup Label="More" Icon="@("more_horiz")">
            <FlareNavLink Href="/components/datagrid">Data Grid</FlareNavLink>
            <FlareNavLink Href="/components/dialog">Dialog</FlareNavLink>
        </FlareNavGroup>
    </FlareNavMenu>
</FlareCard>
