@* HideScrollbar="true" lets the menu scroll its overflow while hiding the scrollbar.
   The fixed-height card constrains the menu so it actually scrolls. *@
<FlareCard Variant="CardVariant.Filled" Style="max-width:280px;height:200px;padding:0.75rem 0;background:var(--flare-color-surface-container-low);border-radius:var(--flare-shape-medium);display:flex;">
    <FlareNavMenu HideScrollbar="true">
        @for (var i = 1; i <= 15; i++)
        {
            var n = i;
            <FlareNavLink Href="@($"#item-{n}")">
                <Icon><FlareIcon Size="1.1rem" Name="folder" /></Icon>
                <ChildContent>Item @n</ChildContent>
            </FlareNavLink>
        }
    </FlareNavMenu>
</FlareCard>
