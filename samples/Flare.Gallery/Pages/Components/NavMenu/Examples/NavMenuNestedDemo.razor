@* Groups can nest. Both groups below start collapsed, but auto-expand because the deep
   link is Active - a child link becoming active reveals its whole ancestor group chain. *@
<FlareCard Variant="CardVariant.Filled" Style="max-width:280px;padding:0.75rem 0;background:var(--flare-color-surface-container-low);border-radius:var(--flare-shape-medium);">
    <FlareNavMenu>
        <FlareNavLink Href="/" Match="NavMatchMode.Exact">
            <Icon><FlareIcon Size="1.1rem" Name="home" /></Icon>
            <ChildContent>Home</ChildContent>
        </FlareNavLink>
        <FlareNavGroup Label="Components" Icon="widgets">
            <FlareNavLink Href="/components/buttons">Buttons</FlareNavLink>
            <FlareNavGroup Label="Inputs" Icon="edit">
                <FlareNavLink Href="/components/input">Text Field</FlareNavLink>
                <FlareNavLink Href="/components/select">Select</FlareNavLink>
                @* Active forces this link active -> "Inputs" and "Components" auto-expand *@
                <FlareNavLink Href="/components/slider" Active="true">Slider</FlareNavLink>
            </FlareNavGroup>
            <FlareNavGroup Label="Layout" Icon="dashboard">
                <FlareNavLink Href="/components/stack">Stack</FlareNavLink>
                <FlareNavLink Href="/components/grid">Grid</FlareNavLink>
            </FlareNavGroup>
        </FlareNavGroup>
    </FlareNavMenu>
</FlareCard>
