@using Flare.Components.IDE

@* FlareMenuBar: a thin horizontal bar of top-level menus (File / Edit / View). Each menu is a base
   FlareMenu whose activator is a text button and whose items are FlareMenuItem entries. *@
<FlareStack Gap="FlareSpacing.Small">
    <div style="border:1px solid var(--flare-color-outline-variant);border-radius:var(--flare-shape-medium);overflow:hidden;">
        <FlareMenuBar>
            <FlareMenu Anchor="MenuAnchor.BottomLeft" AriaLabel="File menu">
                <Activator>
                    <FlareButton Variant="ButtonVariant.Text" Size="ButtonSize.Sm">File</FlareButton>
                </Activator>
                <ChildContent>
                    <FlareMenuItem Icon="@MaterialDesign3Icons.Regular.NoteAdd" OnClick="@(() => Set("File > New"))">New</FlareMenuItem>
                    <FlareMenuItem Icon="@MaterialDesign3Icons.Regular.FolderOpen" OnClick="@(() => Set("File > Open"))">Open</FlareMenuItem>
                    <FlareMenuItem Icon="@MaterialDesign3Icons.Regular.Save" OnClick="@(() => Set("File > Save"))">Save</FlareMenuItem>
                </ChildContent>
            </FlareMenu>
            <FlareMenu Anchor="MenuAnchor.BottomLeft" AriaLabel="Edit menu">
                <Activator>
                    <FlareButton Variant="ButtonVariant.Text" Size="ButtonSize.Sm">Edit</FlareButton>
                </Activator>
                <ChildContent>
                    <FlareMenuItem Icon="@MaterialDesign3Icons.Regular.ContentCut" OnClick="@(() => Set("Edit > Cut"))">Cut</FlareMenuItem>
                    <FlareMenuItem Icon="@MaterialDesign3Icons.Regular.ContentCopy" OnClick="@(() => Set("Edit > Copy"))">Copy</FlareMenuItem>
                    <FlareMenuItem Icon="@MaterialDesign3Icons.Regular.ContentPaste" OnClick="@(() => Set("Edit > Paste"))">Paste</FlareMenuItem>
                </ChildContent>
            </FlareMenu>
            <FlareMenu Anchor="MenuAnchor.BottomLeft" AriaLabel="View menu">
                <Activator>
                    <FlareButton Variant="ButtonVariant.Text" Size="ButtonSize.Sm">View</FlareButton>
                </Activator>
                <ChildContent>
                    <FlareMenuItem Icon="@MaterialDesign3Icons.Regular.AccountTree" OnClick="@(() => Set("View > Solution Explorer"))">Solution Explorer</FlareMenuItem>
                    <FlareMenuItem Icon="@MaterialDesign3Icons.Regular.Terminal" OnClick="@(() => Set("View > Terminal"))">Terminal</FlareMenuItem>
                </ChildContent>
            </FlareMenu>
        </FlareMenuBar>
    </div>

    <FlareText Typo="TypographyScale.BodySmall" Color="FlareColor.OnSurfaceVariant">
        Last command: <strong>@_status</strong>
    </FlareText>
</FlareStack>

@code {
    private string _status = "(none)";

    private void Set(string action) => _status = action;
}
