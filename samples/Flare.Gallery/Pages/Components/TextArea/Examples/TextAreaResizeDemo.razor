<FlareStack Gap="FlareSpacing.Medium" Style="max-width:32rem;">
    <FlareTextArea @bind-Value="_notes" Label="Notes (resizable + clearable + spellcheck)"
                   Rows="3" Resize="TextAreaResize.Vertical" Clearable="true" Spellcheck="true" />
    <FlareTextArea @bind-Value="_code" Label="Code (no spellcheck, not resizable)"
                   Rows="3" Resize="TextAreaResize.None" Spellcheck="false" />
</FlareStack>

@code {
    private string? _notes = "Drag the bottom edge to resize me.";
    private string? _code;
}
