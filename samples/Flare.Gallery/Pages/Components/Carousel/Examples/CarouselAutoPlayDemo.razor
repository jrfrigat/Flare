<FlareCarousel TItem="SlideData" Items="_slides" AutoPlay="true" AutoPlayIntervalMs="2500">
    <ItemTemplate Context="slide">
        <FlareStack Align="FlareAlignItems.Center" Justify="FlareJustifyContent.Center" Gap="FlareSpacing.Small" Style="@($"padding:3rem 1rem;background:{slide.Color};min-height:200px;")">
            <FlareIconView Size="3rem" Color="FlareColor.OnSurface" Name="@slide.Icon" />
            <FlareText Typo="TypographyScale.TitleMedium">@slide.Label</FlareText>
        </FlareStack>
    </ItemTemplate>
</FlareCarousel>
<FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.BodySmall" Style="margin-top:0.5rem">
    Auto-advances every 2.5 seconds.
</FlareText>