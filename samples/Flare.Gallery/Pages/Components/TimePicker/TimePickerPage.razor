@page "/components/time-picker"
@inherits LocalizedPage

<PageTitle>@GalleryStrings.TimePicker_Title - Flare</PageTitle>

<GalleryPageTitle Api="FlareTimePicker">
    <FlareText Typo="TypographyScale.HeadlineMedium">@GalleryStrings.TimePicker_Title</FlareText>
    <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.BodyLarge">@GalleryStrings.TimePicker_Subtitle</FlareText>
</GalleryPageTitle>

<AutoDemoSection Title="@GalleryStrings.TimePicker_Basic" DemoType="typeof(Examples.TimePickerDemo)" />
<AutoDemoSection Title="@GalleryStrings.TimePicker_Advanced" DemoType="typeof(Examples.TimePickerAdvancedDemo)" />
