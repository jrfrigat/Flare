@inject ISnackbarService Snackbar

<FlareStack Row Gap="FlareSpacing.XLarge" Wrap Align="FlareAlignItems.End" Style="min-height:12rem;padding:3rem 1rem 1rem;">
    <FlareStack Align="FlareAlignItems.Center" Gap="FlareSpacing.XSmall">
        <FlareFloatingActionButton Position="FabPosition.Static" AriaLabel="Actions (up)">
            <Icon><FlareIcon Icon="add" /></Icon>
            <ChildContent>
                <FlareFloatingActionMenu Direction="FabMenuDirection.Up">
                    <FlareFloatingActionMenuItem Icon="edit" Label="Edit" OnClick="@(() => Snackbar.Show("Edit"))" />
                    <FlareFloatingActionMenuItem Icon="share" Label="Share" OnClick="@(() => Snackbar.Show("Share"))" />
                    <FlareFloatingActionMenuItem Icon="delete" Label="Delete" OnClick="@(() => Snackbar.Show("Delete", SnackbarSeverity.Error))" />
                </FlareFloatingActionMenu>
            </ChildContent>
        </FlareFloatingActionButton>
        <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.LabelSmall">Up</FlareText>
    </FlareStack>

    <FlareStack Align="FlareAlignItems.Center" Gap="FlareSpacing.XSmall">
        <FlareFloatingActionButton Position="FabPosition.Static" Color="@Colors.Secondary" AriaLabel="Actions (right)">
            <Icon><FlareIcon Icon="more_horiz" /></Icon>
            <ChildContent>
                <FlareFloatingActionMenu Direction="FabMenuDirection.Right">
                    <FlareFloatingActionMenuItem Icon="download" Label="Download" OnClick="@(() => Snackbar.Show("Downloading…"))" />
                    <FlareFloatingActionMenuItem Icon="print" Label="Print" OnClick="@(() => Snackbar.Show("Printing…"))" />
                </FlareFloatingActionMenu>
            </ChildContent>
        </FlareFloatingActionButton>
        <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.LabelSmall">Right</FlareText>
    </FlareStack>
</FlareStack>
