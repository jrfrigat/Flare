@page "/components/slider"
@inherits LocalizedPage

<PageTitle>@GalleryStrings.Slider_Title - Flare</PageTitle>

<GalleryPageTitle Api="FlareSlider">
    <FlareText Typo="TypographyScale.HeadlineMedium">@GalleryStrings.Slider_Title</FlareText>
    <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.BodyLarge">@GalleryStrings.Slider_Subtitle</FlareText>
</GalleryPageTitle>

<AutoDemoSection Title="@GalleryStrings.Slider_Slider" DemoType="typeof(Examples.SliderBasicDemo)" />
