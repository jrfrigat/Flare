<AutoDemoSection Title="@GalleryStrings.Slider_Init" DemoType="typeof(Examples.SliderInitDemo)" />
<AutoDemoSection Title="@GalleryStrings.Slider_Colors" DemoType="typeof(Examples.SliderColorsDemo)" />
<AutoDemoSection Title="@GalleryStrings.Slider_Vertical" DemoType="typeof(Examples.SliderVerticalDemo)" />
<AutoDemoSection Title="@GalleryStrings.Slider_Range" DemoType="typeof(Examples.SliderRangeDemo)" />
<AutoDemoSection Title="@GalleryStrings.Slider_Zones" DemoType="typeof(Examples.SliderZonesDemo)" />
