<FlareStack Gap="FlareSpacing.Large" Style="max-width:28rem;">
    @* Media seek bar: BufferValue draws the "loaded so far" band behind the playback fill.
       Thin track (Xs) + wheel-to-seek make it feel like an audio/video scrubber. *@
    <FlareSlider @bind-Value="_played" BufferValue="_buffered" Label="Now playing" Min="0" Max="100"
                 ShowValue="true" Size="SliderSize.Xs" StartIcon="play_arrow" MouseWheel="true" />

    <FlareStack Row Gap="FlareSpacing.Small">
        <FlareButton Size="ButtonSize.Sm" Variant="ButtonVariant.Outlined" OnClick="@(() => _buffered = Math.Min(100, _buffered + 10))">Load more</FlareButton>
        <FlareText Typo="TypographyScale.LabelSmall" Color="FlareColor.OnSurfaceVariant" Style="align-self:center;">Buffered: @_buffered%</FlareText>
    </FlareStack>
</FlareStack>

@code {
    private double _played = 30;
    private double _buffered = 65;
}
