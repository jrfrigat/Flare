@* StartIcon / EndIcon render Material Symbols flanking the track. *@
<FlareStack Gap="FlareSpacing.Large" Style="max-width:30rem;">
    <FlareSlider @bind-Value="_volume" Label="Volume"
                 StartIcon="@MaterialDesign3Icons.Regular.VolumeMute" EndIcon="@MaterialDesign3Icons.Regular.VolumeUp" />
    <FlareSlider @bind-Value="_brightness" Label="Brightness" Size="TrackSize.Md"
                 StartIcon="@MaterialDesign3Icons.Regular.Brightness5" EndIcon="@MaterialDesign3Icons.Regular.Brightness7" />
</FlareStack>

@code {
    private double _volume = 40;
    private double _brightness = 70;
}
