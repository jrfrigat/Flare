@* Vertical="true" rotates the slider; value increases upward.
   Length is set with the --flare-slider-length CSS var. *@
<FlareStack Row Gap="FlareSpacing.Large" Align="FlareAlignItems.End">
    <FlareSlider @bind-Value="_a" Vertical="true" ShowValue="false"
                 StartIcon="@MaterialDesign3Icons.Regular.VolumeMute" EndIcon="@MaterialDesign3Icons.Regular.VolumeUp" Style="--flare-slider-length:13rem" />
    <FlareSlider @bind-Value="_b" Vertical="true" ShowValue="false" Color="FlareColor.Secondary"
                 Stepper="true" Min="0" Max="100" Step="10" Style="--flare-slider-length:13rem" />
    <FlareSlider @bind-Value="_c" Vertical="true" ShowValue="false" Size="TrackSize.Md"
                 Color="FlareColor.Tertiary" Style="--flare-slider-length:13rem" />
    <FlareSlider @bind-Value="_d" Vertical="true" ShowValue="false" Disabled="true"
                 Style="--flare-slider-length:13rem" />
</FlareStack>
<FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.LabelSmall" Style="margin-top:0.75rem">
    @_a / @_b / @_c
</FlareText>

@code {
    private double _a = 70;
    private double _b = 40;
    private double _c = 55;
    private double _d = 30;
}
