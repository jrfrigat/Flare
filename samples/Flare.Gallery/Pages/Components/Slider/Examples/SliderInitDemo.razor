@* Init anchors the fill: the active track grows from Init toward Value (not from Min).
   Great for left/right balance controls (Min=-100, Max=100, Init=0). *@
<FlareStack Gap="FlareSpacing.Large" Style="max-width:30rem;">
    <FlareSlider @bind-Value="_balance" Label="Speaker balance (L / R)"
                 Min="-100" Max="100" Init="0" Step="5"
                 StartIcon="@MaterialDesign3Icons.Regular.VolumeUp" EndIcon="@MaterialDesign3Icons.Regular.VolumeUp" Indicator="true" />
    <FlareSlider @bind-Value="_trim" Label="Trim around 0"
                 Min="-12" Max="12" Init="0" Step="1" Stepper="true" Format="+0;-0;0" />
</FlareStack>
<FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.LabelSmall" Style="margin-top:0.75rem">
    Balance: @_balance | Trim: @_trim
</FlareText>

@code {
    private double _balance = -50;
    private double _trim = 4;
}
