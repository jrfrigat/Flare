<FlareStack Gap="FlareSpacing.Large" Style="max-width:28rem;">
    <FlareSlider @bind-Value="_brightness" Label="Brightness"
                 HelperText="Drag to adjust the screen brightness" />
    <FlareSlider Value="15" Label="Threshold" Min="0" Max="100"
                 ErrorText="Value is below the allowed minimum" ShowValue="false" />
</FlareStack>

@code {
    private double _brightness = 70;
}
