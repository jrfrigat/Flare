<FlareStack Row Justify="FlareJustifyContent.Center" Gap="FlareSpacing.Small" Wrap Style="padding:3rem 1.5rem;">
    <FlareTooltip Placement="TooltipPlacement.Bottom">
        <ChildContent>
            <FlareButton Variant="ButtonVariant.Outlined">Rich tooltip</FlareButton>
        </ChildContent>
        <TooltipContent>
            <FlareStack Gap="FlareSpacing.XSmall" Style="max-width:14rem;">
                <FlareText Typo="TypographyScale.TitleSmall">Save document</FlareText>
                <FlareText Typo="TypographyScale.BodySmall">Stores your changes and updates the preview.</FlareText>
            </FlareStack>
        </TooltipContent>
    </FlareTooltip>
</FlareStack>
