<FlareStack Row Justify="FlareJustifyContent.Center" Gap="FlareSpacing.Small" Wrap Style="padding:3rem 1.5rem;">
    <FlareTooltip Content="No delay" Delay="0">
        <FlareButton Variant="ButtonVariant.Outlined">No delay</FlareButton>
    </FlareTooltip>
    <FlareTooltip Content="500ms delay" Delay="500">
        <FlareButton Variant="ButtonVariant.Outlined">500ms delay</FlareButton>
    </FlareTooltip>
    <FlareTooltip Content="1 second delay" Delay="1000">
        <FlareButton Variant="ButtonVariant.Outlined">1s delay</FlareButton>
    </FlareTooltip>
</FlareStack>
