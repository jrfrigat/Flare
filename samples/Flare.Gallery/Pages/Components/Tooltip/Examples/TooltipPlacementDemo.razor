<FlareStack Row Justify="FlareJustifyContent.Center" Gap="FlareSpacing.Small" Wrap Style="padding:3rem 1.5rem;">
    <FlareTooltip Content="Top tooltip">
        <FlareButton Variant="ButtonVariant.Outlined">Hover (top)</FlareButton>
    </FlareTooltip>
    <FlareTooltip Content="Bottom tooltip" Placement="TooltipPlacement.Bottom">
        <FlareButton Variant="ButtonVariant.Outlined">Hover (bottom)</FlareButton>
    </FlareTooltip>
    <FlareTooltip Content="Left tooltip" Placement="TooltipPlacement.Left">
        <FlareButton Variant="ButtonVariant.Outlined">Hover (left)</FlareButton>
    </FlareTooltip>
    <FlareTooltip Content="Right tooltip" Placement="TooltipPlacement.Right">
        <FlareButton Variant="ButtonVariant.Outlined">Hover (right)</FlareButton>
    </FlareTooltip>
</FlareStack>
