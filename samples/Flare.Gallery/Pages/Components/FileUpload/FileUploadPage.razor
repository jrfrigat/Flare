@page "/components/fileupload"
@inherits LocalizedPage

<PageTitle>@GalleryStrings.FileUpload_Title - Flare</PageTitle>

<GalleryPageTitle Api="FlareFileUploadZone">
    <FlareText Typo="TypographyScale.HeadlineMedium">@GalleryStrings.FileUpload_Title</FlareText>
    <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.BodyLarge">@GalleryStrings.FileUpload_Subtitle</FlareText>
</GalleryPageTitle>

<AutoDemoSection Title="@GalleryStrings.FileUpload_Button" DemoType="typeof(Examples.FileUploadButtonDemo)" />
<AutoDemoSection Title="@GalleryStrings.FileUpload_DropZone" DemoType="typeof(Examples.FileUploadDropZoneDemo)" />
<AutoDemoSection Title="@GalleryStrings.FileUpload_DropZoneCustom" DemoType="typeof(Examples.FileUploadDropZoneCustomDemo)" />
<AutoDemoSection Title="@GalleryStrings.FileUpload_Multiple" DemoType="typeof(Examples.FileUploadMultipleDemo)" />
<AutoDemoSection Title="@GalleryStrings.FileUpload_SingleImageOnly" DemoType="typeof(Examples.FileUploadSingleDemo)" />
