@* FlareFileUploadButton: opens the OS file dialog from a button in a row, where a full drop zone would be
   overkill. It takes FlareButton's own Variant/Size/Color/Shape, so it lines up with the buttons beside it
   instead of standing out - which is the whole point of it being a separate component from the zone. *@
<FlareStack Style="max-width:32rem;">
    <FlareStack Row="true" Gap="FlareSpacing.Small" Align="FlareAlignItems.Center">
        <FlareFileUploadButton Variant="ButtonVariant.Outlined"
                               Size="ButtonSize.Sm"
                               Accept=".json"
                               ShowFileList="false"
                               Text="Import"
                               OnFilesChanged="HandleImport">
            <LeadingIcon><FlareIconView Value="@MaterialDesign3Icons.Regular.Publish" /></LeadingIcon>
        </FlareFileUploadButton>
        <FlareButton Variant="ButtonVariant.Outlined" Size="ButtonSize.Sm">Export</FlareButton>
        <FlareButton Variant="ButtonVariant.Filled" Size="ButtonSize.Sm">New endpoint</FlareButton>
    </FlareStack>
    @if (_name is not null)
    {
        <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.LabelSmall" Style="margin-top:0.5rem">Selected: @_name</FlareText>
    }
</FlareStack>

@code {
    private string? _name;

    private void HandleImport(IReadOnlyList<Microsoft.AspNetCore.Components.Forms.IBrowserFile> files)
        => _name = files.FirstOrDefault()?.Name;
}
