@inherits LocalizedPage

<FlareStack Gap="FlareSpacing.Small">
    <FlareAlert Severity="AlertSeverity.Info" Title="@GalleryStrings.AlertDemo_InfoTitle">@GalleryStrings.AlertDemo_InfoBody</FlareAlert>
    <FlareAlert Severity="AlertSeverity.Success" Title="@GalleryStrings.AlertDemo_SuccessTitle">@GalleryStrings.AlertDemo_SuccessBody</FlareAlert>
    <FlareAlert Severity="AlertSeverity.Warning" Title="@GalleryStrings.AlertDemo_WarningTitle">@GalleryStrings.AlertDemo_WarningBody</FlareAlert>
    <FlareAlert Severity="AlertSeverity.Error" Title="@GalleryStrings.AlertDemo_ErrorTitle" Dismissible="true">@GalleryStrings.AlertDemo_ErrorBody</FlareAlert>
</FlareStack>