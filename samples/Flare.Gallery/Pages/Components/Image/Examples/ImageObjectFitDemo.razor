@inherits LocalizedPage

<FlareStack Row Gap="FlareSpacing.Medium">
    <FlareStack Align="FlareAlignItems.Center">
        <FlareImage Src="https://picsum.photos/seed/cover/300/200" Alt="Cover" Width="180px" Height="120px" ObjectFit="ImageObjectFit.Cover" BorderRadius="0.5rem" />
        <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.LabelSmall" Style="margin-top:0.25rem">Cover</FlareText>
    </FlareStack>
    <FlareStack Align="FlareAlignItems.Center">
        <FlareImage Src="https://picsum.photos/seed/contain/300/200" Alt="Contain" Width="180px" Height="120px" ObjectFit="ImageObjectFit.Contain" BorderRadius="0.5rem" Style="background:var(--flare-color-surface-container);" />
        <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.LabelSmall" Style="margin-top:0.25rem">Contain</FlareText>
    </FlareStack>
    <FlareStack Align="FlareAlignItems.Center">
        <FlareImage Src="https://picsum.photos/seed/fill/300/200" Alt="Fill" Width="180px" Height="120px" ObjectFit="ImageObjectFit.Fill" BorderRadius="0.5rem" />
        <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.LabelSmall" Style="margin-top:0.25rem">Fill</FlareText>
    </FlareStack>
</FlareStack>
