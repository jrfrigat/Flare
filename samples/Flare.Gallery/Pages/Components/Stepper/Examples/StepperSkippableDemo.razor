@* External control + Skippable: the buttons below drive the stepper through @bind-ActiveIndex, and
   the optional middle step is marked Skippable, so the "Review" indicator can be clicked to jump
   straight past it. *@
<FlareStepper @bind-ActiveIndex="_index">
    <FlareStep Label="Plan" Description="Choose a plan">
        <FlareText Typo="TypographyScale.BodyMedium">Select the plan that fits your team.</FlareText>
    </FlareStep>
    <FlareStep Label="Add-ons" Optional="true" Skippable="true">
        <FlareText Typo="TypographyScale.BodyMedium">
            Optional and skippable - click the "Review" indicator to jump past this step.
        </FlareText>
    </FlareStep>
    <FlareStep Label="Review" Description="Confirm">
        <FlareAlert Severity="AlertSeverity.Success" Title="Ready to submit">All steps complete.</FlareAlert>
    </FlareStep>
</FlareStepper>

<FlareStack Row Gap="FlareSpacing.Small" Align="FlareAlignItems.Center" Wrap="true" Style="margin-top:1rem;">
    <FlareButton Variant="ButtonVariant.Outlined" Disabled="@(_index == 0)" OnClick="@(() => _index--)">Prev</FlareButton>
    <FlareButton Variant="ButtonVariant.Outlined" Disabled="@(_index >= 2)" OnClick="@(() => _index++)">Next</FlareButton>
    <FlareButton Variant="ButtonVariant.Tonal" Disabled="@(_index == 2)" OnClick="@(() => _index = 2)">Skip to review</FlareButton>
    <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.LabelSmall">Bound index: @_index</FlareText>
</FlareStack>

@code {
    // @bind-ActiveIndex makes the stepper fully controlled: setting _index from the buttons moves it,
    // and a step-indicator click writes the new index straight back here.
    private int _index;
}
