<FlareStepper OnStepChanging="GuardAsync">
    <FlareStep Label="Terms" Description="Required">
        <Icon><FlareIconView Value="@MaterialDesign3Icons.Regular.Gavel" /></Icon>
        <ChildContent>
            <FlareText Typo="TypographyScale.BodyMedium" Style="margin-bottom:1rem;">
                You must accept the terms before continuing. The async guard blocks "Next" until you do.
            </FlareText>
            <FlareCheckbox @bind-Value="_agreed" Label="I accept the terms" />
            @if (_blocked)
            {
                <FlareText Color="FlareColor.Error" Typo="TypographyScale.BodySmall" Style="display:block;margin-top:0.5rem;">
                    Please accept the terms to continue.
                </FlareText>
            }
        </ChildContent>
    </FlareStep>
    <FlareStep Label="Details">
        <FlareStack Gap="FlareSpacing.Small" Style="max-width:20rem;">
            <FlareField TValue="string" Label="Name" Placeholder="John Doe" />
        </FlareStack>
    </FlareStep>
    <FlareStep Label="Done" Description="Confirm">
        <FlareAlert Severity="AlertSeverity.Success" Title="All set">You got past the guard.</FlareAlert>
    </FlareStep>
</FlareStepper>

@code {
    private bool? _agreed;
    private bool _blocked;

    // Validate forward moves only; always allow going back. Returning false vetoes the change.
    private Task<bool> GuardAsync(StepperChange change)
    {
        if (change.To <= change.From) { _blocked = false; return Task.FromResult(true); }
        if (change.From == 0 && _agreed != true)
        {
            _blocked = true;
            return Task.FromResult(false);
        }
        _blocked = false;
        return Task.FromResult(true);
    }
}
