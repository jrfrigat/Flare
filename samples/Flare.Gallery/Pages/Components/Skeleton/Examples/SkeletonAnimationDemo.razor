<FlareStack Row Gap="FlareSpacing.Large" Wrap Align="FlareAlignItems.Start">
    <FlareStack Gap="FlareSpacing.XSmall" Style="width:14rem;">
        <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.LabelSmall" Style="margin-bottom:0.25rem">Wave (default)</FlareText>
        <FlareSkeleton Variant="SkeletonVariant.Text" Animation="SkeletonAnimation.Wave" Height="1rem" />
        <FlareSkeleton Variant="SkeletonVariant.Text" Animation="SkeletonAnimation.Wave" Width="70%" Height="1rem" />
    </FlareStack>
    <FlareStack Gap="FlareSpacing.XSmall" Style="width:14rem;">
        <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.LabelSmall" Style="margin-bottom:0.25rem">Pulse</FlareText>
        <FlareSkeleton Variant="SkeletonVariant.Text" Animation="SkeletonAnimation.Pulse" Height="1rem" />
        <FlareSkeleton Variant="SkeletonVariant.Text" Animation="SkeletonAnimation.Pulse" Width="70%" Height="1rem" />
    </FlareStack>
    <FlareStack Gap="FlareSpacing.XSmall" Style="width:14rem;">
        <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.LabelSmall" Style="margin-bottom:0.25rem">None</FlareText>
        <FlareSkeleton Variant="SkeletonVariant.Rect" Animation="SkeletonAnimation.None" Height="4rem" />
    </FlareStack>
</FlareStack>
