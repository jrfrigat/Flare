    private List<string> _filtered => string.IsNullOrWhiteSpace(_search)
        ? _allSvgIcons
        : _allSvgIcons.Where(n => n.Contains(_search, StringComparison.OrdinalIgnoreCase)).ToList();

    private (string Name, string Member, FlareIcon Icon)[] _materialFiltered => string.IsNullOrWhiteSpace(_search)
        ? _allMaterialIcons
        : _allMaterialIcons.Where(t => t.Name.Contains(_search, StringComparison.OrdinalIgnoreCase)).ToArray();

    private void SetTab(string tab)
    {
        _tab = tab;
        _copiedName = null;
    }

    private async Task CopyUsage(string code, string label)
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", code);
        _copiedName = label;
        StateHasChanged();
        await Task.Delay(2000);
        if (_copiedName == label) _copiedName = null;
        StateHasChanged();
    }

    private static string Pascal(string id) =>
        string.Concat(id.Split('_', StringSplitOptions.RemoveEmptyEntries).Select(p => char.ToUpperInvariant(p[0]) + p[1..]));
