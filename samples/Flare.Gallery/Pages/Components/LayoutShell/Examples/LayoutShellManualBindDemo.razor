<div style="height:320px;overflow:hidden;border-radius:var(--flare-shape-medium);">
    <FlareLayout>
        <FlareLayoutAppBar>
            <FlareButton Variant="ButtonVariant.Text" OnClick="@(() => _open = !_open)">
                <LeadingIcon><FlareIconView Value="@MaterialDesign3Icons.Regular.Menu" /></LeadingIcon>
                <ChildContent>Menu</ChildContent>
            </FlareButton>
            <FlareText Typo="TypographyScale.TitleLarge" Style="margin-left:0.5rem;">Manual bind</FlareText>
        </FlareLayoutAppBar>

        @* @bind-Open keeps the drawer in sync with the parent field the button toggles. *@
        <FlareLayoutDrawer @bind-Open="_open" Variant="DrawerVariant.Persistent" Width="14rem">
            <FlareStack Style="padding:1rem 0.5rem;">
                <FlareText Typo="TypographyScale.BodyMedium">Drawer state is driven by the parent.</FlareText>
            </FlareStack>
        </FlareLayoutDrawer>

        <FlareLayoutContent>
            <FlareText Typo="TypographyScale.BodyMedium">Drawer open: @_open</FlareText>
        </FlareLayoutContent>
    </FlareLayout>
</div>

@code {
    private bool _open = true;
}
