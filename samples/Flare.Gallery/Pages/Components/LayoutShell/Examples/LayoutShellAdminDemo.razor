<div style="height:420px;overflow:hidden;border-radius:var(--flare-shape-medium);">
    <FlareLayout>
        <FlareLayoutAppBar DrawerToggle="true">
            <FlareText Typo="TypographyScale.TitleLarge">My App</FlareText>
            <FlareStack Row Style="flex:1;" />
            <FlareAvatar Icon="@MaterialDesign3Icons.Regular.AccountCircle" Size="AvatarSize.Sm" />
        </FlareLayoutAppBar>

        @* The drawer owns its own open state; the app-bar toggle flips it. *@
        <FlareLayoutDrawer @bind-Open="_open" Variant="DrawerVariant.Persistent" Width="14rem">
            <FlareStack Style="padding:1rem 0.5rem;">
                <FlareNavMenu>
                    <FlareNavLink Href="#" Match="NavMatchMode.Exact">
                        <Icon><FlareIconView Size="1.1rem" Value="@MaterialDesign3Icons.Regular.Dashboard" /></Icon>
                        <ChildContent>Dashboard</ChildContent>
                    </FlareNavLink>
                    <FlareNavLink Href="#">
                        <Icon><FlareIconView Size="1.1rem" Value="@MaterialDesign3Icons.Regular.Group" /></Icon>
                        <ChildContent>Users</ChildContent>
                    </FlareNavLink>
                    <FlareNavLink Href="#">
                        <Icon><FlareIconView Size="1.1rem" Value="@MaterialDesign3Icons.Regular.Settings" /></Icon>
                        <ChildContent>Settings</ChildContent>
                    </FlareNavLink>
                </FlareNavMenu>
            </FlareStack>
        </FlareLayoutDrawer>

        <FlareLayoutContent>
            <FlareText Typo="TypographyScale.HeadlineSmall" Style="margin-bottom:1rem;">Dashboard</FlareText>
            <FlareGrid Columns="3" Gap="FlareSpacing.Small">
                <FlareCol Span="1">
                    <FlareCard>
                        <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.LabelMedium">Users</FlareText>
                        <FlareText Typo="TypographyScale.DisplaySmall">1,234</FlareText>
                    </FlareCard>
                </FlareCol>
                <FlareCol Span="1">
                    <FlareCard>
                        <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.LabelMedium">Revenue</FlareText>
                        <FlareText Typo="TypographyScale.DisplaySmall">$56k</FlareText>
                    </FlareCard>
                </FlareCol>
                <FlareCol Span="1">
                    <FlareCard>
                        <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.LabelMedium">Orders</FlareText>
                        <FlareText Typo="TypographyScale.DisplaySmall">891</FlareText>
                    </FlareCard>
                </FlareCol>
            </FlareGrid>
        </FlareLayoutContent>
    </FlareLayout>
</div>

@code {
    private bool _open = true;
}
