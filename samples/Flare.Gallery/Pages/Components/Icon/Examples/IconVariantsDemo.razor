@inherits LocalizedPage

@* Material Symbols ship in two fills; with the inline-SVG catalog you pick the Regular or Filled member
   (font-variation-settings only applies to the icon font, not to SVG). *@
<FlareStack Row Gap="FlareSpacing.Small" Wrap>
    <FlareIconView Size="2rem" Color="FlareColor.Primary" Value="@MaterialDesign3Icons.Regular.Home" />
    <FlareIconView Size="2rem" Color="FlareColor.Primary" Value="@MaterialDesign3Icons.Filled.Home" />
    <FlareIconView Size="2rem" Color="FlareColor.Tertiary" Value="@MaterialDesign3Icons.Regular.Star" />
    <FlareIconView Size="2rem" Color="FlareColor.Tertiary" Value="@MaterialDesign3Icons.Filled.Star" />
    <FlareIconView Size="2rem" Color="FlareColor.Error" Value="@MaterialDesign3Icons.Regular.Favorite" />
    <FlareIconView Size="2rem" Color="FlareColor.Error" Value="@MaterialDesign3Icons.Filled.Favorite" />
</FlareStack>
