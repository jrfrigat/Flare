<FlareStack Row Wrap Gap="FlareSpacing.Large" Align="FlareAlignItems.Center">
    <FlareIcon Name="favorite" Color="FlareColor.Error" SizePx="32" AriaLabel="Favorite" />
    <FlareIcon Name="star" Color="FlareColor.Primary" SizePx="40" />
    <FlareIcon Name="bolt" Color="_amber" Size="3rem" />
    <FlareIcon Name="check_circle" Color="FlareColor.Secondary" SizePx="48" />
</FlareStack>

@code {
    private readonly FlareColor _amber = FlareColor.Custom("#FFB300");
}
