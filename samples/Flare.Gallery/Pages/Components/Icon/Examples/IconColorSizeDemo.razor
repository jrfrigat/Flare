<FlareStack Row Wrap Gap="FlareSpacing.Large" Align="FlareAlignItems.Center">
    <FlareIconView Name="favorite" Color="FlareColor.Error" SizePx="32" AriaLabel="Favorite" />
    <FlareIconView Name="star" Color="FlareColor.Primary" SizePx="40" />
    <FlareIconView Name="bolt" Color="_amber" Size="3rem" />
    <FlareIconView Name="check_circle" Color="FlareColor.Secondary" SizePx="48" />
</FlareStack>

@code {
    private readonly FlareColor _amber = FlareColor.Custom("#FFB300");
}
