<FlareStack Row Wrap Gap="FlareSpacing.Large" Align="FlareAlignItems.Center">
    <FlareIconView Value="@MaterialDesign3Icons.Regular.Favorite" Color="FlareColor.Error" SizePx="32" AriaLabel="Favorite" />
    <FlareIconView Value="@MaterialDesign3Icons.Regular.Star" Color="FlareColor.Primary" SizePx="40" />
    <FlareIconView Value="@MaterialDesign3Icons.Regular.Bolt" Color="_amber" Size="3rem" />
    <FlareIconView Value="@MaterialDesign3Icons.Regular.CheckCircle" Color="FlareColor.Secondary" SizePx="48" />
</FlareStack>

@code {
    private readonly FlareColor _amber = FlareColor.Custom("#FFB300");
}
