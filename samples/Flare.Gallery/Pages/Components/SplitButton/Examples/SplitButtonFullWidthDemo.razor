@* FullWidth stretches the split button; Loading shows a spinner on the primary action; Open()/Close()
   drive the dropdown programmatically. *@
<FlareStack Gap="FlareSpacing.Medium" Style="max-width:26rem;">
    <FlareSplitButton @ref="_split" FullWidth Loading="@_loading" Variant="ButtonVariant.Filled" Color="FlareColor.Primary" OnClick="@SaveAsync">
        <ChildContent>Save</ChildContent>
        <MenuItems>
            <FlareMenuItem Icon="save_as" OnClick="@SaveAsync">Save as…</FlareMenuItem>
            <FlareMenuItem Icon="download">Export…</FlareMenuItem>
        </MenuItems>
    </FlareSplitButton>
    <FlareStack Row Gap="FlareSpacing.Small">
        <FlareButton Variant="ButtonVariant.Outlined" Size="ButtonSize.Sm" OnClick="@(() => _split!.Open())">Open menu</FlareButton>
        <FlareButton Variant="ButtonVariant.Text" Size="ButtonSize.Sm" OnClick="@(() => _split!.Close())">Close menu</FlareButton>
    </FlareStack>
</FlareStack>

@code {
    private FlareSplitButton? _split;
    private bool _loading;

    private async Task SaveAsync()
    {
        _loading = true;
        StateHasChanged();
        await Task.Delay(1200);
        _loading = false;
    }
}
