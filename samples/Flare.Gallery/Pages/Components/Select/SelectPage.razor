@page "/components/select"
@inherits LocalizedPage

<PageTitle>@GalleryStrings.Select_Title - Flare</PageTitle>

<GalleryPageTitle Api="FlareSelect">
    <FlareText Typo="TypographyScale.HeadlineMedium">@GalleryStrings.Select_Title</FlareText>
    <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.BodyLarge">@GalleryStrings.Select_Subtitle</FlareText>
</GalleryPageTitle>

<AutoDemoSection Title="@GalleryStrings.Select_Basic" DemoType="typeof(Examples.SelectBasicDemo)" />
<AutoDemoSection Title="@GalleryStrings.Select_ItemTemplate" DemoType="typeof(Examples.SelectTemplateDemo)" />
<AutoDemoSection Title="@GalleryStrings.Select_Grouped" DemoType="typeof(Examples.SelectGroupedDemo)" />
<AutoDemoSection Title="@GalleryStrings.Select_Validation" DemoType="typeof(Examples.SelectValidationDemo)" />
<AutoDemoSection Title="@GalleryStrings.Field_Sizes" DemoType="typeof(Examples.SelectSizesDemo)" />
<AutoDemoSection Title="@GalleryStrings.Field_Variants" DemoType="typeof(Examples.SelectVariantsDemo)" />
