<FlareStack Row Gap="FlareSpacing.Large" Align="FlareAlignItems.Start">
    <FlarePaper Elevation="2" Padding="FlareSpacing.Large">
        <FlareText Typo="TypographyScale.BodyMedium">Rounded (default)</FlareText>
    </FlarePaper>
    <FlarePaper Elevation="2" Padding="FlareSpacing.Large" Square="true">
        <FlareText Typo="TypographyScale.BodyMedium">Square</FlareText>
    </FlarePaper>
    <FlarePaper Outlined="true" Padding="FlareSpacing.Large">
        <FlareText Typo="TypographyScale.BodyMedium">Outlined (no shadow)</FlareText>
    </FlarePaper>
</FlareStack>
