@* All buttons share the same Size (Md); only the Typo override changes the label type scale. *@
<FlareStack Row Wrap Align="FlareAlignItems.Center">
    <FlareButton Typo="TypographyScale.LabelSmall">Label Small</FlareButton>
    <FlareButton Typo="TypographyScale.LabelLarge">Label Large</FlareButton>
    <FlareButton Typo="TypographyScale.BodyLarge">Body Large</FlareButton>
    <FlareButton Typo="TypographyScale.TitleMedium">Title Medium</FlareButton>
    <FlareButton Typo="TypographyScale.TitleLarge">Title Large</FlareButton>
    <FlareButton Typo="TypographyScale.HeadlineSmall">Headline Small</FlareButton>
</FlareStack>
