@inject ISnackbarService Snackbar

<FlareButton Variant="ButtonVariant.Filled">
    <LeadingIcon><FlareIconView Value="@MaterialDesign3Icons.Regular.Add" /></LeadingIcon>
    <ChildContent>Add item</ChildContent>
</FlareButton>
<FlareButton Variant="ButtonVariant.Outlined">
    <LeadingIcon><FlareIconView Value="@MaterialDesign3Icons.Regular.Download" /></LeadingIcon>
    <ChildContent>Download</ChildContent>
</FlareButton>
<FlareButton Variant="ButtonVariant.Tonal">
    <TrailingIcon><FlareIconView Value="@MaterialDesign3Icons.Regular.ArrowForward" /></TrailingIcon>
    <ChildContent>Next</ChildContent>
</FlareButton>
<FlareButton Variant="ButtonVariant.Text"
                OnClick="@(() => Snackbar.Show("Deleted!", SnackbarSeverity.Error))">
    <LeadingIcon><FlareIconView Value="@MaterialDesign3Icons.Regular.Delete" /></LeadingIcon>
    <ChildContent>Delete</ChildContent>
</FlareButton>
<FlareButton Variant="ButtonVariant.Elevated"
                OnClick="@(() => Snackbar.Show("Shared!"))">
    <LeadingIcon><FlareIconView Value="@MaterialDesign3Icons.Regular.Share" /></LeadingIcon>
    <ChildContent>Share</ChildContent>
</FlareButton>