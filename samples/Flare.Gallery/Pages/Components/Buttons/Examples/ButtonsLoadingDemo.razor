<FlareButton Variant="ButtonVariant.Filled" Loading="@_loading" LoadingText="Saving…" OnClick="@ToggleLoading">
    Save
</FlareButton>
<FlareButton Variant="ButtonVariant.Outlined" Loading="@_loading" OnClick="@ToggleLoading">
    Submit
</FlareButton>
<FlareButton Variant="ButtonVariant.Tonal" Loading="@_loading" Size="ButtonSize.Sm" OnClick="@ToggleLoading">
    Upload
</FlareButton>
@* LoadingTemplate: a custom indicator instead of the default spinner. *@
<FlareButton Variant="ButtonVariant.Filled" Color="FlareColor.Tertiary" Loading="@_loading" OnClick="@ToggleLoading">
    <LoadingTemplate>
        <FlareIconView Name="hourglass_top" Size="1.1rem" />
        <FlareText Element="span">Working…</FlareText>
    </LoadingTemplate>
    <ChildContent>Export</ChildContent>
</FlareButton>

@code{
    private bool _loading;
    private void ToggleLoading() => _loading = !_loading;
}