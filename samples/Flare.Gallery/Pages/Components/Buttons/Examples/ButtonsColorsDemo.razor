<FlareStack Gap="FlareSpacing.Medium" Align="FlareAlignItems.Start">
    <FlareStack Wrap Row>
        <FlareButton Color="@Colors.Primary">Primary</FlareButton>
        <FlareButton Color="@Colors.Secondary">Secondary</FlareButton>
        <FlareButton Color="@Colors.Success">Success</FlareButton>
        <FlareButton Color="@Colors.Warning">Warning</FlareButton>
        <FlareButton Color="@Colors.Error">Error</FlareButton>
        <FlareButton Color="@Colors.Info">Info</FlareButton>
    </FlareStack>

    <FlareStack Wrap Row>
        <FlareButton Variant="ButtonVariant.Tonal" Color="@Colors.Primary">Primary</FlareButton>
        <FlareButton Variant="ButtonVariant.Tonal" Color="@Colors.Secondary">Secondary</FlareButton>
        <FlareButton Variant="ButtonVariant.Tonal" Color="@Colors.Success">Success</FlareButton>
        <FlareButton Variant="ButtonVariant.Tonal" Color="@Colors.Warning">Warning</FlareButton>
        <FlareButton Variant="ButtonVariant.Tonal" Color="@Colors.Error">Error</FlareButton>
        <FlareButton Variant="ButtonVariant.Tonal" Color="@Colors.Info">Info</FlareButton>
    </FlareStack>

    <FlareStack Wrap Row>
        <FlareButton Variant="ButtonVariant.Outlined" Color="@Colors.Primary">Primary</FlareButton>
        <FlareButton Variant="ButtonVariant.Outlined" Color="@Colors.Secondary">Secondary</FlareButton>
        <FlareButton Variant="ButtonVariant.Outlined" Color="@Colors.Success">Success</FlareButton>
        <FlareButton Variant="ButtonVariant.Outlined" Color="@Colors.Warning">Warning</FlareButton>
        <FlareButton Variant="ButtonVariant.Outlined" Color="@Colors.Error">Error</FlareButton>
        <FlareButton Variant="ButtonVariant.Outlined" Color="@Colors.Info">Info</FlareButton>
    </FlareStack>
</FlareStack>
