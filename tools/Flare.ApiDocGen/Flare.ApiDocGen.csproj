<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Flare.ApiDocGen - build-time tool that extracts component API documentation
    (structure + types + default values via reflection, summaries via XML docs)
    and emits a generated C# registry consumed by Flare.Gallery.

    This project is a DOCS-ONLY tool. It is NOT packed and NOT published to NuGet.
    It references the Flare meta-package solely so the component assemblies and
    their .xml documentation files are copied next to the tool for reflection.
  -->
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <IsPackable>false</IsPackable>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
    <!-- Suppress the umbrella package's own doc warnings; we only consume XML here. -->
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Flare\Flare.csproj" />
  </ItemGroup>

</Project>
