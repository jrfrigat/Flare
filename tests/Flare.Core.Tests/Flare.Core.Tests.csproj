<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="coverlet.collector">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="xunit.v3" />
    <PackageReference Include="xunit.runner.visualstudio" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="Xunit" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Flare.Abstractions\Flare.Abstractions.csproj" />
    <ProjectReference Include="..\..\src\Flare.Theming\Flare.Theming.csproj" />
    <ProjectReference Include="..\..\src\Flare.Components\Flare.Components.csproj" />
    <ProjectReference Include="..\..\src\Flare.Infrastructure\Flare.Infrastructure.csproj" />
    <!-- A concrete reference DesignTokens for the FlareThemeBuilder tests (the core ships no baseline). -->
    <ProjectReference Include="..\..\src\Flare.Theme.MaterialDesign3.Tokens\Flare.Theme.MaterialDesign3.Tokens.csproj" />
    <!-- Reusable audit logic for the CssClasses/CSS/theme in-sync guard test. -->
    <ProjectReference Include="..\..\tools\Flare.CssAudit\Flare.CssAudit.csproj" />
  </ItemGroup>

</Project>