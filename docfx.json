{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "src": "src",
          "files": [
            "Flare/**/*.csproj",
            "Flare.Core/**/*.csproj",
            "Flare.Components/**/*.csproj",
            "Flare.Components.*/**/*.csproj",
            "Flare.Icons/**/*.csproj",
            "Flare.Theme.*/**/*.csproj"
          ]
        }
      ],
      "dest": "api",
      "outputFormat": "mref",
      "properties": {
        "TargetFramework": "net10.0"
      },
      "EnumSortOrder": "alphabetic",
      "namespaceLayout": "nested",
      "memberLayout": "separatePages"
    }
  ],
  "build": {
    "content": [
      {
        "files": [ "api/**.yml", "api/index.md" ]
      },
      {
        "files": [ "index.md", "toc.yml" ]
      },
      {
        "files": [ "**.md", "toc.yml" ],
        "src": "docs",
        "dest": "docs"
      }
    ],
    "resource": [
      {
        "files": [ "icon.png", "llms.txt" ]
      }
    ],
    "output": "_site",
    "template": [ "default", "modern" ],
    "globalMetadata": {
      "_appName": "Flare",
      "_appTitle": "Flare - Blazor UI components",
      "_appFooter": "Flare - MIT licensed Blazor UI library. Docs built with docfx.",
      "_enableSearch": true,
      "_appLogoPath": "icon.png",
      "_disableContribution": false,
      "_gitContribute": {
        "repo": "https://github.com/jrfrigat/Flare",
        "branch": "main"
      }
    },
    "sitemap": {
      "baseUrl": "https://jrfrigat.github.io/Flare/"
    },
    "postProcessors": [ "ExtractSearchIndex" ]
  }
}
