<Project Sdk="Microsoft.NET.Sdk.Razor">

  <!-- MaterialDesign3Icons.g.cs is generated by tools/MaterialSymbolsGen from Google's Material Symbols
       SVGs (rounded); re-run that tool to refresh or switch style. -->

  <PropertyGroup>
    <TargetFrameworks>$(FlareLibTargetFrameworks)</TargetFrameworks>
    <TargetFramework></TargetFramework>
    <PackageId>Flare.Icons.MaterialDesign3.Svg</PackageId>
    <RootNamespace>Flare.Components</RootNamespace>
    <IsTrimmable>true</IsTrimmable>
    <Description>Material Design 3 (Material Symbols) as inline SVG for the Flare Blazor component library. Adds the MaterialDesign3Icons catalog of ready FlareSvgIcon values (Regular + Filled), usable anywhere a FlareIcon is accepted - no icon font required.</Description>
    <PackageTags>blazor;components;icons;material;materialsymbols;materialdesign</PackageTags>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
    <NoWarn>$(NoWarn.Replace('CS1591',''))</NoWarn>
    <WarningsAsErrors>$(WarningsAsErrors);CS1591</WarningsAsErrors>
  </PropertyGroup>

  <ItemGroup>
    <SupportedPlatform Include="browser" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Flare.Components\Flare.Components.csproj" />
  </ItemGroup>

</Project>
