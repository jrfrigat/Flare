@namespace Flare.Components.IDE
@inherits FlareComponentBase

@* A ribbon button that opens a dropdown menu / gallery (Office "Styles", "Paste options" etc.).
   Built on the base FlareMenu: the activator is a ribbon-styled button and MenuContent holds the
   menu items (FlareMenuItem). Large (icon + label + chevron) or small (icon + chevron) modes. *@
<FlareTooltip Content="@Tooltip" Placement="@TooltipPlacement.Bottom">
    <FlareMenu Anchor="MenuAnchor.BottomLeft" AriaLabel="@Tooltip">
        <Activator>
            <FlareButton Variant="@ButtonVariant.Text" Size="@(IsLarge ? ButtonSize.Lg : ButtonSize.Sm)"
                         Disabled="@Disabled" AriaLabel="@Tooltip"
                         class="@(IsLarge ? $"{Css.Classes.Ide.Ribbon.Button} {Css.Classes.Ide.Ribbon.ButtonLarge}" : Css.Classes.Ide.Ribbon.Button)">
                @if (Icon is not null)
                {
                    <FlareIconView Value="Icon" />
                }
                @if (!string.IsNullOrEmpty(Label))
                {
                    <span class="@Css.Classes.Ide.Ribbon.ButtonLabel">
                        @Label <FlareIconView Value="FlareIcons.ArrowDropDown" Class="@Css.Classes.Ide.Ribbon.Caret" />
                    </span>
                }
                else
                {
                    <FlareIconView Value="FlareIcons.ArrowDropDown" Class="@Css.Classes.Ide.Ribbon.Caret" />
                }
            </FlareButton>
        </Activator>
        <ChildContent>
            @MenuContent
        </ChildContent>
    </FlareMenu>
</FlareTooltip>

@code {
    /// <summary>Icon displayed in the button - any provider (a bare string is a Material Symbols name).</summary>
    [Parameter] public FlareIcon? Icon { get; set; }

    /// <summary>Label text shown next to / below the icon.</summary>
    [Parameter] public string? Label { get; set; }

    /// <summary>Tooltip and accessible label for the dropdown.</summary>
    [Parameter] public string? Tooltip { get; set; }

    /// <summary>Large mode shows icon + label vertically; small mode is icon-only.</summary>
    [Parameter] public bool IsLarge { get; set; }

    /// <summary>Whether the dropdown is disabled.</summary>
    [Parameter] public bool Disabled { get; set; }

    /// <summary>The dropdown menu items, typically <c>FlareMenuItem</c> entries.</summary>
    [Parameter] public RenderFragment? MenuContent { get; set; }

    /// <inheritdoc />
    protected override string ComponentCssClass => Css.Classes.Ide.Ribbon.Button;
}
