@* Requires interactive render mode (not compatible with static SSR). *@
@namespace Flare.Components
@inherits FlareComponentBase
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="@BuildCssClass()" style="@Style" @attributes="AdditionalAttributes">
    <video class="flare-video-player__video"
           @ref="_video"
           src="@Src"
           poster="@Poster"
           autoplay="@AutoPlay"
           loop="@Loop"
           muted="@(Muted || _isMuted)"
           playsinline
           aria-label="@(AriaLabel ?? "Video player")">
        @if (!string.IsNullOrEmpty(SubtitleSrc))
        {
            <track kind="subtitles" src="@SubtitleSrc" default />
        }
    </video>

    @if (Controls)
    {
        <div class="flare-video-player__controls">
            <button class="flare-video-player__btn"
                    type="button"
                    aria-label="@(_isPlaying ? "Pause" : "Play")"
                    @onclick="TogglePlayAsync">
                <FlareIconView Name="@(_isPlaying ? "pause" : "play_arrow")" Size="1.25rem" />
            </button>

            <input class="flare-video-player__progress"
                   type="range"
                   min="0"
                   max="@((int)(_duration > 0 ? _duration : 1))"
                   value="@((int)_currentTime)"
                   step="1"
                   aria-label="Seek"
                   @oninput="OnSeekInput" />

            <span class="flare-video-player__time">@FormatTime(_currentTime) / @FormatTime(_duration)</span>

            <button class="flare-video-player__btn"
                    type="button"
                    aria-label="@(_isMuted ? "Unmute" : "Mute")"
                    @onclick="ToggleMuteAsync">
                <FlareIconView Name="@(_isMuted ? "volume_off" : "volume_up")" Size="1.25rem" />
            </button>

            <input class="flare-video-player__progress"
                   type="range"
                   min="0"
                   max="1"
                   step="0.05"
                   value="@_volume.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)"
                   aria-label="Volume"
                   style="flex:0 0 5rem"
                   @oninput="OnVolumeInput" />

            @if (PlaybackRates is { Count: > 0 })
            {
                <select class="flare-video-player__rate"
                        aria-label="Playback speed"
                        @onchange="OnPlaybackRateChange">
                    @foreach (var rate in PlaybackRates)
                    {
                        <option value="@rate.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                selected="@(_playbackRate == rate)">
                            @rate.ToString("G")x
                        </option>
                    }
                </select>
            }

            <button class="flare-video-player__btn"
                    type="button"
                    aria-label="Fullscreen"
                    @onclick="RequestFullscreenAsync">
                <FlareIconView Name="fullscreen" Size="1.25rem" />
            </button>
        </div>
    }
</div>

@code {
    /// <summary>URL of the video source to display.</summary>
    [Parameter] public string? Src { get; set; }

    /// <summary>URL of a poster image shown before the video plays.</summary>
    [Parameter] public string? Poster { get; set; }

    /// <summary>Automatically starts playback when the component mounts.</summary>
    [Parameter] public bool AutoPlay { get; set; }

    /// <summary>Loops video playback when it reaches the end.</summary>
    [Parameter] public bool Loop { get; set; }

    /// <summary>Starts the video in a muted state.</summary>
    [Parameter] public bool Muted { get; set; }

    /// <summary>Shows the custom Flare-themed control bar.</summary>
    [Parameter] public bool Controls { get; set; } = true;
    /// <summary>URL of a WebVTT subtitle track to display. Adds a &lt;track&gt; element to the video.</summary>
    [Parameter] public string? SubtitleSrc { get; set; }
    /// <summary>Available playback speed options shown in a select control. E.g. [0.5, 1.0, 1.5, 2.0].</summary>
    [Parameter] public IReadOnlyList<double>? PlaybackRates { get; set; }

    /// <summary>Accessible label for the video element. Defaults to "Video player".</summary>
    [Parameter] public string? AriaLabel { get; set; }

    protected override string ComponentCssClass => "flare-video-player";

    private ElementReference _video;
    private IJSObjectReference? _module;
    private DotNetObjectReference<FlareVideoPlayer>? _dotNetRef;
    private readonly string _id = Guid.NewGuid().ToString("N");

    private bool _isPlaying;
    private double _currentTime;
    private double _duration;
    private double _volume = 1.0;
    private bool _isMuted;
    private double _playbackRate = 1.0;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try
        {
            _module = await JS.InvokeAsync<IJSObjectReference>(
                "import", "./_content/Flare.Components.Media/js/videoplayer.js");
            _dotNetRef = DotNetObjectReference.Create(this);
            await _module.InvokeVoidAsync("init", _id, _video, _dotNetRef);
        }
        catch (InvalidOperationException) { }
        catch (JSDisconnectedException) { }
    }

    private async Task TogglePlayAsync()
    {
        if (_module is null) return;
        try
        {
            if (_isPlaying)
                await _module.InvokeVoidAsync("pause", _id);
            else
                await _module.InvokeVoidAsync("play", _id);
        }
        catch (InvalidOperationException) { }
        catch (JSDisconnectedException) { }
    }

    private async Task ToggleMuteAsync()
    {
        if (_module is null) return;
        try
        {
            _isMuted = !_isMuted;
            await _module.InvokeVoidAsync("toggleMute", _id);
        }
        catch (InvalidOperationException) { }
        catch (JSDisconnectedException) { }
    }

    private async Task RequestFullscreenAsync()
    {
        if (_module is null) return;
        try
        {
            await _module.InvokeVoidAsync("requestFullscreen", _id);
        }
        catch (InvalidOperationException) { }
        catch (JSDisconnectedException) { }
    }

    private async Task OnSeekInput(ChangeEventArgs e)
    {
        if (_module is null) return;
        if (double.TryParse(e.Value?.ToString(), System.Globalization.NumberStyles.Any,
                System.Globalization.CultureInfo.InvariantCulture, out var t))
        {
            try { await _module.InvokeVoidAsync("seek", _id, t); }
            catch (InvalidOperationException) { }
            catch (JSDisconnectedException) { }
        }
    }

    private async Task OnVolumeInput(ChangeEventArgs e)
    {
        if (_module is null) return;
        if (double.TryParse(e.Value?.ToString(), System.Globalization.NumberStyles.Any,
                System.Globalization.CultureInfo.InvariantCulture, out var v))
        {
            _volume = v;
            try { await _module.InvokeVoidAsync("setVolume", _id, v); }
            catch (InvalidOperationException) { }
            catch (JSDisconnectedException) { }
        }
    }

    private async Task OnPlaybackRateChange(ChangeEventArgs e)
    {
        if (_module is null) return;
        if (double.TryParse(e.Value?.ToString(), System.Globalization.NumberStyles.Any,
                System.Globalization.CultureInfo.InvariantCulture, out var rate))
        {
            _playbackRate = rate;
            try { await _module.InvokeVoidAsync("setPlaybackRate", _id, rate); }
            catch (InvalidOperationException) { }
            catch (JSDisconnectedException) { }
        }
    }

    [JSInvokable]
    public void OnTimeUpdate(double current, double duration)
    {
        _currentTime = current;
        _duration = duration;
        InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public void OnEnded()
    {
        _isPlaying = false;
        InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public void OnPlayStateChanged(bool isPlaying)
    {
        _isPlaying = isPlaying;
        InvokeAsync(StateHasChanged);
    }

    private static string FormatTime(double seconds)
    {
        var ts = TimeSpan.FromSeconds(seconds);
        return ts.TotalHours >= 1
            ? ts.ToString(@"h\:mm\:ss")
            : ts.ToString(@"m\:ss");
    }

    public override async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try { await _module.InvokeVoidAsync("destroy", _id); }
            catch (InvalidOperationException) { }
            catch (JSDisconnectedException) { }
            await _module.DisposeAsync();
        }
        _dotNetRef?.Dispose();
        await base.DisposeAsync();
    }
}
