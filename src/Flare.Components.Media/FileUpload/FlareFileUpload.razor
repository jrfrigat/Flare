@namespace Flare.Components
@inherits FlareComponentBase
@using Microsoft.AspNetCore.Components.Forms

<div class="@BuildCssClass(_variantClass, _draggingClass, _disabledClass)"
     style="@Style"
     @ondragover:preventDefault="true"
     @ondragenter:preventDefault="true"
     @ondragover="@(() => _isDragging = true)"
     @ondragleave="@(() => _isDragging = false)"
     @ondrop:preventDefault="true"
     @attributes="AdditionalAttributes">
    <div class="flare-file-upload__drop-wrap">
        @if (Variant == FileUploadVariant.Button)
        {
            <label class="flare-file-upload__button" for="@_inputId">
                <span class="flare-file-upload__button-icon material-symbols-rounded" aria-hidden="true">upload_file</span>
                <span>@(ButtonText ?? FlareStrings.FileUpload_ButtonText)</span>
            </label>
        }
        else
        {
            <label class="flare-file-upload__zone" for="@_inputId">
                <span class="flare-file-upload__icon material-symbols-rounded" aria-hidden="true">upload_file</span>
                <span class="flare-file-upload__primary">@(DropText ?? FlareStrings.FileUpload_DropText)</span>
                @if (!string.IsNullOrEmpty(Accept))
                {
                    <span class="flare-file-upload__hint">@(FlareStrings.FileUpload_Accepted) @Accept</span>
                }
            </label>
        }
        <InputFile id="@_inputId"
                   class="flare-file-upload__input"
                   accept="@Accept"
                   multiple="@Multiple"
                   disabled="@Disabled"
                   OnChange="HandleChange" />
    </div>
    @if (_files.Count > 0)
    {
        <ul class="flare-file-upload__list">
            @foreach (var file in _files)
            {
                <li class="flare-file-upload__file">
                    <span class="flare-file-upload__file-icon material-symbols-rounded" aria-hidden="true">description</span>
                    <span class="flare-file-upload__file-name">@file.Name</span>
                    <span class="flare-file-upload__file-size">@FormatSize(file.Size)</span>
                </li>
            }
        </ul>
    }
</div>

@code {
    /// <summary>Callback invoked with the list of selected files.</summary>
    [Parameter] public EventCallback<IReadOnlyList<IBrowserFile>> OnFilesChanged { get; set; }
    /// <summary>Accepted file types as a MIME or extension filter string.</summary>
    [Parameter] public string? Accept { get; set; }
    /// <summary>Allows selecting multiple files when true.</summary>
    [Parameter] public bool Multiple { get; set; }
    /// <summary>Disables the upload zone when true.</summary>
    [Parameter] public bool Disabled { get; set; }
    /// <summary>Instructional text shown inside the drop zone. Defaults to the localized "FileUpload_DropText" string.</summary>
    [Parameter] public string? DropText { get; set; }
    /// <summary>Maximum number of files that can be selected.</summary>
    [Parameter] public int MaxFiles { get; set; } = 10;
    /// <summary>The visual form of the trigger - a drag-and-drop zone (default) or a compact button.</summary>
    [Parameter] public FileUploadVariant Variant { get; set; } = FileUploadVariant.DropZone;
    /// <summary>Label for the <see cref="FileUploadVariant.Button"/> trigger. Defaults to the localized
    /// "choose file" text.</summary>
    [Parameter] public string? ButtonText { get; set; }

    protected override string ComponentCssClass => "flare-file-upload";

    private bool _isDragging;
    private string _variantClass => Variant == FileUploadVariant.Button ? "flare-file-upload--button" : string.Empty;
    private readonly List<IBrowserFile> _files = [];
    private readonly string _inputId = $"flare-fu-{Guid.NewGuid():N}";

    private string _draggingClass => _isDragging ? "flare-file-upload--dragging" : string.Empty;
    private string _disabledClass => Disabled ? "flare-file-upload--disabled" : string.Empty;

    private async Task HandleChange(InputFileChangeEventArgs e)
    {
        _isDragging = false;
        _files.Clear();
        _files.AddRange(e.GetMultipleFiles(MaxFiles));
        await OnFilesChanged.InvokeAsync(_files.AsReadOnly());
    }

    private static string FormatSize(long bytes) => bytes switch
    {
        < 1024             => $"{bytes} B",
        < 1024 * 1024      => $"{bytes / 1024.0:F1} KB",
        _                  => $"{bytes / (1024.0 * 1024):F1} MB",
    };
}
