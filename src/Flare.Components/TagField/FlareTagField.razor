@namespace Flare.Components
@inherits FlareFieldBase
@implements IFlareMultiField<string>
@using System.Linq.Expressions
@using Microsoft.AspNetCore.Components.Forms

<div class="@BuildCssClass(_stateClass, _variantClass, _sizeClass)"
     style="@Style"
     @onclick="FocusInputAsync"
     @attributes="AdditionalAttributes">
    @if (!string.IsNullOrEmpty(Label))
    {
        <label class="@Css.Classes.Input.Label">@Label</label>
    }
    <div class="@Css.Classes.TagInput.Wrapper">
        <div class="@Css.Classes.Input.Field @Css.Classes.TagInput.Field">
            @foreach (var tag in _tags)
            {
                var t = tag;
                var chipStyle = ChipColor?.Invoke(t);
                <span class="@Css.Classes.TagInput.Chip" style="@chipStyle">
                    @t
                    @if (!Disabled && !ReadOnly)
                    {
                        <button type="button"
                                class="@Css.Classes.TagInput.Remove"
                                @onclick="@(() => RemoveTagAsync(t))"
                                @onclick:stopPropagation="true"
                                aria-label="@(FlareStrings.TagInput_Remove)"
                                tabindex="-1">x</button>
                    }
                </span>
            }
            @if (!Disabled && !ReadOnly && (MaxTags <= 0 || _tags.Count < MaxTags))
            {
                <input @ref="_inputRef"
                       class="@Css.Classes.Input.Control @Css.Classes.TagInput.Input"
                       style="@(Typo is { } _t ? FlareTypography.FontStyle(_t) : null)"
                       value="@_inputValue"
                       placeholder="@(_tags.Count == 0 ? Placeholder : null)"
                       disabled="@Disabled"
                       role="@(_hasSuggestionsApi ? "combobox" : null)"
                       aria-expanded="@(_hasSuggestionsApi ? _open.ToString().ToLowerInvariant() : null)"
                       aria-autocomplete="@(_hasSuggestionsApi ? "list" : null)"
                       aria-required="@(Required ? "true" : null)"
                       @oninput="HandleInputAsync"
                       @onfocus="HandleFocusAsync"
                       @onblur="HandleBlurAsync"
                       @onkeydown="HandleKeyDownAsync" />
            }
        </div>
        @if (_open && _hasSuggestionsApi)
        {
            <FlareListbox TItem="string"
                          Items="_options"
                          ItemLabel="@(s => s)"
                          ActiveIndex="_activeIdx"
                          OnSelect="SelectSuggestionAsync"
                          DropdownClass="@Css.Classes.Listbox.Dropdown"
                          PreventMouseDownDefault="true">
                <EmptyContent>
                    @if (!_loading)
                    {
                        <div class="@Css.Classes.TagInput.Empty" role="status">@(NoResultsText ?? FlareStrings.Field_NoResults)</div>
                    }
                </EmptyContent>
            </FlareListbox>
        }
    </div>
    @if (!string.IsNullOrEmpty(_displayedError))
    {
        <span class="@Css.Classes.Input.Helper @Css.Classes.Input.HelperError">@_displayedError</span>
    }
    else if (!string.IsNullOrEmpty(HelperText))
    {
        <span class="@Css.Classes.Input.Helper">@HelperText</span>
    }
</div>

@code {
    /// <summary>Current list of tags.</summary>
    [Parameter] public IReadOnlyList<string> Values { get; set; } = [];
    /// <summary>Callback invoked when the tag list changes.</summary>
    [Parameter] public EventCallback<IReadOnlyList<string>> ValuesChanged { get; set; }
    // Label, Placeholder, HelperText, ErrorText, Disabled, ReadOnly and Required are inherited from
    // FlareFieldBase (IFlareField). ReadOnly prevents adding/removing tags; Required marks the field
    // (at least one tag expected) via aria-required on the editing input.
    /// <summary>Allows adding duplicate tags when true.</summary>
    [Parameter] public bool AllowDuplicates { get; set; }
    /// <summary>Adds the current input as a tag when focus leaves.</summary>
    [Parameter] public bool AddOnBlur { get; set; } = true;
    /// <summary>Maximum number of tags allowed; 0 means unlimited.</summary>
    [Parameter] public int MaxTags { get; set; }
    /// <summary>Optional function that returns an inline CSS style string for each chip (e.g. background color). Receives the tag value.</summary>
    [Parameter] public Func<string, string?>? ChipColor { get; set; }
    /// <summary>Expression used to bind and validate the field.</summary>
    [Parameter] public Expression<Func<IReadOnlyList<string>>>? For { get; set; }
    /// <summary>Keyboard keys that commit the current input as a tag. Defaults to Enter, comma, and semicolon.</summary>
    [Parameter] public IReadOnlyList<string> Separators { get; set; } = DefaultSeparators;
    /// <summary>Static list of suggestions offered in a dropdown as the user types. Already-added tags are excluded.</summary>
    [Parameter] public IEnumerable<string>? Suggestions { get; set; }
    /// <summary>Async suggestion provider (server-side). Receives the current input; overrides <see cref="Suggestions"/> when set.</summary>
    [Parameter] public Func<string, Task<IEnumerable<string>>>? SearchFunc { get; set; }
    /// <summary>Maximum number of suggestions shown in the dropdown.</summary>
    [Parameter] public int MaxSuggestions { get; set; } = 8;
    /// <summary>Minimum characters typed before suggestions appear.</summary>
    [Parameter] public int MinChars { get; set; } = 1;
    /// <summary>Debounce in milliseconds before querying <see cref="SearchFunc"/>.</summary>
    [Parameter] public int DebounceMs { get; set; } = 200;
    /// <summary>Text shown in the dropdown when a query returns no suggestions. When null, falls back to the localized default.</summary>
    [Parameter] public string? NoResultsText { get; set; }

    protected override string ComponentCssClass => Css.Classes.TagInput.Root;

    /// <summary>Visual variant (Filled/Outlined) independent of the theme, shared with FlareField.
    /// Default keeps the theme's own field style.</summary>
    [Parameter] public InputVariant Variant { get; set; } = InputVariant.Default;
    private string? _variantClass => VariantClass(Variant);

    /// <summary>Control size (Xs..Xl), shared with FlareField. Medium is the default field height.</summary>
    [Parameter] public FieldSize Size { get; set; } = FieldSize.Md;
    /// <summary>Optional typography scale for the input text. Overrides the size-derived font; null keeps the default.</summary>
    [Parameter] public TypographyScale? Typo { get; set; }
    private string? _sizeClass => Size switch
    {
        FieldSize.Xs => Css.Classes.Input.SizeXs,
        FieldSize.Sm => Css.Classes.Input.SizeSm,
        FieldSize.Lg => Css.Classes.Input.SizeLg,
        FieldSize.Xl => Css.Classes.Input.SizeXl,
        _ => null,
    };

    private static readonly IReadOnlyList<string> DefaultSeparators = ["Enter", ",", ";"];

    private ElementReference _inputRef;
    private string _inputValue = string.Empty;
    private List<string> _tags = [];
    private IReadOnlyList<string>? _prevValues;

    // Suggestion dropdown state
    private bool _open;
    private bool _loading;
    private int _activeIdx = -1;
    private List<string> _options = [];
    private readonly CancelScope _searchCts = new();
    private bool _hasSuggestionsApi => Suggestions is not null || SearchFunc is not null;

    // Focus ring is pure :focus-within on the shared flare-input__field; error/disabled use the shared
    // flare-input--error / --disabled modifiers (same as every other field).
    private string _stateClass =>
        !string.IsNullOrEmpty(_displayedError) ? Css.Classes.Input.Error :
        Disabled ? Css.Classes.Input.Disabled : string.Empty;

    // EditContext subscription, the bound FieldIdentifier and the validation lookup are provided by
    // FlareFieldBase; here we only feed it the For accessor, sync the tag list and surface the error.
    protected override void OnParametersSet()
    {
        UpdateFieldIdentifier(For);

        if (!ReferenceEquals(Values, _prevValues))
        {
            _prevValues = Values;
            _tags = [.. Values];
        }
    }

    public override async ValueTask DisposeAsync()
    {
        _searchCts.Dispose();
        await base.DisposeAsync();
    }

    private string? _displayedError => DisplayedError(ErrorText);

    private async Task FocusInputAsync()
    {
        // The text input is only rendered when editable; clicking the field while Disabled/ReadOnly
        // must not try to focus a non-existent element (default ElementReference -> JS error).
        if (Disabled || ReadOnly) return;
        await _inputRef.FocusAsync();
    }

    private async Task AddTagAsync(string tag)
    {
        tag = tag.Trim();
        if (string.IsNullOrEmpty(tag)) return;
        if (MaxTags > 0 && _tags.Count >= MaxTags) return;
        if (!AllowDuplicates && _tags.Contains(tag, StringComparer.OrdinalIgnoreCase)) return;

        _tags.Add(tag);
        await ValuesChanged.InvokeAsync(_tags.AsReadOnly());
        NotifyFieldChanged();
    }

    private async Task RemoveTagAsync(string tag)
    {
        _tags.Remove(tag);
        await ValuesChanged.InvokeAsync(_tags.AsReadOnly());
        NotifyFieldChanged();
    }

    private async Task HandleKeyDownAsync(KeyboardEventArgs e)
    {
        // Dropdown navigation takes precedence when open.
        if (_open && _hasSuggestionsApi)
        {
            switch (e.Key)
            {
                case "ArrowDown":
                    _activeIdx = _options.Count == 0 ? -1 : Math.Min(_activeIdx + 1, _options.Count - 1);
                    return;
                case "ArrowUp":
                    _activeIdx = Math.Max(_activeIdx - 1, 0);
                    return;
                case "Escape":
                    _open = false;
                    _activeIdx = -1;
                    return;
                case "Enter" when _activeIdx >= 0 && _activeIdx < _options.Count:
                    await SelectSuggestionAsync(_options[_activeIdx]);
                    return;
            }
        }

        if (Separators.Contains(e.Key))
        {
            if (!string.IsNullOrWhiteSpace(_inputValue))
            {
                await AddTagAsync(_inputValue);
                _inputValue = string.Empty;
                CloseDropdown();
            }
        }
        else if (e.Key == "Backspace" && string.IsNullOrEmpty(_inputValue) && _tags.Count > 0)
        {
            await RemoveTagAsync(_tags[^1]);
        }
    }

    private async Task HandleBlurAsync(FocusEventArgs e)
    {
        // Let an option @onclick land before the dropdown closes.
        if (_hasSuggestionsApi) await Task.Delay(150);
        if (AddOnBlur && !string.IsNullOrWhiteSpace(_inputValue))
        {
            await AddTagAsync(_inputValue);
            _inputValue = string.Empty;
        }
        CloseDropdown();
        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleFocusAsync()
    {
        if (_hasSuggestionsApi) await RefreshOptionsAsync();
    }

    private async Task HandleInputAsync(ChangeEventArgs e)
    {
        _inputValue = e.Value?.ToString() ?? string.Empty;
        _activeIdx = -1;
        if (_hasSuggestionsApi) await RefreshOptionsAsync();
    }

    private async Task RefreshOptionsAsync()
    {
        var query = _inputValue?.Trim() ?? string.Empty;
        if (query.Length < MinChars)
        {
            CloseDropdown();
            return;
        }

        var token = _searchCts.Next();

        IEnumerable<string> results;
        if (SearchFunc is not null)
        {
            _loading = true;
            _open = true;
            StateHasChanged();
            try
            {
                if (DebounceMs > 0) await Task.Delay(DebounceMs, token);
                if (token.IsCancellationRequested) return;
                results = await SearchFunc(query);
            }
            catch (TaskCanceledException) { return; }
            finally { _loading = false; }
            if (token.IsCancellationRequested) return;
        }
        else
        {
            results = (Suggestions ?? Enumerable.Empty<string>())
                .Where(s => s.Contains(query, StringComparison.OrdinalIgnoreCase));
        }

        _options = results
            .Where(s => !_tags.Contains(s, StringComparer.OrdinalIgnoreCase))
            .Take(MaxSuggestions)
            .ToList();
        _open = true;
        StateHasChanged();
    }

    private async Task SelectSuggestionAsync(string suggestion)
    {
        await AddTagAsync(suggestion);
        _inputValue = string.Empty;
        CloseDropdown();
        await _inputRef.FocusAsync();
    }

    private void CloseDropdown()
    {
        _open = false;
        _activeIdx = -1;
        _options = [];
    }
}
