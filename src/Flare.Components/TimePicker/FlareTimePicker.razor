@namespace Flare.Components
@inherits FlareFieldBase
@implements IFlareField<TimeOnly?>
@using System
@using System.Globalization
@using System.Linq.Expressions
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@inject Flare.Components.Services.IOverlayJsService Overlay

@* Composes the shared FlareFieldChrome frame (root + label + helper/error). The time field owns its
   trigger well (input + clock toggle) and the anchored clock/dropdown popup, rendered in the Field slot. *@
<FlareFieldChrome ComponentClass="@Css.Classes.TimePicker.Root"
                  Variant="Variant" Size="Size"
                  Invalid="@_invalid"
                  Disabled="Disabled" ReadOnly="ReadOnly"
                  Label="@Label" LabelFor="@ControlId"
                  HelperText="@HelperText" HelperId="@HelperId"
                  ErrorText="@DisplayedErrorText" ErrorId="@ErrorId"
                  Style="@Style">
    <Field>
        <div class="@Css.Classes.Input.Field" @ref="_fieldEl">
            <input class="@Css.Classes.Input.Control"
                   id="@ControlId"
                   @ref="_inputEl"
                   style="@(Typo is { } _t ? FlareTypography.FontStyle(_t) : null)"
                   type="text"
                   inputmode="numeric"
                   maxlength="@(ShowSeconds ? 8 : 5)"
                   value="@_text"
                   placeholder="@(Placeholder ?? (ShowSeconds ? "HH:mm:ss" : "HH:mm"))"
                   disabled="@Disabled"
                   readonly="@ReadOnly"
                   required="@Required"
                   aria-required="@(Required ? "true" : null)"
                   aria-label="@(Label ?? FlareStrings.TimePicker_FieldLabel)"
                   aria-invalid="@(_invalid ? "true" : null)"
                   aria-describedby="@SupportDescribedBy"
                   @oninput="HandleInput"
                   @onchange="HandleCommitText"
                   @attributes="AdditionalAttributes" />
            <button type="button" class="@Css.Classes.Input.Toggle flare-input__icon flare-input__icon--trailing"
                    disabled="@(Disabled || ReadOnly)" aria-haspopup="dialog" aria-expanded="@_open"
                    aria-label="@FlareStrings.TimePicker_Open" @onclick="Toggle">
                <FlareIcon Name="schedule" Style="font-size:1.25rem;" />
            </button>
        </div>

        @if (_open)
        {
        <div class="@Css.Classes.Picker.Scrim" @onclick="Close" aria-hidden="true"></div>
        <div class="@($"{Css.Classes.Picker.Panel} {Css.Classes.TimePicker.Panel} {Css.Classes.TimePicker.Panel}--{PopupVariant.ToString().ToLowerInvariant()}")"
             @ref="_panelEl" role="dialog" aria-modal="true" aria-label="@_headline">
            <div class="@Css.Classes.TimePicker.PanelHeadline">@_headline</div>

            @if (PopupVariant == TimePickerVariant.Dial)
            {
                <FlareClockDial Hour="_tempHour" HourChanged="h => _tempHour = h"
                                Minute="_tempMinute" MinuteChanged="m => _tempMinute = m"
                                Is24Hour="_is24Hour" />
            }
            else
            {
                <div class="@Css.Classes.TimePicker.Display" aria-hidden="true">
                    <span class="@Css.Classes.TimePicker.DisplayPart @(_dropActive == 0 ? Css.Classes.TimePicker.DisplayPartActive : "")">@_tempHour.ToString("00")</span>
                    <span class="@Css.Classes.TimePicker.DisplaySep">:</span>
                    <span class="@Css.Classes.TimePicker.DisplayPart @(_dropActive == 1 ? Css.Classes.TimePicker.DisplayPartActive : "")">@_tempMinute.ToString("00")</span>
                    @if (ShowSeconds)
                    {
                        <span class="@Css.Classes.TimePicker.DisplaySep">:</span>
                        <span class="@Css.Classes.TimePicker.DisplayPart @(_dropActive == 2 ? Css.Classes.TimePicker.DisplayPartActive : "")">@_tempSecond.ToString("00")</span>
                    }
                </div>
                <div class="@Css.Classes.TimePicker.Columns" tabindex="0" @ref="_dropRef" @onkeydown="OnDropKey">
                    <div class="@Css.Classes.TimePicker.Col" role="listbox" aria-label="@FlareStrings.TimePicker_Hours">
                        @for (var h = 0; h < 24; h += _hourStep)
                        {
                            var hour = h;
                            <button type="button"
                                    class="@Css.Classes.TimePicker.Cell @(hour == _tempHour ? Css.Classes.TimePicker.CellSelected : "")"
                                    role="option" aria-selected="@(hour == _tempHour)" disabled="@HourDisabled(hour)"
                                    @onclick="@(() => _tempHour = hour)">@hour.ToString("00")</button>
                        }
                    </div>
                    <div class="@Css.Classes.TimePicker.ColumnsSep">:</div>
                    <div class="@Css.Classes.TimePicker.Col" role="listbox" aria-label="@FlareStrings.TimePicker_Minutes">
                        @for (var m = 0; m < 60; m += MinuteStep)
                        {
                            var min = m;
                            <button type="button"
                                    class="@Css.Classes.TimePicker.Cell @(min == _tempMinute ? Css.Classes.TimePicker.CellSelected : "")"
                                    role="option" aria-selected="@(min == _tempMinute)" disabled="@MinuteDisabled(min)"
                                    @onclick="@(() => SelectMinute(min))">@min.ToString("00")</button>
                        }
                    </div>
                    @if (ShowSeconds)
                    {
                        <div class="@Css.Classes.TimePicker.ColumnsSep">:</div>
                        <div class="@Css.Classes.TimePicker.Col" role="listbox" aria-label="@FlareStrings.TimePicker_Seconds">
                            @for (var s = 0; s < 60; s++)
                            {
                                var sec = s;
                                <button type="button"
                                        class="@Css.Classes.TimePicker.Cell @(sec == _tempSecond ? Css.Classes.TimePicker.CellSelected : "")"
                                        role="option" aria-selected="@(sec == _tempSecond)" disabled="@SecondDisabled(sec)"
                                        @onclick="@(() => SelectSecond(sec))">@sec.ToString("00")</button>
                            }
                        </div>
                    }
                </div>
            }

            <div class="@Css.Classes.TimePicker.Actions">
                <FlareButton Variant="ButtonVariant.Text" Size="ButtonSize.Sm" OnClick="Close">@(CancelText ?? FlareStrings.Picker_Cancel)</FlareButton>
                <FlareButton Variant="ButtonVariant.Text" Size="ButtonSize.Sm" OnClick="Confirm">@(OkText ?? FlareStrings.Picker_Ok)</FlareButton>
            </div>
        </div>
        }
    </Field>
</FlareFieldChrome>

@code {
    /// <summary>Currently selected time.</summary>
    [Parameter] public TimeOnly? Value { get; set; }
    /// <summary>Callback invoked when the selected time changes.</summary>
    [Parameter] public EventCallback<TimeOnly?> ValueChanged { get; set; }
    // Label, Placeholder, HelperText, ErrorText, Disabled, ReadOnly and Required are inherited from
    // FlareFieldBase (IFlareField). ReadOnly keeps the trigger focusable but blocks typing and the popup.
    /// <summary>Popup style: an analog clock <see cref="TimePickerVariant.Dial"/> (default) or <see cref="TimePickerVariant.Dropdown"/> columns.</summary>
    [Parameter] public TimePickerVariant PopupVariant { get; set; } = TimePickerVariant.Dial;
    /// <summary>Forces 12-hour (AM/PM) or 24-hour clock. Null (default) auto-detects from the current culture.</summary>
    [Parameter] public bool? Use24Hour { get; set; }
    /// <summary>Minute increment shown in the Dropdown column. Default 1.</summary>
    [Parameter] public int MinuteStep { get; set; } = 1;
    /// <summary>Headline shown at the top of the picker popup. When null, falls back to the localized default.</summary>
    [Parameter] public string? Headline { get; set; }
    /// <summary>Confirm button text. When null, falls back to the localized "OK".</summary>
    [Parameter] public string? OkText { get; set; }
    /// <summary>Cancel button text. When null, falls back to the localized "Cancel".</summary>
    [Parameter] public string? CancelText { get; set; }
    /// <summary>Expression used to bind and validate the field.</summary>
    [Parameter] public Expression<Func<TimeOnly?>>? For { get; set; }
    /// <summary>Adds a seconds column (Dropdown variant) and HH:mm:ss text entry. Default false.</summary>
    [Parameter] public bool ShowSeconds { get; set; }
    /// <summary>Hour increment shown in the Dropdown column. Default 1.</summary>
    [Parameter] public int HourStep { get; set; } = 1;
    /// <summary>Earliest selectable time (inclusive); out-of-range cells are disabled.</summary>
    [Parameter] public TimeOnly? Min { get; set; }
    /// <summary>Latest selectable time (inclusive); out-of-range cells are disabled.</summary>
    [Parameter] public TimeOnly? Max { get; set; }
    /// <summary>Confirms and closes as soon as the last time unit is selected (no OK press). Default false.</summary>
    [Parameter] public bool AutoClose { get; set; }
    /// <summary>Raised when the picker popup opens.</summary>
    [Parameter] public EventCallback Opened { get; set; }
    /// <summary>Raised when the picker popup closes.</summary>
    [Parameter] public EventCallback Closed { get; set; }

    protected override string ComponentCssClass => Css.Classes.TimePicker.Root;

    private bool _open;
    private int _tempHour;
    private int _tempMinute;
    private int _tempSecond;
    private string _text = string.Empty;
    private TimeOnly? _syncedValue;
    private bool _is24Hour;

    private ElementReference _inputEl;
    private ElementReference _fieldEl;

    private int _hourStep => HourStep < 1 ? 1 : HourStep;
    private string _timeFormat => ShowSeconds ? "HH:mm:ss" : "HH:mm";

    /// <summary>Opens the picker popup.</summary>
    public Task OpenAsync() { if (!_open) return Toggle(); return Task.CompletedTask; }
    /// <summary>Closes the picker popup.</summary>
    public Task CloseAsync() => Close();
    /// <summary>Toggles the picker popup.</summary>
    public Task ToggleAsync() => Toggle();
    /// <summary>Clears the selected time.</summary>
    public async Task ClearAsync() { await Commit(null); await Close(); }
    /// <summary>Sets keyboard focus to the time input.</summary>
    public ValueTask FocusAsync() => _inputEl.FocusAsync();

    private bool TimeInRange(TimeOnly t) => (!Min.HasValue || t >= Min.Value) && (!Max.HasValue || t <= Max.Value);
    private bool HourDisabled(int h) => (Min.HasValue && new TimeOnly(h, 59, 59) < Min.Value) || (Max.HasValue && new TimeOnly(h, 0, 0) > Max.Value);
    private bool MinuteDisabled(int m) => (Min.HasValue && new TimeOnly(_tempHour, m, 59) < Min.Value) || (Max.HasValue && new TimeOnly(_tempHour, m, 0) > Max.Value);
    private bool SecondDisabled(int s) => !TimeInRange(new TimeOnly(_tempHour, _tempMinute, s));

    private async Task SelectMinute(int m)
    {
        _tempMinute = m;
        if (AutoClose && !ShowSeconds) await Confirm();
    }

    private async Task SelectSecond(int s)
    {
        _tempSecond = s;
        if (AutoClose) await Confirm();
    }
    private ElementReference _panelEl;
    private bool _panelPositioned;
    private readonly string _panelId = $"flare-timepicker-{Guid.NewGuid():N}";

    protected override void OnParametersSet()
    {
        if (MinuteStep < 1) MinuteStep = 1;
        _is24Hour = Use24Hour ?? !CultureInfo.CurrentUICulture.DateTimeFormat.ShortTimePattern.Contains('h');
        UpdateFieldIdentifier(For);

        if (!Equals(Value, _syncedValue))
        {
            _syncedValue = Value;
            _text = Value?.ToString(_timeFormat) ?? string.Empty;
        }
    }

    public override async ValueTask DisposeAsync()
    {
        try { await Overlay.RemoveAnchoredPanelAsync(_panelId); }
        catch (JSDisconnectedException) { }
        await base.DisposeAsync();
    }

    private string _headline => Headline ?? FlareStrings.TimePicker_Headline;

    // Invalid drives the frame's error chrome (a resolved validation message).
    private bool _invalid => !string.IsNullOrEmpty(DisplayedErrorText);

    private async Task HandleInput(ChangeEventArgs e)
    {
        _text = MaskTime(e.Value?.ToString());
        if (_text.Length == (ShowSeconds ? 8 : 5) && TimeOnly.TryParseExact(_text, _timeFormat, CultureInfo.InvariantCulture, DateTimeStyles.None, out var t))
            await Commit(t);
    }

    private async Task HandleCommitText(ChangeEventArgs e)
    {
        _text = MaskTime(e.Value?.ToString());
        if (string.IsNullOrEmpty(_text)) { await Commit(null); return; }
        if (TimeOnly.TryParseExact(_text, _timeFormat, CultureInfo.InvariantCulture, DateTimeStyles.None, out var t) ||
            TimeOnly.TryParse(_text, CultureInfo.CurrentUICulture, DateTimeStyles.None, out t))
        {
            _text = t.ToString(_timeFormat);
            await Commit(t);
        }
    }

    private string MaskTime(string? raw)
    {
        if (string.IsNullOrEmpty(raw)) return string.Empty;
        var digits = new string(raw.Where(char.IsDigit).Take(ShowSeconds ? 6 : 4).ToArray());
        if (digits.Length <= 2) return digits;
        var hh = digits[..2];
        if (int.TryParse(hh, out var h) && h > 23) hh = "23";
        var mm = digits.Length <= 4 ? digits[2..] : digits[2..4];
        if (mm.Length == 2 && int.TryParse(mm, out var m) && m > 59) mm = "59";
        if (digits.Length <= 4) return $"{hh}:{mm}";
        var ss = digits[4..];
        if (ss.Length == 2 && int.TryParse(ss, out var s) && s > 59) ss = "59";
        return $"{hh}:{mm}:{ss}";
    }

    private ElementReference _dropRef;
    private int _dropActive;   // 0 = hour, 1 = minute (Dropdown keyboard)
    private string _dropBuf = string.Empty;
    private bool _focusDrop;

    private async Task Toggle()
    {
        if (Disabled || ReadOnly) return;
        if (!_open)
        {
            _tempHour = Value?.Hour ?? 0;
            _tempMinute = Value?.Minute ?? 0;
            _tempSecond = Value?.Second ?? 0;
            ClampTemp();
            _dropActive = 0;
            _dropBuf = string.Empty;
            _focusDrop = PopupVariant == TimePickerVariant.Dropdown;
            _open = true;
            await Opened.InvokeAsync();
        }
        else
        {
            _open = false;
            await Closed.InvokeAsync();
        }
        StateHasChanged();
    }

    private void ClampTemp()
    {
        var t = new TimeOnly(_tempHour, _tempMinute, _tempSecond);
        var clamp = Min.HasValue && t < Min.Value ? Min.Value
                  : Max.HasValue && t > Max.Value ? Max.Value
                  : (TimeOnly?)null;
        if (clamp is { } c) { _tempHour = c.Hour; _tempMinute = c.Minute; _tempSecond = c.Second; }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Fixed-position the popup under the field on open (clean up on close) so it escapes a Card's
        // overflow:hidden. The scrim handles dismissal, so no document listener is needed here.
        if (_open != _panelPositioned)
        {
            try
            {
                if (_open)
                    await Overlay.PositionAnchoredPanelAsync(_panelId, _fieldEl, _panelEl);
                else
                    await Overlay.RemoveAnchoredPanelAsync(_panelId);
                _panelPositioned = _open;
            }
            catch (JSDisconnectedException) { }
        }

        if (_focusDrop)
        {
            _focusDrop = false;
            try { await _dropRef.FocusAsync(); } catch { /* best-effort */ }
        }
    }

    private void OnDropKey(KeyboardEventArgs e)
    {
        var key = e.Key;
        if (key.Length == 1 && key[0] >= '0' && key[0] <= '9')
        {
            if (_dropActive == 0)
            {
                var (v, buf, complete) = TimeKeyboardEntry.Feed(_dropBuf, key[0], 23);
                _dropBuf = buf; _tempHour = v;
                if (complete) { _dropActive = 1; _dropBuf = string.Empty; }
            }
            else
            {
                var (v, buf, complete) = TimeKeyboardEntry.Feed(_dropBuf, key[0], 59);
                _dropBuf = buf; _tempMinute = v;
                if (complete) _dropBuf = string.Empty;
            }
        }
        else if (key == "ArrowLeft") { _dropActive = 0; _dropBuf = string.Empty; }
        else if (key == "ArrowRight") { _dropActive = 1; _dropBuf = string.Empty; }
        else if (key == "Backspace") { _dropBuf = string.Empty; }
    }

    private async Task Close()
    {
        if (!_open) return;
        _open = false;
        await Closed.InvokeAsync();
        StateHasChanged();
    }

    private async Task Confirm()
    {
        _open = false;
        await Closed.InvokeAsync();
        await Commit(new TimeOnly(_tempHour, _tempMinute, ShowSeconds ? _tempSecond : 0));
    }

    private async Task Commit(TimeOnly? value)
    {
        _syncedValue = value;
        _text = value?.ToString(_timeFormat) ?? string.Empty;
        await ValueChanged.InvokeAsync(value);
        NotifyFieldChanged();
    }
}
