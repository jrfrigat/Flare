@namespace Flare.Components
@inherits FlareZoneBase

@* A colored region on a SCALE host - FlareSlider or FlareProgress, whose scale is owned by the host
   (Min..Max, or 0-100). A zone is an absolute [Start, End] range: thresholds read naturally as boundaries
   ("danger starts at 90") and each zone is independent of the others. Registers itself with the host and
   renders no DOM of its own - the host draws the band on the inactive track, under the active fill.
   For a part-to-whole breakdown, where the parts themselves define the scale, use <FlareMeterSegment>. *@

@code {
    /// <summary>Start of the range on the host's scale. The <see cref="Start"/>/<see cref="End"/> pair is
    /// ordered, so Start may exceed End. A missing bound collapses the zone, which is then dropped.</summary>
    [Parameter] public double? Start { get; set; }
    /// <summary>End of the range on the host's scale.</summary>
    [Parameter] public double? End { get; set; }

    /// <inheritdoc />
    protected override object Signature => (Start, End, Color);
}
