@namespace Flare.Components
@inherits FlareComponentBase

<div class="@BuildCssClass(Required ? Css.Classes.Input.Required : null)" style="@Style" @attributes="AdditionalAttributes">
    @if (!string.IsNullOrEmpty(Label))
    {
        <label class="@Css.Classes.Input.Label" for="@For">@Label</label>
    }
    <div class="@Css.Classes.Input.ControlSlot">
        @ChildContent
    </div>
    @if (!string.IsNullOrEmpty(HelperText))
    {
        <span class="@Css.Classes.Input.Helper">@HelperText</span>
    }
</div>

@code {
    /// <summary>Label text shown above the field control.</summary>
    [Parameter] public string? Label { get; set; }
    /// <summary>ID of the input element this label targets (HTML for attribute).</summary>
    [Parameter] public string? For { get; set; }
    /// <summary>Helper text shown below the field control.</summary>
    [Parameter] public string? HelperText { get; set; }
    /// <summary>Marks the field as required, adding a visual indicator.</summary>
    [Parameter] public bool Required { get; set; }
    /// <summary>Field content (input, select, etc.).</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    // The form-field wrapper reuses the shared flare-input root (label + control slot + helper stack);
    // the required-asterisk (flare-input--required) and the control slot are shared input-family classes.
    protected override string ComponentCssClass => Css.Classes.Input.Root;
}
