@namespace Flare.Components
@inherits FlareComponentBase
@inject IBrowserViewportService Viewport
@implements IAsyncDisposable

@if (ChildContent is not null)
{
    <CascadingValue Value="_current" IsFixed="false">
        @ChildContent(_current)
    </CascadingValue>
}

@code {
    /// <summary>
    /// Content rendered with the current <see cref="Breakpoint"/> as context, e.g.
    /// <c>&lt;FlareMediaQuery Context="bp"&gt;@if (bp &lt;= Breakpoint.Sm) { ... }&lt;/FlareMediaQuery&gt;</c>.
    /// The breakpoint is also supplied to descendants as a cascading value.
    /// </summary>
    [Parameter] public RenderFragment<Breakpoint>? ChildContent { get; set; }

    /// <summary>Raised whenever the active breakpoint changes.</summary>
    [Parameter] public EventCallback<Breakpoint> OnChanged { get; set; }

    /// <summary>The breakpoint assumed during prerender / before the first JS measurement. Default Md.</summary>
    [Parameter] public Breakpoint InitialBreakpoint { get; set; } = Breakpoint.Md;

    /// <summary>The currently active breakpoint.</summary>
    public Breakpoint Current => _current;

    protected override string ComponentCssClass => Css.Classes.MediaQuery.Root;

    private Breakpoint _current;
    private IAsyncDisposable? _subscription;

    protected override void OnInitialized() => _current = InitialBreakpoint;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try
        {
            // One call: the service delivers the current breakpoint immediately and on every change.
            _subscription = await Viewport.SubscribeBreakpointAsync(OnBreakpointAsync);
        }
        catch (InvalidOperationException) { /* prerender */ }
        catch (JSDisconnectedException) { }
    }

    private async Task OnBreakpointAsync(Breakpoint bp)
    {
        if (bp == _current) return;
        _current = bp;
        await OnChanged.InvokeAsync(_current);
        await InvokeAsync(StateHasChanged);
    }

    public override async ValueTask DisposeAsync()
    {
        if (_subscription is not null)
        {
            try { await _subscription.DisposeAsync(); }
            catch (InvalidOperationException) { }
            catch (JSDisconnectedException) { }
        }
        await base.DisposeAsync();
    }
}
