@namespace Flare.Components
@implements IAsyncDisposable
@inherits FlareComponentBase
@inject IJSRuntime JS
@inject NavigationManager Nav

<CascadingValue Value="_ctx" IsFixed="false">
    <div class="@BuildCssClass(_drawerClass, _miniRailClass)" style="@Style" @attributes="AdditionalAttributes">
        @AppBar
        @if (ChildContent is not null)
        {
            @ChildContent
        }
        else
        {
            <div class="@Css.Classes.Layout.Body">
                @Drawer
                <main class="@Css.Classes.Layout.Main @ContentClass" style="@ContentStyle">
                    <div class="@Css.Classes.Layout.ContentFrame @_contentMaxWidthClass @_contentAlignClass">
                        @Content
                    </div>
                </main>
            </div>
        }

        @* Mobile-only scrim: dims the content and closes the off-canvas drawer on tap.
           Hidden on desktop and when the drawer is closed (CSS), so it never blocks clicks there. *@
        <div class="@Css.Classes.Layout.Scrim" @onclick="CloseDrawer" aria-hidden="true"></div>
    </div>
</CascadingValue>

@code {
    /// <summary>App bar slot (slot-based API).</summary>
    [Parameter] public RenderFragment? AppBar { get; set; }
    /// <summary>Drawer slot (slot-based API).</summary>
    [Parameter] public RenderFragment? Drawer { get; set; }
    /// <summary>Main content slot (slot-based API).</summary>
    [Parameter] public RenderFragment? Content { get; set; }
    /// <summary>Extra CSS class for the main content element (slot-based API), e.g. for a max-width frame.</summary>
    [Parameter] public string? ContentClass { get; set; }
    /// <summary>Inline style for the main content element (slot-based API).</summary>
    [Parameter] public string? ContentStyle { get; set; }
    /// <summary>
    /// Optional readable-width cap for the content (slot-based API); the content is centered
    /// horizontally while the scrollbar stays at the window edge. Defaults to
    /// <see cref="ContainerMaxWidth.Full"/> (no constraint -- full width with padding).
    /// </summary>
    [Parameter] public ContainerMaxWidth ContentMaxWidth { get; set; } = ContainerMaxWidth.Full;
    /// <summary>
    /// Horizontal placement of the content within the main area when <see cref="ContentMaxWidth"/>
    /// caps it (slot-based API). Defaults to <see cref="LayoutContentAlignment.Center"/>.
    /// </summary>
    [Parameter] public LayoutContentAlignment ContentAlignment { get; set; } = LayoutContentAlignment.Center;
    /// <summary>Free-form children (component-based API: FlareLayoutAppBar + FlareLayoutDrawer + FlareLayoutContent).</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }
    /// <summary>Initial drawer open state. Supports @bind-DrawerOpen.</summary>
    [Parameter] public bool DrawerOpen { get; set; } = true;
    /// <summary>Callback fired when the drawer state changes.</summary>
    [Parameter] public EventCallback<bool> DrawerOpenChanged { get; set; }
    /// <summary>
    /// When true (default) the layout is responsive: below the medium breakpoint (960px) the
    /// drawer becomes an off-canvas overlay, starts closed, and closes on navigation; above it
    /// the drawer is a permanent sidebar. Set false to manage the drawer entirely yourself.
    /// </summary>
    [Parameter] public bool Responsive { get; set; } = true;
    /// <summary>
    /// When true, collapsing the drawer on desktop leaves a narrow icon rail
    /// (<c>--flare-drawer-mini-width</c>) instead of hiding it entirely; the toggle switches
    /// between the rail and the full-width drawer. Has no effect on mobile, where the drawer is
    /// always a full off-canvas overlay.
    /// </summary>
    [Parameter] public bool MiniRail { get; set; }

    protected override string ComponentCssClass => Css.Classes.Layout.Root;
    private string _drawerClass => _ctx.DrawerOpen ? Css.Classes.Layout.DrawerOpen : string.Empty;
    private string _miniRailClass => MiniRail ? Css.Classes.Layout.MiniRail : string.Empty;
    private string _contentMaxWidthClass => LayoutContentWidth.ToClass(ContentMaxWidth);
    private string _contentAlignClass => LayoutContentWidth.ToAlignClass(ContentAlignment);

    private readonly FlareLayoutContext _ctx = new();
    private readonly string _id = Guid.NewGuid().ToString("N");
    private IJSObjectReference? _module;
    private DotNetObjectReference<FlareLayout>? _dotNetRef;
    private bool _isMobile;

    protected override void OnInitialized()
    {
        _ctx.DrawerOpen = DrawerOpen;
        _ctx.MiniRail = MiniRail;
        _ctx.StateChanged += OnContextStateChanged;
        Nav.LocationChanged += OnLocationChanged;
    }

    protected override void OnParametersSet()
    {
        if (_ctx.DrawerOpen != DrawerOpen)
            _ctx.DrawerOpen = DrawerOpen;
        _ctx.MiniRail = MiniRail;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || !Responsive) return;
        try
        {
            _module = await JS.InvokeAsync<IJSObjectReference>(
                "import", "./_content/Flare.Components/js/flare-ui.js");
            _dotNetRef = DotNetObjectReference.Create(this);

            var bp = await _module.InvokeAsync<string>("getBreakpoint");
            _isMobile = IsMobile(bp);
            if (_isMobile && _ctx.DrawerOpen)
                _ctx.DrawerOpen = false; // don't cover content on small screens

            await _module.InvokeVoidAsync("subscribeBreakpoint", _id, _dotNetRef);
        }
        catch (InvalidOperationException) { }
        catch (JSDisconnectedException) { }
    }

    [JSInvokable]
    public Task OnBreakpointChanged(string breakpoint)
    {
        var mobile = IsMobile(breakpoint);
        if (mobile != _isMobile)
        {
            _isMobile = mobile;
            _ctx.DrawerOpen = !mobile; // closed on mobile, open (permanent) on desktop
            StateHasChanged();
        }
        return Task.CompletedTask;
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        if (Responsive && _isMobile && _ctx.DrawerOpen)
            InvokeAsync(() => { _ctx.DrawerOpen = false; StateHasChanged(); });
    }

    private static bool IsMobile(string breakpoint) => breakpoint is "Xs" or "Sm";

    private void OnContextStateChanged()
    {
        _ = DrawerOpenChanged.InvokeAsync(_ctx.DrawerOpen);
        StateHasChanged();
    }

    private void CloseDrawer() => _ctx.DrawerOpen = false;

    public override async ValueTask DisposeAsync()
    {
        _ctx.StateChanged -= OnContextStateChanged;
        Nav.LocationChanged -= OnLocationChanged;
        if (_module is not null)
        {
            try { await _module.InvokeVoidAsync("unsubscribeBreakpoint", _id); } catch { }
            await _module.DisposeAsync();
        }
        _dotNetRef?.Dispose();
        await base.DisposeAsync();
    }
}
