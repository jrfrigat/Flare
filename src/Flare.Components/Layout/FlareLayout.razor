@namespace Flare.Components
@implements IAsyncDisposable
@inherits FlareComponentBase
@inject Flare.Components.Services.IUiJsService Ui
@inject NavigationManager Nav

@* Application shell. Compose it from a FlareLayoutAppBar, one or more FlareLayoutDrawer (each owning
   its own @bind-Open), and a FlareLayoutContent. The layout reserves a grid track for every in-flow
   drawer so the content is pushed aside rather than covered. *@
<CascadingValue Value="_ctx" IsFixed="true">
    <div class="@BuildCssClass(_mobileClass, _scrimClass)"
         style="--flare-layout-cols:@_ctx.GridTemplateColumns;@Style"
         @attributes="AdditionalAttributes">
        @ChildContent
        @* Scrim: dims the content and closes any floating drawer on tap. Hidden by CSS unless a
           drawer is currently a floating overlay, so it never blocks clicks otherwise. *@
        <div class="@Css.Classes.Layout.Scrim" @onclick="OnScrimClickAsync" aria-hidden="true"></div>
    </div>
</CascadingValue>

@code {
    /// <summary>
    /// The composed layout: a <see cref="FlareLayoutAppBar"/>, one or more <see cref="FlareLayoutDrawer"/>,
    /// and a <see cref="FlareLayoutContent"/>. Place start drawers before the content and end drawers
    /// after it (markup order = visual order).
    /// </summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// When true (default) the layout watches the viewport and turns push drawers into off-canvas
    /// overlays below the mobile breakpoint (960px); set false to manage drawers entirely yourself.
    /// </summary>
    [Parameter] public bool Responsive { get; set; } = true;

    protected override string ComponentCssClass => Css.Classes.Layout.Root;
    private string _mobileClass => _isMobile ? Css.Classes.Layout.Mobile : string.Empty;
    private string _scrimClass => _ctx.AnyOverlayOpen ? Css.Classes.Layout.ScrimOpen : string.Empty;

    private readonly FlareLayoutContext _ctx = new();
    private readonly string _id = Guid.NewGuid().ToString("N");
    private DotNetObjectReference<FlareLayout>? _dotNetRef;
    private bool _isMobile;

    protected override void OnInitialized()
    {
        _ctx.StateChanged += OnContextStateChanged;
        Nav.LocationChanged += OnLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || !Responsive) return;
        try
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            var bp = await Ui.GetBreakpointAsync();
            await SetMobileAsync(IsMobile(bp));
            await Ui.SubscribeBreakpointAsync(_id, _dotNetRef);
        }
        catch (InvalidOperationException) { }
        catch (JSDisconnectedException) { }
    }

    [JSInvokable]
    public Task OnBreakpointChanged(string breakpoint) => InvokeAsync(() => SetMobileAsync(IsMobile(breakpoint)));

    private async Task SetMobileAsync(bool mobile)
    {
        var changed = _isMobile != mobile;
        _isMobile = mobile;
        _ctx.IsMobile = mobile; // raises StateChanged when it actually changes
        if (changed) StateHasChanged();
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        // On mobile, navigating away closes any floating drawer so it does not linger over the new page.
        if (Responsive && _isMobile && _ctx.AnyOverlayOpen)
            InvokeAsync(async () => { await _ctx.CloseOverlaysAsync(); StateHasChanged(); });
    }

    private static bool IsMobile(string breakpoint) => breakpoint is "Xs" or "Sm";

    private void OnContextStateChanged() => InvokeAsync(StateHasChanged);

    private async Task OnScrimClickAsync()
    {
        await _ctx.CloseOverlaysAsync();
        StateHasChanged();
    }

    public override async ValueTask DisposeAsync()
    {
        _ctx.StateChanged -= OnContextStateChanged;
        Nav.LocationChanged -= OnLocationChanged;
        try { await Ui.UnsubscribeBreakpointAsync(_id); } catch { }
        _dotNetRef?.Dispose();
        await base.DisposeAsync();
    }
}
