@namespace Flare.Components
@inherits FlareComponentBase

<header class="@BuildCssClass(_denseClass)" style="@_style" @attributes="AdditionalAttributes">
    @if (DrawerToggle)
    {
        <button class="@Css.Classes.Layout.AppBarToggle @(_isOpen ? Css.Classes.Layout.AppbarToggleOpen : null)"
                @onclick="ToggleDrawer"
                aria-label="@(FlareStrings.Aria_ToggleDrawer)"
                aria-expanded="@(_isOpen ? "true" : "false")"
                type="button">
            <span class="@Css.Classes.Burger.Root" aria-hidden="true">
                <span class="@Css.Classes.Burger.Bar"></span>
                <span class="@Css.Classes.Burger.Bar"></span>
                <span class="@Css.Classes.Burger.Bar"></span>
            </span>
        </button>
    }
    @MenuButton
    @ChildContent
</header>

@code {
    [CascadingParameter] private FlareLayoutContext? Layout { get; set; }

    /// <summary>Child content rendered in the app bar.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }
    /// <summary>Custom menu/hamburger button at the leading edge (slot-based API).</summary>
    [Parameter] public RenderFragment? MenuButton { get; set; }
    /// <summary>When true, renders a hamburger that toggles the layout's primary drawer (the first
    /// non-overlay start drawer) via the cascading <see cref="FlareLayoutContext"/>.</summary>
    [Parameter] public bool DrawerToggle { get; set; }
    /// <summary>An explicit app bar height (any CSS length, e.g. <c>"50px"</c> or <c>"3.5rem"</c>). Overrides
    /// the default 64px and the <see cref="Dense"/> preset. Sets the <c>--flare-layout-appbar-height</c> token.</summary>
    [Parameter] public string? Height { get; set; }
    /// <summary>Renders a slimmer app bar (the <c>--flare-layout-appbar-height-dense</c> token, 3rem by
    /// default) - a common request for tool-window / IDE-style shells. Ignored when <see cref="Height"/> is set.</summary>
    [Parameter] public bool Dense { get; set; }

    protected override string ComponentCssClass => Css.Classes.Layout.AppBar;

    private bool _isOpen => Layout?.PrimaryOpen ?? false;

    private string? _denseClass => Dense ? Css.Classes.Layout.AppBarDense : null;

    // An explicit Height sets the height token inline (authoritative over the Dense class and the default),
    // sanitized before injection. Merged with any caller Style.
    private string? _style
    {
        get
        {
            if (string.IsNullOrEmpty(Height)) return Style;
            var safe = Flare.Components.Security.CssValidator.StripDangerous(Height);
            var heightVar = string.IsNullOrEmpty(safe) ? null : $"{Css.Tokens.LayoutField.AppBarHeight}:{safe}";
            return string.Join(';', new[] { Style, heightVar }.Where(s => !string.IsNullOrEmpty(s)));
        }
    }

    private Task ToggleDrawer() => Layout?.TogglePrimaryAsync() ?? Task.CompletedTask;
}
