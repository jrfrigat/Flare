@namespace Flare.Components
@inherits FlareComponentBase
@inject ICollisionService CollisionService
@inject Flare.Components.Services.IOverlayJsService Overlay
@implements IAsyncDisposable

<div class="@BuildCssClass()" style="@Style" @attributes="AdditionalAttributes"
     @onmouseenter="HandleMouseEnter" @onmouseleave="HandleMouseLeave">
    @if (Trigger == PopoverTrigger.Click)
    {
        <span style="display:inline-flex;cursor:pointer" @onclick="ToggleAsync">@AnchorContent</span>
    }
    else
    {
        @AnchorContent
    }
    @if (Open)
    {
        @if (Trigger != PopoverTrigger.Hover)
        {
            <div class="@Css.Classes.Popover.Backdrop" @onclick="CloseAsync" aria-hidden="true"></div>
        }
        <div @ref="_floatingRef"
             class="@Css.Classes.Popover.Paper @_placementClass @_arrowClass @_matchWidthClass"
             style="@_paperStyle">
            <CascadingValue Value="@((Func<Task>)CloseAsync)" Name="ClosePopover">
                @ChildContent
            </CascadingValue>
        </div>
    }
</div>

@code {
    /// <summary>Content rendered inside the popover panel.</summary>
    [Parameter] public RenderFragment?      ChildContent  { get; set; }
    /// <summary>The anchor element that the popover is attached to.</summary>
    [Parameter] public RenderFragment?      AnchorContent { get; set; }
    /// <summary>Controls whether the popover panel is visible.</summary>
    [Parameter] public bool                 Open          { get; set; }
    /// <summary>Callback raised when the open state should change.</summary>
    [Parameter] public EventCallback<bool>  OpenChanged   { get; set; }
    /// <summary>How the popover opens. <see cref="PopoverTrigger.Click"/> toggles it from the anchor,
    /// <see cref="PopoverTrigger.Hover"/> opens on hover, and <see cref="PopoverTrigger.Manual"/> (default)
    /// leaves it fully controlled. All modes still drive <see cref="Open"/>/<see cref="OpenChanged"/>.</summary>
    [Parameter] public PopoverTrigger       Trigger       { get; set; } = PopoverTrigger.Manual;
    /// <summary>Position of the panel relative to the anchor element.</summary>
    [Parameter] public PopoverPlacement     Placement     { get; set; } = PopoverPlacement.BottomStart;
    /// <summary>CSS max-width applied to the popover panel.</summary>
    [Parameter] public string?              MaxWidth      { get; set; }
    /// <summary>CSS min-width applied to the popover panel.</summary>
    [Parameter] public string?              MinWidth      { get; set; }
    /// <summary>CSS max-height applied to the panel; taller content scrolls inside it.</summary>
    [Parameter] public string?              MaxHeight     { get; set; }
    /// <summary>Sizes the panel to the anchor's width (like a dropdown). Overrides <see cref="MinWidth"/>/
    /// <see cref="MaxWidth"/> and applies to the default (non-<see cref="SmartPosition"/>) positioning.</summary>
    [Parameter] public bool                 MatchAnchorWidth { get; set; }
    /// <summary>Shows a directional arrow pointing to the anchor.</summary>
    [Parameter] public bool                 Arrow         { get; set; }
    /// <summary>Enables collision detection (flip/shift) to keep the popover within viewport.</summary>
    [Parameter] public bool                 SmartPosition { get; set; }
    /// <summary>Offset in pixels between anchor and popover.</summary>
    [Parameter] public int                  Offset        { get; set; } = 8;
    /// <summary>For <see cref="PopoverTrigger.Hover"/>: milliseconds to wait before opening on hover.</summary>
    [Parameter] public int                  Delay         { get; set; }
    /// <summary>For <see cref="PopoverTrigger.Hover"/>: milliseconds to wait before closing after the pointer
    /// leaves (a short grace period so brief gaps between anchor and panel do not close it).</summary>
    [Parameter] public int                  HideDelay     { get; set; } = 120;

    protected override string ComponentCssClass => Css.Classes.Popover.Anchor;

    private ElementReference _floatingRef;
    private string? _floatingStyle;
    private bool _initialized;
    private bool _wasOpen;
    // Debounce guard: each hover enter/leave bumps this so a stale delayed open/close is discarded.
    private int _hoverGen;
    private readonly string _id = "flare-popover-" + Guid.NewGuid().ToString("N")[..8];

    private string _placementClass => Placement switch
    {
        PopoverPlacement.Top         => Css.Classes.Popover.PaperTop,
        PopoverPlacement.TopStart    => Css.Classes.Popover.PaperTopStart,
        PopoverPlacement.TopEnd      => Css.Classes.Popover.PaperTopEnd,
        PopoverPlacement.Bottom      => Css.Classes.Popover.PaperBottom,
        PopoverPlacement.BottomEnd   => Css.Classes.Popover.PaperBottomEnd,
        PopoverPlacement.Left        => Css.Classes.Popover.PaperLeft,
        PopoverPlacement.LeftStart   => Css.Classes.Popover.PaperLeftStart,
        PopoverPlacement.LeftEnd     => Css.Classes.Popover.PaperLeftEnd,
        PopoverPlacement.Right       => Css.Classes.Popover.PaperRight,
        PopoverPlacement.RightStart  => Css.Classes.Popover.PaperRightStart,
        PopoverPlacement.RightEnd    => Css.Classes.Popover.PaperRightEnd,
        _                            => Css.Classes.Popover.PaperBottomStart,
    };

    private string _arrowClass => Arrow ? Css.Classes.Popover.Arrow : string.Empty;
    private string _matchWidthClass => MatchAnchorWidth ? Css.Classes.Popover.PaperMatchWidth : string.Empty;

    // Width/height caps ride on the panel style, merged with the JS position (when SmartPosition).
    // MatchAnchorWidth owns the width, so the min/max-width params are skipped in that mode.
    private string? _paperStyle
    {
        get
        {
            var parts = new List<string>(4);
            if (!string.IsNullOrEmpty(_floatingStyle)) parts.Add(_floatingStyle!);
            if (!MatchAnchorWidth)
            {
                AddLength(parts, "min-width", MinWidth);
                AddLength(parts, "max-width", MaxWidth);
            }
            AddLength(parts, "max-height", MaxHeight);
            return parts.Count == 0 ? null : string.Join(';', parts);
        }
    }

    private static void AddLength(List<string> parts, string prop, string? value)
    {
        if (string.IsNullOrEmpty(value)) return;
        var safe = Flare.Components.Security.CssValidator.StripDangerous(value);
        if (!string.IsNullOrEmpty(safe)) parts.Add($"{prop}:{safe}");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Open && !_wasOpen)
        {
            _wasOpen = true;
            if (SmartPosition)
            {
                await UpdatePositionAsync();
                _initialized = true;
            }
            // A hover popover is not modal: it must not trap focus (that would steal focus on hover).
            // Click/Manual popovers trap Tab focus and refocus the trigger on close.
            if (Trigger != PopoverTrigger.Hover)
            {
                try { await Overlay.TrapFocusAsync(_id, _floatingRef); } catch { }
            }
        }
        else if (!Open && _wasOpen)
        {
            _wasOpen = false;
            _initialized = false;
            try { await Overlay.ReleaseFocusTrapAsync(_id); } catch { }
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (Open && SmartPosition && _initialized)
        {
            await UpdatePositionAsync();
        }
    }

    private async Task UpdatePositionAsync()
    {
        try
        {
            var placement = Placement.ToString().ToLowerInvariant();
            var result = await CollisionService.CalculatePlacementAsync(
                _floatingRef,
                _floatingRef,
                placement,
                new CollisionOptions
                {
                    Offset = Offset,
                    Flip = true,
                    Shift = true,
                    ArrowSize = Arrow ? 8 : 0
                });

            _floatingStyle = $"position:fixed;top:{result.Top:F0}px;left:{result.Left:F0}px;z-index:9999";
            StateHasChanged();
        }
        catch (InvalidOperationException) { }
    }

    private async Task CloseAsync() => await OpenChanged.InvokeAsync(false);

    // Built-in anchor handler for Trigger="Click".
    private async Task ToggleAsync() => await OpenChanged.InvokeAsync(!Open);

    // Hover trigger: open after Delay, close after HideDelay. Bumping _hoverGen is what discards a delayed
    // action that a later enter/leave has overtaken - it is the only cancellation there is, so every enter
    // must bump it even when there is nothing to open.
    //
    // The panel is a DOM descendant of this root, so crossing from the anchor into it does not fire
    // mouseleave - EXCEPT across the Offset gap: the panel is absolutely positioned and adds nothing to the
    // root's box, so the dead band between them is outside every element here and the leave is real. That is
    // precisely the case HideDelay exists to survive, and it can only survive it if the re-entry cancels.
    private async Task HandleMouseEnter()
    {
        if (Trigger != PopoverTrigger.Hover) return;
        // Always, and before the redundant-open guard below: re-entering an OPEN popover is exactly the
        // case that has to cancel a pending hide.
        var gen = ++_hoverGen;
        if (Open) return;
        if (Delay > 0)
        {
            await Task.Delay(Delay);
            if (gen != _hoverGen) return;
        }
        await OpenChanged.InvokeAsync(true);
    }

    private async Task HandleMouseLeave()
    {
        if (Trigger != PopoverTrigger.Hover) return;
        // Same order as above, for the mirrored reason: while the open delay runs the popover is still
        // CLOSED, so guarding on !Open first would let a pointer that merely passed through open it anyway.
        var gen = ++_hoverGen;
        if (!Open) return;
        if (HideDelay > 0)
        {
            await Task.Delay(HideDelay);
            if (gen != _hoverGen) return;
        }
        await OpenChanged.InvokeAsync(false);
    }

    public override async ValueTask DisposeAsync()
    {
        if (_wasOpen)
        {
            try { await Overlay.ReleaseFocusTrapAsync(_id); } catch { }
        }
        await base.DisposeAsync();
    }
}
