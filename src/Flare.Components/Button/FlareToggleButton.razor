@namespace Flare.Components
@inherits FlareComponentBase

<button @ref="_element"
        class="@BuildCssClass(_pressedClass, _sizeClass, _iconOnlyClass, _colorClass, _edgeClass)"
        style="@_btnStyle"
        type="button"
        disabled="@_effectiveDisabled"
        aria-label="@AriaLabel"
        aria-pressed="@(_pressed ? "true" : "false")"
        @onclick="HandleClick"
        @attributes="AdditionalAttributes">
    @if (_pressed && _showCheck)
    {
        <FlareIconView Value="FlareIcons.Check" Class="@Css.Classes.ToggleButton.Check" />
    }
    @{ var icon = _pressed ? (OnIcon ?? OffIcon) : OffIcon; }
    @if (icon is not null)
    {
        <span class="@Css.Classes.ToggleButton.Icon">@icon</span>
    }
    @if (ChildContent is not null)
    {
        <span class="@Css.Classes.ToggleButton.Label">@ChildContent</span>
    }
</button>

@code {
    /// <summary>Button label content shown alongside the icon.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }
    /// <summary>Icon rendered when the button is not pressed.</summary>
    [Parameter] public RenderFragment? OffIcon { get; set; }
    /// <summary>Icon rendered when the button is pressed. Defaults to OffIcon if not set.</summary>
    [Parameter] public RenderFragment? OnIcon { get; set; }
    /// <summary>Whether the button is currently in the pressed/active state.</summary>
    [Parameter] public bool Toggled { get; set; }
    /// <summary>Callback raised when the pressed state changes.</summary>
    [Parameter] public EventCallback<bool> ToggledChanged { get; set; }
    /// <summary>Size of the toggle button. Overridden by the parent <c>FlareToggleGroup.Size</c> when that is set.</summary>
    [Parameter] public ButtonSize Size { get; set; } = ButtonSize.Md;
    /// <summary>Color tinting the selected state. Role -> shared color class; custom -> inline tokens.
    /// Overridden by the parent <c>FlareToggleGroup.Color</c> when that is set. Default = theme's secondary container.</summary>
    [Parameter] public FlareColor Color { get; set; } = FlareColor.Default;
    /// <summary>Disables the button when true. Also disabled when the parent <c>FlareToggleGroup.Disabled</c> is true.</summary>
    [Parameter] public bool Disabled { get; set; }
    /// <summary>Accessible label forwarded as aria-label.</summary>
    [Parameter] public string? AriaLabel { get; set; }
    /// <summary>Optical edge alignment - a negative inline margin pulling the button toward the container edge.</summary>
    [Parameter] public ButtonEdge Edge { get; set; } = ButtonEdge.None;
    /// <summary>The value reported to a parent FlareToggleGroup when toggled.</summary>
    [Parameter] public object? Value { get; set; }

    /// <summary>Cascading context supplied by a parent FlareToggleGroup.</summary>
    [CascadingParameter] public FlareToggleGroupContext? Group { get; set; }

    protected override string ComponentCssClass => Css.Classes.ToggleButton.Root;

    private bool _pressed;
    // Tracks the last Toggled parameter seen so we can detect external changes vs local clicks
    private bool _lastToggled;
    private ElementReference _element;

    /// <summary>Sets keyboard focus to the toggle button element.</summary>
    public ValueTask FocusAsync() => _element.FocusAsync();

    /// <summary>Toggles the pressed state, exactly as a user click would (honors the disabled state and,
    /// inside a group, the group's selection rules).</summary>
    public Task Toggle() => HandleClick();

    /// <summary>Sets the pressed state programmatically. No-op when disabled or already in that state;
    /// inside a group it routes through the group so the group's binding stays authoritative.</summary>
    public async Task SetToggledAsync(bool toggled)
    {
        if (_effectiveDisabled || _pressed == toggled) return;
        if (Group is not null) { await Group.Toggle(Value); return; }
        _pressed = toggled;
        _lastToggled = toggled;
        await ToggledChanged.InvokeAsync(_pressed);
        StateHasChanged();
    }

    private string _pressedClass => _pressed ? Css.Classes.ToggleButton.Pressed : string.Empty;
    private bool _showCheck => Group?.CheckMark == true;

    private string _edgeClass => Edge switch
    {
        ButtonEdge.Start => Css.Classes.Button.EdgeStart,
        ButtonEdge.End => Css.Classes.Button.EdgeEnd,
        _ => string.Empty,
    };

    // Group settings cascade: a group value overrides the button's own (Size/Color), or forces Disabled.
    private ButtonSize _effectiveSize => Group?.Size ?? Size;
    private FlareColor _effectiveColor => Group?.Color ?? Color;
    private bool _effectiveDisabled => Disabled || (Group?.Disabled ?? false);

    // Role -> shared color class (sets --fc-container/--fc-on-container); custom -> inline those tokens.
    private string _colorClass => _effectiveColor.CssClass ?? string.Empty;
    private string? _btnStyle => _effectiveColor.StyleContainerSolid() is { } tokens ? tokens + Style : Style;

    private string _sizeClass => _effectiveSize switch
    {
        ButtonSize.Xs => Css.Classes.ToggleButton.Xs,
        ButtonSize.Sm => Css.Classes.ToggleButton.Sm,
        ButtonSize.Md => Css.Classes.ToggleButton.Md,
        ButtonSize.Lg => Css.Classes.ToggleButton.Lg,
        ButtonSize.Xl => Css.Classes.ToggleButton.Xl,
        _ => Css.Classes.ToggleButton.Md,
    };

    private string _iconOnlyClass => ChildContent is null ? Css.Classes.ToggleButton.IconOnly : string.Empty;

    protected override void OnParametersSet()
    {
        if (Group is not null)
        {
            _pressed = Group.SelectedValues.Contains(Value);
        }
        else if (ToggledChanged.HasDelegate)
        {
            // Controlled: always follow the bound parameter
            _pressed = Toggled;
            _lastToggled = Toggled;
        }
        else if (Toggled != _lastToggled)
        {
            // Uncontrolled but caller changed Toggled externally - respect it
            _pressed = Toggled;
            _lastToggled = Toggled;
        }
        // Otherwise: uncontrolled with no external change - keep local _pressed state
    }

    private async Task HandleClick()
    {
        if (_effectiveDisabled) return;
        if (Group is not null)
        {
            await Group.Toggle(Value);
        }
        else
        {
            _pressed = !_pressed;
            await ToggledChanged.InvokeAsync(_pressed);
            StateHasChanged(); // needed when invoked via the public Toggle() (no automatic event re-render)
        }
    }
}
