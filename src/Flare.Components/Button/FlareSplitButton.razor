@namespace Flare.Components
@inherits FlareComponentBase
@implements IFlareButton

<div class="@BuildCssClass(_sizeClass, _openedClass, _fullClass)" style="@Style" @attributes="AdditionalAttributes">
    <FlareButton @ref="_main" Class="@Css.Classes.SplitButton.Main"
                 Variant="Variant" Color="Color" Size="Size"
                 Disabled="Disabled" Loading="Loading"
                 Href="@Href" Target="@Target" Rel="@Rel"
                 OnClick="OnClick">
        @ChildContent
    </FlareButton>
    <FlareMenu @ref="_menu" Anchor="Placement" AriaLabel="@MenuAriaLabel" Class="@Css.Classes.SplitButton.Menu" OnToggle="ToggleMenuState">
        <Activator>
            <FlareButton Class="@Css.Classes.SplitButton.Trigger"
                         Variant="Variant" Color="Color" Size="Size"
                         Disabled="Disabled" AriaLabel="@MenuAriaLabel">
                <span class="material-symbols-rounded @Css.Classes.SplitButton.Caret" aria-hidden="true">expand_more</span>
            </FlareButton>
        </Activator>
        <ChildContent>
            @MenuItems
        </ChildContent>
    </FlareMenu>
</div>

@code {
    /// <summary>Label/content of the primary action button.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }
    /// <summary>FlareMenuItem entries shown in the dropdown opened by the trigger.</summary>
    [Parameter] public RenderFragment? MenuItems { get; set; }
    /// <summary>Visual style variant applied to both the main and trigger buttons.</summary>
    [Parameter] public ButtonVariant Variant { get; set; } = ButtonVariant.Filled;
    /// <summary>Size applied to both buttons.</summary>
    [Parameter] public ButtonSize Size { get; set; } = ButtonSize.Md;
    /// <summary>Semantic color applied to both buttons.</summary>
    [Parameter] public FlareColor Color { get; set; } = FlareColor.Default;
    /// <summary>Disables the whole split button.</summary>
    [Parameter] public bool Disabled { get; set; }
    /// <summary>Shows a spinner on the primary action button and disables it.</summary>
    [Parameter] public bool Loading { get; set; }
    /// <summary>Stretches the split button to the full width of its container (the primary action grows).</summary>
    [Parameter] public bool FullWidth { get; set; }
    /// <summary>When set, the primary action button renders as a link (&lt;a&gt;) to this URL.</summary>
    [Parameter] public string? Href { get; set; }
    /// <summary>Target for the primary link (e.g. "_blank"). Only used with <see cref="Href"/>.</summary>
    [Parameter] public string? Target { get; set; }
    /// <summary>The primary link's <c>rel</c> (link mode); null + <see cref="Target"/> <c>_blank</c> defaults to
    /// <c>noopener noreferrer</c>.</summary>
    [Parameter] public string? Rel { get; set; }
    /// <summary>Corner of the trigger the dropdown menu aligns to. Defaults to <see cref="MenuAnchor.BottomRight"/>.</summary>
    [Parameter] public MenuAnchor Placement { get; set; } = MenuAnchor.BottomRight;
    /// <summary>Callback invoked when the primary action button is clicked.</summary>
    [Parameter] public EventCallback<MouseEventArgs> OnClick { get; set; }
    /// <summary>Accessible label for the dropdown trigger (aria-label / menu label).</summary>
    [Parameter] public string MenuAriaLabel { get; set; } = "More actions";

    protected override string ComponentCssClass => Css.Classes.SplitButton.Root;

    private bool _menuOpen;
    private FlareButton? _main;
    private FlareMenu? _menu;

    /// <summary>Sets keyboard focus to the primary action button.</summary>
    public ValueTask FocusAsync() => _main?.FocusAsync() ?? ValueTask.CompletedTask;

    /// <summary>Opens the dropdown menu programmatically.</summary>
    public Task Open() => _menu?.OpenAsync() ?? Task.CompletedTask;

    /// <summary>Closes the dropdown menu programmatically.</summary>
    public Task Close() => _menu?.CloseAsync() ?? Task.CompletedTask;

    private string _fullClass => FullWidth ? Css.Classes.SplitButton.Full : string.Empty;

    private void ToggleMenuState(bool opened)
    {
        _menuOpen = opened;
    }
    
    // Size mapping for the split-button CSS isolation
    private string _sizeClass => Size switch
    {
        ButtonSize.Xs => Css.Classes.SplitButton.Xs,
        ButtonSize.Sm => Css.Classes.SplitButton.Sm,
        ButtonSize.Md => Css.Classes.SplitButton.Md,
        ButtonSize.Lg => Css.Classes.SplitButton.Lg,
        ButtonSize.Xl => Css.Classes.SplitButton.Xl,
        _ => Css.Classes.SplitButton.Md,
    };

    private string _openedClass => _menuOpen ? Css.Classes.SplitButton.Opened : string.Empty;
}
