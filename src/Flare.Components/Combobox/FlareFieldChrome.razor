@namespace Flare.Components
@inherits FlareComponentBase

@* The one shared field frame for the WHOLE field/input family (text, numeric, mask, password, textarea,
   otp, select, multiselect, combobox, tagfield, pickers). It renders the shared column: the .flare-input
   root (carrying the universal variant/size/state modifier classes), the label, the Field slot (the
   well/control the field owns), and the supporting-text row (helper OR error + an optional counter). It
   owns NOTHING behavioural and no TValue -- that boundary is what keeps it from becoming a super-component.
   The field supplies its own root modifier via ComponentClass and its control markup via Field. *@

<div class="@RootClass()"
     style="@Style"
     @ref="_root"
     @attributes="Attributes">
    @if (!string.IsNullOrEmpty(Label) && !FloatingLabel)
    {
        <label class="@Css.Classes.Input.Label" id="@LabelId" for="@LabelFor">@Label</label>
    }
    @Field
    @if (HasSupport)
    {
        <div class="@Css.Classes.Input.Support">
            @if (!string.IsNullOrEmpty(ErrorText))
            {
                <span id="@ErrorId" class="@Css.Classes.Input.Helper @Css.Classes.Input.HelperError" role="alert">@ErrorText</span>
            }
            else if (!string.IsNullOrEmpty(HelperText))
            {
                <span id="@HelperId" class="@Css.Classes.Input.Helper">@HelperText</span>
            }
            @Counter
        </div>
    }
</div>

@code {
    /// <summary>The field's own root modifier class (e.g. <c>flare-select</c>); appended after the shared
    /// <c>flare-input</c> root so component-specific CSS still keys off it.</summary>
    [Parameter] public string? ComponentClass { get; set; }

    /// <summary>Any extra component-specific modifier classes (open/floating/auto/margin/adornment).</summary>
    [Parameter] public string? ExtraClass { get; set; }

    /// <summary>Visual variant (Filled/Outlined), emitted as the shared variant modifier class.</summary>
    [Parameter] public InputVariant Variant { get; set; } = InputVariant.Default;

    /// <summary>Control size (Xs..Xl), emitted as the shared size modifier class.</summary>
    [Parameter] public FieldSize Size { get; set; } = FieldSize.Md;

    /// <summary>Invalid/error state; emits the shared <c>flare-input--error</c> modifier.</summary>
    [Parameter] public bool Invalid { get; set; }

    /// <summary>Disabled state; emits the shared <c>flare-input--disabled</c> modifier.</summary>
    [Parameter] public bool Disabled { get; set; }

    /// <summary>Read-only state; forwarded by fields to their control (the frame draws no read-only chrome).</summary>
    [Parameter] public bool ReadOnly { get; set; }

    /// <summary>The field label text; omitted when null/empty or when <see cref="FloatingLabel"/> (the field
    /// renders its own floating label inside the well).</summary>
    [Parameter] public string? Label { get; set; }

    /// <summary>The field renders its own floating label inside the well; the frame suppresses the top label.</summary>
    [Parameter] public bool FloatingLabel { get; set; }

    /// <summary>The label element id (for <c>aria-labelledby</c> from a div trigger).</summary>
    [Parameter] public string? LabelId { get; set; }

    /// <summary>The <c>for</c> target of the label (the input id), for real-input fields; null for div triggers.</summary>
    [Parameter] public string? LabelFor { get; set; }

    /// <summary>Helper text shown below the field when there is no error.</summary>
    [Parameter] public string? HelperText { get; set; }

    /// <summary>The helper element id, referenced via <c>aria-describedby</c>.</summary>
    [Parameter] public string? HelperId { get; set; }

    /// <summary>Error text; when set it replaces the helper and is announced as an alert.</summary>
    [Parameter] public string? ErrorText { get; set; }

    /// <summary>The error element id, referenced via <c>aria-describedby</c>.</summary>
    [Parameter] public string? ErrorId { get; set; }

    /// <summary>Extra attributes splatted onto the root element (inline <c>Style</c> comes from the base).</summary>
    [Parameter] public IReadOnlyDictionary<string, object>? Attributes { get; set; }

    /// <summary>The field content (the well: control + adornments), rendered between the label and the support row.</summary>
    [Parameter, EditorRequired] public RenderFragment? Field { get; set; }

    /// <summary>Optional trailing content for the support row (a character counter).</summary>
    [Parameter] public RenderFragment? Counter { get; set; }

    private ElementReference _root;

    /// <inheritdoc />
    protected override string ComponentCssClass => Css.Classes.Input.Root;

    /// <summary>The root element, for anchored positioning and dismissal containment by the field.</summary>
    public ElementReference Root => _root;

    private bool HasSupport =>
        !string.IsNullOrEmpty(ErrorText) || !string.IsNullOrEmpty(HelperText) || Counter is not null;

    // The shared root always carries .flare-input; the component modifier + the universal state/variant/size
    // modifier classes + any extra component modifier follow. State precedence is Disabled-first (a disabled
    // field never also shows the error indicator), matching the field shells.
    private string RootClass()
    {
        var sb = new System.Text.StringBuilder(Css.Classes.Input.Root);
        Append(sb, ComponentClass);
        Append(sb, Disabled ? Css.Classes.Input.Disabled : Invalid ? Css.Classes.Input.Error : null);
        Append(sb, VariantClassOf());
        Append(sb, SizeClass());
        Append(sb, ExtraClass);
        Append(sb, Class);
        return sb.ToString();
    }

    private string? SizeClass() => Size switch
    {
        FieldSize.Xs => Css.Classes.Input.SizeXs,
        FieldSize.Sm => Css.Classes.Input.SizeSm,
        FieldSize.Lg => Css.Classes.Input.SizeLg,
        FieldSize.Xl => Css.Classes.Input.SizeXl,
        _ => null,
    };

    private string? VariantClassOf() => Variant switch
    {
        InputVariant.Filled => Css.Classes.Input.VariantFilled,
        InputVariant.Outlined => Css.Classes.Input.VariantOutlined,
        _ => null,
    };

    private static void Append(System.Text.StringBuilder sb, string? cls)
    {
        if (!string.IsNullOrEmpty(cls)) { sb.Append(' '); sb.Append(cls); }
    }
}
