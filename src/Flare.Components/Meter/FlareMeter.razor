@namespace Flare.Components
@inherits FlareComponentBase
@using System.Globalization

@* Segmented "meter" bar: shows how a whole divides into proportional colored parts - a latency
   breakdown (DB vs network), a quota bar (used vs free), a pass/fail/skip ribbon. Non-interactive.
   Parts are declared as <FlareMeterSegment Value="..."> children: a meter owns no external scale, so the
   parts themselves define the whole (unlike a slider/progress zone, which is a range on a host-owned
   scale). The track's rounded ends and resting background reuse the FlareProgress linear-track tokens so a
   meter and a progress bar line up visually. *@

<div class="@BuildCssClass(_sizeClass, _emptyClass)" role="img" aria-label="@_ariaLabel" style="@Style" @attributes="AdditionalAttributes">
    <div class="@Css.Classes.Meter.Track">
        @foreach (var v in _views)
        {
            <span class="@v.SegClass" style="@v.SegStyle" title="@v.Title"></span>
        }
    </div>
    @if (ShowLegend)
    {
        <div class="@Css.Classes.Meter.Legend">
            @foreach (var v in _views)
            {
                <span class="@Css.Classes.Meter.LegendItem">
                    <span class="@v.SwatchClass" style="@v.SwatchStyle" aria-hidden="true"></span>
                    @if (!string.IsNullOrEmpty(v.Label))
                    {
                        <span class="@Css.Classes.Meter.LegendLabel">@v.Label</span>
                    }
                    @if (ShowValues)
                    {
                        <span class="@Css.Classes.Meter.LegendValue">@v.DisplayValue</span>
                    }
                </span>
            }
        </div>
    }
    @* Segments register via the cascaded collection and render no DOM of their own. IsFixed: the
       collection instance never changes identity. *@
    <CascadingValue TValue="IFlareZoneHost" Value="_zones" IsFixed="true">@ChildContent</CascadingValue>
</div>

@code {
    /// <summary>The parts, declared as <see cref="FlareMeterSegment"/> children (each with a <c>Value</c> weight).</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }
    /// <summary>
    /// Track thickness, as a step on the shared <see cref="TrackSize"/> scale used by
    /// <see cref="FlareSlider"/> and <see cref="FlareProgress"/>. A meter reads the same per-size tokens as
    /// a linear progress bar, so the two are the same thickness at the same step.
    /// </summary>
    [Parameter] public TrackSize Size { get; set; } = TrackSize.Md;
    /// <summary>Shows a key below the track: one entry per segment (color swatch + label). Default false.</summary>
    [Parameter] public bool ShowLegend { get; set; }
    /// <summary>Shows each segment's numeric value - in the legend, the hover tooltip and the accessible
    /// label alike. Default false.</summary>
    [Parameter] public bool ShowValues { get; set; }
    /// <summary>
    /// Format string applied to segment values wherever they are shown (e.g. <c>"N1"</c>). Defaults to a
    /// bounded two-decimal format: a meter is fed raw measurements, and the round-trip <c>"G"</c> default
    /// would read a 0.0627 ms slice out as <c>0.06269999999999998</c>.
    /// </summary>
    [Parameter] public string? Format { get; set; }

    protected override string ComponentCssClass => Css.Classes.Meter.Root;

    // The size class only selects which per-size theme token the CSS reads; it carries no geometry itself.
    private string _sizeClass => Size switch
    {
        TrackSize.Sm => Css.Classes.Meter.Sm,
        TrackSize.Md => Css.Classes.Meter.Md,
        TrackSize.Lg => Css.Classes.Meter.Lg,
        TrackSize.Xl => Css.Classes.Meter.Xl,
        _ => Css.Classes.Meter.Xs,
    };

    // Shared zone registration; the collection pokes StateHasChanged when segments change.
    private readonly ZoneCollection _zones;

    public FlareMeter() => _zones = new ZoneCollection(StateHasChanged);

    private string _emptyClass => _views.Count == 0 ? Css.Classes.Meter.Empty : string.Empty;

    // Values are shown with a bounded default: "G" round-trips a double to full precision, which is right
    // for storing one and wrong for reading one out.
    private const string DefaultFormat = "0.##";

    // The grow factors are scaled to sum to this rather than passed through raw - see _views.
    private const double GrowTotal = 100d;

    private readonly struct SegView
    {
        public string SegClass { get; init; }
        public string SegStyle { get; init; }
        public string SwatchClass { get; init; }
        public string? SwatchStyle { get; init; }
        public string? Title { get; init; }
        public string? Label { get; init; }
        public string DisplayValue { get; init; }
    }

    private IReadOnlyList<SegView> _views
    {
        get
        {
            var inv = CultureInfo.InvariantCulture;
            var parts = _zones
                .Typed<FlareMeterSegment>(nameof(FlareMeter), "<FlareMeterSegment Value=\"..\" /> children")
                .Where(s => (s.Value ?? 0) > 0)
                .ToList();
            // Sum first: the grow factors have to be scaled against the whole before any is emitted.
            var total = parts.Sum(s => s.Value ?? 0);

            var list = new List<SegView>(parts.Count);
            foreach (var s in parts)
            {
                var value = s.Value ?? 0;
                var display = value.ToString(Format ?? DefaultFormat, CultureInfo.CurrentCulture);
                var colorStyle = s.Color.StyleMain();
                var title = s.Label is { Length: > 0 } lbl
                    ? (ShowValues ? $"{lbl}: {display}" : lbl)
                    : display;
                // Scale the factors to a fixed total instead of passing the raw value through. Flex only
                // distributes ALL the free space when the grow factors sum to >= 1 (CSS Flexbox 1, 7.1.1);
                // below that each item takes just its own fraction and the track ends early - in correct
                // proportions, which is what makes it easy to miss. Raw sub-1 values are ordinary for a meter
                // (fractions of a millisecond, ratios), so normalizing here keeps "declare raw values" true
                // while still leaving the division to the browser - one factor per segment, no rounding gaps.
                var grow = value / total * GrowTotal;
                list.Add(new SegView
                {
                    SegClass = string.IsNullOrEmpty(s.Color.CssClass)
                        ? Css.Classes.Meter.Seg
                        : $"{Css.Classes.Meter.Seg} {s.Color.CssClass}",
                    SegStyle = $"flex-grow:{grow.ToString("G", inv)};{colorStyle}",
                    SwatchClass = string.IsNullOrEmpty(s.Color.CssClass)
                        ? Css.Classes.Meter.LegendSwatch
                        : $"{Css.Classes.Meter.LegendSwatch} {s.Color.CssClass}",
                    SwatchStyle = colorStyle,
                    Title = title,
                    Label = s.Label,
                    DisplayValue = display,
                });
            }
            return list;
        }
    }

    // Screen-reader summary: the same information a sighted user gets, so the values follow ShowValues just
    // as the legend and the tooltip do - a meter that deliberately hides them must not announce them. With
    // no label there is nothing else to say, so the value stands in regardless.
    // Segments are joined with "; " because a culture that uses the decimal comma (ru: "0,25") would
    // otherwise separate values and segments with the same character.
    private string? _ariaLabel
    {
        get
        {
            var parts = _views.Select(v => string.IsNullOrEmpty(v.Label)
                ? v.DisplayValue
                : ShowValues ? $"{v.Label} {v.DisplayValue}" : v.Label!);
            var joined = string.Join("; ", parts);
            return string.IsNullOrEmpty(joined) ? null : joined;
        }
    }
}
