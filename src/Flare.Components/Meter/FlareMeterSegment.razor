@namespace Flare.Components
@implements IDisposable

@* One part of a FlareMeter. Registers itself with the parent meter (which draws the proportional
   segment inside the track) and renders no DOM of its own. Use inside <FlareMeter>...</FlareMeter>. *@

@code {
    [CascadingParameter] private FlareMeter? Meter { get; set; }

    /// <summary>This part's magnitude. Segments are sized in proportion to the sum of all segment
    /// values, so the units are arbitrary (milliseconds, bytes, counts, ...). Negative values are ignored.</summary>
    [Parameter] public double Value { get; set; }
    /// <summary>Segment fill color. Role (e.g. <see cref="FlareColor.Error"/>) -> shared class; custom
    /// (<c>FlareColor.Custom("#...")</c>) -> inline token. Defaults to <see cref="FlareColor.Primary"/>.</summary>
    [Parameter] public FlareColor Color { get; set; } = FlareColor.Primary;
    /// <summary>Optional label used for the hover tooltip and the legend entry.</summary>
    [Parameter] public string? Label { get; set; }

    private bool _registered;
    private (double Value, FlareColor Color, string? Label)? _last;

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        Meter?.RegisterSegment(this);
        _registered = Meter is not null;
        _last = (Value, Color, Label);
    }

    // Redraw the parent only when this segment's values actually change, so the parent's re-render
    // (which re-runs this with identical params) does not loop.
    /// <inheritdoc />
    protected override void OnParametersSet()
    {
        var sig = (Value, Color, Label);
        if (_registered && _last is { } prev && !prev.Equals(sig))
            Meter?.NotifySegmentChanged();
        _last = sig;
    }

    /// <inheritdoc />
    public void Dispose() => Meter?.UnregisterSegment(this);
}
