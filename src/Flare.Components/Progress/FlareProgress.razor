@namespace Flare.Components
@inherits FlareComponentBase
@using System.Globalization

@if (Variant == ProgressVariant.Circular && _wavyActive)
{
    @* Wavy ring: ONLY the active indicator is wavy; the remaining track is a
       normal smooth circle. The active arc is a wavy path whose phase is animated (SMIL d-morph) so
       the crests travel around the ring. pathLength=100 keeps the active-arc dash in percent units. *@
    <div class="@BuildCssClass(Css.Classes.Progress.Circular, Css.Classes.Progress.Wavy, _colorClass)"
         role="progressbar"
         aria-valuenow="@_clampedValue.ToString("F0")"
         aria-valuemin="0"
         aria-valuemax="100"
         style="@($"width:{Size}px;height:{Size}px;{_colorTokens}{Style}")"
         @attributes="AdditionalAttributes">
        @* -90deg start offset on the group; the wavy indicator flows via a CSS rotation synced with
           stroke-dashoffset (the fill window stays put while the wave crests travel around). *@
        <svg viewBox="0 0 44 44" class="@Css.Classes.Progress.Svg">
            <g transform="rotate(-90 22 22)">
                <circle class="@Css.Classes.Progress.Track" cx="22" cy="22" r="18" fill="none" stroke-width="4"
                        stroke-dasharray="@_trackDash" />
                <path class="@Css.Classes.Progress.Indicator" d="@_wavyRingPath" pathLength="100" fill="none" stroke-width="4"
                      stroke-dasharray="@_wavyIndicatorDash" />
            </g>
        </svg>
    </div>
}
else if (Variant == ProgressVariant.Circular)
{
    <div class="@BuildCssClass(Css.Classes.Progress.Circular, _indeterminate ? Css.Classes.Progress.Indeterminate : null, _colorClass)"
         role="progressbar"
         aria-valuenow="@(_indeterminate ? null : _clampedValue.ToString("F0"))"
         aria-valuemin="0"
         aria-valuemax="100"
         style="@($"width:{Size}px;height:{Size}px;{_colorTokens}{Style}")"
         @attributes="AdditionalAttributes">
        <svg viewBox="0 0 44 44" class="@Css.Classes.Progress.Svg">
            <circle class="@Css.Classes.Progress.Track" cx="22" cy="22" r="18" fill="none" stroke-width="4"
                    stroke-dasharray="@(_indeterminate ? null : _trackDash)"
                    transform="rotate(-90 22 22)" />
            <circle class="@Css.Classes.Progress.Indicator" cx="22" cy="22" r="18" fill="none" stroke-width="4"
                    stroke-dasharray="@(_indeterminate ? null : _indicatorDash)"
                    transform="rotate(-90 22 22)" />
        </svg>
    </div>
}
else if (Variant == ProgressVariant.Linear && _wavyActive)
{
    @* Wavy linear: split-track layout (active bar + gap + remaining track +
       trailing stop indicator). The active bar holds a continuous sine path (constant wavelength,
       amplitude and speed from theme tokens) that is clipped to the bar and translated one
       wavelength per cycle for a seamless flow. The remaining track stays a flat line. *@
    <div class="@BuildCssClass(Css.Classes.Progress.Linear, Css.Classes.Progress.Wavy, Css.Classes.Progress.Split, _colorClass)"
         role="progressbar"
         aria-valuenow="@_clampedValue.ToString("F0")"
         aria-valuemin="0"
         aria-valuemax="100"
         style="@($"{_colorTokens}{_thicknessToken}{Style}")"
         @attributes="AdditionalAttributes">
        <div class="@Css.Classes.Progress.Bar" style="width:@(_clampedValue.ToString("F0", System.Globalization.CultureInfo.InvariantCulture))%">
            <svg class="@Css.Classes.Progress.Wave" width="@_inv(_linWaveWidth)" height="@_inv(_wavyHeightPx)"
                 viewBox="@($"0 0 {_inv(_linWaveWidth)} {_inv(_wavyHeightPx)}")" preserveAspectRatio="none" aria-hidden="true">
                <path d="@_linWavePath" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" />
            </svg>
        </div>
        <div class="@Css.Classes.Progress.Remain"></div>
    </div>
}
else if (Variant == ProgressVariant.Buffer)
{
    <div class="@BuildCssClass(Css.Classes.Progress.Linear, Css.Classes.Progress.Buffer, _colorClass)"
         role="progressbar"
         aria-valuenow="@(_indeterminate ? null : _clampedValue.ToString("F0"))"
         aria-valuemin="0"
         aria-valuemax="100"
         style="@($"{_colorTokens}{_thicknessToken}{Style}")"
         @attributes="AdditionalAttributes">
        <div class="@Css.Classes.Progress.BufferFill" style="width:@(_clampedBufferValue.ToString("F0"))%"></div>
        <div class="@Css.Classes.Progress.Bar" style="width:@(_clampedValue.ToString("F0"))%"></div>
    </div>
}
else if (Variant == ProgressVariant.Query)
{
    <div class="@BuildCssClass(Css.Classes.Progress.Linear, Css.Classes.Progress.Query, _colorClass)"
         role="progressbar"
         aria-valuemin="0"
         aria-valuemax="100"
         style="@($"{_colorTokens}{_thicknessToken}{Style}")"
         @attributes="AdditionalAttributes">
        <div class="@Css.Classes.Progress.Bar"></div>
    </div>
}
else
{
    <div class="@BuildCssClass(Css.Classes.Progress.Linear, _trackClass, _colorClass)"
         role="progressbar"
         aria-valuenow="@(_indeterminate ? null : _clampedValue.ToString("F0"))"
         aria-valuemin="0"
         aria-valuemax="100"
         style="@($"{_colorTokens}{_thicknessToken}{Style}")"
         @attributes="AdditionalAttributes">
        @foreach (var z in _zoneBands)
        {
            <span class="@z.CssClass" style="@z.Style"></span>
        }
        <div class="@Css.Classes.Progress.Bar"
             style="@(_indeterminate ? null : $"width:{_clampedValue:F0}%")"></div>
        @if (!_indeterminate && !_hasZones)
        {
            <div class="@Css.Classes.Progress.Remain"></div>
        }
        @* Zones register via the cascaded collection and render no DOM of their own; the bands above
           draw them. IsFixed: the collection instance never changes identity. *@
        @if (Zones is not null)
        {
            <CascadingValue TValue="IFlareZoneHost" Value="_zones" IsFixed="true">@Zones</CascadingValue>
        }
    </div>
}

@code {
    /// <summary>Percentage value (0-100); null for indeterminate mode.</summary>
    [Parameter] public double? Value { get; set; }
    /// <summary>Display style: Linear bar, Circular spinner, Buffer, or Query.</summary>
    [Parameter] public ProgressVariant Variant { get; set; } = ProgressVariant.Linear;
    /// <summary>Pixel size (width and height) used when Variant is Circular. Defaults to 40.</summary>
    [Parameter] public int Size { get; set; } = 40;
    /// <summary>Track thickness in pixels for the linear variants (Linear/Buffer/Query). 0 = theme default (4px).</summary>
    [Parameter] public int Thickness { get; set; }
    /// <summary>Wavy active indicator (determinate linear only). The active portion renders as an animated sine wave.</summary>
    [Parameter] public bool Wavy { get; set; }
    /// <summary>Secondary buffer fill percentage (0-100), used only with Variant=Buffer.</summary>
    [Parameter] public double BufferValue { get; set; }
    /// <summary>Semantic color applied to the progress indicator.</summary>
    [Parameter] public FlareColor Color { get; set; } = FlareColor.Default;
    /// <summary>
    /// Declarative colored zones on the track: one or more <see cref="FlareZone"/> children, each an
    /// absolute <c>[Start, End]</c> region on the 0-100 scale in its own color (threshold/danger ranges,
    /// a loaded-so-far band). Zones are read-only annotations drawn under the active bar. Applies to the
    /// determinate linear bar; because zones need an uninterrupted track, using them renders a continuous
    /// track instead of the split (gap + trailing stop dot) one.
    /// </summary>
    [Parameter] public RenderFragment? Zones { get; set; }

    protected override string ComponentCssClass => Css.Classes.Progress.Root;

    // Shared zone registration; the collection pokes StateHasChanged when zones change.
    private readonly ZoneCollection _zones;

    public FlareProgress() => _zones = new ZoneCollection(StateHasChanged);

    private bool _hasZones => _zones.Zones.Count > 0;

    // Indeterminate wins; zones force a continuous track; otherwise the default split track.
    private string _trackClass => _indeterminate
        ? Css.Classes.Progress.Indeterminate
        : _hasZones ? Css.Classes.Progress.WithZones : Css.Classes.Progress.Split;

    // Renderable band per zone: percent-positioned via --_z0/--_z1 CSS vars. Progress is a scale host on
    // the fixed 0-100 range, so a zone is read as an absolute [Start, End]. Empty/invalid zones are dropped.
    private IEnumerable<(string CssClass, string Style)> _zoneBands
    {
        get
        {
            var inv = CultureInfo.InvariantCulture;
            foreach (var z in _zones.Zones)
            {
                var lo = Math.Clamp(Math.Min(z.Start ?? 0, z.End ?? 0), 0, 100);
                var hi = Math.Clamp(Math.Max(z.Start ?? 0, z.End ?? 0), 0, 100);
                if (hi - lo <= 0.001) continue;
                var cls = string.IsNullOrEmpty(z.Color.CssClass)
                    ? Css.Classes.Progress.Zone
                    : $"{Css.Classes.Progress.Zone} {z.Color.CssClass}";
                var style = $"--_z0:{lo.ToString("F2", inv)}%;--_z1:{hi.ToString("F2", inv)}%;{z.Color.StyleMain()}";
                yield return (cls, style);
            }
        }
    }

    private const double _circumference = 2 * Math.PI * 18;
    private bool _indeterminate => Value is null;

    // Clamp Value and BufferValue to 0-100 to prevent bar overflow.
    private double _clampedValue => Math.Clamp(Value ?? 0, 0, 100);
    private double _clampedBufferValue => Math.Clamp(BufferValue, 0, 100);

    private double _arc => _circumference * _clampedValue / 100;
    // Role -> shared flare-color-* class (sets --fc-main); custom -> inline --fc-main token.
    private string _colorClass => Color.CssClass ?? string.Empty;
    private string _colorTokens => Color.IsCustom ? $"{Css.Tokens.LocalColor.Main}:{Color.Value};" : string.Empty;
    // Linear track thickness override (px). Empty when Thickness is unset -> CSS default applies.
    private string _thicknessToken => Thickness > 0 ? $"--flare-progress-linear-height:{Thickness}px;" : string.Empty;

    // Both circular arcs are expressed as plain numeric dash patterns so SVG renders
    // them reliably (no CSS calc() in stroke-dasharray). The leading "0 <space>" pair
    // carves the gap directly into the pattern - no stroke-dashoffset needed.
    //   indicator: empty(gap/2) - (arc-gap) - rest        -> active arc, inset gap/2 each end
    //   track:     empty(arc+gap/2) - (circ-arc-gap) - rest -> remaining track, same gaps
    private string _indicatorDash => Dash(_circularGap / 2, Math.Max(0, _arc - _circularGap));
    private string _trackDash => Dash(_arc + _circularGap / 2, Math.Max(0, _circumference - _arc - _circularGap));

    private string Dash(double lead, double len) =>
        string.Create(System.Globalization.CultureInfo.InvariantCulture,
            $"0 {lead:F2} {len:F2} {_circumference:F2}");

    private double _circularGap => ReadTokenNum("--flare-progress-circular-gap", 0);

    // ===========================================================================================
    // WAVY - opt-in per theme via --flare-progress-wavy-enabled (1=on). A theme
    // that doesn't define it renders the plain bar/ring even when Wavy="true".
    // ===========================================================================================
    private bool _wavyActive => Wavy && !_indeterminate && ReadTokenNum("--flare-progress-wavy-enabled", 0) > 0;

    private double _wavyHeightPx => ReadTokenNum("--flare-progress-wavy-height", 10);
    private double _waveLen => ReadTokenNum("--flare-progress-wave-length", 40);
    private double _waveAmp => ReadTokenNum("--flare-progress-wave-amplitude", 3);
    private string _waveSpeed => ReadTokenStr("--flare-progress-wave-speed", "1s");

    private static string _inv(double v) => v.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);

    // -- Linear wave: one continuous sine path spanning many wavelengths; the bar clips it and CSS
    //    translates it one wavelength per cycle. Drawn 1:1 in px so the wavelength is constant. ----
    private double _linWaveWidth => _waveLen * 40;   // enough periods for any realistic bar width
    private string _linWavePath => BuildLinearWavePath(_linWaveWidth, _waveLen, _waveAmp, _wavyHeightPx / 2);
    private static string BuildLinearWavePath(double width, double period, double amp, double midY)
    {
        var step = period / 12;
        var sb = new System.Text.StringBuilder();
        for (double x = 0; x <= width + 0.01; x += step)
        {
            var y = midY - amp * Math.Sin(2 * Math.PI * x / period);
            sb.Append(x <= 0 ? "M" : "L");
            sb.Append(_inv(x)); sb.Append(' '); sb.Append(_inv(y)); sb.Append(' ');
        }
        return sb.ToString();
    }

    // -- Wavy ring: ONLY the active arc is wavy (the track stays a smooth circle). A single static
    //    wavy path is drawn; the flow comes from a CSS rotation synced with stroke-dashoffset (see
    //    progress.css) so crests travel while the fill window stays put. pathLength=100 -> % dash. ---
    private int _ringWaves => Math.Max(3, (int)ReadTokenNum("--flare-progress-ring-waves", 8));
    private double _ringAmp => ReadTokenNum("--flare-progress-ring-wave-amplitude", 1.6);

    private string _wavyRingPath => BuildWavyCirclePath(_ringWaves, _ringAmp, 0);

    private static string BuildWavyCirclePath(int waves, double amp, double phase, double r = 18, double cx = 22, double cy = 22, int seg = 120)
    {
        var sb = new System.Text.StringBuilder();
        for (var i = 0; i <= seg; i++)
        {
            var t = 2 * Math.PI * i / seg; //-V3064 seg is a fixed positive segment count (120) from the sole caller
            var rr = r + amp * Math.Sin(waves * t + phase);
            var x = cx + rr * Math.Cos(t);
            var y = cy + rr * Math.Sin(t);
            sb.Append(i == 0 ? "M" : "L");
            sb.Append(_inv(x)); sb.Append(' '); sb.Append(_inv(y)); sb.Append(' ');
        }
        sb.Append('Z');
        return sb.ToString();
    }

    // Active-arc dash for the wavy ring, in pathLength=100 (percent) units, with the same gap as the
    // plain ring (expressed as a fraction of the circle circumference).
    private double _gapPct => _circumference > 0d ? _circularGap / _circumference * 100d : 0d;
    private string _wavyIndicatorDash => Dash100(_gapPct / 2, Math.Max(0, _clampedValue - _gapPct));
    private static string Dash100(double lead, double len) =>
        string.Create(System.Globalization.CultureInfo.InvariantCulture, $"0 {lead:F2} {len:F2} 100");

    // Reads a numeric (optionally px-suffixed) theme token; falls back when unset/unparseable.
    private double ReadTokenNum(string name, double fallback)
    {
        var raw = ReadTokenRaw(name);
        if (string.IsNullOrWhiteSpace(raw)) return fallback;
        raw = raw.Trim();
        if (raw.EndsWith("px", StringComparison.OrdinalIgnoreCase)) raw = raw[..^2];
        return double.TryParse(raw, System.Globalization.NumberStyles.Float,
            System.Globalization.CultureInfo.InvariantCulture, out var v) ? v : fallback;
    }

    private string ReadTokenStr(string name, string fallback)
    {
        var raw = ReadTokenRaw(name);
        return string.IsNullOrWhiteSpace(raw) ? fallback : raw.Trim();
    }

    private string? ReadTokenRaw(string name)
    {
        if (ThemeService is null) return null;
        if (ThemeService.GetCustomTokens() is { } custom && custom.TryGetValue(name, out var c)) return c;
        if (ThemeService.CurrentTheme?.Design?.Extended is { } ext && ext.TryGetValue(name, out var e)) return e;
        return null;
    }
}
