@namespace Flare.Components
@inherits FlareComponentBase

<div class="@BuildCssClass()" style="@Style" @attributes="AdditionalAttributes">
    @ChildContent
</div>

@code {
    /// <summary>Footer content of the card (metadata, status, links). For button rows prefer FlareCardActions.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    protected override string ComponentCssClass => Css.Classes.Card.Footer;
}
