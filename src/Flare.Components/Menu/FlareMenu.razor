@namespace Flare.Components
@inherits FlareComponentBase

<div class="@BuildCssClass(_denseClass)" style="@Style" @attributes="AdditionalAttributes">
    <div class="@Css.Classes.Menu.Activator"
         @onclick="HandleActivatorClick"
         @oncontextmenu="HandleActivatorContextMenu"
         @oncontextmenu:preventDefault="@(Activation == MenuActivation.RightClick)"
         aria-haspopup="menu" aria-expanded="@_open.ToString().ToLowerInvariant()" aria-controls="@_panelId">
        @Activator
    </div>
    @if (_open)
    {
        <div class="@Css.Classes.Menu.Backdrop" @onclick="CloseAsync" @oncontextmenu="CloseAsync" @oncontextmenu:preventDefault="true" aria-hidden="true"></div>
        <div id="@_panelId" @ref="_panelEl" class="@Css.Classes.Menu.Panel @_anchorClass @_scrollClass" style="@_panelStyle" role="menu" tabindex="-1"
             aria-label="@AriaLabel" aria-activedescendant="@_focusedItem?.ItemId"
             @onkeydown="HandleMenuKeyDown" @onkeydown:preventDefault="true">
            <CascadingValue Value="_menuContext" IsFixed="true">
                <CascadingValue Value="@_focusedItem" Name="MenuFocusedItem">
                    @ChildContent
                </CascadingValue>
            </CascadingValue>
        </div>
    }
</div>

@code {
    /// <summary>Element that opens the menu when clicked.</summary>
    [Parameter] public RenderFragment? Activator { get; set; }
    /// <summary>Menu items rendered inside the dropdown panel.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }
    /// <summary>Corner of the activator the panel aligns to.</summary>
    [Parameter] public MenuAnchor Anchor { get; set; } = MenuAnchor.BottomLeft;
    /// <summary>Accessible label for the menu panel (role="menu").</summary>
    [Parameter] public string? AriaLabel { get; set; }
    /// <summary>Callback triggered whenever the menu open state changes.</summary>
    [Parameter] public EventCallback<bool> OnToggle { get; set; }
    /// <summary>Reduces item height/padding for a denser menu (consistent with other components' Dense).</summary>
    [Parameter] public bool Dense { get; set; }
    /// <summary>How the menu opens from its activator. <see cref="MenuActivation.RightClick"/> turns it into a
    /// context menu (and suppresses the browser's own menu).</summary>
    [Parameter] public MenuActivation Activation { get; set; } = MenuActivation.LeftClick;
    /// <summary>Opens the panel pinned to the pointer position instead of the activator corner - the
    /// expected behavior for a context menu.</summary>
    [Parameter] public bool PositionAtCursor { get; set; }
    /// <summary>Optional CSS max-height for the panel (e.g. <c>"20rem"</c>); a longer list scrolls instead
    /// of overflowing the viewport.</summary>
    [Parameter] public string? MaxHeight { get; set; }

    protected override string ComponentCssClass => Css.Classes.Menu.Root;

    private string? _denseClass => Dense ? Css.Classes.Menu.Dense : null;

    private bool _open;
    private bool _wasOpen;
    // Pointer coordinates captured when a menu opens at the cursor (context menu / PositionAtCursor).
    private double? _cursorX;
    private double? _cursorY;
    private ElementReference _panelEl;
    private FlareMenuItem? _focusedItem;
    private readonly List<FlareMenuItem> _items = [];
    private readonly string _panelId = "flare-menu-" + Guid.NewGuid().ToString("N")[..8];
    // Stable close/register callbacks shared with every FlareMenuItem via one cascading context.
    private FlareMenuContext? _menuContext;

    protected override void OnInitialized()
    {
        base.OnInitialized();
        _menuContext = new FlareMenuContext(CloseAsync, RegisterItem);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_open && !_wasOpen)
        {
            _wasOpen = true;
            // Focus the panel so its keydown handler receives arrow/Home/End/Tab keys, and start the
            // active item on the first enabled one (announced to screen readers via aria-activedescendant).
            _focusedItem ??= _items.FirstOrDefault(i => !i.Disabled);
            try { await _panelEl.FocusAsync(); } catch (JSException) { } catch (InvalidOperationException) { }
            StateHasChanged();
        }
        else if (!_open && _wasOpen)
        {
            _wasOpen = false;
        }
    }

    // When opened at the pointer the panel is fixed-positioned (via inline style), so it uses the neutral
    // at-cursor class rather than an activator-corner anchor.
    private string _anchorClass => _cursorX is not null ? Css.Classes.Menu.AtCursor : Anchor switch
    {
        MenuAnchor.BottomRight => Css.Classes.Menu.BottomRight,
        MenuAnchor.TopLeft     => Css.Classes.Menu.TopLeft,
        MenuAnchor.TopRight    => Css.Classes.Menu.TopRight,
        MenuAnchor.BottomLeft  => Css.Classes.Menu.BottomLeft,
        _                      => Css.Classes.Menu.BottomLeft,
    };

    private string _scrollClass => string.IsNullOrEmpty(MaxHeight) ? string.Empty : Css.Classes.Menu.PanelScroll;

    // Cursor coordinates (context menu) and/or a MaxHeight cap ride on an inline style; sanitize the
    // caller-supplied length before injecting it.
    private string? _panelStyle
    {
        get
        {
            var parts = new List<string>(2);
            if (_cursorX is not null && _cursorY is not null)
                parts.Add(FormattableString.Invariant($"left:{_cursorX.Value:F0}px;top:{_cursorY.Value:F0}px"));
            if (!string.IsNullOrEmpty(MaxHeight))
            {
                var safe = Flare.Components.Security.CssValidator.StripDangerous(MaxHeight);
                if (!string.IsNullOrEmpty(safe)) parts.Add($"max-height:{safe}");
            }
            return parts.Count == 0 ? null : string.Join(';', parts);
        }
    }

    // Left-click activation only toggles when Activation is LeftClick; RightClick uses oncontextmenu.
    private async Task HandleActivatorClick(MouseEventArgs e)
    {
        if (Activation == MenuActivation.LeftClick)
            await Toggle(e);
    }

    private async Task HandleActivatorContextMenu(MouseEventArgs e)
    {
        if (Activation != MenuActivation.RightClick) return;
        if (_open) { await CloseAsync(); return; }
        await OpenAt(e);
    }

    /// <summary>Opens the menu when closed, or closes it when open, and raises <see cref="OnToggle"/>.</summary>
    private async Task Toggle(MouseEventArgs e)
    {
        if (_open) { await CloseAsync(); return; }
        await OpenAt(e);
    }

    // Open the panel, capturing the pointer position when PositionAtCursor so it pins to the cursor.
    private async Task OpenAt(MouseEventArgs e)
    {
        if (PositionAtCursor)
        {
            _cursorX = e.ClientX;
            _cursorY = e.ClientY;
        }
        _open = true;
        await OnToggle.InvokeAsync(true);
        StateHasChanged();
    }

    /// <summary>Opens the menu programmatically (no-op if already open) and raises <see cref="OnToggle"/>.</summary>
    public async Task OpenAsync()
    {
        if (_open) return;
        _open = true;
        await OnToggle.InvokeAsync(true);
        StateHasChanged();
    }

    /// <summary>Closes the menu (also callable programmatically), clears registered items and keyboard
    /// focus, and raises <see cref="OnToggle"/>.</summary>
    public async Task CloseAsync()
    {
        if (!_open) return;
        _open = false;
        _items.Clear();
        _focusedItem = null;
        _cursorX = null;
        _cursorY = null;

        await OnToggle.InvokeAsync(false);
        StateHasChanged();
    }

    /// <summary>Registers a child <see cref="FlareMenuItem"/> for keyboard navigation. Called by items on init.</summary>
    /// <param name="item">The menu item to track.</param>
    internal void RegisterItem(FlareMenuItem item)
    {
        if (!_items.Contains(item))
            _items.Add(item);
    }

    /// <summary>Handles keyboard navigation inside the open panel (Escape closes; Arrow/Home/End move focus; Tab cycles).</summary>
    /// <param name="e">The keyboard event arguments.</param>
    private async Task HandleMenuKeyDown(KeyboardEventArgs e)
    {
        if (!_open) return;

        if (e.Key == "Escape") { await CloseAsync(); return; }

        var enabled = _items.Where(i => !i.Disabled).ToList();
        if (enabled.Count == 0) return;

        var currentIdx = _focusedItem is not null ? enabled.IndexOf(_focusedItem) : -1;

        if (e.Key == "ArrowDown")
            _focusedItem = enabled[(currentIdx + 1) % enabled.Count];
        else if (e.Key == "ArrowUp")
            _focusedItem = enabled[((currentIdx - 1) + enabled.Count) % enabled.Count];
        else if (e.Key == "Home")
            _focusedItem = enabled[0];
        else if (e.Key == "End")
            _focusedItem = enabled[^1];
        else if (e.Key == "Tab")
        {
            // Tab cycles through menu items
            if (e.ShiftKey)
                _focusedItem = enabled[((currentIdx - 1) + enabled.Count) % enabled.Count];
            else
                _focusedItem = enabled[(currentIdx + 1) % enabled.Count];
        }
    }
}
