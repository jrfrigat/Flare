@namespace Flare.Core.Components
@inject IThemeService ThemeService

@* Emits <link> tags for static assets of registered themes/palettes.
   By default, emits ALL registered assets (required for ClassToggle switching).
   Set ActiveOnly="true" to emit only the current theme/palette CSS (smaller payload,
   but prevents runtime switching to other themes without additional CSS). *@
<HeadContent>
    @foreach (var href in _hrefs)
    {
        <link @key="href" href="@href" rel="stylesheet" />
    }
</HeadContent>

@code {
    /// <summary>
    /// When true, only emits CSS for the currently active theme and palette.
    /// Default false (emits all registered themes/palettes for runtime switching).
    /// </summary>
    [Parameter] public bool ActiveOnly { get; set; }

    private IEnumerable<string> _hrefs => ActiveOnly ? ActiveHrefs : AllHrefs;

    private IEnumerable<string> AllHrefs =>
        ThemeService.Themes.SelectMany(t => t.StyleAssets)
            .Concat(ThemeService.Palettes
                .Select(p => p.StyleAsset)
                .Where(a => !string.IsNullOrEmpty(a))
                .Select(a => a!))
            .Distinct();

    private IEnumerable<string> ActiveHrefs =>
        ThemeService.CurrentTheme.StyleAssets
            .Concat(new[] { ThemeService.CurrentPalette.StyleAsset }
                .Where(a => !string.IsNullOrEmpty(a))
                .Select(a => a!))
            .Distinct();
}
