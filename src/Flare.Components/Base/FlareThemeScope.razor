@namespace Flare.Core.Components
@implements IDisposable
@using Flare.Core.Abstractions
@using Flare.Core.Services
@using Flare.Core.Tokens

@*
   Re-themes a subtree without affecting the rest of the app. Any axis left unset inherits from the
   surrounding theme:
     <FlareThemeScope Theme="md3-expressive" Palette="violet" Mode="ThemeMode.Dark"> ... </FlareThemeScope>
   Works with the ClassToggle delivery: the wrapper carries the theme/palette/mode classes so the
   static token rules re-assert for the subtree, and a scoped IThemeService is cascaded so components
   that read the theme in C# (e.g. FlareProgress) also see the scoped values.
*@
<CascadingValue Value="@_scoped" IsFixed="false">
    <CascadingValue Value="@_snapshot" IsFixed="false">
        <div class="@_cssClass" style="@Style" data-flare-theme="@_theme.Id">
            @ChildContent
        </div>
    </CascadingValue>
</CascadingValue>

@code {
    /// <summary>Child content rendered under the scoped theme.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }
    /// <summary>Design-system theme id to apply to the subtree. Unset inherits the outer theme.</summary>
    [Parameter] public string? Theme { get; set; }
    /// <summary>Color palette id to apply to the subtree. Unset inherits the outer palette.</summary>
    [Parameter] public string? Palette { get; set; }
    /// <summary>Light/dark mode for the subtree. Unset inherits the outer mode.</summary>
    [Parameter] public ThemeMode? Mode { get; set; }
    /// <summary>Extra CSS classes for the wrapper element.</summary>
    [Parameter] public string? Class { get; set; }
    /// <summary>Inline style for the wrapper element.</summary>
    [Parameter] public string? Style { get; set; }

    [CascadingParameter] private IThemeService? Outer { get; set; }

    private ScopedThemeService _scoped = default!;
    private ThemeSnapshot _snapshot = default!;
    private ITheme _theme = default!;
    private Palette _palette = default!;
    private bool _isDark;
    private string _cssClass = string.Empty;
    private IThemeService? _subscribed;
    private int _version;

    protected override void OnInitialized()
    {
        if (Outer is null)
            throw new InvalidOperationException(
                "FlareThemeScope must be placed inside a FlareThemeProvider (no cascading IThemeService found).");
        _scoped = new ScopedThemeService(Outer);
        _snapshot = CreateSnapshot();
        Outer.OnThemeChanged += OnOuterChangedAsync;
        _subscribed = Outer;
    }

    protected override void OnParametersSet() => Resolve();

    private void Resolve()
    {
        var outer = Outer!;

        _theme = Theme is { } t && outer.Themes.FirstOrDefault(x => x.Id == t) is { } th ? th : outer.CurrentTheme;
        _palette = Palette is { } p && outer.Palettes.FirstOrDefault(x => x.Id == p) is { Id: not null } pal ? pal : outer.CurrentPalette;

        var mode = Mode ?? outer.Mode;
        _isDark = Mode switch
        {
            ThemeMode.Dark => true,
            ThemeMode.Light => false,
            _ => outer.IsDark,   // Auto / unset -> follow the outer resolved state
        };

        _cssClass = string.Join(' ',
            Css.Classes.Theme.Root,
            Css.Classes.Theme.ForTheme(_theme.Id),
            Css.Classes.Theme.ForPalette(_palette.Id),
            Css.Classes.Theme.Mode(_isDark),
            Class);

        _scoped.Set(_theme, _palette, mode, _isDark);

        // The static stylesheet only carries the active theme/palette by default; make sure this
        // scope's (possibly different) combination is emitted so its class rules actually resolve.
        _ = outer.RequireThemeAssetsAsync(_theme.Id, _palette.Id);
    }

    private async Task OnOuterChangedAsync()
    {
        Resolve();
        _snapshot = CreateSnapshot();
        await _scoped.RaiseAsync();
        await InvokeAsync(StateHasChanged);
    }

    private ThemeSnapshot CreateSnapshot()
    {
        _version++;
        return new ThemeSnapshot
        {
            Theme = _theme,
            Palette = _palette,
            IsDark = _isDark,
            Delivery = Outer?.Delivery ?? ThemeDelivery.ClassToggle,
            Version = _version
        };
    }

    public void Dispose()
    {
        if (_subscribed is not null)
            _subscribed.OnThemeChanged -= OnOuterChangedAsync;
    }
}
