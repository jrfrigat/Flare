@namespace Flare.Components
@implements IAsyncDisposable
@inject IThemeService ThemeService
@inject IThemeStorageService ThemeStorage
@inject IThemeJsService ThemeJsService
@using Flare.Abstractions.Tokens

<CascadingValue Value="@_snapshot" IsFixed="false">
    <CascadingValue Value="@ThemeService" IsFixed="false">
        <FlareStyles />

        <div class="@Css.Classes.Theme.Root @Css.Classes.Theme.ForTheme(ThemeService.CurrentTheme.Id) @Css.Classes.Theme.ForPalette(ThemeService.CurrentPalette.Id) @(ThemeService.IsHighContrast ? Css.Classes.Theme.ModeHighContrast : ThemeService.IsDark ? Css.Classes.Theme.ModeDark : null) @(ThemeService.IsRtl ? Css.Classes.Theme.Rtl : null)"
             data-flare-theme="@ThemeService.CurrentTheme.Id"
             dir="@(ThemeService.IsRtl ? "rtl" : "ltr")">
            @ChildContent
        </div>
    </CascadingValue>
</CascadingValue>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public bool RespectSystemColorScheme { get; set; } = true;

    /// <summary>
    /// When true (default), the provider fades out the anti-FOUC startup splash painted by
    /// <c>flare-bootstrap.js</c> once the theme stylesheets and web fonts have loaded and the first
    /// themed frame has painted -- so the app is revealed fully styled, with no flash of unstyled
    /// content. Set to false to manage the splash yourself (call <c>window.hideFlareSplash()</c>).
    /// </summary>
    [Parameter] public bool ManageSplash { get; set; } = true;

    private readonly string _id = Guid.NewGuid().ToString("N");
    private DotNetObjectReference<FlareThemeProvider>? _dotNetRef;
    private ThemeSnapshot _snapshot = default!;
    private int _version;

    // Dynamic Color: guard against re-entrancy (ApplyDynamicPaletteAsync raises OnThemeChanged) and
    // track which theme the current dynamic palette was generated for, so we regenerate on theme switch.
    private bool _dynamicBusy;
    private string? _dynamicThemeId;

    protected override void OnInitialized()
    {
        _snapshot = CreateSnapshot();
        ThemeService.OnThemeChanged += HandleThemeChangedAsync;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        try
        {
            await ThemeService.EnsureStaticCssAsync();

            var saved = await ThemeStorage.GetAsync();
            if (saved is { } sel)
            {
                if (ThemeService.Themes.Any(t => t.Id == sel.ThemeId))
                    await ThemeService.SetThemeAsync(sel.ThemeId);
                if (ThemeService.Palettes.Any(p => p.Id == sel.PaletteId))
                    await ThemeService.SetPaletteAsync(sel.PaletteId);
                await ThemeService.SetModeAsync(sel.Mode);
            }

            _dotNetRef = DotNetObjectReference.Create(this);

            if (RespectSystemColorScheme)
            {
                var dark = await ThemeJsService.PrefersColorSchemeDarkAsync();
                await ThemeService.SetSystemDarkAsync(dark);
                await ThemeJsService.SubscribeColorSchemeAsync(_id, _dotNetRef);
            }

            // Dynamic Color: seed the active dynamic palette from the OS accent and keep it live
            // (re-read on window focus). No-op for fixed palettes.
            if (ThemeService.IsDynamicPalette)
                await RefreshDynamicPaletteAsync();
            await ThemeJsService.SubscribeAccentAsync(_id, _dotNetRef);

            await ApplyRootClassesAsync();

            // Everything that could cause a visible flash has now settled (theme classes + static
            // CSS applied, theme stylesheets loaded, dynamic palette generated). Reveal the app once
            // the web fonts are ready, so it appears fully styled instead of flashing unstyled.
            if (ManageSplash)
                await RevealWhenReadyAsync();
        }
        catch (InvalidOperationException) { }
        catch (JSDisconnectedException) { }
    }

    // Gate the anti-FOUC splash on the last thing that still loads asynchronously after the themed
    // markup is in place: the web fonts. revealApp then waits two frames so the themed CSS paints
    // before the splash fades out.
    private async Task RevealWhenReadyAsync()
    {
        try
        {
            await ThemeJsService.WhenFontsReadyAsync();
            await ThemeJsService.RevealAppAsync();
        }
        catch (JSDisconnectedException) { }
    }

    [JSInvokable]
    public async Task OnSystemColorSchemeChanged(bool isDark)
    {
        await ThemeService.SetSystemDarkAsync(isDark);
        // The OS accent often changes together with the light/dark switch -- re-read it.
        if (ThemeService.IsDynamicPalette)
            await RefreshDynamicPaletteAsync();
        await InvokeAsync(StateHasChanged);
    }

    /// <summary>Invoked from JS when the window regains focus, in case the OS accent color changed.</summary>
    [JSInvokable]
    public async Task OnAccentColorChanged()
    {
        if (!ThemeService.IsDynamicPalette) return;
        await RefreshDynamicPaletteAsync();
        await InvokeAsync(StateHasChanged);
    }

    // Reads the OS accent color (or the configured fallback) and regenerates the dynamic palette via
    // the active theme's generator. Re-entrancy-guarded because ApplyDynamicPaletteAsync re-raises
    // OnThemeChanged.
    private async Task RefreshDynamicPaletteAsync()
    {
        if (_dynamicBusy || ThemeService.CurrentPalette.Id != Palette.DynamicId) return;
        _dynamicBusy = true;
        try
        {
            string? accent = null;
            try { accent = await ThemeJsService.GetAccentColorAsync(); } catch (JSDisconnectedException) { }
            _dynamicThemeId = ThemeService.CurrentTheme.Id;

            // A genuine OS accent (e.g. Firefox, or an installed app where the engine exposes it) seeds
            // the palette via the active theme's generator. When it is unavailable -- notably Chrome/Edge,
            // which return a placeholder rather than the real accent, so GetAccentColorAsync yields null --
            // prefer the curated fallback palette (exact colors), falling back to seed generation.
            if (!string.IsNullOrWhiteSpace(accent))
                await ThemeService.ApplyDynamicPaletteAsync(new PaletteSeed(accent!));
            else if (ThemeService.DynamicFallbackPalette is { } fallback)
                await ThemeService.ApplyDynamicPaletteAsync(fallback);
            else
                await ThemeService.ApplyDynamicPaletteAsync(new PaletteSeed(ThemeService.DynamicFallbackSeed));
        }
        finally { _dynamicBusy = false; }
    }

    private async Task ApplyRootClassesAsync()
    {
        try
        {
            foreach (var href in ThemeService.CurrentTheme.StyleAssets)
                await ThemeJsService.EnsureStylesheetAsync(href);

            await ThemeJsService.SetThemeClassesAsync(
                ThemeService.CurrentTheme.Id, ThemeService.CurrentPalette.Id, ThemeService.IsDark);
        }
        catch (JSDisconnectedException) { }
    }

    private async Task HandleThemeChangedAsync()
    {
        await ThemeStorage.SaveAsync(new ThemeSelection(
            ThemeService.CurrentTheme.Id, ThemeService.CurrentPalette.Id, ThemeService.Mode));

        // When the dynamic palette is active and the THEME changed, regenerate it with the new
        // theme's color rules (MD3 tonal vs Fluent ramp etc.). Guarded so the re-applied palette's
        // own OnThemeChanged does not recurse.
        if (!_dynamicBusy
            && ThemeService.CurrentPalette.Id == Palette.DynamicId
            && _dynamicThemeId != ThemeService.CurrentTheme.Id)
        {
            await RefreshDynamicPaletteAsync();
            return;
        }

        _snapshot = CreateSnapshot();

        await ApplyRootClassesAsync();
        await InvokeAsync(StateHasChanged);
    }

    private ThemeSnapshot CreateSnapshot()
    {
        _version++;
        return new ThemeSnapshot
        {
            Theme = ThemeService.CurrentTheme,
            Palette = ThemeService.CurrentPalette,
            IsDark = ThemeService.IsDark,
            IsHighContrast = ThemeService.IsHighContrast,
            IsRtl = ThemeService.IsRtl,
            Delivery = ThemeService.Delivery,
            Version = _version
        };
    }

    public async ValueTask DisposeAsync()
    {
        ThemeService.OnThemeChanged -= HandleThemeChangedAsync;
        try { await ThemeJsService.UnsubscribeColorSchemeAsync(_id); } catch { }
        try { await ThemeJsService.UnsubscribeAccentAsync(_id); } catch { }
        _dotNetRef?.Dispose();
    }
}
