@namespace Flare.Components
@implements IDisposable

@* A colored zone on a FlareSlider track. Registers itself with the parent slider (which draws the
   band inside the rail) and renders no DOM of its own. Use inside
   <FlareSlider><Zones>...</Zones></FlareSlider>. *@

@code {
    [CascadingParameter] private FlareSlider? Slider { get; set; }

    /// <summary>Start value of the zone on the slider scale. Clamped to the slider Min/Max; the
    /// <see cref="Start"/>/<see cref="End"/> pair is ordered, so Start may be greater than End.</summary>
    [Parameter] public double Start { get; set; }
    /// <summary>End value of the zone on the slider scale.</summary>
    [Parameter] public double End { get; set; }
    /// <summary>Zone fill color. Role (e.g. <see cref="FlareColor.Success"/>) -> shared class; custom
    /// (<c>FlareColor.Custom("#...")</c>) -> inline token. Defaults to <see cref="FlareColor.Primary"/>.</summary>
    [Parameter] public FlareColor Color { get; set; } = FlareColor.Primary;

    private bool _registered;
    private (double Start, double End, FlareColor Color)? _last;

    protected override void OnInitialized()
    {
        Slider?.RegisterZone(this);
        _registered = Slider is not null;
        _last = (Start, End, Color);
    }

    // Poke the parent to redraw only when this zone's values actually change, so the parent's
    // re-render (which re-runs this method with identical params) does not loop.
    protected override void OnParametersSet()
    {
        var sig = (Start, End, Color);
        if (_registered && _last is { } prev && !prev.Equals(sig))
            Slider?.NotifyZoneChanged();
        _last = sig;
    }

    /// <inheritdoc />
    public void Dispose() => Slider?.UnregisterZone(this);
}
