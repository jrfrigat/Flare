@namespace Flare.Components
@inherits FlareComponentBase
@inject Flare.Components.Services.IOverlayJsService Overlay

@if (_isFlyout)
{
    @* Rail flyout mode (MD3 navigation rail): the group is a collapsed icon trigger whose children
       open in a floating panel anchored next to it, so nested destinations stay reachable without
       re-opening the drawer. Hover/focus opens it; a safe-area hide delay bridges the gap to the
       panel; click toggles it for touch/keyboard. The panel is positioned fixed (via the overlay
       port) so it escapes the drawer's overflow clipping. *@
    <div class="@BuildCssClass(Css.Classes.Navigation.NavGroupFlyout)" style="@Style" @ref="_rootRef"
         @onmouseenter="ShowFlyout" @onmouseleave="ScheduleHideFlyout"
         @onfocusin="OnFlyoutFocusIn" @onfocusout="OnFlyoutFocusOut"
         @onkeydown="HandleFlyoutKeyDown" @attributes="AdditionalAttributes">
        <button class="@Css.Classes.Navigation.NavGroupHeader" @ref="_anchorRef" title="@Label"
                @onclick="ToggleFlyout" type="button"
                aria-haspopup="true" aria-expanded="@_flyoutOpen.ToString().ToLowerInvariant()"
                aria-controls="@_panelId">
            @if (Icon is not null)
            {
                <span class="material-symbols-rounded @Css.Classes.Nav.GroupIcon">@Icon</span>
            }
            <span class="@Css.Classes.Navigation.NavGroupTitle">@Label</span>
            <span class="material-symbols-rounded @Css.Classes.Nav.GroupChevron" aria-hidden="true">chevron_right</span>
        </button>
        @if (_flyoutOpen)
        {
            <div id="@_panelId" class="@Css.Classes.Navigation.NavGroupFlyoutPanel"
                 role="group" aria-label="@Label"
                 @onmouseenter="ShowFlyout" @onmouseleave="ScheduleHideFlyout">
                <div class="@Css.Classes.Navigation.NavGroupFlyoutHeader">@Label</div>
                <div class="@Css.Classes.Navigation.NavGroupFlyoutItems">
                    @* Cascade self so descendant links (and nested groups) can auto-expand this group. *@
                    <CascadingValue Value="this" IsFixed="true">
                        @ChildContent
                    </CascadingValue>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="@BuildCssClass(_expandedClass)" style="@Style" @attributes="AdditionalAttributes">
        <button class="@Css.Classes.Navigation.NavGroupHeader" title="@Label" @onclick="Toggle" aria-expanded="@_expanded.ToString().ToLowerInvariant()">
            @if (Icon is not null)
            {
                <span class="material-symbols-rounded @Css.Classes.Nav.GroupIcon">@Icon</span>
            }
            <span class="@Css.Classes.Navigation.NavGroupTitle">@Label</span>
            <span class="material-symbols-rounded @Css.Classes.Nav.GroupChevron @(_expanded ? Css.Classes.Navigation.NavGroupChevron : "")" aria-hidden="true">expand_more</span>
        </button>
        <div class="@Css.Classes.Nav.GroupItems @(_expanded ? Css.Classes.Nav.GroupItemsOpen : "")" role="group" aria-hidden="@(!_expanded)">
            <div class="@Css.Classes.Nav.GroupItemsInner">
                @* Cascade self so descendant links (and nested groups) can auto-expand this group. *@
                <CascadingValue Value="this" IsFixed="true">
                    @ChildContent
                </CascadingValue>
            </div>
        </div>
    </div>
}

@code {
    // Nearest ancestor group (set when this group is nested inside another), so expansion
    // bubbles up the whole chain when a deeply nested link becomes active.
    [CascadingParameter] private FlareNavGroup? ParentGroup { get; set; }

    // Drives the rail flyout automatically when the layout drawer is collapsed in RailFlyout mode.
    [CascadingParameter] private FlareLayoutContext? Layout { get; set; }

    /// <summary>Material Symbols icon name rendered before the label.</summary>
    [Parameter] public string? Icon { get; set; }
    /// <summary>Group title text.</summary>
    [Parameter] public string? Label { get; set; }
    /// <summary>Child nav links rendered inside the group.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }
    /// <summary>Whether the group is expanded. Supports <c>@bind-Expanded</c>.</summary>
    [Parameter] public bool Expanded { get; set; }
    /// <summary>Callback fired when the expanded state changes.</summary>
    [Parameter] public EventCallback<bool> ExpandedChanged { get; set; }
    /// <summary>
    /// Delay in milliseconds before the rail flyout hides after the pointer leaves, so the user can
    /// cross the gap from the icon to the panel without it closing. Only used in flyout mode.
    /// </summary>
    [Parameter] public int FlyoutHideDelay { get; set; } = 150;

    protected override string ComponentCssClass => Css.Classes.Navigation.NavGroup;

    // Internal expanded state. Kept separate from the Expanded parameter so an auto-expansion
    // (from an active child) is NOT reset when a parent component re-renders and re-applies the
    // original Expanded value. The parameter only re-seeds this when it actually changes.
    private bool _expanded;
    private bool _lastParamExpanded;

    private string _expandedClass => _expanded ? Css.Classes.Navigation.NavGroupExpanded : string.Empty;

    // Flyout mode applies only to top-level groups (a nested group inside a flyout panel renders
    // normally), and only while the drawer is collapsed in RailFlyout mode.
    private bool _isFlyout => ParentGroup is null && (Layout?.RailFlyout ?? false);

    private bool _flyoutOpen;
    private bool _outsideClickRegistered;
    private CancellationTokenSource? _hideCts;
    private ElementReference _rootRef;
    private ElementReference _anchorRef;
    private DotNetObjectReference<FlareNavGroup>? _dotNetRef;
    private readonly string _panelId = "flare-nav-flyout-" + Guid.NewGuid().ToString("N")[..8];
    // True while keyboard focus is anywhere inside the group (trigger or panel); drives focus return
    // when the panel auto-hides. Set by the focusin/out handlers.
    private bool _focusInside;
    // One-shot guard: Escape returns focus to the trigger, whose focusin would otherwise re-open the
    // flyout. Set just before that programmatic FocusAsync and consumed by the next focusin.
    private bool _suppressNextFocusIn;

    protected override void OnParametersSet()
    {
        if (Expanded != _lastParamExpanded)
        {
            _expanded = Expanded;
            _lastParamExpanded = Expanded;
        }
        // Leaving flyout mode (e.g. the drawer re-opened, or the mode changed) closes any open
        // flyout so OnAfterRenderAsync tears down its outside-click handler.
        if (!_isFlyout && _flyoutOpen)
        {
            _hideCts?.Cancel();
            _flyoutOpen = false;
        }
    }

    private async Task Toggle()
    {
        _expanded = !_expanded;
        await ExpandedChanged.InvokeAsync(_expanded);
    }

    /// <summary>
    /// Expands this group (and every ancestor group) in response to a descendant
    /// <c>FlareNavLink</c> becoming active. Safe to call when already expanded.
    /// </summary>
    public async Task ExpandFromChild()
    {
        var changed = !_expanded;
        if (changed)
        {
            _expanded = true;
            await ExpandedChanged.InvokeAsync(true);
        }
        if (ParentGroup is not null)
            await ParentGroup.ExpandFromChild();
        if (changed)
            StateHasChanged();
    }

    // --- Rail flyout (MD3 navigation rail) ---

    // Opens the flyout and cancels any pending hide (used by hover, focus and click-to-open).
    private void ShowFlyout()
    {
        _hideCts?.Cancel();
        _hideCts = null;
        _flyoutOpen = true;
    }

    // Focus entering the group opens the flyout (keyboard parity with hover), unless this focusin is
    // the programmatic return-to-trigger after Escape, which must not re-open it.
    private void OnFlyoutFocusIn()
    {
        _focusInside = true;
        if (_suppressNextFocusIn) { _suppressNextFocusIn = false; return; }
        ShowFlyout();
    }

    // Focus leaving the group starts the safe-area hide timer; a following focusin (e.g. tabbing
    // between panel links) re-enters and cancels it.
    private void OnFlyoutFocusOut()
    {
        _focusInside = false;
        ScheduleHideFlyout();
    }

    // Starts the safe-area hide timer; a hover/focus re-entry cancels it before it fires.
    private void ScheduleHideFlyout()
    {
        _hideCts?.Cancel();
        _hideCts = new CancellationTokenSource();
        var ct = _hideCts.Token;
        _ = Task.Delay(FlyoutHideDelay, ct).ContinueWith(_ =>
        {
            if (!ct.IsCancellationRequested)
                InvokeAsync(CloseFromHideTimer);
        }, TaskScheduler.Default);
    }

    // Closes the flyout after the hide delay. If keyboard focus was still parked inside the panel
    // (e.g. the pointer left without the user tabbing out), return focus to the trigger so it is not
    // dropped to the document body when the panel is removed.
    private async Task CloseFromHideTimer()
    {
        if (!_flyoutOpen) return;
        var returnFocus = _focusInside;
        _flyoutOpen = false;
        StateHasChanged();
        if (returnFocus)
        {
            _suppressNextFocusIn = true;
            try { await _anchorRef.FocusAsync(); } catch (JSException) { } catch (InvalidOperationException) { }
        }
    }

    // Header click toggles the flyout (so touch and keyboard users can open and close it).
    private void ToggleFlyout()
    {
        if (_flyoutOpen) { _hideCts?.Cancel(); _flyoutOpen = false; }
        else ShowFlyout();
    }

    private async Task HandleFlyoutKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape" && _flyoutOpen)
        {
            _hideCts?.Cancel();
            _flyoutOpen = false;
            // Returning focus to the trigger fires focusin on the wrapper; suppress that one so the
            // flyout does not immediately re-open.
            _suppressNextFocusIn = true;
            try { await _anchorRef.FocusAsync(); } catch (JSException) { } catch (InvalidOperationException) { }
        }
    }

    // Closes the flyout when invoked by the document outside-click handler.
    [JSInvokable]
    public Task CloseFlyoutFromJs()
    {
        if (!_flyoutOpen) return Task.CompletedTask;
        _hideCts?.Cancel();
        _flyoutOpen = false;
        return InvokeAsync(StateHasChanged);
    }

    // Like the MD3 navigation rail, the panel persists after a destination is selected (it stays
    // open while the pointer/focus remains inside), so it is NOT closed on navigation. The active
    // link simply updates; leaving the rail, Escape, an outside click, or opening another group's
    // flyout dismisses it.

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await base.OnAfterRenderAsync(firstRender);

        // The full-height panel is positioned by CSS (a column beside the rail); only the
        // outside-click dismissal needs JS interop.
        if (_isFlyout && _flyoutOpen && !_outsideClickRegistered)
        {
            _outsideClickRegistered = true;
            _dotNetRef ??= DotNetObjectReference.Create(this);
            try
            {
                // Dismiss when clicking anywhere outside the group (root contains both icon and panel).
                await Overlay.RegisterOutsideClickAsync(_panelId, _rootRef, _dotNetRef, nameof(CloseFlyoutFromJs));
            }
            catch (JSException) { }
            catch (InvalidOperationException) { }
            catch (JSDisconnectedException) { }
        }
        else if (_outsideClickRegistered && !_flyoutOpen)
        {
            _outsideClickRegistered = false;
            try { await Overlay.RemoveOutsideClickAsync(_panelId); }
            catch (JSException) { }
            catch (InvalidOperationException) { }
            catch (JSDisconnectedException) { }
        }
    }

    public override async ValueTask DisposeAsync()
    {
        _hideCts?.Cancel();
        _hideCts?.Dispose();
        if (_outsideClickRegistered)
        {
            try { await Overlay.RemoveOutsideClickAsync(_panelId); }
            catch (JSException) { }
            catch (InvalidOperationException) { }
            catch (JSDisconnectedException) { }
        }
        _dotNetRef?.Dispose();
        await base.DisposeAsync();
    }
}
