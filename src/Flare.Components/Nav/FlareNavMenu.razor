@namespace Flare.Components
@inherits FlareComponentBase

<nav class="@BuildCssClass(_noScrollbarClass, _railClass, _railLabeledClass, _framedClass)" style="@Style"
     aria-label="@(string.IsNullOrEmpty(AriaLabel) ? (FlareStrings.Nav_Navigation) : AriaLabel)"
     @attributes="AdditionalAttributes">
    @if (_framed)
    {
        @* Framed layout: Header and Footer stay pinned while the items scroll between them. The pinned
           regions hold ordinary nav items (FlareNavLink/FlareNavGroup), so they collapse to icons in a
           mini-rail exactly like the scrolling items. *@
        @if (Header is not null)
        {
            <div class="@Css.Classes.Navigation.NavMenuHeader">@Header</div>
        }
        <div class="@Css.Classes.Navigation.NavMenuScroll">@ChildContent</div>
        @if (Footer is not null)
        {
            <div class="@Css.Classes.Navigation.NavMenuFooter">@Footer</div>
        }
    }
    else
    {
        @ChildContent
    }
</nav>

@code {
    /// <summary>Navigation items rendered inside the menu.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }
    /// <summary>
    /// Optional items pinned to the top of the menu, above the scrolling area. Setting either
    /// <see cref="Header"/> or <see cref="Footer"/> switches the menu to a framed layout that fills its
    /// container's height: the header and footer stay fixed while <see cref="ChildContent"/> scrolls
    /// between them. Put ordinary nav items here so they collapse to icons in a mini-rail too.
    /// </summary>
    [Parameter] public RenderFragment? Header { get; set; }
    /// <summary>Optional items pinned to the bottom of the menu, below the scrolling area. See
    /// <see cref="Header"/> for the framed-layout behavior this enables.</summary>
    [Parameter] public RenderFragment? Footer { get; set; }
    /// <summary>Accessible label for the navigation landmark, forwarded as aria-label.</summary>
    [Parameter] public string? AriaLabel { get; set; }
    /// <summary>
    /// When true, the menu scrolls its own overflow vertically but the scrollbar is hidden
    /// (scrolling still works via wheel/touch/keyboard). Useful inside a fixed-height drawer.
    /// </summary>
    [Parameter] public bool HideScrollbar { get; set; }
    /// <summary>
    /// Mini-rail mode: collapses every item to its icon only -- link/group text, the group
    /// expand chevron and link badges are hidden and the icons are centered. When the menu is
    /// inside a <c>FlareLayout</c> with <c>MiniRail</c>, this turns on automatically while the
    /// drawer is collapsed, so no wiring is needed; set it explicitly to force the rail anywhere.
    /// Inside a layout the rail also expands into a full-width overlay while hovered or focused,
    /// so nested groups stay reachable without re-opening the drawer.
    /// </summary>
    [Parameter] public bool Rail { get; set; }

    /// <summary>
    /// Presentation of the menu (<see cref="NavMenuMode.Full"/> or <see cref="NavMenuMode.Rail"/>),
    /// decoupled from any surrounding layout. When set, it takes precedence over <see cref="Rail"/>
    /// and the collapsed-drawer auto-rail; leave it unset (null) to keep the legacy behavior.
    /// </summary>
    [Parameter] public NavMenuMode? Mode { get; set; }

    // Drives the rail automatically when the layout drawer is collapsed into its icon rail.
    [CascadingParameter] private FlareLayoutContext? Layout { get; set; }

    protected override string ComponentCssClass => Css.Classes.Navigation.NavMenu;

    // An explicit Mode wins; otherwise fall back to the Rail flag or the collapsed layout drawer.
    private bool _isRail => Mode switch
    {
        NavMenuMode.Rail or NavMenuMode.RailLabeled => true,
        NavMenuMode.Full => false,
        _ => Rail || (Layout?.RailIconOnly ?? false),
    };

    // Labeled rail (icon + caption) vs the icon-only rail.
    private bool _railLabeled => Mode == NavMenuMode.RailLabeled;

    // Framed layout (pinned header/footer + scrolling middle) turns on as soon as either slot is used.
    private bool _framed => Header is not null || Footer is not null;

    private string _noScrollbarClass => HideScrollbar ? Css.Classes.Navigation.NavMenuNoScrollbar : string.Empty;
    private string _railClass => _isRail ? Css.Classes.Navigation.NavMenuRail : string.Empty;
    private string _railLabeledClass => _railLabeled ? Css.Classes.Navigation.NavMenuRailLabeled : string.Empty;
    private string _framedClass => _framed ? Css.Classes.Navigation.NavMenuFramed : string.Empty;
}
