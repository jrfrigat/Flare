@namespace Flare.Components
@inherits FlareFieldBase
@typeparam TValue
@using System.Linq.Expressions
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@inject IJSRuntime JS

<div class="@BuildCssClass(_stateClass, _openClass, _sizeClass, _variantClass)" style="@Style" @ref="_rootEl" @attributes="AdditionalAttributes">
    @if (!string.IsNullOrEmpty(Label))
    {
        <label class="@Css.Classes.Select.Label" id="@_labelId">@Label</label>
    }
    <div class="@Css.Classes.Select.Control"
         id="@_selectId"
         @ref="_controlEl"
         style="@(Typo is { } _t ? FlareTypography.FontStyle(_t) : null)"
         role="combobox"
         aria-haspopup="listbox"
         aria-expanded="@_isOpen"
         aria-labelledby="@(!string.IsNullOrEmpty(Label) ? _labelId : null)"
         aria-invalid="@(!string.IsNullOrEmpty(_displayedError) ? "true" : null)"
         aria-describedby="@(!string.IsNullOrEmpty(_displayedError) ? _errorId : !string.IsNullOrEmpty(HelperText) ? _helperId : null)"
         aria-disabled="@(Disabled ? "true" : null)"
         tabindex="@(Disabled ? -1 : 0)"
         @onclick="ToggleDropdown"
         @onkeydown="HandleKeyDown">
        <span class="@Css.Classes.Select.Value">
            @{ var selIdx = _ordered.FindIndex(i => EqualityComparer<TValue>.Default.Equals(i, Value)); }
            @if (selIdx >= 0 && (ItemTemplate is not null || !string.IsNullOrEmpty(LabelOf(_ordered[selIdx]))))
            {
                @if (ItemTemplate is not null) { @ItemTemplate(_ordered[selIdx]) }
                else { @LabelOf(_ordered[selIdx]) }
            }
            else
            {
                <span class="@Css.Classes.Select.Placeholder">@Placeholder</span>
            }
        </span>
        <FlareIcon Name="@(_isOpen ? "expand_less" : "expand_more")" Class="@Css.Classes.Select.Arrow" />
    </div>
    @if (_isOpen)
    {
        <FlareListbox TItem="TValue"
                      @ref="_listbox"
                      Items="_ordered"
                      GroupBy="GroupBy"
                      ItemTemplate="ItemTemplate"
                      ItemLabel="LabelOf"
                      Selected="@(i => EqualityComparer<TValue>.Default.Equals(i, Value))"
                      ShowCheck="true"
                      ActiveIndex="_activeIndex"
                      OnSelect="SelectItem"
                      OptionClass="@Css.Classes.Select.Option"
                      DropdownClass="@Css.Classes.Select.Dropdown"
                      StopPropagation="true"
                      AriaLabelledBy="@(!string.IsNullOrEmpty(Label) ? _labelId : null)" />
    }
    @if (!string.IsNullOrEmpty(_displayedError))
    {
        <span id="@_errorId" class="@Css.Classes.Select.Helper @Css.Classes.Select.HelperError" role="alert">@_displayedError</span>
    }
    else if (!string.IsNullOrEmpty(HelperText))
    {
        <span id="@_helperId" class="@Css.Classes.Select.Helper">@HelperText</span>
    }
</div>

@code {
    /// <summary>Currently selected item value.</summary>
    [Parameter] public TValue? Value { get; set; }
    /// <summary>Callback invoked when the selection changes.</summary>
    [Parameter] public EventCallback<TValue?> ValueChanged { get; set; }
    /// <summary>Label text displayed above the select.</summary>
    [Parameter] public string? Label { get; set; }
    /// <summary>Placeholder text shown in the control when no item is selected.</summary>
    [Parameter] public string? Placeholder { get; set; }
    /// <summary>Helper text shown below the select.</summary>
    [Parameter] public string? HelperText { get; set; }
    /// <summary>Overrides validation with a custom error message.</summary>
    [Parameter] public string? ErrorText { get; set; }
    /// <summary>Collection of items to populate the dropdown.</summary>
    [Parameter] public IEnumerable<TValue>? Items { get; set; }
    /// <summary>Function that returns the display text for an item.</summary>
    [Parameter] public Func<TValue, string>? ItemLabel { get; set; }
    /// <summary>Custom render template for an item (control + dropdown). Overrides <see cref="ItemLabel"/> text.</summary>
    [Parameter] public RenderFragment<TValue>? ItemTemplate { get; set; }
    /// <summary>Disables the select when true.</summary>
    [Parameter] public bool Disabled { get; set; }
    /// <summary>Expression used to bind and validate the field.</summary>
    [Parameter] public Expression<Func<TValue>>? For { get; set; }
    /// <summary>Returns the group label for an item. When non-null, options are grouped under headers.</summary>
    [Parameter] public Func<TValue, string>? GroupBy { get; set; }
    /// <summary>Control size (Xs..Xl). Medium is the default field height.</summary>
    [Parameter] public FieldSize Size { get; set; } = FieldSize.Md;
    /// <summary>Optional typography scale for the control text. Overrides the size-derived font; null keeps the default.</summary>
    [Parameter] public TypographyScale? Typo { get; set; }
    /// <summary>Visual variant (Filled/Outlined) independent of the theme, shared with FlareField.
    /// Default keeps the theme's field style (MD3 filled / Fluent outlined).</summary>
    [Parameter] public InputVariant Variant { get; set; } = InputVariant.Default;

    protected override string ComponentCssClass => Css.Classes.Select.Root;

    private bool _isOpen;
    private int _activeIndex = -1;

    private readonly string _selectId = $"flare-select-{Guid.NewGuid():N}";
    private string _labelId  => $"{_selectId}-label";
    private string _errorId  => $"{_selectId}-err";
    private string _helperId => $"{_selectId}-help";

    // The options flattened in display order (groups kept contiguous) for keyboard nav + index alignment
    // with the shared FlareListbox, which renders group headers at group boundaries.
    private List<TValue> _ordered
    {
        get
        {
            var src = GroupBy is null
                ? (Items ?? Enumerable.Empty<TValue>())
                : (Items ?? Enumerable.Empty<TValue>()).GroupBy(GroupBy).SelectMany(g => g);
            return src.ToList();
        }
    }

    private string LabelOf(TValue item) => ItemLabel?.Invoke(item) ?? item?.ToString() ?? string.Empty;

    protected override void OnParametersSet() => UpdateFieldIdentifier(For);

    public override async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try
            {
                if (_outsideRegistered)
                {
                    await _module.InvokeVoidAsync("removeOutsideClick", _selectId);
                    await _module.InvokeVoidAsync("removeAnchoredPanel", _selectId);
                }
                await _module.DisposeAsync();
            }
            catch (JSDisconnectedException) { }
        }
        _selfRef?.Dispose();
        await base.DisposeAsync();
    }

    private string? _displayedError => DisplayedError(ErrorText);

    private string? _openClass => _isOpen ? Css.Classes.Select.Open : null;

    private string _stateClass =>
        Disabled ? Css.Classes.Select.Disabled :
        !string.IsNullOrEmpty(_displayedError) ? Css.Classes.Select.Error : string.Empty;

    private string _sizeClass => Size switch
    {
        FieldSize.Xs => Css.Classes.Select.SizeXs,
        FieldSize.Sm => Css.Classes.Select.SizeSm,
        FieldSize.Lg => Css.Classes.Select.SizeLg,
        FieldSize.Xl => Css.Classes.Select.SizeXl,
        _ => string.Empty,
    };

    // Reuses FlareField's variant tokens (--flare-input-*), which the control reads.
    private string? _variantClass => VariantClass(Variant);

    private void ToggleDropdown()
    {
        if (Disabled) return;
        _isOpen = !_isOpen;
        if (_isOpen)
            _activeIndex = _ordered.FindIndex(e => EqualityComparer<TValue>.Default.Equals(e, Value));
    }

    private ElementReference _rootEl;
    private ElementReference _controlEl;
    private FlareListbox<TValue>? _listbox;
    private IJSObjectReference? _module;
    private DotNetObjectReference<FlareSelect<TValue>>? _selfRef;
    private bool _outsideRegistered;

    // Close on any pointer-down outside the select via a document listener (no overlay element),
    // so the page still scrolls freely while the dropdown is open.
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_isOpen == _outsideRegistered) return;
        try
        {
            _module ??= await JS.InvokeAsync<IJSObjectReference>("import", "./_content/Flare.Components/js/flare-theme.js");
            if (_isOpen && _listbox is not null)
            {
                _selfRef ??= DotNetObjectReference.Create(this);
                await _module.InvokeVoidAsync("registerOutsideClick", _selectId, _rootEl, _selfRef, nameof(CloseFromOutside));
                // Fixed-position the dropdown under the control so a Card's overflow:hidden can't crop it.
                await _module.InvokeVoidAsync("positionAnchoredPanel", _selectId, _controlEl, _listbox.Element, new { matchWidth = true });
                _outsideRegistered = true;
            }
            else if (!_isOpen)
            {
                await _module.InvokeVoidAsync("removeOutsideClick", _selectId);
                await _module.InvokeVoidAsync("removeAnchoredPanel", _selectId);
                _outsideRegistered = false;
            }
        }
        catch (JSDisconnectedException) { }
    }

    /// <summary>Closes the dropdown; invoked from JS when a pointer-down lands outside the select.</summary>
    [JSInvokable]
    public Task CloseFromOutside()
    {
        if (!_isOpen) return Task.CompletedTask;
        _isOpen = false;
        return InvokeAsync(StateHasChanged);
    }

    private async Task SelectItem(TValue? item)
    {
        _isOpen = false;
        if (!EqualityComparer<TValue>.Default.Equals(item, Value))
        {
            await ValueChanged.InvokeAsync(item);
            NotifyFieldChanged();
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (Disabled) return;
        var list = _ordered;

        switch (e.Key)
        {
            case "Escape":
                _isOpen = false;
                break;

            case "ArrowDown":
                if (!_isOpen) { _isOpen = true; _activeIndex = Math.Max(0, list.FindIndex(x => EqualityComparer<TValue>.Default.Equals(x, Value))); }
                else _activeIndex = Math.Min(_activeIndex + 1, list.Count - 1);
                break;

            case "ArrowUp":
                if (_isOpen) _activeIndex = Math.Max(_activeIndex - 1, 0);
                break;

            case "Home":
                if (_isOpen) _activeIndex = 0;
                break;

            case "End":
                if (_isOpen) _activeIndex = list.Count - 1;
                break;

            case "Enter":
            case " ":
                if (!_isOpen) { _isOpen = true; _activeIndex = Math.Max(0, list.FindIndex(x => EqualityComparer<TValue>.Default.Equals(x, Value))); }
                else if (_activeIndex >= 0 && _activeIndex < list.Count) await SelectItem(list[_activeIndex]);
                break;

            default:
                return;
        }
    }
}
