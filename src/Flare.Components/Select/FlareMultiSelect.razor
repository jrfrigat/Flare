@namespace Flare.Components
@inherits FlareFieldBase
@implements IFlareMultiField<TValue>
@typeparam TValue
@using System.Linq.Expressions
@using Microsoft.JSInterop
@inject Flare.Components.Services.IOverlayJsService Overlay

<div class="@BuildCssClass(_stateClass, _openClass, _sizeClass, _variantClass)" style="@Style" @attributes="AdditionalAttributes" @ref="_container">
    @if (!string.IsNullOrEmpty(Label))
    {
        <label class="@Css.Classes.Input.Label" for="@_controlId">@Label</label>
    }
    <div class="@Css.Classes.Input.Field @Css.Classes.Multiselect.Control"
         id="@_controlId"
         @onclick="ToggleDropdown"
         role="combobox"
         aria-expanded="@_isOpen"
         aria-haspopup="listbox"
         aria-label="@(Label ?? Placeholder)"
         aria-disabled="@(Disabled ? "true" : null)"
         aria-readonly="@(ReadOnly ? "true" : null)"
         aria-required="@(Required ? "true" : null)"
         aria-invalid="@(!string.IsNullOrEmpty(_displayedError) ? "true" : null)"
         aria-describedby="@(!string.IsNullOrEmpty(_displayedError) ? _errorId : !string.IsNullOrEmpty(HelperText) ? _helperId : null)"
         tabindex="@(Disabled ? -1 : 0)"
         @onkeydown="HandleKeyDown">
        <span class="@Css.Classes.Multiselect.Value">
            @if (Values.Any())
            {
                @if (Chips)
                {
                    <span class="@Css.Classes.Multiselect.Chips">
                        @foreach (var v in Values)
                        {
                            <span class="@Css.Classes.Multiselect.Chip">
                                <span>@LabelFor(v)</span>
                                @if (!Disabled && !ReadOnly)
                                {
                                    <button type="button" class="@Css.Classes.Multiselect.ChipRemove"
                                            tabindex="-1" aria-label="@(FlareStrings.Input_Clear)"
                                            @onclick="@(() => ToggleItem(v))" @onclick:stopPropagation="true">&#x2715;</button>
                                }
                            </span>
                        }
                    </span>
                }
                else
                {
                    @BuildSelectedLabel()
                }
            }
            else
            {
                <span class="@Css.Classes.Input.Placeholder">@Placeholder</span>
            }
        </span>
        <FlareIcon Name="@(_isOpen ? "expand_less" : "expand_more")" Class="@Css.Classes.Input.Arrow" />
    </div>
    @if (_isOpen)
    {
        <FlareListbox TItem="TValue"
                      Items="_visibleItems"
                      GroupBy="GroupBy"
                      ItemTemplate="ItemTemplate"
                      ItemLabel="GetLabel"
                      Selected="@(item => Values.Contains(GetValue(item)))"
                      Multiple="true"
                      Virtualizable="true"
                      VirtualizeThreshold="VirtualizeThreshold"
                      ActiveIndex="_activeIndex"
                      OnSelect="@(item => ToggleItem(GetValue(item)))"
                      OptionClass="@Css.Classes.Multiselect.Option"
                      DropdownClass="@Css.Classes.Listbox.Dropdown"
                      Multiselectable="true"
                      StopPropagation="true">
            <Header>
                @if (Searchable)
                {
                    <div class="@Css.Classes.Multiselect.SearchWrap">
                        <input class="@Css.Classes.Multiselect.Search"
                               type="text"
                               style="@(Typo is { } _t ? FlareTypography.FontStyle(_t) : null)"
                               placeholder="@(FlareStrings.MultiSelect_Search)"
                               value="@_search"
                               @oninput="e => { _search = e.Value?.ToString() ?? string.Empty; _activeIndex = -1; }"
                               @onclick:stopPropagation="true" />
                    </div>
                }
                @if (ShowSelectAll && Items != null)
                {
                    var filteredAll = _visibleItems;
                    var allSelected = filteredAll.Count > 0 && filteredAll.All(i => Values.Contains(GetValue(i)));
                    var someSelected = !allSelected && filteredAll.Any(i => Values.Contains(GetValue(i)));
                    <div class="@Css.Classes.Multiselect.Option @Css.Classes.Listbox.Option @Css.Classes.Multiselect.OptionSelectAll"
                         role="option"
                         aria-selected="@allSelected"
                         @onclick="ToggleSelectAll"
                         @onclick:stopPropagation="true">
                        <FlareCheckbox Value="@(allSelected ? true : (someSelected ? (bool?)null : false))" />
                        <span>@(FlareStrings.MultiSelect_SelectAll)</span>
                    </div>
                }
            </Header>
        </FlareListbox>
    }
    @if (!string.IsNullOrEmpty(_displayedError))
    {
        <span id="@_errorId" class="@Css.Classes.Input.Helper @Css.Classes.Input.HelperError" role="alert">@_displayedError</span>
    }
    else if (!string.IsNullOrEmpty(HelperText))
    {
        <span id="@_helperId" class="@Css.Classes.Input.Helper">@HelperText</span>
    }
</div>

@code {
    private bool _isOpen;
    private string _search = string.Empty;
    private ElementReference _container;
    private readonly string _controlId = $"flare-multiselect-{Guid.NewGuid():N}";

    // Per-render memo for _visibleItems (search-filtered + ordered). It depends on _search, which changes
    // on internal input (not just OnParametersSet), so it is memoized only for the duration of one render
    // pass and cleared at both render-cycle boundaries (ShouldRender start, OnAfterRenderAsync end). This
    // dedups the several reads per render without ever handing out a stale filtered list.
    private List<TValue>? _visibleMemo;

    // value -> label lookup, rebuilt only when Items/GetValue/GetLabel change (OnParametersSet), so the
    // control summary and each selected chip resolve a label in O(1) instead of scanning Items per call.
    private readonly Dictionary<TValue, string> _labelByValue = new();

    /// <summary>Clears the per-render <c>_visibleItems</c> memo at the start of each render pass.</summary>
    protected override bool ShouldRender()
    {
        _visibleMemo = null;
        return true;
    }

    /// <inheritdoc/>
    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        UpdateFieldIdentifier(For);
        _labelByValue.Clear();
        if (Items is not null)
            foreach (var item in Items)
            {
                var value = GetValue(item);
                // First label wins (mirrors the previous FirstOrDefault); null values are not keyable.
                if (value is not null && !_labelByValue.ContainsKey(value))
                    _labelByValue[value] = GetLabel(item);
            }
    }

    private DotNetObjectReference<FlareMultiSelect<TValue>>? _selfRef;
    private bool _outsideRegistered;

    // Close on any pointer-down outside the control via a document listener (no overlay element),
    // so the page still scrolls freely while the dropdown is open.
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Drop the per-render memo once the render has committed, so any read from an event handler
        // between renders recomputes against the current search text.
        _visibleMemo = null;
        if (_isOpen == _outsideRegistered) return;
        try
        {
            if (_isOpen)
            {
                _selfRef ??= DotNetObjectReference.Create(this);
                await Overlay.RegisterOutsideClickAsync(_controlId, _container, _selfRef, nameof(CloseFromOutside));
            }
            else
            {
                await Overlay.RemoveOutsideClickAsync(_controlId);
            }
            _outsideRegistered = _isOpen;
        }
        catch (JSDisconnectedException) { }
    }

    /// <summary>Closes the dropdown; invoked from JS when a pointer-down lands outside the control.</summary>
    [JSInvokable]
    public Task CloseFromOutside()
    {
        if (!_isOpen) return Task.CompletedTask;
        _isOpen = false;
        _search = string.Empty;
        _activeIndex = -1;
        return InvokeAsync(StateHasChanged);
    }

    public override async ValueTask DisposeAsync()
    {
        if (_outsideRegistered)
        {
            try { await Overlay.RemoveOutsideClickAsync(_controlId); }
            catch (JSDisconnectedException) { }
        }
        _selfRef?.Dispose();
        await base.DisposeAsync();
    }

    /// <summary>The items to display in the dropdown.</summary>
    [Parameter] public IEnumerable<TValue>? Items { get; set; }
    /// <summary>Function to get the display label from an item.</summary>
    [Parameter] public Func<TValue, string> GetLabel { get; set; } = v => v?.ToString() ?? "";
    /// <summary>Custom render template for a dropdown option. Overrides <see cref="GetLabel"/> text in the list (the control summary still uses the label text).</summary>
    [Parameter] public RenderFragment<TValue>? ItemTemplate { get; set; }
    /// <summary>Function to get the value key from an item.</summary>
    [Parameter] public Func<TValue, TValue> GetValue { get; set; } = v => v;
    /// <summary>The bound collection of selected values (see <see cref="IFlareMultiField{TValue}"/>).</summary>
    [Parameter] public IReadOnlyList<TValue> Values { get; set; } = System.Array.Empty<TValue>();
    /// <summary>Fires when the selection changes, enabling <c>@bind-Values</c>.</summary>
    [Parameter] public EventCallback<IReadOnlyList<TValue>> ValuesChanged { get; set; }
    /// <summary>Expression used to bind and validate the field (EditContext).</summary>
    [Parameter] public Expression<Func<IReadOnlyList<TValue>>>? For { get; set; }
    /// <summary>Renders the selected values as removable chips in the control (instead of a comma list).</summary>
    [Parameter] public bool Chips { get; set; }
    /// <summary>Returns the group label for an item. When non-null, dropdown options are grouped under headers.</summary>
    [Parameter] public Func<TValue, string>? GroupBy { get; set; }
    /// <summary>Shows a search input at the top of the dropdown to filter options.</summary>
    [Parameter] public bool Searchable { get; set; }
    /// <summary>Ranks the filtered options by relevance (best match first) instead of insertion order,
    /// using <see cref="FlareSearch"/>. Has no effect without a search query.</summary>
    [Parameter] public bool Fuzzy { get; set; }
    /// <summary>Custom relevance scorer <c>(item, query) =&gt; score</c>; only positive scores are kept,
    /// ordered best-first. Overrides <see cref="Fuzzy"/>.</summary>
    [Parameter] public Func<TValue, string, double>? RankFunc { get; set; }
    /// <summary>Shows a select-all checkbox at the top of the dropdown.</summary>
    [Parameter] public bool ShowSelectAll { get; set; }
    /// <summary>When the filtered item count exceeds this threshold, the dropdown switches to virtualized rendering. Default: 50.</summary>
    [Parameter] public int VirtualizeThreshold { get; set; } = 50;
    /// <summary>Control size (Xs..Xl). Medium is the default field height.</summary>
    [Parameter] public FieldSize Size { get; set; } = FieldSize.Md;
    /// <summary>Optional typography scale for the control text. Overrides the size-derived font; null keeps the default.</summary>
    [Parameter] public TypographyScale? Typo { get; set; }
    /// <summary>Visual variant (Filled/Outlined) independent of the theme, shared with FlareField.
    /// Default keeps the theme's field style (MD3 filled / Fluent outlined).</summary>
    [Parameter] public InputVariant Variant { get; set; } = InputVariant.Default;

    protected override string ComponentCssClass => Css.Classes.Multiselect.Root;

    private string? _openClass => _isOpen ? Css.Classes.Multiselect.Open : null;

    // Shared state modifiers (parity with FlareSelect): the fused trigger's disabled/error rules key
    // off flare-input--disabled/--error, and the shared flare-input__label/__helper dimming applies.
    private string? _stateClass =>
        Disabled ? Css.Classes.Input.Disabled :
        !string.IsNullOrEmpty(_displayedError) ? Css.Classes.Input.Error : null;

    // Explicit ErrorText or the bound EditContext validation message (parity with FlareSelect).
    private string? _displayedError => DisplayedError(ErrorText);
    private string _errorId  => $"{_controlId}-err";
    private string _helperId => $"{_controlId}-help";

    private string? _sizeClass => Size switch
    {
        FieldSize.Xs => Css.Classes.Input.SizeXs,
        FieldSize.Sm => Css.Classes.Input.SizeSm,
        FieldSize.Lg => Css.Classes.Input.SizeLg,
        FieldSize.Xl => Css.Classes.Input.SizeXl,
        _ => null,
    };
    // Reuses FlareField's variant tokens (--flare-input-*), which the control reads.
    private string? _variantClass => VariantClass(Variant);

    private IEnumerable<TValue> FilteredItems
    {
        get
        {
            if (Items is null) return Enumerable.Empty<TValue>();
            if (string.IsNullOrWhiteSpace(_search)) return Items;
            if (RankFunc is not null)
                return FlareSearch.Rank(Items, i => RankFunc(i, _search));
            if (Fuzzy)
                return FlareSearch.Rank(Items, i => FlareSearch.Score(GetLabel(i), _search));
            return Items.Where(i => GetLabel(i).Contains(_search, StringComparison.OrdinalIgnoreCase));
        }
    }

    // Options in final display order (grouped contiguous when GroupBy is set) so the shared
    // FlareListbox renders group headers correctly and keyboard active index stays aligned.
    private List<TValue> _visibleItems
    {
        get
        {
            if (_visibleMemo is not null) return _visibleMemo;
            var src = GroupBy is null ? FilteredItems : FilteredItems.GroupBy(GroupBy).SelectMany(g => g);
            return _visibleMemo = src.ToList();
        }
    }

    private string LabelFor(TValue v)
    {
        if (v is not null && _labelByValue.TryGetValue(v, out var label)) return label;
        return v?.ToString() ?? "";
    }

    private string BuildSelectedLabel()
    {
        if (Items is null) return "";
        return string.Join(", ", Values.Select(LabelFor));
    }

    private void ToggleDropdown()
    {
        // ReadOnly stays focusable (unlike Disabled) but must not open the listbox.
        if (!Disabled && !ReadOnly)
        {
            _isOpen = !_isOpen;
            if (!_isOpen) _search = string.Empty;
        }
    }

    private async Task ToggleItem(TValue value)
    {
        var current = new HashSet<TValue>(Values);
        if (!current.Remove(value)) current.Add(value);
        await ValuesChanged.InvokeAsync(current.ToArray());
        NotifyFieldChanged();
    }

    private async Task ToggleSelectAll()
    {
        var filtered = _visibleItems;
        var current = new HashSet<TValue>(Values);
        var allSelected = filtered.Count > 0 && filtered.All(i => current.Contains(GetValue(i)));
        if (allSelected)
            foreach (var item in filtered) current.Remove(GetValue(item));
        else
            foreach (var item in filtered) current.Add(GetValue(item));
        await ValuesChanged.InvokeAsync(current.ToArray());
        NotifyFieldChanged();
    }

    private int _activeIndex = -1;

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (Disabled || ReadOnly) return;

        switch (e.Key)
        {
            case "Escape":
                _isOpen = false;
                _search = string.Empty;
                _activeIndex = -1;
                break;

            case "ArrowDown":
                if (!_isOpen) { _isOpen = true; _activeIndex = 0; }
                else _activeIndex = Math.Min(_activeIndex + 1, _visibleItems.Count - 1);
                break;

            case "ArrowUp":
                if (_isOpen) _activeIndex = Math.Max(_activeIndex - 1, 0);
                break;

            case "Home":
                if (_isOpen) _activeIndex = 0;
                break;

            case "End":
                if (_isOpen) _activeIndex = _visibleItems.Count - 1;
                break;

            case "Enter":
            case " ":
                if (!_isOpen) { _isOpen = true; _activeIndex = 0; }
                else if (_activeIndex >= 0)
                {
                    var list = _visibleItems;
                    if (_activeIndex < list.Count)
                        await ToggleItem(GetValue(list[_activeIndex]));
                }
                else ToggleDropdown();
                break;

            default:
                return;
        }
    }
}
