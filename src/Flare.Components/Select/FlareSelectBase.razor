@namespace Flare.Components
@inherits FlareFieldBase
@typeparam TValue
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@inject Flare.Components.Services.IOverlayJsService Overlay

@* Shared implementation of the single-value (FlareSelect) and multi-value (FlareMultiSelect) combobox.
   Owns the whole control: the trigger chrome, the anchored dropdown, keyboard navigation, outside-click
   dismissal, an in-field search input (when Searchable), virtualization, grouping, declarative <option>
   parsing and label resolution. The two public facades derive from this and only override the selection
   cardinality (single value vs. collection), the value-area rendering flags and the per-component CSS
   class names, so there is one source of behaviour for both. Visuals come from the shared .flare-input /
   .flare-select / .flare-multiselect / .flare-listbox CSS. *@

<div class="@BuildCssClass(_stateClass, _openClass, _sizeClass, _variantClass)"
     style="@Style"
     @ref="_rootEl"
     @attributes="AdditionalAttributes">
    @if (!string.IsNullOrEmpty(Label))
    {
        <label class="@Css.Classes.Input.Label" id="@_labelId">@Label</label>
    }
    <div class="@Css.Classes.Input.Field @ControlCssClass"
         id="@_controlId"
         @ref="_controlEl"
         style="@(Typo is { } _t ? FlareTypography.FontStyle(_t) : null)"
         role="@(Searchable ? null : "combobox")"
         aria-haspopup="@(Searchable ? null : "listbox")"
         aria-expanded="@(Searchable ? null : (_isOpen ? "true" : "false"))"
         aria-controls="@(!Searchable && _isOpen ? _listboxId : null)"
         aria-activedescendant="@(Searchable ? null : _activeDescendantId)"
         aria-labelledby="@(!Searchable && !string.IsNullOrEmpty(Label) ? _labelId : null)"
         aria-label="@(!Searchable && string.IsNullOrEmpty(Label) ? Placeholder : null)"
         aria-invalid="@(!Searchable && !string.IsNullOrEmpty(_displayedError) ? "true" : null)"
         aria-describedby="@(Searchable ? null : _describedBy)"
         aria-disabled="@(Disabled ? "true" : null)"
         aria-readonly="@(ReadOnly ? "true" : null)"
         aria-required="@(!Searchable && Required ? "true" : null)"
         tabindex="@(Disabled || Searchable ? -1 : 0)"
         @onclick="OnControlClick"
         @onkeydown="HandleKeyDownAsync">
        <span class="@ValueCssClass" style="@(!Multiple && Searchable && _editing ? "flex:0" : null)">
            @{ var singleIdx = Multiple ? -1 : _ordered.FindIndex(IsSelected); }
            @if (Multiple && SelectedValues.Count > 0)
            {
                @if (ChipsEnabled)
                {
                    <span class="@Css.Classes.Multiselect.Chips">
                        @foreach (var v in SelectedValues)
                        {
                            var val = v;
                            <span class="@Css.Classes.Multiselect.Chip">
                                <span>@LabelOf(val)</span>
                                @if (!Disabled && !ReadOnly)
                                {
                                    <button type="button" class="@Css.Classes.Multiselect.ChipRemove"
                                            tabindex="-1" aria-label="@FlareStrings.Input_Clear"
                                            @onclick="@(() => HandleSelectAsync(val))"
                                            @onclick:stopPropagation="true"
                                            @onmousedown:preventDefault="true">&#x2715;</button>
                                }
                            </span>
                        }
                    </span>
                }
                else
                {
                    @string.Join(", ", SelectedValues.Select(LabelOf))
                }
            }
            else if (!Multiple && singleIdx >= 0 && !_editing)
            {
                @if (ItemTemplate is not null)
                {
                    @ItemTemplate(_ordered[singleIdx])
                }
                else
                {
                    @LabelOf(_ordered[singleIdx])
                }
            }
            @if (_showPlaceholder)
            {
                <span class="@Css.Classes.Input.Placeholder">@Placeholder</span>
            }
        </span>
        @if (Searchable)
        {
            <input class="@Css.Classes.Select.Search"
                   style="@(!Multiple && !_editing ? "flex:0;width:0;min-width:0;padding:0" : null)"
                   @ref="_inputRef"
                   value="@_search"
                   placeholder="@_inputPlaceholder"
                   disabled="@Disabled"
                   readonly="@ReadOnly"
                   autocomplete="off"
                   spellcheck="false"
                   role="combobox"
                   aria-haspopup="listbox"
                   aria-expanded="@(_isOpen ? "true" : "false")"
                   aria-controls="@(_isOpen ? _listboxId : null)"
                   aria-autocomplete="list"
                   aria-activedescendant="@_activeDescendantId"
                   aria-labelledby="@(!string.IsNullOrEmpty(Label) ? _labelId : null)"
                   aria-label="@(string.IsNullOrEmpty(Label) ? Placeholder : null)"
                   aria-describedby="@_describedBy"
                   aria-required="@(Required ? "true" : null)"
                   aria-invalid="@(!string.IsNullOrEmpty(_displayedError) ? "true" : null)"
                   @oninput="OnSearchInput"
                   @onfocus="OnInputFocus"
                   @onblur="OnInputBlurAsync"
                   @onkeydown="HandleKeyDownAsync"
                   @onkeydown:stopPropagation="true" />
        }
        <FlareIcon Name="@(_isOpen ? "expand_less" : "expand_more")" Class="@Css.Classes.Input.Arrow" />
    </div>
    @if (_isOpen)
    {
        <FlareListbox TItem="TValue"
                      @ref="_listbox"
                      Id="@_listboxId"
                      Items="_visibleItems"
                      GroupBy="GroupBy"
                      ItemTemplate="ItemTemplate"
                      ItemLabel="LabelOf"
                      Selected="IsSelected"
                      Multiple="Multiple"
                      ShowCheck="@(!Multiple)"
                      Virtualizable="true"
                      VirtualizeThreshold="VirtualizeThreshold"
                      ActiveIndex="_activeIndex"
                      OnSelect="HandleSelectAsync"
                      OptionClass="@OptionCssClass"
                      DropdownClass="@DropdownCssClass"
                      Multiselectable="Multiple"
                      StopPropagation="true"
                      PreventMouseDownDefault="Searchable"
                      AriaLabelledBy="@(!string.IsNullOrEmpty(Label) ? _labelId : null)">
            <Header>
                @if (Multiple && ShowSelectAllEnabled && _ordered.Count > 0)
                {
                    var visible = _visibleItems;
                    var allSelected = visible.Count > 0 && visible.All(IsSelected);
                    var someSelected = !allSelected && visible.Any(IsSelected);
                    <div class="@OptionCssClass @Css.Classes.Listbox.Option @Css.Classes.Multiselect.OptionSelectAll"
                         role="option"
                         aria-selected="@allSelected"
                         @onclick="@(() => ToggleSelectAllAsync(visible))"
                         @onclick:stopPropagation="true">
                        <FlareCheckbox Value="@(allSelected ? true : (someSelected ? (bool?)null : false))" />
                        <span>@FlareStrings.MultiSelect_SelectAll</span>
                    </div>
                }
            </Header>
            <EmptyContent>
                @if (Searchable && !string.IsNullOrEmpty(_search))
                {
                    <div class="@Css.Classes.Select.Empty" role="status">@(NoResultsText ?? FlareStrings.Field_NoResults)</div>
                }
            </EmptyContent>
        </FlareListbox>
    }
    @if (!string.IsNullOrEmpty(_displayedError))
    {
        <span id="@_errorId" class="@Css.Classes.Input.Helper @Css.Classes.Input.HelperError" role="alert">@_displayedError</span>
    }
    else if (!string.IsNullOrEmpty(HelperText))
    {
        <span id="@_helperId" class="@Css.Classes.Input.Helper">@HelperText</span>
    }
</div>

@code {
    /// <summary>Collection of items to populate the dropdown. An alternative to declaring native
    /// <c>&lt;option&gt;</c> children via <see cref="ChildContent"/>.</summary>
    [Parameter] public IEnumerable<TValue>? Items { get; set; }

    /// <summary>Declarative options as native <c>&lt;option value=".."&gt;Label&lt;/option&gt;</c> child markup.
    /// Each option's <c>value</c> attribute is converted to <c>TValue</c> and its inner text is the label.
    /// Used instead of (and taking precedence over) the <see cref="Items"/> collection when supplied.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>Returns the display text for an item. When null, the declarative label or
    /// <c>ToString()</c> is used.</summary>
    [Parameter] public Func<TValue, string>? ItemLabel { get; set; }

    /// <summary>Custom render template for an item (used both in the trigger and the dropdown row).
    /// Overrides <see cref="ItemLabel"/> text.</summary>
    [Parameter] public RenderFragment<TValue>? ItemTemplate { get; set; }

    /// <summary>Returns the group label for an item. When non-null, options are grouped under headers.</summary>
    [Parameter] public Func<TValue, string>? GroupBy { get; set; }

    /// <summary>Shows an in-field search input in the trigger that filters the options as the user types.</summary>
    [Parameter] public bool Searchable { get; set; }

    /// <summary>Ranks the filtered options by relevance (best match first) instead of insertion order,
    /// using <see cref="FlareSearch"/>. Has no effect without a search query.</summary>
    [Parameter] public bool Fuzzy { get; set; }

    /// <summary>Custom relevance scorer <c>(item, query) =&gt; score</c>; only positive scores are kept,
    /// ordered best-first. Overrides <see cref="Fuzzy"/>.</summary>
    [Parameter] public Func<TValue, string, double>? RankFunc { get; set; }

    /// <summary>Text shown in the dropdown when a search query matches no options. When null, falls back
    /// to the localized default.</summary>
    [Parameter] public string? NoResultsText { get; set; }

    /// <summary>When the filtered option count exceeds this threshold, the dropdown switches to
    /// virtualized rendering (disabled while grouping). Default: 50.</summary>
    [Parameter] public int VirtualizeThreshold { get; set; } = 50;

    /// <summary>Control size (Xs..Xl). Medium is the default field height.</summary>
    [Parameter] public FieldSize Size { get; set; } = FieldSize.Md;

    /// <summary>Optional typography scale for the control text. Overrides the size-derived font; null keeps the default.</summary>
    [Parameter] public TypographyScale? Typo { get; set; }

    /// <summary>Visual variant (Filled/Outlined) independent of the theme, shared with FlareField.
    /// Default keeps the theme's own field style.</summary>
    [Parameter] public InputVariant Variant { get; set; } = InputVariant.Default;

    // ---- Cardinality + presentation hooks (overridden by the facades) ------------------------------

    /// <summary>True for the multi-value facade: renders leading checkboxes, keeps the dropdown open on
    /// select and shows the selection as chips or a comma list. False renders a single rich value.</summary>
    protected virtual bool Multiple => false;

    /// <summary>Closes the dropdown after a selection (single-select); the multi facade keeps it open.</summary>
    protected virtual bool CloseOnSelect => true;

    /// <summary>Renders the selection as removable chips (multi facade opt-in).</summary>
    protected virtual bool ChipsEnabled => false;

    /// <summary>Renders a select-all row at the top of the dropdown (multi facade opt-in).</summary>
    protected virtual bool ShowSelectAllEnabled => false;

    /// <summary>The currently selected value(s): a single-element (or empty) list for the single facade,
    /// the bound collection for the multi facade. Drives the trigger display.</summary>
    protected virtual IReadOnlyList<TValue> SelectedValues => System.Array.Empty<TValue>();

    /// <summary>Whether an item is currently selected (selected styling + trigger display).</summary>
    protected virtual bool IsSelected(TValue item) => false;

    /// <summary>Commits an item: sets the value (single) or toggles it in the collection (multi).</summary>
    protected virtual Task CommitAsync(TValue item) => Task.CompletedTask;

    /// <summary>Toggles selection of every currently visible item (multi select-all).</summary>
    protected virtual Task ToggleSelectAllAsync(IReadOnlyList<TValue> visible) => Task.CompletedTask;

    /// <summary>Recomputes the bound-field identifier from the facade's <c>For</c> accessor (validation).</summary>
    protected virtual void UpdateBoundField() { }

    // ---- Per-component CSS class names (overridden by the facades) ----------------------------------

    /// <summary>The component's root CSS class (default: single-select).</summary>
    protected virtual string RootCssClass => Css.Classes.Select.Root;
    /// <summary>The open-state modifier CSS class.</summary>
    protected virtual string OpenModifierClass => Css.Classes.Select.Open;
    /// <summary>The combobox trigger CSS class.</summary>
    protected virtual string ControlCssClass => Css.Classes.Select.Control;
    /// <summary>The trigger value-area CSS class.</summary>
    protected virtual string ValueCssClass => Css.Classes.Select.Value;
    /// <summary>The option-row CSS class applied on top of the shared listbox option.</summary>
    protected virtual string OptionCssClass => Css.Classes.Select.Option;
    /// <summary>The dropdown positioning CSS class (JS-anchored fixed).</summary>
    protected virtual string DropdownCssClass => Css.Classes.Select.Dropdown;

    /// <inheritdoc />
    protected override string ComponentCssClass => RootCssClass;

    // ---- State -------------------------------------------------------------------------------------

    private bool _isOpen;
    private int _activeIndex = -1;
    private string _search = string.Empty;
    private bool _editing;        // the in-field search input is focused/active (single-select swaps to it)
    private bool _focusQueued;    // request an input focus after the next render (entered edit via click)
    private CancellationTokenSource? _blurCts;  // cancellable delayed close so a re-focus keeps the field open

    // Per-render memo for the search-filtered, ordered list. Depends on _search (changes on internal
    // input, not just OnParametersSet), so it is memoized only for one render pass and cleared at both
    // render-cycle boundaries (ShouldRender start, OnAfterRenderAsync end) to never hand out a stale list.
    private List<TValue>? _visibleMemo;

    // Options in final display order (grouped contiguous when GroupBy is set), recomputed only when the
    // inputs change (OnParametersSet). Used for the single-select trigger lookup and as the unfiltered base.
    private List<TValue> _ordered = new();

    private readonly string _controlId = $"flare-select-{Guid.NewGuid():N}";
    private string _labelId => $"{_controlId}-label";
    private string _errorId => $"{_controlId}-err";
    private string _helperId => $"{_controlId}-help";
    private string _listboxId => $"{_controlId}-listbox";
    private string? _describedBy =>
        !string.IsNullOrEmpty(_displayedError) ? _errorId :
        !string.IsNullOrEmpty(HelperText) ? _helperId : null;

    // The active option's id (matches FlareListbox's per-option id scheme), so the focused combobox
    // announces the keyboard-highlighted option via aria-activedescendant. Null when closed / none active.
    private string? _activeDescendantId => _isOpen && _activeIndex >= 0 ? $"{_listboxId}-opt-{_activeIndex}" : null;

    private ElementReference _rootEl;
    private ElementReference _controlEl;
    private ElementReference _inputRef;
    private FlareListbox<TValue>? _listbox;
    private DotNetObjectReference<FlareSelectBase<TValue>>? _selfRef;
    private bool _outsideRegistered;

    private string? _displayedError => DisplayedError(ErrorText);
    private string? _openClass => _isOpen ? OpenModifierClass : null;

    // Placeholder shows in the value area only when nothing is displayed there and the in-field input is
    // not visibly holding the placeholder (multi searchable + single while editing put it on the input).
    private bool _showPlaceholder
    {
        get
        {
            if (Multiple) return SelectedValues.Count == 0 && !Searchable;
            if (_editing) return false;
            return _ordered.FindIndex(IsSelected) < 0;
        }
    }

    // Placeholder text for the in-field search input: only when nothing is selected.
    private string? _inputPlaceholder =>
        (Multiple ? SelectedValues.Count == 0 : _ordered.FindIndex(IsSelected) < 0) ? Placeholder : null;

    // Shared state modifiers: the fused trigger's disabled/error rules key off flare-input--disabled/--error,
    // and the shared flare-input__label/__helper dimming applies since those are flare-input__* elements.
    private string? _stateClass =>
        Disabled ? Css.Classes.Input.Disabled :
        !string.IsNullOrEmpty(_displayedError) ? Css.Classes.Input.Error : null;

    private string? _sizeClass => Size switch
    {
        FieldSize.Xs => Css.Classes.Input.SizeXs,
        FieldSize.Sm => Css.Classes.Input.SizeSm,
        FieldSize.Lg => Css.Classes.Input.SizeLg,
        FieldSize.Xl => Css.Classes.Input.SizeXl,
        _ => null,
    };

    // Reuses FlareField's variant tokens (--flare-input-*), which the control reads.
    private string? _variantClass => VariantClass(Variant);

    /// <summary>Clears the per-render <c>_visibleItems</c> memo at the start of each render pass.</summary>
    protected override bool ShouldRender()
    {
        _visibleMemo = null;
        return true;
    }

    /// <inheritdoc />
    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        UpdateBoundField();
        ParseDeclaredOptions();
        _ordered = BuildOrdered();
    }

    // ---- Data: ordering, search filtering and label resolution -------------------------------------

    private IEnumerable<TValue> SourceValues =>
        _declarative ? _declaredValues : (Items ?? Enumerable.Empty<TValue>());

    private List<TValue> BuildOrdered()
    {
        var values = SourceValues;
        return (GroupBy is null ? values : values.GroupBy(GroupBy).SelectMany(g => g)).ToList();
    }

    private IEnumerable<TValue> Filtered()
    {
        if (!Searchable || string.IsNullOrWhiteSpace(_search)) return SourceValues;
        if (RankFunc is not null) return FlareSearch.Rank(SourceValues, i => RankFunc(i, _search));
        if (Fuzzy) return FlareSearch.Rank(SourceValues, i => FlareSearch.Score(LabelOf(i), _search));
        return SourceValues.Where(i => LabelOf(i).Contains(_search, StringComparison.OrdinalIgnoreCase));
    }

    // Options in final display order for the dropdown (search-filtered + grouped contiguous), memoized
    // per render pass.
    private List<TValue> _visibleItems
    {
        get
        {
            if (_visibleMemo is not null) return _visibleMemo;
            var src = Filtered();
            var ordered = GroupBy is null ? src : src.GroupBy(GroupBy).SelectMany(g => g);
            return _visibleMemo = ordered.ToList();
        }
    }

    /// <summary>Resolves an item's display label: <see cref="ItemLabel"/>, then a declarative label, then
    /// <c>ToString()</c>.</summary>
    protected string LabelOf(TValue item)
    {
        if (ItemLabel is not null) return ItemLabel(item);
        if (_declarative && item is not null && _declaredLabels.TryGetValue(item, out var text)) return text;
        return item?.ToString() ?? string.Empty;
    }

    // ---- Interaction -------------------------------------------------------------------------------

    private void OnControlClick()
    {
        // ReadOnly stays focusable (unlike Disabled) but must not open the listbox.
        if (Disabled || ReadOnly) return;
        if (Searchable)
        {
            // Clicking the trigger chrome (chevron / value area) blurs the input, which schedules a close;
            // cancel it because we are re-focusing to keep the field open.
            _blurCts?.Cancel();
            _editing = true;
            if (!_isOpen)
            {
                _isOpen = true;
                _activeIndex = _visibleItems.FindIndex(IsSelected);
            }
            _focusQueued = true;
        }
        else
        {
            _isOpen = !_isOpen;
            if (_isOpen) _activeIndex = _visibleItems.FindIndex(IsSelected);
        }
    }

    private void OnInputFocus()
    {
        if (Disabled || ReadOnly) return;
        _blurCts?.Cancel();   // focus returned before a pending close fired
        _editing = true;
        if (!_isOpen)
        {
            _isOpen = true;
            _activeIndex = _visibleItems.FindIndex(IsSelected);
        }
    }

    private async Task OnInputBlurAsync()
    {
        // Let an option's click land (the listbox prevents its own mousedown default, so a within-dropdown
        // click does not blur the input). The close is cancellable: a re-focus (OnInputFocus / a trigger
        // click) cancels it so clicking the chevron or a chip does not close a field that stays focused.
        _blurCts?.Cancel();
        var cts = _blurCts = new CancellationTokenSource();
        try { await Task.Delay(150, cts.Token); }
        catch (TaskCanceledException) { return; }
        if (cts.IsCancellationRequested) return;
        _editing = false;
        _search = string.Empty;
        _isOpen = false;
        _activeIndex = -1;
        await InvokeAsync(StateHasChanged);
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        // Typing is always an edit: for single-select this reveals the input in place of the rich value
        // (so a keystroke can never drive a hidden, zero-width input after a mouse selection).
        _editing = true;
        _search = e.Value?.ToString() ?? string.Empty;
        _activeIndex = -1;
        _visibleMemo = null;
        if (!_isOpen) _isOpen = true;
    }

    private async Task HandleSelectAsync(TValue item)
    {
        await CommitAsync(item);
        if (CloseOnSelect)
        {
            _isOpen = false;
            _editing = false;
            _search = string.Empty;
        }
        else
        {
            // Multi: clear the query so the next pick starts fresh, keep the dropdown open + focused.
            _search = string.Empty;
            _activeIndex = -1;
            _visibleMemo = null;
        }
    }

    private async Task HandleKeyDownAsync(KeyboardEventArgs e)
    {
        if (Disabled || ReadOnly) return;
        var list = _visibleItems;

        switch (e.Key)
        {
            case "Escape":
                _isOpen = false;
                _search = string.Empty;
                _editing = false;
                _activeIndex = -1;
                break;

            case "ArrowDown":
                if (!_isOpen) { _isOpen = true; _activeIndex = Math.Max(0, list.FindIndex(IsSelected)); }
                else _activeIndex = Math.Min(_activeIndex + 1, list.Count - 1);
                break;

            case "ArrowUp":
                if (_isOpen) _activeIndex = Math.Max(_activeIndex - 1, 0);
                break;

            case "Home":
                // While searching, Home/End are text-caret navigation in the input.
                if (_isOpen && !Searchable) _activeIndex = 0;
                else return;
                break;

            case "End":
                if (_isOpen && !Searchable) _activeIndex = list.Count - 1;
                else return;
                break;

            case "Enter":
                if (!_isOpen) { _isOpen = true; _activeIndex = Math.Max(0, list.FindIndex(IsSelected)); }
                else if (_activeIndex >= 0 && _activeIndex < list.Count) await HandleSelectAsync(list[_activeIndex]);
                break;

            case " ":
                // Space types a space in the search input; only toggles when not editable.
                if (Searchable) return;
                if (!_isOpen) { _isOpen = true; _activeIndex = Math.Max(0, list.FindIndex(IsSelected)); }
                else if (_activeIndex >= 0 && _activeIndex < list.Count) await HandleSelectAsync(list[_activeIndex]);
                break;

            case "Backspace":
                // Empty query + a selection -> remove the last selected (chip), mirroring the tag field.
                if (Searchable && Multiple && string.IsNullOrEmpty(_search) && SelectedValues.Count > 0)
                    await CommitAsync(SelectedValues[^1]);
                else return;
                break;

            default:
                return;
        }
    }

    // ---- Anchored positioning + outside-click dismissal --------------------------------------------

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Drop the per-render memo once the render has committed, so any read from an event handler
        // between renders recomputes against the current search text.
        _visibleMemo = null;

        if (_focusQueued)
        {
            _focusQueued = false;
            try { await _inputRef.FocusAsync(); } catch (JSException) { } catch (InvalidOperationException) { }
        }

        if (_isOpen == _outsideRegistered) return;
        try
        {
            if (_isOpen && _listbox is not null)
            {
                _selfRef ??= DotNetObjectReference.Create(this);
                await Overlay.RegisterOutsideClickAsync(_controlId, _rootEl, _selfRef, nameof(CloseFromOutside));
                // Fixed-position the dropdown under the control so a Card's overflow:hidden can't crop it.
                await Overlay.PositionAnchoredPanelAsync(_controlId, _controlEl, _listbox.Element, new { matchWidth = true });
                _outsideRegistered = true;
            }
            else if (!_isOpen)
            {
                await Overlay.RemoveOutsideClickAsync(_controlId);
                await Overlay.RemoveAnchoredPanelAsync(_controlId);
                _outsideRegistered = false;
            }
        }
        catch (JSDisconnectedException) { }
    }

    /// <summary>Closes the dropdown; invoked from JS when a pointer-down lands outside the control.</summary>
    [JSInvokable]
    public Task CloseFromOutside()
    {
        if (!_isOpen) return Task.CompletedTask;
        _isOpen = false;
        _editing = false;
        _search = string.Empty;
        _activeIndex = -1;
        return InvokeAsync(StateHasChanged);
    }

    /// <inheritdoc />
    public override async ValueTask DisposeAsync()
    {
        if (_outsideRegistered)
        {
            try
            {
                await Overlay.RemoveOutsideClickAsync(_controlId);
                await Overlay.RemoveAnchoredPanelAsync(_controlId);
            }
            catch (JSDisconnectedException) { }
        }
        _blurCts?.Cancel();
        _blurCts?.Dispose();
        _selfRef?.Dispose();
        await base.DisposeAsync();
    }
}
