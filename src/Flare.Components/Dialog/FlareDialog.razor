@namespace Flare.Components
@inherits FlareComponentBase
@inject Flare.Components.Services.IOverlayJsService Overlay
@inject Flare.Components.Services.IDialogDragJsService DialogDrag
@inject NavigationManager Navigation
@implements IAsyncDisposable

@if (Visible)
{
    <div class="@_scrimClass" @onclick="HandleScrimClick">
        <div class="@BuildCssClass(_sizeClass, _positionClass, _draggableClass, PanelClass)" style="@Style" @onclick:stopPropagation="true"
             @attributes="AdditionalAttributes"
             role="dialog" aria-modal="true"
             aria-labelledby="@(string.IsNullOrEmpty(Title) ? null : _titleId)"
             aria-label="@(string.IsNullOrEmpty(Title) ? AriaLabel : null)"
             aria-describedby="@_contentId"
             @ref="_dialogEl">
            @if (ShowGrabber && Position == DialogPosition.Bottom)
            {
                <div class="@Css.Classes.Dialog.Grabber" aria-hidden="true"></div>
            }
            @if (ShowCloseButton)
            {
                <button type="button" class="@Css.Classes.Dialog.CloseButton" aria-label="@FlareStrings.Dialog_Close"
                        @onclick="HandleCloseButton">
                    <span class="material-symbols-rounded" aria-hidden="true">close</span>
                </button>
            }
            @if (Icon is not null)
            {
                <div class="@Css.Classes.Dialog.Icon" aria-hidden="true">@Icon</div>
            }
            @if (_showHeader)
            {
                <div class="@Css.Classes.Dialog.Header @(Icon is not null ? Css.Classes.Dialog.HeaderCentered : null) @(Draggable ? Css.Classes.Dialog.DragHandle : null)"
                     @ref="_headerEl">
                    @if (!string.IsNullOrEmpty(Title))
                    {
                        <h2 class="@Css.Classes.Dialog.Title" id="@_titleId">@Title</h2>
                    }
                </div>
            }
            @if (Divider)
            {
                <div class="@Css.Classes.Dialog.Divider" role="separator"></div>
            }
            <div class="@Css.Classes.Dialog.Content" id="@_contentId">
                @ChildContent
            </div>
            @if (Actions is not null)
            {
                <div class="@Css.Classes.Dialog.Actions">
                    @Actions
                </div>
            }
            @if (Resizable)
            {
                <div class="@Css.Classes.Dialog.Resizer" @ref="_resizerEl" aria-hidden="true"></div>
            }
        </div>
    </div>
}

@code {
    /// <summary>Controls whether the dialog is shown.</summary>
    [Parameter] public bool Visible { get; set; }
    /// <summary>Callback raised when visibility should change.</summary>
    [Parameter] public EventCallback<bool> VisibleChanged { get; set; }
    /// <summary>Title text displayed in the dialog header.</summary>
    [Parameter] public string? Title { get; set; }
    /// <summary>Accessible name for a header-less dialog (rendered as <c>aria-label</c> when
    /// <see cref="Title"/> is empty). Ignored when a title is present, since the title labels the dialog.</summary>
    [Parameter] public string? AriaLabel { get; set; }
    /// <summary>Optional hero icon shown centered above the title.</summary>
    [Parameter] public RenderFragment? Icon { get; set; }
    /// <summary>Shows a divider between the header and the content.</summary>
    [Parameter] public bool Divider { get; set; }
    /// <summary>Main body content rendered inside the dialog.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }
    /// <summary>Action buttons rendered in the dialog footer.</summary>
    [Parameter] public RenderFragment? Actions { get; set; }
    /// <summary>Closes the dialog when the scrim backdrop is clicked.</summary>
    [Parameter] public bool CloseOnScrimClick { get; set; } = true;
    /// <summary>Closes the dialog when the Escape key is pressed.</summary>
    [Parameter] public bool CloseOnEsc { get; set; } = true;
    /// <summary>Dismisses the dialog automatically when the app navigates to a new route. Default <see langword="true"/>.</summary>
    [Parameter] public bool CloseOnNavigation { get; set; } = true;
    /// <summary>Shows a built-in close (X) button in the top corner of the panel.</summary>
    [Parameter] public bool ShowCloseButton { get; set; }
    /// <summary>Lets the user move the dialog by dragging its header.</summary>
    [Parameter] public bool Draggable { get; set; }
    /// <summary>Lets the user resize the dialog from a bottom-right gripper.</summary>
    [Parameter] public bool Resizable { get; set; }
    /// <summary>Optional guard consulted before a scrim / Escape / close-button dismissal. Return
    /// <see langword="true"/> to allow the close or <see langword="false"/> to veto it (e.g. to keep the
    /// dialog open while there are unsaved changes).</summary>
    [Parameter] public Func<DialogCloseReason, ValueTask<bool>>? BeforeClose { get; set; }
    /// <summary>Maximum width of the dialog.</summary>
    [Parameter] public DialogSize Size { get; set; } = DialogSize.Md;
    /// <summary>Where the dialog is anchored. <see cref="DialogPosition.Bottom"/> renders a slide-up bottom sheet.</summary>
    [Parameter] public DialogPosition Position { get; set; } = DialogPosition.Center;
    /// <summary>Shows a drag-grabber handle at the top (only for <see cref="DialogPosition.Bottom"/> sheets).</summary>
    [Parameter] public bool ShowGrabber { get; set; }
    /// <summary>Extra CSS class(es) applied to the dialog panel.</summary>
    [Parameter] public string? PanelClass { get; set; }
    /// <summary>Extra CSS class(es) applied to the scrim/backdrop.</summary>
    [Parameter] public string? ScrimClass { get; set; }

    protected override string ComponentCssClass => Css.Classes.Dialog.Root;

    private string _positionClass => Position == DialogPosition.Bottom ? Css.Classes.Dialog.PositionBottom : string.Empty;
    private string _draggableClass => Draggable ? Css.Classes.Dialog.Draggable : string.Empty;
    // Render a header bar whenever there is a title or the dialog is draggable (the header is the drag handle).
    private bool _showHeader => !string.IsNullOrEmpty(Title) || Draggable;

    // Scrim = base + (bottom-aligned when a sheet) + any caller scrim class.
    private string _scrimClass => string.Join(' ', new[]
    {
        Css.Classes.Dialog.Scrim,
        Position == DialogPosition.Bottom ? Css.Classes.Dialog.ScrimBottom : null,
        ScrimClass,
    }.Where(c => !string.IsNullOrEmpty(c)));

    private readonly string _id = Guid.NewGuid().ToString("N")[..8];
    private string _titleId   => $"flare-dialog-title-{_id}";
    private string _contentId => $"flare-dialog-content-{_id}";
    private string? _sizeClass;
    private ElementReference _dialogEl;
    private ElementReference _headerEl;
    private ElementReference _resizerEl;
    private DotNetObjectReference<FlareDialog>? _dotNetRef;
    private bool _wasVisible;

    protected override void OnInitialized()
    {
        base.OnInitialized();
        Navigation.LocationChanged += HandleLocationChanged;
    }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        _sizeClass = Size switch
        {
            DialogSize.Xs         => Css.Classes.Dialog.SizeXs,
            DialogSize.Sm         => Css.Classes.Dialog.SizeSm,
            DialogSize.Lg         => Css.Classes.Dialog.SizeLg,
            DialogSize.Xl         => Css.Classes.Dialog.SizeXl,
            DialogSize.FullScreen => Css.Classes.Dialog.SizeFull,
            DialogSize.FullWidth  => Css.Classes.Dialog.Fullwidth,
            _                     => Css.Classes.Dialog.SizeMd,
        };
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Visible && !_wasVisible)
        {
            _wasVisible = true;
            try
            {
                _dotNetRef ??= DotNetObjectReference.Create(this);

                await Overlay.LockBodyScrollAsync();

                if (CloseOnEsc)
                    await Overlay.RegisterDialogEscAsync(_id, _dotNetRef);

                await Overlay.TrapFocusAsync(_id, _dialogEl);

                if (Draggable)
                    await DialogDrag.RegisterDragAsync(_headerEl, _dialogEl);
                if (Resizable)
                    await DialogDrag.RegisterResizeAsync(_resizerEl, _dialogEl, "240", "160");
            }
            catch { /* SSR or pre-render: JS not available */ }
        }
        else if (!Visible && _wasVisible)
        {
            _wasVisible = false;
            try
            {
                await Overlay.UnlockBodyScrollAsync();
                await Overlay.RemoveDialogEscAsync(_id);
                await Overlay.ReleaseFocusTrapAsync(_id);
                if (Draggable) await DialogDrag.RemoveDragAsync(_headerEl);
                if (Resizable) await DialogDrag.RemoveResizeAsync(_resizerEl);
            }
            catch { }
        }
    }

    [JSInvokable]
    public async Task CloseFromEsc()
    {
        if (CloseOnEsc)
            await TryCloseAsync(DialogCloseReason.EscapeKey);
    }

    private async Task HandleScrimClick()
    {
        if (CloseOnScrimClick)
            await TryCloseAsync(DialogCloseReason.ScrimClick);
    }

    private Task HandleCloseButton() => TryCloseAsync(DialogCloseReason.CloseButton);

    // Consults the BeforeClose guard (if any) before dismissing; a false result vetoes the close.
    private async Task TryCloseAsync(DialogCloseReason reason)
    {
        if (BeforeClose is not null && !await BeforeClose(reason))
            return;
        await VisibleChanged.InvokeAsync(false);
    }

    // Auto-dismiss on navigation (opt-out via CloseOnNavigation); navigation cannot be vetoed, so the
    // BeforeClose guard is not consulted here.
    private void HandleLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
        => InvokeAsync(async () =>
        {
            if (Visible && CloseOnNavigation)
                await VisibleChanged.InvokeAsync(false);
        });

    public override async ValueTask DisposeAsync()
    {
        Navigation.LocationChanged -= HandleLocationChanged;
        // If the dialog is still open when disposed (e.g. page navigation), release locks/handlers.
        if (_wasVisible)
        {
            try { await Overlay.UnlockBodyScrollAsync(); } catch { }
            if (Draggable) { try { await DialogDrag.RemoveDragAsync(_headerEl); } catch { } }
            if (Resizable) { try { await DialogDrag.RemoveResizeAsync(_resizerEl); } catch { } }
        }
        try { await Overlay.RemoveDialogEscAsync(_id); } catch { }
        try { await Overlay.ReleaseFocusTrapAsync(_id); } catch { }
        _dotNetRef?.Dispose();
        await base.DisposeAsync();
    }
}
