@namespace Flare.Components
@inherits FlareFieldBase
@inject Flare.Components.Services.IElementJsService Element
@inject IFlareClipboard Clipboard
@using System.Linq.Expressions

@* OTP composes the shared FlareFieldChrome frame (label + helper/error + variant/size/state) like the rest
   of the field family; the N-cell row is a group control in the Field slot and keeps its own look, wired to
   the label via aria-labelledby (not a single for=) exactly like the div-trigger Select. *@

<FlareFieldChrome Variant="Variant" Size="Size"
                  Invalid="@_invalid"
                  Disabled="Disabled" ReadOnly="ReadOnly"
                  Label="@Label" LabelId="@_labelId"
                  HelperText="@HelperText" HelperId="@HelperId"
                  ErrorText="@DisplayedErrorText" ErrorId="@ErrorId"
                  Style="@Style" Attributes="AdditionalAttributes">
    <Field>
        <div class="@BuildCssClass(_disabledClass)"
             role="group"
             aria-labelledby="@(string.IsNullOrEmpty(Label) ? null : _labelId)"
             aria-label="@(string.IsNullOrEmpty(Label) ? (AriaLabel ?? FlareStrings.OtpInput_GroupLabel) : null)"
             aria-describedby="@SupportDescribedBy"
             aria-invalid="@(_invalid ? "true" : null)">
            @for (var i = 0; i < Length; i++)
            {
                var idx = i;
                <input class="@Css.Classes.Otp.Cell @(idx == _active ? Css.Classes.Otp.CellFocused : "") @(_invalid ? Css.Classes.Otp.CellError : "")"
                       type="@_inputType"
                       inputmode="@InputMode"
                       maxlength="1"
                       value="@(_digits[idx])"
                       disabled="@Disabled"
                       readonly="@ReadOnly"
                       autocomplete="@AutoComplete"
                       aria-label="@(string.Format(FlareStrings.OtpInput_CellLabel, idx + 1, Length))"
                       @ref="_refs[idx]"
                       @oninput="@(e => OnInput(e, idx))"
                       @onkeydown="@(e => OnKeyDown(e, idx))"
                       @onfocus="@(() => _active = idx)"
                       @onblur="@(() => _active = -1)"
                       @onpaste="@(e => OnPaste(e))" />
            }
        </div>
    </Field>
</FlareFieldChrome>

@code {
    /// <summary>Number of OTP digits. Default is 6.</summary>
    [Parameter] public int Length { get; set; } = 6;
    /// <summary>Current value as a string of digits. Supports @bind-Value. Empty string means no input.</summary>
    [Parameter] public string Value { get; set; } = string.Empty;
    /// <summary>Callback fired when the value changes.</summary>
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    /// <summary>Callback fired when all digits are filled.</summary>
    [Parameter] public EventCallback<string> OnComplete { get; set; }
    /// <summary>When true, hides digits like a password field.</summary>
    [Parameter] public bool Masked { get; set; }
    /// <summary>Numeric input mode (default). Set to "text" for alphanumeric codes.</summary>
    [Parameter] public string InputMode { get; set; } = "numeric";
    /// <summary>Forces the error (invalid) visual state on all cells without a message. The error state is
    /// also shown automatically whenever <see cref="FlareFieldBase.ErrorText"/> or a bound validation message is present.</summary>
    [Parameter] public bool Error { get; set; }
    /// <summary>ARIA group label, used only when no <see cref="FlareFieldBase.Label"/> is set. When null, falls back to the localizer key OtpInput_GroupLabel.</summary>
    [Parameter] public string? AriaLabel { get; set; }
    /// <summary>HTML autocomplete value for each input cell. Use "one-time-code" to enable browser OTP autofill. Default: "off".</summary>
    [Parameter] public string AutoComplete { get; set; } = "off";
    /// <summary>Focuses the first cell on first render (best-effort).</summary>
    [Parameter] public bool Autofocus { get; set; }
    /// <summary>Expression used to bind and validate the field inside an <c>EditForm</c>.</summary>
    [Parameter] public Expression<Func<string>>? For { get; set; }
    // Label, HelperText, ErrorText, Disabled, ReadOnly, Required, Variant, Size are inherited from FlareFieldBase.

    protected override string ComponentCssClass => Css.Classes.Otp.Root;
    private string _disabledClass => Disabled ? Css.Classes.Otp.Disabled : string.Empty;
    private string _inputType => Masked ? "password" : "text";
    private string _labelId => $"{ControlId}-label";
    // Error is on when explicitly forced (Error) or when a message/validation error is displayed.
    private bool _invalid => Error || !string.IsNullOrEmpty(DisplayedErrorText);

    private string[] _digits = [];
    private ElementReference[] _refs = [];
    private int _active = -1;

    protected override void OnParametersSet()
    {
        if (_digits.Length != Length)
        {
            _digits = new string[Length];
            _refs = new ElementReference[Length];
        }

        for (var i = 0; i < Length; i++)
            _digits[i] = i < Value.Length ? Value[i].ToString() : string.Empty;

        UpdateFieldIdentifier(For);
    }

    private bool _autofocused;

    /// <inheritdoc />
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && Autofocus && !_autofocused && !Disabled)
        {
            _autofocused = true;
            await FocusCell(0);
        }
    }

    /// <summary>Sets keyboard focus to the first OTP cell.</summary>
    public ValueTask FocusAsync() => new(FocusCell(0));

    private async Task OnInput(ChangeEventArgs e, int idx)
    {
        var text = e.Value?.ToString() ?? string.Empty;
        if (string.IsNullOrEmpty(text))
        {
            _digits[idx] = string.Empty;
        }
        else
        {
            _digits[idx] = text[^1].ToString();
            if (idx < Length - 1)
                await FocusCell(idx + 1);
        }

        await NotifyChange();
    }

    private async Task OnKeyDown(KeyboardEventArgs e, int idx)
    {
        switch (e.Key)
        {
            case "Backspace":
                if (string.IsNullOrEmpty(_digits[idx]) && idx > 0)
                {
                    _digits[idx - 1] = string.Empty;
                    await FocusCell(idx - 1);
                    await NotifyChange();
                }
                else if (!string.IsNullOrEmpty(_digits[idx]))
                {
                    _digits[idx] = string.Empty;
                    await NotifyChange();
                }
                break;
            case "ArrowLeft":
                if (idx > 0) await FocusCell(idx - 1);
                break;
            case "ArrowRight":
                if (idx < Length - 1) await FocusCell(idx + 1);
                break;
            case "Delete":
                _digits[idx] = string.Empty;
                await NotifyChange();
                break;
        }
    }

    private async Task OnPaste(ClipboardEventArgs e)
    {
        var text = await Clipboard.ReadAsync();
        if (string.IsNullOrEmpty(text)) return;
        var clean = new string(text.Where(c => char.IsLetterOrDigit(c)).ToArray());
        for (var i = 0; i < Length && i < clean.Length; i++)
            _digits[i] = clean[i].ToString();
        var focus = Math.Min(clean.Length, Length - 1);
        await FocusCell(focus);
        await NotifyChange();
    }

    private async Task NotifyChange()
    {
        var value = string.Concat(_digits);
        await ValueChanged.InvokeAsync(value);
        NotifyFieldChanged();
        if (value.Length == Length && _digits.All(d => !string.IsNullOrEmpty(d)))
            await OnComplete.InvokeAsync(value);
        StateHasChanged();
    }

    private async Task FocusCell(int idx)
    {
        _active = idx;
        try { await Element.FocusAndSelectAsync(_refs[idx]); }
        catch { /* ignore if not yet rendered */ }
    }

    /// <summary>Clears all digits and focuses the first cell.</summary>
    public async Task ClearAsync()
    {
        for (var i = 0; i < Length; i++) _digits[i] = string.Empty;
        await ValueChanged.InvokeAsync(string.Empty);
        await FocusCell(0);
        StateHasChanged();
    }
}
