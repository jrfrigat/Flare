@namespace Flare.Components
@inherits FlareComponentBase
@inject Flare.Components.Services.IOverlayJsService Overlay
@implements IAsyncDisposable

@if (Open && Variant == DrawerVariant.Temporary)
{
    <div class="@Css.Classes.Drawer.Scrim @_autoCloseScrimClass" @onclick="CloseDrawer" aria-hidden="true" />
}

<div class="@BuildCssClass(_anchorClass, _openClass, _variantClass, _autoCloseClass)"
     style="@_sizeStyle @Style"
     role="@_role"
     aria-modal="@(Variant is DrawerVariant.Temporary or DrawerVariant.Persistent ? "true" : null)"
     aria-label="@AriaLabel"
     @ref="_drawerEl"
     @attributes="AdditionalAttributes">
    @if (Header is not null)
    {
        <div class="@Css.Classes.Drawer.Header">
            @Header
        </div>
    }
    <div class="@Css.Classes.Drawer.Content">
        @ChildContent
    </div>
</div>

@code {
    /// <summary>Controls whether the drawer is visible.</summary>
    [Parameter] public bool Open { get; set; }
    /// <summary>Callback fired when the drawer open state changes.</summary>
    [Parameter] public EventCallback<bool> OpenChanged { get; set; }
    /// <summary>Main content rendered inside the drawer body.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }
    /// <summary>Optional header content shown above the body.</summary>
    [Parameter] public RenderFragment? Header { get; set; }
    /// <summary>Drawer variant - temporary (slides in/out, default), permanent (always visible), or mini (icon-only, expands on hover).</summary>
    [Parameter] public DrawerVariant Variant { get; set; } = DrawerVariant.Temporary;
    /// <summary>Edge from which the drawer slides in.</summary>
    [Parameter] public DrawerAnchor Anchor { get; set; } = DrawerAnchor.Left;
    /// <summary>Width applied to left/right anchored drawers.</summary>
    [Parameter] public string Width { get; set; } = "280px";
    /// <summary>Height applied to top/bottom anchored drawers.</summary>
    [Parameter] public string Height { get; set; } = "320px";
    /// <summary>Closes the drawer when the scrim backdrop is clicked.</summary>
    [Parameter] public bool CloseOnScrimClick { get; set; } = true;
    /// <summary>Closes the drawer when the Escape key is pressed.</summary>
    [Parameter] public bool CloseOnEsc { get; set; } = true;
    /// <summary>Accessible label for the drawer dialog element.</summary>
    [Parameter] public string AriaLabel { get; set; } = "Drawer";
    /// <summary>Breakpoint below which the drawer is automatically hidden.</summary>
    [Parameter] public Breakpoint? AutoCloseBelow { get; set; }

    protected override string ComponentCssClass => Css.Classes.Drawer.Root;

    private readonly string _id = Guid.NewGuid().ToString("N")[..8];
    private DotNetObjectReference<FlareDrawer>? _dotNetRef;
    private bool _wasOpen;

    private string? _anchorClass;
    private string? _openClass;
    private string? _variantClass;
    private string? _autoCloseClass;
    private string? _autoCloseScrimClass;

    private string _role => Variant is DrawerVariant.Temporary or DrawerVariant.Persistent ? "dialog" : "navigation";

    private string _sizeStyle => Anchor is DrawerAnchor.Left or DrawerAnchor.Right
        ? $"width:{Width};"
        : $"height:{Height};";

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        _anchorClass = $"flare-drawer--{Anchor.ToString().ToLowerInvariant()}";

        _openClass = Variant == DrawerVariant.Temporary && Open ? Css.Classes.Drawer.Open : null;

        _variantClass = Variant switch
        {
            DrawerVariant.Permanent => Css.Classes.Drawer.Permanent,
            DrawerVariant.Mini      => Css.Classes.Drawer.Mini,
            _                       => null,
        };

        _autoCloseClass = AutoCloseBelow switch
        {
            Breakpoint.Sm => Css.Classes.Drawer.AcSm,
            Breakpoint.Md => Css.Classes.Drawer.AcMd,
            Breakpoint.Lg => Css.Classes.Drawer.AcLg,
            Breakpoint.Xl => Css.Classes.Drawer.AcXl,
            _             => null,
        };

        _autoCloseScrimClass = AutoCloseBelow switch
        {
            Breakpoint.Sm => Css.Classes.Drawer.ScrimAcSm,
            Breakpoint.Md => Css.Classes.Drawer.ScrimAcMd,
            Breakpoint.Lg => Css.Classes.Drawer.ScrimAcLg,
            Breakpoint.Xl => Css.Classes.Drawer.ScrimAcXl,
            _             => null,
        };
    }

    private ElementReference _drawerEl;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Open && !_wasOpen && Variant == DrawerVariant.Temporary)
        {
            _wasOpen = true;
            try
            {
                _dotNetRef ??= DotNetObjectReference.Create(this);

                if (CloseOnEsc)
                    await Overlay.RegisterDialogEscAsync(_id, _dotNetRef);

                await Overlay.TrapFocusAsync(_id, _drawerEl);
            }
            catch (InvalidOperationException) { }
            catch (JSDisconnectedException) { }
        }
        else if (!Open && _wasOpen && Variant == DrawerVariant.Temporary)
        {
            _wasOpen = false;
            try { await Overlay.RemoveDialogEscAsync(_id); } catch { }
            try { await Overlay.ReleaseFocusTrapAsync(_id); } catch { }
        }
    }

    [JSInvokable]
    public async Task CloseFromEsc()
    {
        if (CloseOnEsc)
            await OpenChanged.InvokeAsync(false);
    }

    private async Task CloseDrawer()
    {
        if (CloseOnScrimClick)
            await OpenChanged.InvokeAsync(false);
    }

    public override async ValueTask DisposeAsync()
    {
        try { await Overlay.RemoveDialogEscAsync(_id); } catch { }
        try { await Overlay.ReleaseFocusTrapAsync(_id); } catch { }
        _dotNetRef?.Dispose();
        await base.DisposeAsync();
    }
}
