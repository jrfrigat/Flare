@namespace Flare.Components
@inherits FlareComponentBase

@if (_isSvg)
{
    <svg class="@BuildCssClass(Css.Classes.Icon.Svg, Color.CssClass)"
         viewBox="@ViewBox"
         width="1em"
         height="1em"
         fill="currentColor"
         style="@_svgStyle"
         aria-label="@AriaLabel"
         aria-hidden="@(AriaLabel is null ? "true" : null)"
         role="@(AriaLabel is not null ? "img" : null)"
         @attributes="AdditionalAttributes">
        @if (_isMarkup)
        {
            @((MarkupString)Icon!)
        }
        else
        {
            <path d="@Icon" />
        }
    </svg>
}
else
{
    <span class="@BuildCssClass("material-symbols-rounded", Color.CssClass)"
          style="@_inlineStyle"
          aria-hidden="@(string.IsNullOrEmpty(AriaLabel) ? "true" : null)"
          role="@(string.IsNullOrEmpty(AriaLabel) ? null : "img")"
          aria-label="@AriaLabel"
          @attributes="AdditionalAttributes">@_iconContent</span>
}

@code {
    /// <summary>Material Symbols icon name (e.g. "home", "chevron_left").</summary>
    [Parameter] public string? Name { get; set; }
    /// <summary>
    /// SVG path data or full SVG markup (rendered verbatim), or a legacy Material Symbol name.
    /// Prefer <see cref="Name"/> for Material Symbols. SECURITY: markup is emitted without
    /// sanitization, so only pass trusted, developer-authored values (e.g. <c>Icons.*</c>) here --
    /// never untrusted/user input.
    /// </summary>
    [Parameter] public string? Icon { get; set; }
    /// <summary>
    /// Icon size as any CSS length (e.g. "3rem", "48px", "1.5em"). Applies to BOTH SVG and
    /// Material Symbols icons (the icon box is 1em, so size is driven by font-size). When unset,
    /// inherits the themed default. Takes precedence over <see cref="SizePx"/>.
    /// </summary>
    [Parameter] public string? Size { get; set; }
    /// <summary>Icon color. Role (<c>FlareColor.Primary</c>) -> shared class; custom (<c>FlareColor.Custom("#...")</c>) -> inline token. Default inherits.</summary>
    [Parameter] public FlareColor Color { get; set; } = FlareColor.Default;
    /// <summary>Convenience pixel size for both SVG and Material icons (e.g. <c>48</c> -> "48px"). Ignored when <see cref="Size"/> is set.</summary>
    [Parameter] public int? SizePx { get; set; }
    /// <summary>SVG viewBox for custom path data in <see cref="Icon"/>. Defaults to the Material 24x24 grid; set e.g. "0 0 1024 1024" for icons authored on a different canvas.</summary>
    [Parameter] public string ViewBox { get; set; } = "0 0 24 24";
    /// <summary>Accessible label; sets aria-label and role=img when provided.</summary>
    [Parameter] public string? AriaLabel { get; set; }

    protected override string ComponentCssClass => Css.Classes.Icon.Root;

    // SVG branch: Icon contains path-data (SVG d= attribute) or full <svg> markup.
    // Material Symbol names are lowercase snake_case words (e.g. "home", "share") and many
    // of them START with a path-command letter (s, m, c, l, h, ...), so the command letter
    // alone is not enough — real path data has a number/sign/space/dot right after it.
    private bool _isSvg => !string.IsNullOrEmpty(Icon) &&
        (Icon.TrimStart().StartsWith('<') || _looksLikePathData(Icon));

    // Full SVG markup (e.g. "<path .../>", possibly several, or a nested "<svg>...") is rendered
    // verbatim; bare path data goes into a single <path d="...">.
    private bool _isMarkup => Icon is not null && Icon.TrimStart().StartsWith('<');

    private static bool _looksLikePathData(string s)
    {
        var t = s.TrimStart();
        if (t.Length == 0 || !"MmLlHhVvCcSsQqTtAaZz".Contains(t[0])) return false;
        // 'Z'/'z' (closepath) takes no args; otherwise the command must be followed by a
        // path-data token (digit, sign, dot, whitespace or comma) — never another letter.
        if (t[0] is 'Z' or 'z') return t.Length == 1 || char.IsWhiteSpace(t[1]);
        return t.Length > 1 && (char.IsDigit(t[1]) || t[1] is '-' or '+' or '.' or ',' || char.IsWhiteSpace(t[1]));
    }

    private string? _iconContent => Name ?? Icon;

    // The icon box is 1em (see icon.css), so both SVG and font icons are sized via font-size.
    private string? _sizeCss => Size ?? (SizePx is int px ? $"{px}px" : null);

    private string? _svgStyle => _buildStyle();
    private string? _inlineStyle => _buildStyle();

    private string? _buildStyle()
    {
        var parts = new List<string>(3);
        if (_sizeCss is not null) parts.Add($"font-size:{_sizeCss}");
        if (Color.IsCustom) parts.Add($"{Css.Tokens.LocalColor.Main}:{Color.Value}");
        if (Style is not null) parts.Add(Style);
        return parts.Count > 0 ? string.Join(';', parts) : null;
    }
}
