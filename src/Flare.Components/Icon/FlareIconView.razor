@namespace Flare.Components
@inherits FlareComponentBase

@_effective.Render()

@code {
    /// <summary>
    /// A ready-made icon descriptor to render - any provider (<see cref="FlareMaterialIcon"/>,
    /// <see cref="FlareSvgIcon"/>, a Fluent/Font Awesome pack type, ...). Takes precedence; the
    /// <see cref="Name"/>/<see cref="Icon"/> shortcuts build one when it is null.
    /// </summary>
    [Parameter] public FlareIcon? Value { get; set; }

    /// <summary>Material Symbols icon name shortcut, e.g. <c>"home"</c> (builds a <see cref="FlareMaterialIcon"/>).</summary>
    [Parameter] public string? Name { get; set; }

    /// <summary>
    /// SVG path data / markup, or a Material Symbols name (auto-detected). Prefer <see cref="Value"/> or
    /// <see cref="Name"/>. SECURITY: markup is emitted verbatim - pass only trusted, developer-authored values.
    /// </summary>
    [Parameter] public string? Icon { get; set; }

    /// <summary>Icon size as any CSS length (e.g. <c>"3rem"</c>). Overrides <see cref="Value"/>'s size when set.</summary>
    [Parameter] public string? Size { get; set; }

    /// <summary>Convenience pixel size (e.g. <c>48</c> -&gt; <c>"48px"</c>). Ignored when <see cref="Size"/> is set.</summary>
    [Parameter] public int? SizePx { get; set; }

    /// <summary>Icon color. Overrides <see cref="Value"/>'s color when not <see cref="FlareColor.Default"/>.</summary>
    [Parameter] public FlareColor Color { get; set; } = FlareColor.Default;

    /// <summary>SVG viewBox used when building from <see cref="Icon"/> path data. Defaults to a 24x24 grid.</summary>
    [Parameter] public string ViewBox { get; set; } = "0 0 24 24";

    /// <summary>Accessible label; sets aria-label + role=img. Overrides <see cref="Value"/>'s label when set.</summary>
    [Parameter] public string? AriaLabel { get; set; }

    // This component renders the icon element directly (no wrapper of its own).
    protected override string ComponentCssClass => string.Empty;

    private FlareIcon _effective => BuildEffective();

    // Merge the caller-facing shortcuts/overrides onto the chosen descriptor. A view-level value wins over
    // the descriptor's; an unset view value keeps the descriptor's.
    private FlareIcon BuildEffective()
    {
        var icon = Value ?? BuildFromShortcut();
        return icon with
        {
            Size = _sizeCss ?? icon.Size,
            Color = Color.IsDefault ? icon.Color : Color,
            AriaLabel = AriaLabel ?? icon.AriaLabel,
            Class = Class ?? icon.Class,
            Style = Style ?? icon.Style,
            Attributes = AdditionalAttributes ?? icon.Attributes,
        };
    }

    private FlareIcon BuildFromShortcut()
    {
        if (!string.IsNullOrEmpty(Icon) && _looksLikeSvg(Icon))
            return new FlareSvgIcon { Data = Icon, ViewBox = ViewBox };
        // A bare name resolves to the built-in SVG when known, else a Material glyph (same rule as the
        // string -> FlareIcon conversion), so Name/Icon shortcuts do not force the font by default.
        var name = Name ?? Icon ?? string.Empty;
        return FlareIcons.Find(name) ?? (FlareIcon)new FlareMaterialIcon { Name = name };
    }

    private string? _sizeCss => Size ?? (SizePx is int px ? $"{px}px" : null);

    // Material Symbol names are lowercase snake_case words (e.g. "home", "share"), many of which START with
    // a path-command letter (s, m, c, l, h, ...), so the command letter alone is not enough - real path
    // data has a number/sign/space/dot right after it, or the string is full markup starting with '<'.
    private static bool _looksLikeSvg(string s) => s.TrimStart().StartsWith('<') || _looksLikePathData(s);

    private static bool _looksLikePathData(string s)
    {
        var t = s.TrimStart();
        if (t.Length == 0 || !"MmLlHhVvCcSsQqTtAaZz".Contains(t[0])) return false;
        // 'Z'/'z' (closepath) takes no args; otherwise the command must be followed by a path-data token
        // (digit, sign, dot, whitespace or comma) - never another letter.
        if (t[0] is 'Z' or 'z') return t.Length == 1 || char.IsWhiteSpace(t[1]);
        return t.Length > 1 && (char.IsDigit(t[1]) || t[1] is '-' or '+' or '.' or ',' || char.IsWhiteSpace(t[1]));
    }
}
