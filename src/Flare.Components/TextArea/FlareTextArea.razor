@namespace Flare.Components
@inherits FlareEditableFieldBase
@implements IFlareField<string>
@using System.Linq.Expressions
@using Microsoft.AspNetCore.Components.Web

@* Multi-line text field. Composes the shared FlareFieldChrome frame + FlareTextInput in multiline mode
   (a <textarea>), so it shares the family chrome + input logic and only adds the textarea-specific rows /
   auto-grow / max-lines. *@

<FlareFieldChrome Variant="Variant" Size="Size"
                  Invalid="@(!string.IsNullOrEmpty(DisplayedErrorText))"
                  Disabled="Disabled" ReadOnly="ReadOnly"
                  ExtraClass="@(AutoGrow ? Css.Classes.Textarea.Autogrow : null)"
                  Label="@Label" LabelFor="@ControlId"
                  HelperText="@HelperText" HelperId="@HelperId"
                  ErrorText="@DisplayedErrorText" ErrorId="@ErrorId"
                  Style="@Style">
    <Field>
        <div class="@Css.Classes.Input.Field">
            <FlareTextInput @ref="_input"
                               Multiline="true"
                               Value="@Value"
                               ValueChanged="EmitValue"
                               Id="@ControlId"
                               ControlClass="@Css.Classes.Textarea.Control"
                               Placeholder="@Placeholder"
                               Disabled="Disabled"
                               ReadOnly="ReadOnly"
                               Required="Required"
                               Rows="Rows"
                               MaxLength="MaxLength"
                               Spellcheck="Spellcheck"
                               AriaInvalid="@(!string.IsNullOrEmpty(DisplayedErrorText))"
                               AriaDescribedBy="@SupportDescribedBy"
                               Immediate="Immediate"
                               DebounceInterval="DebounceInterval"
                               OnFocus="OnFocus"
                               OnBlur="OnBlur"
                               OnKeyDown="OnKeyDown"
                               OnKeyUp="OnKeyUp"
                               Style="@_controlStyle"
                               AdditionalAttributes="AdditionalAttributes" />
            @if (Clearable && !string.IsNullOrEmpty(Value) && !Disabled && !ReadOnly)
            {
                <button type="button"
                        class="@Css.Classes.Input.Clear"
                        aria-label="@(FlareStrings.Input_Clear)"
                        tabindex="-1"
                        @onclick="HandleClear">
                    <span aria-hidden="true">&#x2715;</span>
                </button>
            }
        </div>
    </Field>
    <Counter>
        @if (_showCounter)
        {
            <span class="@Css.Classes.Input.Counter" aria-hidden="true">@(Value?.Length ?? 0)@(MaxLength > 0 ? $"/{MaxLength}" : null)</span>
        }
    </Counter>
</FlareFieldChrome>

@code {
    /// <summary>Current text content of the textarea.</summary>
    [Parameter] public string? Value { get; set; }
    /// <summary>Callback invoked when the text changes.</summary>
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }
    // Label, Placeholder, HelperText, ErrorText, Disabled, ReadOnly and Required are inherited from
    // FlareFieldBase (IFlareField).
    /// <summary>Number of visible text rows.</summary>
    [Parameter] public int Rows { get; set; } = 4;
    /// <summary>Auto-resizes the textarea height to fit its content (zero-JS, via CSS field-sizing).</summary>
    [Parameter] public bool AutoGrow { get; set; }
    /// <summary>With <see cref="AutoGrow"/>, caps growth at this many lines (then scrolls). 0 = unlimited.</summary>
    [Parameter] public int MaxLines { get; set; }
    /// <summary>Maximum number of characters allowed. 0 = no limit. Server-side validation is always required.</summary>
    [Parameter] public int MaxLength { get; set; } = 0;
    /// <summary>Shows a character counter in the supporting-text row. Auto-enabled when <see cref="MaxLength"/> is set.</summary>
    [Parameter] public bool ShowCharacterCount { get; set; }
    /// <summary>When true, the value updates on every keystroke (oninput) rather than only on change/blur.</summary>
    [Parameter] public bool Immediate { get; set; }
    /// <summary>Debounce in milliseconds for <see cref="Immediate"/> updates. 0 = no debounce.</summary>
    [Parameter] public int DebounceInterval { get; set; }
    /// <summary>Expression used to bind and validate the field.</summary>
    [Parameter] public Expression<Func<string?>>? For { get; set; }
    /// <summary>Shows a clear (x) button inside the field when it has a value.</summary>
    [Parameter] public bool Clearable { get; set; }
    /// <summary>The HTML <c>spellcheck</c> attribute; null (default) leaves the browser default.</summary>
    [Parameter] public bool? Spellcheck { get; set; }
    /// <summary>User-drag resize affordance (CSS <c>resize</c>). Ignored while <see cref="AutoGrow"/> is on.</summary>
    [Parameter] public TextAreaResize Resize { get; set; } = TextAreaResize.Default;
    /// <summary>Invoked when the textarea gains focus.</summary>
    [Parameter] public EventCallback<FocusEventArgs> OnFocus { get; set; }
    /// <summary>Invoked when the textarea loses focus.</summary>
    [Parameter] public EventCallback<FocusEventArgs> OnBlur { get; set; }
    /// <summary>Invoked on keydown in the textarea (e.g. to handle Ctrl+Enter submit shortcuts).</summary>
    [Parameter] public EventCallback<KeyboardEventArgs> OnKeyDown { get; set; }
    /// <summary>Invoked on keyup in the textarea.</summary>
    [Parameter] public EventCallback<KeyboardEventArgs> OnKeyUp { get; set; }
    /// <summary>Invoked when the clear (x) button is clicked, after the value has been reset.</summary>
    [Parameter] public EventCallback<MouseEventArgs> OnClearButtonClick { get; set; }

    protected override string ComponentCssClass => Css.Classes.Input.Root;

    private FlareTextInput? _input;

    /// <inheritdoc />
    protected override ValueTask FocusCoreAsync() => _input?.FocusAsync() ?? ValueTask.CompletedTask;
    /// <summary>Selects (highlights) all the text in the textarea.</summary>
    public ValueTask SelectAsync() => _input?.SelectAsync() ?? ValueTask.CompletedTask;
    /// <summary>Removes keyboard focus from the textarea.</summary>
    public ValueTask BlurAsync() => _input?.BlurAsync() ?? ValueTask.CompletedTask;

    private async Task HandleClear(MouseEventArgs e)
    {
        await ValueChanged.InvokeAsync(null);
        NotifyFieldChanged();
        await OnClearButtonClick.InvokeAsync(e);
    }

    private string? ResizeCss() => Resize switch
    {
        TextAreaResize.None => "resize:none",
        TextAreaResize.Vertical => "resize:vertical",
        TextAreaResize.Horizontal => "resize:horizontal",
        TextAreaResize.Both => "resize:both",
        _ => null,
    };

    // EditContext subscription, the bound FieldIdentifier and the validation lookup are provided by
    // FlareFieldBase; here we only feed it the For accessor. ControlId/HelperId/ErrorId/DisplayedErrorText/
    // SupportDescribedBy (the id + supporting-text wiring) are also inherited from FlareFieldBase.
    protected override void OnParametersSet() => UpdateFieldIdentifier(For);

    private bool _showCounter => ShowCharacterCount || MaxLength > 0;

    // Typo wins over the size-derived font via an inline style (size-grid selectors out-specify a class).
    private string? _typoStyle => Typo is { } t ? FlareTypography.FontStyle(t) : null;

    private string? _controlStyle
    {
        get
        {
            var parts = new List<string>();
            if (MaxLines > 0) parts.Add($"--flare-textarea-max-lines:{MaxLines}");
            var resize = ResizeCss();
            if (resize is not null) parts.Add(resize);
            if (_typoStyle is not null) parts.Add(_typoStyle);
            return parts.Count > 0 ? string.Join(';', parts) : null;
        }
    }

    // Debounce/immediate policy lives in FlareTextInput; this just raises the typed callback.
    private async Task EmitValue(string? val)
    {
        await ValueChanged.InvokeAsync(val);
        NotifyFieldChanged();
    }
}
