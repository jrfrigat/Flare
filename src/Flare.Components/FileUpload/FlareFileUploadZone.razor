@namespace Flare.Components
@inherits FlareFileUploadBase
@using Microsoft.AspNetCore.Components.Forms

@* A drop region: it owns its footprint, so it takes no button vocabulary. The button-in-a-row form is a
   separate component, FlareFileUploadButton. *@
<div class="@BuildCssClass(_draggingClass, _disabledClass)"
     style="@Style"
     @ondragover:preventDefault="true"
     @ondragenter:preventDefault="true"
     @ondragover="@(() => _isDragging = true)"
     @ondragleave="@(() => _isDragging = false)"
     @ondrop:preventDefault="true"
     @attributes="AdditionalAttributes">
    <div class="@Css.Classes.FileUpload.DropWrap">
        <label class="@Css.Classes.FileUpload.Zone" for="@InputId">
            @if (Icon is not null)
            {
                <span class="@Css.Classes.FileUpload.Icon">@Icon</span>
            }
            else
            {
                <span class="@Css.Classes.FileUpload.Icon material-symbols-rounded" aria-hidden="true">upload_file</span>
            }
            <span class="@Css.Classes.FileUpload.Primary">@(DropText ?? FlareStrings.FileUpload_DropText)</span>
            @if (!string.IsNullOrEmpty(Accept))
            {
                <span class="@Css.Classes.FileUpload.Hint">@(FlareStrings.FileUpload_Accepted) @Accept</span>
            }
        </label>
        <InputFile id="@InputId"
                   class="@Css.Classes.FileUpload.Input"
                   accept="@Accept"
                   multiple="@Multiple"
                   disabled="@Disabled"
                   OnChange="HandleDropAsync" />
    </div>
    @if (ShowFileList && Files.Count > 0)
    {
        <ul class="@Css.Classes.FileUpload.List">
            @foreach (var file in Files)
            {
                <li class="@Css.Classes.FileUpload.File">
                    <span class="@Css.Classes.FileUpload.FileIcon material-symbols-rounded" aria-hidden="true">description</span>
                    <span class="@Css.Classes.FileUpload.FileName">@file.Name</span>
                    <span class="@Css.Classes.FileUpload.FileSize">@FormatSize(file.Size)</span>
                </li>
            }
        </ul>
    }
</div>

@code {
    /// <summary>Instructional text shown inside the drop zone. Defaults to the localized
    /// "FileUpload_DropText" string.</summary>
    [Parameter] public string? DropText { get; set; }
    /// <summary>Icon shown above the instructional text. Defaults to an upload glyph.</summary>
    [Parameter] public RenderFragment? Icon { get; set; }

    protected override string ComponentCssClass => Css.Classes.FileUpload.Root;

    private bool _isDragging;
    private string _draggingClass => _isDragging ? Css.Classes.FileUpload.Dragging : string.Empty;
    private string _disabledClass => Disabled ? Css.Classes.FileUpload.Disabled : string.Empty;

    // The drag highlight has to clear on drop as well as on dragleave, so the zone does not stay lit.
    private async Task HandleDropAsync(InputFileChangeEventArgs e)
    {
        _isDragging = false;
        await HandleChangeAsync(e);
    }
}
