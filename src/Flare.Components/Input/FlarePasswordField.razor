@namespace Flare.Components
@inherits FlareComponentBase
@using System.Linq.Expressions

<FlareField TValue="string"
            Value="Value"
            ValueChanged="OnValueChanged"
            Label="@Label"
            Placeholder="@Placeholder"
            HelperText="@HelperText"
            ErrorText="@ErrorText"
            Disabled="@Disabled"
            MaxLength="@MaxLength"
            Immediate="@Immediate"
            DebounceInterval="@DebounceInterval"
            Variant="@Variant"
            FullWidth="@FullWidth"
            Margin="@Margin"
            Class="@Class"
            Style="@Style"
            For="@For"
            Type="@(_showPassword ? "text" : "password")"
            AdditionalAttributes="@_fieldAttributes">
    <TrailingIcon>
        <FlareButton Variant="ButtonVariant.Text" Size="ButtonSize.Sm"
                     AriaLabel="@(_showPassword ? "Hide password" : "Show password")"
                     OnClick="ToggleVisibility">
            <LeadingIcon><FlareIcon Name="@(_showPassword ? "visibility_off" : "visibility")" /></LeadingIcon>
        </FlareButton>
    </TrailingIcon>
</FlareField>

@code {
    /// <summary>The bound password value.</summary>
    [Parameter] public string? Value { get; set; }
    /// <summary>Fires when the value changes, so the field can be driven with <c>@bind-Value</c>.</summary>
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }
    /// <summary>Label text.</summary>
    [Parameter] public string? Label { get; set; }
    /// <summary>Placeholder text.</summary>
    [Parameter] public string? Placeholder { get; set; }
    /// <summary>Helper text shown below the field.</summary>
    [Parameter] public string? HelperText { get; set; }
    /// <summary>Error text overrides HelperText when set.</summary>
    [Parameter] public string? ErrorText { get; set; }
    /// <summary>Disables the field.</summary>
    [Parameter] public bool Disabled { get; set; }
    /// <summary>Marks the field as required, emitting the native <c>required</c> attribute on the input.</summary>
    [Parameter] public bool Required { get; set; }
    /// <summary>Maximum number of characters allowed. 0 = no limit. Server-side validation is always required.</summary>
    [Parameter] public int MaxLength { get; set; } = 0;
    /// <summary>When true, the value updates on every keystroke (oninput) rather than only on change/blur.</summary>
    [Parameter] public bool Immediate { get; set; }
    /// <summary>Debounce in milliseconds for <see cref="Immediate"/> updates. 0 = no debounce.</summary>
    [Parameter] public int DebounceInterval { get; set; }
    /// <summary>Visual variant (Filled/Outlined) independent of the theme. Default keeps the theme's style.</summary>
    [Parameter] public InputVariant Variant { get; set; } = InputVariant.Default;
    /// <summary>When true (the default), the field is block-level and fills the width of its container.
    /// Set to false to size the field to its content (inline) instead.</summary>
    [Parameter] public bool FullWidth { get; set; } = true;
    /// <summary>Vertical (block) margin around the field. <see cref="FieldMargin.None"/> (default) leaves
    /// spacing to the surrounding layout; <see cref="FieldMargin.Dense"/> / <see cref="FieldMargin.Normal"/>
    /// add a compact / comfortable margin above and below.</summary>
    [Parameter] public FieldMargin Margin { get; set; } = FieldMargin.None;
    /// <summary>Expression used to bind and validate the field inside an <c>EditForm</c>.</summary>
    [Parameter] public Expression<Func<string>>? For { get; set; }

    private bool _showPassword;
    protected override string ComponentCssClass => Css.Classes.PasswordInput.Root;

    private void ToggleVisibility() => _showPassword = !_showPassword;

    // Propagate the inner field's change to this component's own ValueChanged so a consumer's
    // @bind-Value actually receives the typed value. Assign the local Value first so the field
    // reflects the change immediately (before the parent re-renders it back down).
    private async Task OnValueChanged(string? value)
    {
        Value = value;
        await ValueChanged.InvokeAsync(value);
    }

    // FlareField has no typed Required parameter; it splats AdditionalAttributes onto the input.
    // Forward Required as the native `required` attribute by merging into a copy (never mutate the
    // caller's dictionary), so an unset Required keeps forwarding the original reference untouched.
    private IReadOnlyDictionary<string, object>? _fieldAttributes
    {
        get
        {
            if (!Required) return AdditionalAttributes;
            var merged = AdditionalAttributes is null
                ? new Dictionary<string, object>()
                : new Dictionary<string, object>(AdditionalAttributes);
            merged["required"] = true;
            return merged;
        }
    }
}
