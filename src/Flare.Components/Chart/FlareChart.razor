@namespace Flare.Components
@inherits FlareComponentBase

<div class="@BuildCssClass(_spark ? Css.Classes.Chart.Sparkline : null)" style="@Style" @attributes="AdditionalAttributes">
    @if (Title is not null && !_spark)
    {
        <div class="@Css.Classes.Chart.Title">
            <FlareText Typo="TypographyScale.TitleMedium">@Title</FlareText>
        </div>
    }
    @if (_showLegend && LegendPosition == ChartLegendPosition.Top)
    {
        @RenderLegend()
    }
    <div class="@Css.Classes.Chart.Plot">
        <svg class="@Css.Classes.Chart.Svg" viewBox="0 0 @_svgW @_svgH" xmlns="http://www.w3.org/2000/svg"
             preserveAspectRatio="@(_spark ? "none" : null)"
             aria-label="@(Title ?? "Chart")" role="img">
            <title>@(Title ?? "Chart")</title>
            @if (!string.IsNullOrEmpty(Description))
            {
                <desc>@Description</desc>
            }
            @switch (Type)
            {
                case ChartType.Bar: @RenderBar(); break;
                case ChartType.StackedBar: @RenderStackedBar(); break;
                case ChartType.Pie: @RenderPie(false); break;
                case ChartType.Donut: @RenderPie(true); break;
                case ChartType.Scatter: @RenderScatter(); break;
                case ChartType.Radar: @RenderRadar(); break;
                default: @RenderLine(); break; // Line + Area
            }

            @* Transparent hit zones in viewBox units, so detection scales with the SVG
               (mouse offsets in rendered px would not match the 0..400 viewBox). Suppressed
               for a sparkline (no tooltips in chromeless mode). *@
            @if (!_spark && Type is ChartType.Line or ChartType.Area or ChartType.Bar or ChartType.StackedBar)
            {
                @foreach (var cat in _categories)
                {
                    var c = cat;
                    <rect x="@F(c.XLeft)" y="@F(_padT)" width="@F(c.Width)" height="@F(_plotH)"
                          fill="transparent"
                          @onmouseenter="() => SetHoverCategory(c.Index, c.XCenter)"
                          @onmouseleave="ClearHover" />
                }
            }
            else if (!_spark && Type is ChartType.Pie or ChartType.Donut)
            {
                @foreach (var slice in _slices)
                {
                    var s = slice;
                    <path d="@s.Path" fill="transparent" class="@Css.Classes.Chart.Hit"
                          @onmouseenter="() => SetHoverSlice(s.Index, s.Cx, s.Cy)"
                          @onmouseleave="ClearHover" />
                }
            }
        </svg>
        @if (_tooltipVisible && !string.IsNullOrEmpty(_tooltipText))
        {
            <div class="@Css.Classes.Chart.Tooltip"
                 style="@(string.Create(_inv, $"left:{_hoverXPct:F2}%;top:{_hoverYPct:F2}%"))">
                @_tooltipText
            </div>
        }
    </div>
    @if (_showLegend && LegendPosition == ChartLegendPosition.Bottom)
    {
        @RenderLegend()
    }
</div>

@code {
    /// <summary>Chart rendering type: Line, Bar, Pie, or Donut.</summary>
    [Parameter] public ChartType Type { get; set; } = ChartType.Line;
    /// <summary>Data series and labels to visualize in the chart.</summary>
    [Parameter] public ChartData? Data { get; set; }
    /// <summary>Optional title displayed above the chart and used as the SVG accessible name.</summary>
    [Parameter] public string? Title { get; set; }
    /// <summary>Optional description for the SVG &lt;desc&gt; element, improving screen-reader context.</summary>
    [Parameter] public string? Description { get; set; }
    /// <summary>SVG viewport height in pixels.</summary>
    [Parameter] public int Height { get; set; } = 220;

    /// <summary>Fills the area under each line series with a soft fade from the series color to transparent
    /// (line charts only).</summary>
    [Parameter] public bool Area { get; set; }
    /// <summary>Draws line series as smooth curves instead of straight segments.</summary>
    [Parameter] public bool Smooth { get; set; }
    /// <summary>Draws a marker dot at each line data point.</summary>
    [Parameter] public bool ShowMarkers { get; set; }
    /// <summary>Shows the horizontal grid lines behind an axis chart. Default true.</summary>
    [Parameter] public bool ShowGrid { get; set; } = true;
    /// <summary>Shows the numeric Y-axis labels. Default true.</summary>
    [Parameter] public bool ShowYAxisLabels { get; set; } = true;
    /// <summary>Shows the category X-axis labels. Default true.</summary>
    [Parameter] public bool ShowXAxisLabels { get; set; } = true;
    /// <summary>Shows the series legend. Default true.</summary>
    [Parameter] public bool ShowLegend { get; set; } = true;
    /// <summary>Where the legend sits relative to the plot.</summary>
    [Parameter] public ChartLegendPosition LegendPosition { get; set; } = ChartLegendPosition.Bottom;
    /// <summary>Overrides the plot padding (all sides, in viewBox units). Null keeps the default axis padding.</summary>
    [Parameter] public int? Padding { get; set; }
    /// <summary>Sparkline preset: a compact, chromeless line (no grid, axes, legend or title) that stretches
    /// edge-to-edge with a crisp stroke - for inline metric cards. Combine with <see cref="Area"/> for a fill.</summary>
    [Parameter] public bool Sparkline { get; set; }

    protected override string ComponentCssClass => Css.Classes.Chart.Root;

    // SVG numeric attributes require '.' as the decimal separator; never use the current
    // culture (e.g. ru-RU formats 192.0 as "192,0", which is invalid in SVG).
    private static readonly System.Globalization.CultureInfo _inv = System.Globalization.CultureInfo.InvariantCulture;

    // Unique per-instance id prefix so area gradients from multiple charts on a page never collide.
    private readonly string _uid = $"fc{Guid.NewGuid():N}";

    private const int _svgW = 400;
    private int _svgH => Height;

    private bool _spark => Sparkline;
    // Area fill is on for the explicit Area flag or the Area chart type.
    private bool _area => Area || Type == ChartType.Area;
    // Sparkline zeroes the chrome; otherwise a Padding override applies to all sides, else the axis defaults.
    private int _padL => _spark ? 2 : (Padding ?? 36);
    private int _padR => _spark ? 2 : (Padding ?? 12);
    private int _padT => _spark ? 2 : (Padding ?? 12);
    private int _padB => _spark ? 2 : (Padding ?? 28);
    private int _plotW => _svgW - _padL - _padR;
    private int _plotH => _svgH - _padT - _padB;

    // Chrome toggles - all forced off in sparkline mode.
    private bool _showGrid => !_spark && ShowGrid;
    private bool _showY => !_spark && ShowYAxisLabels;
    private bool _showX => !_spark && ShowXAxisLabels;
    private bool _showLegend => !_spark && ShowLegend && LegendPosition != ChartLegendPosition.None
        && Data?.Series is { Count: > 0 };

    // Tooltip state. Position is a percentage of the SVG box so it tracks the scaled
    // viewBox without needing the rendered pixel size.
    private bool _tooltipVisible;
    private double _hoverXPct;
    private double _hoverYPct;
    private string _tooltipText = string.Empty;

    private string F(double d) => d.ToString("F1", _inv);

    private static readonly string[] _palette =
    [
        "var(--flare-color-primary)",
        "var(--flare-color-secondary)",
        "var(--flare-color-tertiary)",
        "var(--flare-color-error)",
        "var(--flare-color-primary-container)",
        "var(--flare-color-secondary-container)",
        "var(--flare-color-tertiary-container)",
        "var(--flare-color-error-container)",
    ];

    private string GetColor(int idx) =>
        Data?.Series[idx].Color ?? _palette[idx % _palette.Length];

    /// <summary>Clamps NaN/Infinity data values to 0 to prevent SVG coordinate corruption.</summary>
    private static double SafeValue(double v) =>
        double.IsNaN(v) || double.IsInfinity(v) ? 0.0 : v;

    private int _pts => Data?.Series is { Count: > 0 } s ? s.Max(x => x.Values.Count) : 0;

    private RenderFragment RenderLegend() => builder =>
    {
        var series = Data!.Series;
        builder.OpenElement(0, "div");
        builder.AddAttribute(1, "class", Css.Classes.Chart.Legend);
        for (int i = 0; i < series.Count; i++)
        {
            builder.OpenElement(2, "div");
            builder.AddAttribute(3, "class", Css.Classes.Chart.LegendItem);
            builder.OpenElement(4, "span");
            builder.AddAttribute(5, "class", Css.Classes.Chart.LegendDot);
            builder.AddAttribute(6, "style", $"--flare-chart-dot:{GetColor(i)}");
            builder.CloseElement();
            builder.OpenElement(7, "span");
            builder.AddContent(8, series[i].Label);
            builder.CloseElement();
            builder.CloseElement();
        }
        builder.CloseElement();
    };

    // Category hit zones (line/bar), in viewBox units.
    private IEnumerable<(int Index, double XLeft, double Width, double XCenter)> _categories
    {
        get
        {
            int pts = _pts;
            if (pts <= 0) yield break;
            if (Type is ChartType.Bar or ChartType.StackedBar)
            {
                double groupW = _plotW / (double)pts;
                for (int i = 0; i < pts; i++)
                {
                    double left = _padL + i * groupW;
                    yield return (i, left, groupW, left + groupW / 2);
                }
            }
            else
            {
                double step = pts > 1 ? _plotW / (double)(pts - 1) : _plotW;
                for (int i = 0; i < pts; i++)
                {
                    double center = _padL + (pts > 1 ? i * step : _plotW / 2.0);
                    double width = pts > 1 ? step : _plotW;
                    yield return (i, center - width / 2, width, center);
                }
            }
        }
    }

    // Slice geometry (pie/donut) shared by the visual paths and the hit zones.
    private IEnumerable<(int Index, string Path, double Cx, double Cy)> _slices
    {
        get
        {
            if (Data?.Series is not { Count: > 0 } series) yield break;
            bool donut = Type == ChartType.Donut;
            double cx = _svgW / 2.0, cy = _svgH / 2.0;
            double r = Math.Min(cx, cy) - 16;
            double inner = donut ? r * 0.55 : 0;
            double total = series.Sum(s => s.Values.FirstOrDefault());
            if (total == 0) yield break;

            double startAngle = -Math.PI / 2;
            for (int i = 0; i < series.Count; i++)
            {
                double val = SafeValue(series[i].Values.FirstOrDefault());
                double sweep = val / total * 2 * Math.PI;
                double endAngle = startAngle + sweep;
                double x1 = cx + r * Math.Cos(startAngle), y1 = cy + r * Math.Sin(startAngle);
                double x2 = cx + r * Math.Cos(endAngle), y2 = cy + r * Math.Sin(endAngle);
                double ix1 = cx + inner * Math.Cos(startAngle), iy1 = cy + inner * Math.Sin(startAngle);
                double ix2 = cx + inner * Math.Cos(endAngle), iy2 = cy + inner * Math.Sin(endAngle);
                int largeArc = sweep > Math.PI ? 1 : 0;
                string path = donut
                    ? string.Create(_inv, $"M {x1:F2} {y1:F2} A {r:F2} {r:F2} 0 {largeArc} 1 {x2:F2} {y2:F2} L {ix2:F2} {iy2:F2} A {inner:F2} {inner:F2} 0 {largeArc} 0 {ix1:F2} {iy1:F2} Z")
                    : string.Create(_inv, $"M {cx:F2} {cy:F2} L {x1:F2} {y1:F2} A {r:F2} {r:F2} 0 {largeArc} 1 {x2:F2} {y2:F2} Z");
                double mid = startAngle + sweep / 2;
                double rMid = donut ? (r + inner) / 2 : r * 0.6;
                yield return (i, path, cx + rMid * Math.Cos(mid), cy + rMid * Math.Sin(mid));
                startAngle = endAngle;
            }
        }
    }

    private (double Min, double Max) _scale()
    {
        var all = Data!.Series.SelectMany(s => s.Values).ToList();
        if (all.Count == 0) return (0, 1);
        double min = all.Min(), max = all.Max();
        if (Type == ChartType.Bar) { max = Math.Max(max, 0); min = Math.Min(min, 0); }
        if (max == min) max = min + 1;
        return (min, max);
    }

    private double _yOf(double v, double min, double max) =>
        _padT + _plotH - (SafeValue(v) - min) / (max - min) * _plotH;

    private void SetHoverCategory(int index, double xCenter)
    {
        if (Data?.Series is not { Count: > 0 } series) return;
        var label = (Data?.Labels is { } ls && index < ls.Count) ? ls[index] : index.ToString();
        var parts = series.Where(s => index < s.Values.Count)
            .Select(s => string.Create(_inv, $"{s.Label}: {s.Values[index]:G4}"));
        _tooltipText = $"{label}\n{string.Join("\n", parts)}";

        var (min, max) = _scale();
        double yTop = series.Where(s => index < s.Values.Count)
            .Select(s => _yOf(s.Values[index], min, max))
            .DefaultIfEmpty(_padT).Min();

        _hoverXPct = xCenter / _svgW * 100;
        _hoverYPct = yTop / _svgH * 100;
        _tooltipVisible = true;
    }

    private void SetHoverSlice(int index, double cx, double cy)
    {
        if (Data?.Series is not { Count: > 0 } series) return;
        double total = series.Sum(s => s.Values.FirstOrDefault());
        double pct = total > 0 ? series[index].Values.FirstOrDefault() / total * 100 : 0;
        _tooltipText = string.Create(_inv, $"{series[index].Label}: {pct:F1}%");
        _hoverXPct = cx / _svgW * 100;
        _hoverYPct = cy / _svgH * 100;
        _tooltipVisible = true;
    }

    private void ClearHover() => _tooltipVisible = false;

    private RenderFragment RenderLine() => builder =>
    {
        if (Data?.Series is not { Count: > 0 } series) return;
        var allVals = series.SelectMany(s => s.Values).ToList();
        if (allVals.Count == 0) return;
        double min = allVals.Min(), max = allVals.Max();
        if (max == min) { max = min + 1; }
        int pts = series.Max(s => s.Values.Count);
        int seq = 0;

        if (_showGrid || _showY)
            builder.AddMarkupContent(seq++, GridLines(min, max));

        double baseline = _padT + _plotH;
        string vectorEffect = _spark ? " vector-effect=\"non-scaling-stroke\"" : "";

        for (int si = 0; si < series.Count; si++)
        {
            var vals = series[si].Values;
            if (vals.Count == 0) continue;
            var pointList = new List<(double X, double Y)>(vals.Count);
            for (int i = 0; i < vals.Count; i++)
            {
                double sv = SafeValue(vals[i]);
                double x = _padL + (pts > 1 ? i * _plotW / (double)(pts - 1) : _plotW / 2.0);
                double y = _padT + _plotH - (sv - min) / (max - min) * _plotH;
                pointList.Add((x, y));
            }
            var color = GetColor(si);
            string linePath = Smooth ? SmoothPath(pointList) : StraightPath(pointList);

            // Area fill: a gradient from the series color down to transparent. Colors go through style
            // (var() is not resolved in SVG presentation attributes / stop-color, only in CSS values).
            if (_area)
            {
                string gid = $"{_uid}-a{si}";
                builder.AddMarkupContent(seq++,
                    $"<defs><linearGradient id=\"{gid}\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">" +
                    $"<stop offset=\"0\" style=\"stop-color:{color};stop-opacity:0.35\"/>" +
                    $"<stop offset=\"1\" style=\"stop-color:{color};stop-opacity:0\"/></linearGradient></defs>");
                string areaPath = string.Create(_inv,
                    $"{linePath} L {pointList[^1].X:F1} {baseline:F1} L {pointList[0].X:F1} {baseline:F1} Z");
                builder.AddMarkupContent(seq++, $"<path d=\"{areaPath}\" stroke=\"none\" fill=\"url(#{gid})\"/>");
            }

            // The line itself (stroked path; polyline when straight is equivalent to the straight path).
            builder.AddMarkupContent(seq++,
                $"<path d=\"{linePath}\" fill=\"none\" stroke-width=\"2\" stroke-linejoin=\"round\" stroke-linecap=\"round\" style=\"stroke:{color}\"{vectorEffect}/>");

            if (ShowMarkers)
            {
                var sb = new System.Text.StringBuilder();
                foreach (var (x, y) in pointList)
                    sb.Append(string.Create(_inv, $"<circle cx=\"{x:F1}\" cy=\"{y:F1}\" r=\"2.5\" style=\"fill:{color}\"/>"));
                builder.AddMarkupContent(seq++, sb.ToString());
            }
        }
        if (_showX)
            builder.AddMarkupContent(seq++, AxisLabels(min, max, pts));
    };

    private static string StraightPath(IReadOnlyList<(double X, double Y)> pts)
    {
        if (pts.Count == 0) return "";
        var sb = new System.Text.StringBuilder(string.Create(_inv, $"M {pts[0].X:F1} {pts[0].Y:F1}"));
        for (int i = 1; i < pts.Count; i++)
            sb.Append(string.Create(_inv, $" L {pts[i].X:F1} {pts[i].Y:F1}"));
        return sb.ToString();
    }

    // Catmull-Rom -> cubic Bezier for a smooth line through the points.
    private static string SmoothPath(IReadOnlyList<(double X, double Y)> pts)
    {
        if (pts.Count < 3) return StraightPath(pts);
        var sb = new System.Text.StringBuilder(string.Create(_inv, $"M {pts[0].X:F1} {pts[0].Y:F1}"));
        for (int i = 0; i < pts.Count - 1; i++)
        {
            var p0 = pts[Math.Max(0, i - 1)];
            var p1 = pts[i];
            var p2 = pts[i + 1];
            var p3 = pts[Math.Min(pts.Count - 1, i + 2)];
            double c1x = p1.X + (p2.X - p0.X) / 6.0;
            double c1y = p1.Y + (p2.Y - p0.Y) / 6.0;
            double c2x = p2.X - (p3.X - p1.X) / 6.0;
            double c2y = p2.Y - (p3.Y - p1.Y) / 6.0;
            sb.Append(string.Create(_inv, $" C {c1x:F1} {c1y:F1} {c2x:F1} {c2y:F1} {p2.X:F1} {p2.Y:F1}"));
        }
        return sb.ToString();
    }

    private RenderFragment RenderBar() => builder =>
    {
        if (Data?.Series is not { Count: > 0 } series) return;
        var allVals = series.SelectMany(s => s.Values).ToList();
        if (allVals.Count == 0) return;
        double max = Math.Max(allVals.Max(), 0), min = Math.Min(allVals.Min(), 0);
        if (max == min) max = min + 1;
        int pts = series.Max(s => s.Values.Count);
        double groupW = _plotW / (double)pts;
        double barW = groupW / (series.Count + 1);
        int seq = 0;

        if (_showGrid || _showY)
            builder.AddMarkupContent(seq++, GridLines(min, max));

        for (int si = 0; si < series.Count; si++)
        {
            var vals = series[si].Values;
            var color = GetColor(si);
            for (int i = 0; i < vals.Count; i++)
            {
                double sv = SafeValue(vals[i]);
                double x = _padL + i * groupW + si * barW + barW * 0.25;
                double zeroY = _padT + _plotH - (0 - min) / (max - min) * _plotH;
                double barH = Math.Abs(sv / (max - min) * _plotH);
                double y = sv >= 0 ? zeroY - barH : zeroY;
                builder.AddMarkupContent(si * 100 + i + 1,
                    string.Create(_inv, $"<rect x=\"{x:F1}\" y=\"{y:F1}\" width=\"{barW * 0.85:F1}\" height=\"{barH:F1}\" rx=\"2\" style=\"fill:{color}\"/>"));
            }
        }
        if (_showX)
            builder.AddMarkupContent(9999, AxisLabels(min, max, pts));
    };

    private RenderFragment RenderPie(bool donut) => builder =>
    {
        // donut vs pie is already encoded in Type, which _slices reads.
        foreach (var slice in _slices)
        {
            builder.AddMarkupContent(slice.Index,
                $"<path d=\"{slice.Path}\" stroke-width=\"1.5\" style=\"fill:{GetColor(slice.Index)};stroke:var(--flare-color-surface)\"/>");
        }
    };

    private RenderFragment RenderStackedBar() => builder =>
    {
        if (Data?.Series is not { Count: > 0 } series) return;
        int pts = series.Max(s => s.Values.Count);
        if (pts == 0) return;
        // Stacked totals per category (positive stacking).
        double max = 0;
        for (int i = 0; i < pts; i++)
        {
            double sum = 0;
            foreach (var s in series) if (i < s.Values.Count) sum += Math.Max(0, SafeValue(s.Values[i]));
            max = Math.Max(max, sum);
        }
        if (max <= 0) max = 1;
        int seq = 0;
        if (_showGrid || _showY) builder.AddMarkupContent(seq++, GridLines(0, max));

        double groupW = _plotW / (double)pts;
        double barW = groupW * 0.6;
        for (int i = 0; i < pts; i++)
        {
            double x = _padL + i * groupW + (groupW - barW) / 2;
            double yCursor = _padT + _plotH;
            for (int si = 0; si < series.Count; si++)
            {
                if (i >= series[si].Values.Count) continue;
                double v = Math.Max(0, SafeValue(series[si].Values[i]));
                double h = v / max * _plotH;
                yCursor -= h;
                builder.AddMarkupContent(seq++, string.Create(_inv, $"<rect x=\"{x:F1}\" y=\"{yCursor:F1}\" width=\"{barW:F1}\" height=\"{h:F1}\" rx=\"2\" style=\"fill:{GetColor(si)}\"/>"));
            }
        }
        if (_showX) builder.AddMarkupContent(seq++, AxisLabels(0, max, pts));
    };

    private RenderFragment RenderScatter() => builder =>
    {
        if (Data?.Series is not { Count: > 0 } series) return;
        var allPts = series.Where(s => s.Points is { Count: > 0 }).SelectMany(s => s.Points!).ToList();
        if (allPts.Count == 0) return;
        double xMin = allPts.Min(p => p.X), xMax = allPts.Max(p => p.X);
        double yMin = allPts.Min(p => p.Y), yMax = allPts.Max(p => p.Y);
        if (xMax == xMin) xMax = xMin + 1;
        if (yMax == yMin) yMax = yMin + 1;
        int seq = 0;
        if (_showGrid || _showY) builder.AddMarkupContent(seq++, GridLines(yMin, yMax));

        for (int si = 0; si < series.Count; si++)
        {
            var pointsList = series[si].Points;
            if (pointsList is null) continue;
            var color = GetColor(si);
            var sb = new System.Text.StringBuilder();
            foreach (var p in pointsList)
            {
                double x = _padL + (p.X - xMin) / (xMax - xMin) * _plotW;
                double y = _padT + _plotH - (p.Y - yMin) / (yMax - yMin) * _plotH;
                sb.Append(string.Create(_inv, $"<circle cx=\"{x:F1}\" cy=\"{y:F1}\" r=\"3.5\" style=\"fill:{color}\" opacity=\"0.75\"/>"));
            }
            builder.AddMarkupContent(seq++, sb.ToString());
        }
        if (_showX)
        {
            var sb = new System.Text.StringBuilder();
            for (int i = 0; i <= 4; i++)
            {
                double xv = xMin + (xMax - xMin) * i / 4;
                double x = _padL + (xv - xMin) / (xMax - xMin) * _plotW;
                double y = _padT + _plotH + 14;
                sb.Append(string.Create(_inv, $"<text x=\"{x:F1}\" y=\"{y:F1}\" text-anchor=\"middle\" font-size=\"9\" style=\"fill:var(--flare-color-on-surface-variant)\">{xv:G3}</text>"));
            }
            builder.AddMarkupContent(seq++, sb.ToString());
        }
    };

    private RenderFragment RenderRadar() => builder =>
    {
        if (Data?.Series is not { Count: > 0 } series) return;
        int axes = series.Max(s => s.Values.Count);
        if (axes < 3) return; // a radar needs at least 3 axes
        double max = series.SelectMany(s => s.Values).DefaultIfEmpty(0).Max();
        if (max <= 0) max = 1;
        double cx = _svgW / 2.0, cy = _svgH / 2.0;
        double r = Math.Min(cx, cy) - 24;
        int seq = 0;

        if (_showGrid)
        {
            var g = new System.Text.StringBuilder();
            const int levels = 4;
            for (int lv = 1; lv <= levels; lv++)
            {
                double rr = r * lv / levels;
                var poly = new System.Text.StringBuilder();
                for (int k = 0; k < axes; k++)
                {
                    double ang = -Math.PI / 2 + 2 * Math.PI * k / axes;
                    poly.Append(string.Create(_inv, $"{cx + rr * Math.Cos(ang):F1},{cy + rr * Math.Sin(ang):F1} "));
                }
                g.Append($"<polygon points=\"{poly.ToString().Trim()}\" fill=\"none\" stroke-width=\"0.5\" style=\"stroke:var(--flare-color-outline-variant)\"/>");
            }
            for (int k = 0; k < axes; k++)
            {
                double ang = -Math.PI / 2 + 2 * Math.PI * k / axes;
                g.Append(string.Create(_inv, $"<line x1=\"{cx:F1}\" y1=\"{cy:F1}\" x2=\"{cx + r * Math.Cos(ang):F1}\" y2=\"{cy + r * Math.Sin(ang):F1}\" stroke-width=\"0.5\" style=\"stroke:var(--flare-color-outline-variant)\"/>"));
            }
            builder.AddMarkupContent(seq++, g.ToString());
        }

        if (_showX && Data?.Labels is { Count: > 0 } labels)
        {
            var t = new System.Text.StringBuilder();
            for (int k = 0; k < axes && k < labels.Count; k++)
            {
                double ang = -Math.PI / 2 + 2 * Math.PI * k / axes;
                double lx = cx + (r + 10) * Math.Cos(ang), ly = cy + (r + 10) * Math.Sin(ang);
                string anchor = Math.Abs(Math.Cos(ang)) < 0.3 ? "middle" : (Math.Cos(ang) > 0 ? "start" : "end");
                t.Append(string.Create(_inv, $"<text x=\"{lx:F1}\" y=\"{ly + 3:F1}\" text-anchor=\"{anchor}\" font-size=\"9\" style=\"fill:var(--flare-color-on-surface-variant)\">{labels[k]}</text>"));
            }
            builder.AddMarkupContent(seq++, t.ToString());
        }

        for (int si = 0; si < series.Count; si++)
        {
            var vals = series[si].Values;
            if (vals.Count < 3) continue;
            var color = GetColor(si);
            var poly = new System.Text.StringBuilder();
            for (int k = 0; k < axes; k++)
            {
                double v = k < vals.Count ? SafeValue(vals[k]) : 0;
                double rr = v / max * r;
                double ang = -Math.PI / 2 + 2 * Math.PI * k / axes;
                poly.Append(string.Create(_inv, $"{cx + rr * Math.Cos(ang):F1},{cy + rr * Math.Sin(ang):F1} "));
            }
            builder.AddMarkupContent(seq++, $"<polygon points=\"{poly.ToString().Trim()}\" stroke-width=\"2\" stroke-linejoin=\"round\" style=\"fill:{color};stroke:{color};fill-opacity:0.2\"/>");
        }
    };

    private string GridLines(double min, double max)
    {
        var sb = new System.Text.StringBuilder();
        int steps = 4;
        for (int i = 0; i <= steps; i++)
        {
            double v = min + (max - min) * i / steps;
            double y = _padT + _plotH - (v - min) / (max - min) * _plotH;
            if (_showGrid)
                sb.Append(string.Create(_inv, $"<line x1=\"{_padL}\" y1=\"{y:F1}\" x2=\"{_svgW - _padR}\" y2=\"{y:F1}\" stroke-width=\"0.5\" style=\"stroke:var(--flare-color-outline-variant)\"/>"));
            if (_showY)
                sb.Append(string.Create(_inv, $"<text x=\"{_padL - 4}\" y=\"{y + 4:F1}\" text-anchor=\"end\" font-size=\"9\" style=\"fill:var(--flare-color-on-surface-variant)\">{v:G3}</text>"));
        }
        return sb.ToString();
    }

    private string AxisLabels(double min, double max, int pts)
    {
        if (Data?.Labels is not { Count: > 0 } labels) return "";
        var sb = new System.Text.StringBuilder();
        int step = Math.Max(1, pts / 6);
        for (int i = 0; i < pts; i += step)
        {
            if (i >= labels.Count) break;
            double x = _padL + (pts > 1 ? i * _plotW / (double)(pts - 1) : _plotW / 2.0);
            double y = _padT + _plotH + 14;
            sb.Append(string.Create(_inv, $"<text x=\"{x:F1}\" y=\"{y:F1}\" text-anchor=\"middle\" font-size=\"9\" style=\"fill:var(--flare-color-on-surface-variant)\">{labels[i]}</text>"));
        }
        return sb.ToString();
    }
}
