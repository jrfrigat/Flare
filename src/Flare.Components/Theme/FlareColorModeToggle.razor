@namespace Flare.Components
@inherits FlareComponentBase
@using Flare.Abstractions.Tokens

<button class="@BuildCssClass()" @onclick="ToggleAsync"
        aria-label="@(_isDark ? (FlareStrings.Theme_ToggleLight) : (FlareStrings.Theme_ToggleDark))">
    <FlareIcon Name="@(_isDark ? "light_mode" : "dark_mode")" />
    @if (ShowLabel)
    {
        <span class="@Css.Classes.Color.ModeToggleLabel">@(_isDark ? LightLabel : DarkLabel)</span>
    }
</button>

@code {
    // Read the resolved dark state LIVE from the shared theme service, not a cached field: every
    // FlareComponentBase re-renders when the ThemeSnapshot cascade changes (any axis switch), so all
    // toggle instances stay in sync when the mode changes anywhere - another toggle or in code.
    private bool _isDark => ThemeService?.IsDark == true;

    /// <summary>Show a text label beside the icon.</summary>
    [Parameter] public bool ShowLabel { get; set; }
    /// <summary>Label text when clicking switches to light mode.</summary>
    [Parameter] public string LightLabel { get; set; } = "Light";
    /// <summary>Label text when clicking switches to dark mode.</summary>
    [Parameter] public string DarkLabel { get; set; } = "Dark";

    protected override string ComponentCssClass => Css.Classes.Color.ModeToggle;

    private async Task ToggleAsync()
    {
        if (ThemeService == null) return;
        // Explicitly pin the mode (leaves Auto only until the user expresses a preference).
        await ThemeService.SetModeAsync(ThemeService.IsDark ? ThemeMode.Light : ThemeMode.Dark);
    }
}
