@namespace Flare.Components
@inherits FlareComponentBase
@implements IAsyncDisposable
@inject IJSRuntime JS

<div class="@BuildCssClass(_verticalClass, _placementClass, _variantClass, _rotatedClass)" style="@_rootStyle" @attributes="AdditionalAttributes">
    <div class="@Css.Classes.Tabs.BarWrap">
    @if (HeaderStart is not null)
    {
        <div class="@Css.Classes.Tabs.HeaderStart">@HeaderStart</div>
    }
    @if (_showArrows)
    {
        <button type="button" class="@Css.Classes.Tabs.Scroll @Css.Classes.Tabs.ScrollPrev"
                disabled="@_atStart" aria-label="@(FlareStrings.Tabs_ScrollBack)"
                tabindex="-1" @onclick="ScrollPrev">
            <span class="material-symbols-rounded">chevron_left</span>
        </button>
    }
    <div class="@Css.Classes.Tabs.Bar" role="tablist" aria-orientation="@(_vertical ? "vertical" : "horizontal")" @ref="_barRef" @onkeydown="HandleKeyDown">
        @foreach (var tab in _tabs)
        {
            var isActive = tab == _context?.ActiveTab;
            <button class="@Css.Classes.Tabs.TabButton @(isActive ? Css.Classes.Tabs.TabActive : "")"
                    id="@tab.TabId"
                    role="tab"
                    aria-selected="@isActive"
                    aria-controls="@tab.PanelId"
                    title="@tab.Tooltip"
                    tabindex="@(isActive ? 0 : -1)"
                    disabled="@tab.Disabled"
                    @onclick="@(() => OnTabClick(tab))">
                @if (tab.LeadingIcon is not null)
                {
                    @tab.LeadingIcon
                }
                <span class="@Css.Classes.Tabs.Label">@tab.Label</span>
                @if (tab.BadgeDot)
                {
                    <span class="@Css.Classes.Tabs.Badge @Css.Classes.Tabs.BadgeDot @tab.BadgeColor.CssClass" style="@tab.BadgeColor.StyleMainOn()"></span>
                }
                else if (!string.IsNullOrEmpty(tab.Badge))
                {
                    <span class="@Css.Classes.Tabs.Badge @tab.BadgeColor.CssClass" style="@tab.BadgeColor.StyleMainOn()">@tab.Badge</span>
                }
                @if (tab.Closeable)
                {
                    <button class="@Css.Classes.Tabs.TabClose" @onclick="@(() => CloseTab(tab))" @onclick:stopPropagation="true" aria-label="@(FlareStrings.Aria_CloseTab)">
                        <span class="material-symbols-rounded">close</span>
                    </button>
                }
            </button>
        }
    </div>
    @if (_showArrows)
    {
        <button type="button" class="@Css.Classes.Tabs.Scroll @Css.Classes.Tabs.ScrollNext"
                disabled="@_atEnd" aria-label="@(FlareStrings.Tabs_ScrollForward)"
                tabindex="-1" @onclick="ScrollNext">
            <span class="material-symbols-rounded">chevron_right</span>
        </button>
    }
    @if (HeaderEnd is not null)
    {
        <div class="@Css.Classes.Tabs.HeaderEnd">@HeaderEnd</div>
    }
    </div>
    <div class="@Css.Classes.Tabs.Panels">
        <CascadingValue Value="_context" IsFixed="false">
            @ChildContent
        </CascadingValue>
    </div>
</div>

@code {
    /// <summary>FlareTab panels rendered inside the tab container.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }
    /// <summary>Custom content rendered at the start (left/top) of the tab header, before the tabs - e.g. a title or action buttons.</summary>
    [Parameter] public RenderFragment? HeaderStart { get; set; }
    /// <summary>Custom content rendered at the end (right/bottom) of the tab header, after the tabs - e.g. action buttons. The tab bar grows to push this to the far edge.</summary>
    [Parameter] public RenderFragment? HeaderEnd { get; set; }
    /// <summary>Type scale applied to the tab labels. Null (default) keeps the MD3 label-large scale.</summary>
    [Parameter] public TypographyScale? Typo { get; set; }
    /// <summary>Side the tab bar is placed on (Top/Bottom/Left/Right). Left/Right render a vertical bar. Default Top.</summary>
    [Parameter] public TabsPlacement Placement { get; set; } = TabsPlacement.Top;
    /// <summary>Rotation applied to each tab label (0/90/180/270 degrees). Default none.</summary>
    [Parameter] public TabLabelRotation LabelRotation { get; set; } = TabLabelRotation.None;
    /// <summary>Visual variant of the tab bar (theme-independent). Default keeps the active theme's style.</summary>
    [Parameter] public TabsVariant Variant { get; set; } = TabsVariant.Default;
    /// <summary>Callback fired with the label of a closed tab.</summary>
    [Parameter] public EventCallback<string> OnTabClose { get; set; }
    /// <summary>Zero-based index of the active tab. Supports two-way binding (<c>@bind-ActiveIndex</c>).</summary>
    [Parameter] public int ActiveIndex { get; set; }
    /// <summary>Fired with the new active-tab index whenever the selection changes.</summary>
    [Parameter] public EventCallback<int> ActiveIndexChanged { get; set; }
    /// <summary>
    /// Invoked before a tab is activated or closed. Set <see cref="TabInteractionEventArgs.Cancel"/>
    /// in the handler to veto the interaction (e.g. block switching away from a tab with unsaved
    /// changes). Async handlers are awaited before the interaction proceeds.
    /// </summary>
    [Parameter] public EventCallback<TabInteractionEventArgs> OnPreviewInteraction { get; set; }
    /// <summary>
    /// When true, only the active tab's panel content is rendered: switching tabs unmounts the
    /// previous panel and mounts the new one. Keeps heavy tab content (large forms, token editors,
    /// data grids) out of the DOM and the component tree until its tab is opened. Default false
    /// renders every panel up front (inactive ones hidden with CSS), which preserves transient
    /// panel state across switches at the cost of building all panels at once.
    /// </summary>
    [Parameter] public bool Lazy { get; set; }

    protected override string ComponentCssClass => Css.Classes.Tabs.Root;

    private readonly List<FlareTab> _tabs = [];
    private FlareTab? _active;
    private int _currentIndex = -1;
    // Last ActiveIndex value seen from the parent; lets OnParametersSet tell a parent-driven change
    // apart from the user's own clicks (which advance _currentIndex but not ActiveIndex).
    private int _lastBoundIndex;
    private FlareTabsContext? _context;
    private string? _variantClass => Variant switch
    {
        TabsVariant.Underline => Css.Classes.Tabs.Underline,
        TabsVariant.Primary => Css.Classes.Tabs.Primary,
        TabsVariant.Text => Css.Classes.Tabs.Text,
        TabsVariant.Tonal => Css.Classes.Tabs.Tonal,
        TabsVariant.Filled => Css.Classes.Tabs.Filled,
        TabsVariant.Outlined => Css.Classes.Tabs.Outlined,
        _ => null, // Default - theme's native underline styling
    };

    private bool _vertical => Placement is TabsPlacement.Left or TabsPlacement.Right;

    // Left/Right reuse the existing vertical bar styling; Bottom/Right add a flip modifier.
    private string? _verticalClass => _vertical ? Css.Classes.Tabs.Vertical : null;
    private string? _placementClass => Placement switch
    {
        TabsPlacement.Bottom => Css.Classes.Tabs.Bottom,
        TabsPlacement.Right => Css.Classes.Tabs.Right,
        _ => null,
    };

    private int _rotationDeg => LabelRotation switch
    {
        TabLabelRotation.Rotate90 => 90,
        TabLabelRotation.Rotate180 => 180,
        TabLabelRotation.Rotate270 => 270,
        _ => 0,
    };
    private string? _rotatedClass => _rotationDeg is 90 or 270 ? Css.Classes.Tabs.Rotated : null;

    // When Typo is set, repoint the tab-label font tokens at the chosen type scale.
    private string? _typoVars => Typo is { } t
        ? $"--flare-tabs-label-font:var(--flare-typescale-{FlareTypography.Slug(t)}-font);"
          + $"--flare-tabs-label-size:var(--flare-typescale-{FlareTypography.Slug(t)}-size);"
          + $"--flare-tabs-label-weight:var(--flare-typescale-{FlareTypography.Slug(t)}-weight)"
        : null;

    private string _rootStyle =>
        string.Join(";", new[] { $"--flare-tab-label-rotation:{_rotationDeg}deg", _typoVars, Style }.Where(s => !string.IsNullOrEmpty(s)));

    // Overflow scrolling (horizontal only): JS reports overflow + edge state.
    private ElementReference _barRef;
    private IJSObjectReference? _module;
    private DotNetObjectReference<FlareTabs>? _dotNetRef;
    private bool _overflowing;
    private bool _atStart = true;
    private bool _atEnd;
    private bool _showArrows => _overflowing && !_vertical;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_vertical)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            try
            {
                _module ??= await JS.InvokeAsync<IJSObjectReference>(
                    "import", "./_content/Flare.Components/js/flare-ui.js");
                await _module.InvokeVoidAsync("registerTabScroller", _barRef, _dotNetRef);
            }
            catch (InvalidOperationException) { }
            catch (JSException) { }
        }
    }

    [JSInvokable]
    public void OnTabScrollState(bool overflowing, bool atStart, bool atEnd)
    {
        _overflowing = overflowing;
        _atStart = atStart;
        _atEnd = atEnd;
        StateHasChanged();
    }

    private async Task ScrollPrev()
    {
        if (_module is not null) await _module.InvokeVoidAsync("scrollTabs", _barRef, -1);
    }

    private async Task ScrollNext()
    {
        if (_module is not null) await _module.InvokeVoidAsync("scrollTabs", _barRef, 1);
    }

    public override async ValueTask DisposeAsync()
    {
        try
        {
            if (_module is not null)
                await _module.InvokeVoidAsync("removeTabScroller", _barRef);
        }
        catch { }
        _dotNetRef?.Dispose();
        if (_module is not null)
        {
            try { await _module.DisposeAsync(); }
            catch { }
        }
        await base.DisposeAsync();
    }

    protected override void OnInitialized()
    {
        base.OnInitialized();
        RebuildContext();
    }

    // React only when the PARENT changes ActiveIndex (two-way binding / programmatic), tracked via
    // _lastBoundIndex. Comparing against _currentIndex instead would snap the selection back to
    // ActiveIndex on ANY unrelated parent re-render after the user clicked a different tab.
    protected override void OnParametersSet()
    {
        if (ActiveIndex == _lastBoundIndex) return;
        _lastBoundIndex = ActiveIndex;
        if (ActiveIndex >= 0 && ActiveIndex < _tabs.Count)
        {
            _active = _tabs[ActiveIndex];
            _currentIndex = ActiveIndex;
            RebuildContext();
        }
    }

    private void RebuildContext()
    {
        _context = new FlareTabsContext(
            _active,
            tab => _ = InvokeAsync(() => SelectTab(tab)),
            RegisterTab,
            UnregisterTab,
            Lazy);
    }

    private void RegisterTab(FlareTab tab)
    {
        if (_tabs.Contains(tab)) return;
        _tabs.Add(tab);
        // Honor the bound ActiveIndex as tabs arrive: select when nothing is active yet, or when the
        // tab that just registered is the bound target (which may only now have become reachable).
        if (_active is null || _tabs.IndexOf(tab) == ActiveIndex)
            SetActiveByIndex();
        RebuildContext();
        StateHasChanged();
    }

    private void UnregisterTab(FlareTab tab)
    {
        _tabs.Remove(tab);
        if (_active == tab)
        {
            _active = null;
            SetActiveByIndex();
        }
        else
        {
            _currentIndex = _active is null ? -1 : _tabs.IndexOf(_active);
        }
        RebuildContext();
        StateHasChanged();
    }

    // Selects the tab at the bound ActiveIndex, clamping to the first tab when out of range.
    private void SetActiveByIndex()
    {
        if (_tabs.Count == 0)
        {
            _active = null;
            _currentIndex = -1;
            return;
        }
        var idx = ActiveIndex >= 0 && ActiveIndex < _tabs.Count ? ActiveIndex : 0;
        _active = _tabs[idx];
        _currentIndex = idx;
    }

    // Single funnel for selection: runs the preview guard, updates state, and notifies the binding.
    private async Task SelectTab(FlareTab tab)
    {
        if (tab.Disabled || tab == _active) return;
        var index = _tabs.IndexOf(tab);
        if (index < 0) return;
        if (!await AllowInteraction(index, tab.Label, TabInteractionType.Activate)) return;

        _active = tab;
        _currentIndex = index;
        RebuildContext();
        if (ActiveIndexChanged.HasDelegate) await ActiveIndexChanged.InvokeAsync(index);
        StateHasChanged();
    }

    private async Task OnTabClick(FlareTab tab)
    {
        if (tab.OnClick.HasDelegate) await tab.OnClick.InvokeAsync();
        await SelectTab(tab);
    }

    private async Task CloseTab(FlareTab tab)
    {
        var index = _tabs.IndexOf(tab);
        if (!await AllowInteraction(index, tab.Label, TabInteractionType.Close)) return;
        await OnTabClose.InvokeAsync(tab.Label);
    }

    private async Task<bool> AllowInteraction(int index, string label, TabInteractionType type)
    {
        if (!OnPreviewInteraction.HasDelegate) return true;
        var args = new TabInteractionEventArgs { PanelIndex = index, Label = label, InteractionType = type };
        await OnPreviewInteraction.InvokeAsync(args);
        return !args.Cancel;
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        var enabled = _tabs.Where(t => !t.Disabled).ToList();
        if (enabled.Count == 0) return;
        var current = _active is not null ? enabled.IndexOf(_active) : -1;

        FlareTab? target = e.Key switch
        {
            "ArrowRight" or "ArrowDown" => enabled[(current + 1) % enabled.Count],
            "ArrowLeft" or "ArrowUp" => enabled[((current - 1) + enabled.Count) % enabled.Count],
            "Home" => enabled[0],
            "End" => enabled[^1],
            _ => null,
        };
        if (target is not null) await SelectTab(target);
    }
}
