@* Requires interactive render mode (not compatible with static SSR). *@
@namespace Flare.Components
@inherits FlareComponentBase
@inject IJSRuntime JS
@implements IAsyncDisposable

<button class="@BuildCssClass(_visibleClass)"
        type="button"
        aria-label="@(FlareStrings.Nav_BackToTop)"
        style="@Style"
        @onclick="ScrollToTopAsync"
        @attributes="AdditionalAttributes">
    <span class="material-symbols-rounded" aria-hidden="true">keyboard_arrow_up</span>
</button>

@code {
    /// <summary>Scroll distance in pixels before the button appears.</summary>
    [Parameter] public int Threshold { get; set; } = 200;

    /// <summary>
    /// CSS selector of the scroll container to watch (e.g. an app-shell content panel). When null
    /// (the default) the page itself (window) is used.
    /// </summary>
    [Parameter] public string? Selector { get; set; }

    protected override string ComponentCssClass => Css.Classes.Scroll.Top;

    private bool _visible;
    private readonly string _id = Guid.NewGuid().ToString("N");
    private IJSObjectReference? _module;
    private DotNetObjectReference<FlareScrollTop>? _dotNetRef;

    private string _visibleClass => _visible ? Css.Classes.Scroll.TopVisible : string.Empty;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try
        {
            _module = await JS.InvokeAsync<IJSObjectReference>(
                "import", "./_content/Flare.Components/js/flare-ui.js");
            _dotNetRef = DotNetObjectReference.Create(this);
            await _module.InvokeVoidAsync("registerScrollTopHandler", _id, _dotNetRef, Threshold, Selector);
        }
        catch (InvalidOperationException) { }
        catch (JSDisconnectedException) { }
    }

    [JSInvokable]
    public void SetVisible(bool visible)
    {
        if (_visible == visible) return;
        _visible = visible;
        InvokeAsync(StateHasChanged);
    }

    private async Task ScrollToTopAsync()
    {
        if (_module is not null)
            await _module.InvokeVoidAsync("scrollToTop", Selector);
    }

    public override async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try { await _module.InvokeVoidAsync("removeScrollTopHandler", _id); }
            catch (InvalidOperationException) { }
            catch (JSDisconnectedException) { }
            await _module.DisposeAsync();
        }
        _dotNetRef?.Dispose();
        await base.DisposeAsync();
    }
}
